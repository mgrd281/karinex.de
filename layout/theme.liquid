    {%- if template == 'product' or template.name == 'product' -%}
    <script>
      // Global Review Form Toggle
      window.toggleReviewForm = function(btn) {
          const reviewForm = document.getElementById('review-form'); if (!reviewForm) return;
          const openLabel = '<i class="fa-solid fa-pen"></i> Bewertung schreiben';
          const closeLabel = '<i class="fa-solid fa-times"></i> Bewertung verbergen';
          const willOpen = !reviewForm.classList.contains('active');
          reviewForm.classList.toggle('active'); btn.innerHTML = willOpen ? closeLabel : openLabel;
          if (willOpen) reviewForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
      };
      // Global Tab Switcher
      window.switchTab = function(btn) {
          if (!btn) return;
          const targetId = btn.getAttribute('data-tab'); if (!targetId) return;
          const nav = btn.closest('.tab-nav'); if (!nav) return;
          const container = nav.parentElement; if (!container) return;
          nav.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
          btn.classList.add('active'); btn.setAttribute('aria-selected', 'true');
          container.querySelectorAll('.tab-content').forEach(p => p.classList.remove('active'));
          const target = container.querySelector('#' + targetId); if (target) target.classList.add('active');
      };
    </script>
