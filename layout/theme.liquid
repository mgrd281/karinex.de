


<!doctype html>
<!-- Deployment ID: FIX-FINAL-SYNC-V5 -->
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- comment -%} ════ CORE PERFORMANCE PRECONNECTS (MAX 6) ════ {%- endcomment -%}
    {%- render 'affiliate-tracker' -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <style>
      :root {
        {%- assign g_rating_color = settings.global_rating_star_color | default: '#1D4739' -%}
        {%- assign g_rating_shadow = g_rating_color | color_modify: 'alpha', 0.40 -%}
        --rating-star-color: {{ g_rating_color }};
        --rating-star-shadow: 0 1px 3px {{ g_rating_shadow }};
      }
    </style>
    
    {%- render 'smart-script-manager' -%}
    {%- render 'local-fonts' -%}

    <meta name="color-scheme" content="light">
    {% render 'mobile-detector' %}
    <!-- Sync Trigger: Retry at 18:25 -->
    
    {%- comment -%}
    Third-party scripts (Usercentrics, GTM, Tidio, etc.) are managed 
    by smart-script-manager.liquid to optimize TBT.
    {%- endcomment -%}
    <script>
      (function() {
        function loadThemeBasics() {
          // 1. Font Awesome — load only fontawesome-svg-core + solid + brands (~18KB vs 60KB full)
          var faBase = 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/';
          ['fontawesome.min.css', 'solid.min.css', 'brands.min.css'].forEach(function(f) {
            var l = document.createElement('link');
            l.href = faBase + f;
            l.rel = 'stylesheet';
            document.head.appendChild(l);
          });

          // 2. Usercentrics - Intercepted by manager
          const uc = document.createElement('script');
          uc.id = 'usercentrics-cmp';
          uc.src = 'https://web.cmp.usercentrics.eu/ui/loader.js';
          uc.dataset.settingsId = 'DDgih5qHx1UO7E';
          uc.async = true;
          document.head.appendChild(uc);
        }
        
        // Load basics after a short idle
        if ('requestIdleCallback' in window) {
           requestIdleCallback(loadThemeBasics, { timeout: 2000 });
        } else {
           setTimeout(loadThemeBasics, 2000);
        }
      })();
    </script>

    {%- comment -%} ═══ GEO-LANGUAGE AUTO-REDIRECT (Shopify native) ════ {%- endcomment -%}
    {%- unless request.design_mode -%}
      {%- assign _geo_country = localization.country.iso_code -%}
      {%- assign _cur_locale = request.locale.iso_code | downcase -%}

      {%- comment -%} Map country → expected locale: DE/AT/CH/LI/LU → de, PL → pl, all others → en {%- endcomment -%}
      {%- assign _expected = 'en' -%}
      {%- if _geo_country == 'DE' or _geo_country == 'AT' or _geo_country == 'CH' or _geo_country == 'LI' or _geo_country == 'LU' -%}
        {%- assign _expected = 'de' -%}
      {%- elsif _geo_country == 'PL' -%}
        {%- assign _expected = 'pl' -%}
      {%- endif -%}

      {%- if _expected != _cur_locale -%}
        <script>
        (function(){
          /* Respect manual language choice */
          if(document.cookie.indexOf('karinex_lang_set')!==-1)return;
          var p=window.location.pathname;
          var clean=p.replace(/^\/(en|pl)(\/|$)/,'/')||'/';
          {%- if _expected == 'de' -%}
            var dest=clean;
          {%- else -%}
            var dest='/{{ _expected }}'+(clean==='/'?'':clean);
          {%- endif -%}
          window.location.replace(window.location.origin+dest+window.location.search+window.location.hash);
        })();
        </script>
      {%- endif -%}
    {%- endunless -%}

    <!-- ═══════════════════════════════════════════════════════════════════
         USERCENTRICS SHADOW DOM STYLE INJECTOR
         Injects Thalia-like CSS directly into UC CMP v3 Shadow Root.
         Shadow DOM blocks external CSS — this is the only way to style it.
         ═══════════════════════════════════════════════════════════════════ -->
    <script>
      if ('requestIdleCallback' in window) { requestIdleCallback(initUCStyles, { timeout: 3000 }); }
      else { setTimeout(initUCStyles, 3000); }
