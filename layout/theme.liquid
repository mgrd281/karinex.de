          '  display: none !important;',
          '}'

        ].join('\n');

        var UC_HTML = '<div id="karinex-thalia-text" style="text-align: left; margin-bottom: 24px;">' +
                      '<div style="font-size: 20px; font-weight: 700; margin: 0 0 20px; color: #1a1a1a; letter-spacing: -0.01em;">Helfen Sie uns, Ihr KARINEX Erlebnis zu verbessern!</div>' +
                      '<p style="font-size: 14px; line-height: 1.6; color: #4a4a4a; margin: 0 0 16px;">Wir möchten Ihr Shopping-Erlebnis einzigartig und persönlich machen. Dafür verwenden wir und unsere Partner (auch Dritte) Cookies, Pixel und ähnliche Dienste („Services“), die Informationen und Daten speichern und/oder von Ihrem Endgerät abrufen.</p>' +
                      '<p style="font-size: 14px; line-height: 1.6; color: #4a4a4a; margin: 0 0 16px;">Diese Informationen und Daten werden von uns z.B. zur Identifikation auf Drittseiten, zur Personalisierung, Marktforschung, Analyse und zur Produktentwicklung genutzt und können auch im EU-Ausland (Drittstaaten) verarbeitet werden.</p>' +
                      '<p style="font-size: 14px; line-height: 1.6; color: #4a4a4a; margin: 0 0 16px;"><strong>Sie haben die Wahl:</strong> Durch einen Klick auf „Alles akzeptieren“ stimmen Sie der Verwendung und Verarbeitung insgesamt zu.</p>' +
                      '<p style="font-size: 14px; line-height: 1.6; color: #4a4a4a; margin: 0 0 16px;">Lehnen Sie die Verwendung von Cookies ab, sind nur die Dienste aktiv, die wir brauchen, um unsere Website für Sie sicher, zuverlässig und leistungsstark zu halten.</p>' +
                      '<p style="font-size: 14px; line-height: 1.6; color: #4a4a4a; margin: 0;"><strong>Wichtig:</strong> Diese Auswahl können Sie jederzeit und mit Wirkung für die Zukunft widerrufen. Weitere Details finden Sie in unseren Datenschutzhinweisen.</p>' +
                      '</div>';

        // ═══════════════════════════════════════════════════════════════════
        // ELEGANT SHADOW DOM INJECTION (MutationObserver)
        // Replaces polling setInterval with efficient event-based detection
        // ═══════════════════════════════════════════════════════════════════
        let injectionDone = false;
        function tryInject() {
          if (injectionDone) return true;
          var host = document.getElementById('usercentrics-root') || document.getElementById('usercentrics-cmp-ui');
          if (!host || !host.shadowRoot) return false;
          
          // Inject Styles
          if (!host.shadowRoot.getElementById('uc-karinex-custom-styles')) {
            var style = document.createElement('style');
            style.id = 'uc-karinex-custom-styles';
            style.textContent = UC_CSS;
            host.shadowRoot.appendChild(style);
          }

          // Inject Custom HTML
          var introContainer = host.shadowRoot.querySelector('.cb-dialog-intro') || host.shadowRoot.querySelector('#uc-cmp-description');
          if (introContainer && !host.shadowRoot.getElementById('karinex-thalia-text')) {
             var div = document.createElement('div');
             div.innerHTML = UC_HTML;
             introContainer.insertBefore(div.firstChild, introContainer.firstChild);
          }
          
          // If we found both, we are likely done (but UC v3 re-renders, so we might keep watching)
          // For now, let's mark as successful for this cycle
          return !!(host && host.shadowRoot && host.shadowRoot.getElementById('uc-karinex-custom-styles'));
        }

        // Use MutationObserver on body to detect when Usercentrics initializes
        const observer = new MutationObserver((mutations, obs) => {
          if (tryInject()) {
            // Note: UC UI V3 often re-renders or changes views, so we don't disconnect immediately 
            // but we avoid setInterval performance tax. Once fully loaded, we can disconnect.
            const isFullyLoaded = document.querySelector('#usercentrics-root')?.shadowRoot?.querySelector('.accept');
            if (isFullyLoaded) {
              // obs.disconnect(); // Optional: Keep watching for view changes if needed
            }
          }
        });

        observer.observe(document.body, { childList: true, subtree: true });

        // Backup: Interaction triggers
        window.addEventListener('UC_UI_VIEW_CHANGED', tryInject);
        window.addEventListener('UC_UI_INITIALIZED', tryInject);
        
        // Final fallback (one-time)
        setTimeout(tryInject, 4000);
      }
    </script>
    
