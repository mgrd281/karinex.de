    {%- comment -%}
      Product page: dual main section (desktop = product-information,
      mobile = product-aboutyou). Hide the wrong one via CSS so both
      can co-exist without FOUC. Inline + early so it wins over any
      later CSS.
    {%- endcomment -%}
    {%- if template.name == 'product' -%}
      <style>
        /* Shopify wraps JSON-template sections with IDs like
           #shopify-section-template--XXXX__main and ...__main_mobile,
           so we use attribute selectors (ends-with) to match both
           the bare and templated formats. */
        @media (max-width: 768px) {
          [id$="__main"][class*="shopify-section"],
          #shopify-section-main { display: none !important; }
        }
        @media (min-width: 769px) {
          [id$="__main_mobile"][class*="shopify-section"],
          #shopify-section-main_mobile { display: none !important; }
        }
      </style>
    {%- endif -%}

    <!-- Fix: Prevent FOUC (Flash of Unstyled Content) in Header -->
    <style>
      /* Hide header elements until Web Components are defined */
      header-component:not(:defined) {
        visibility: hidden;
        min-height: 60px;
      }
      header-component:not(:defined) * {
        visibility: hidden;
      }
      /* Header defined — show immediately, no animation flash */
      header-component:defined {
        visibility: visible;
      }
      /* Critical FOUC prevention — rules needed before base.css loads */
      .visually-hidden{position:absolute!important;width:1px!important;height:1px!important;padding:0!important;margin:-1px!important;overflow:hidden!important;clip:rect(0,0,0,0)!important;white-space:nowrap!important;border:0!important}
      .cart-bubble__background{display:none!important}
      .badge--sale{background-color:#000!important;color:#fff!important}
      header-actions .icon-badge,header-actions .wishlist-count-badge{display:none!important}
    </style>

