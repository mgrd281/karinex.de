    {%- comment -%}
    Third-party scripts (Usercentrics, GTM, Tidio, etc.) are managed
    by smart-script-manager.liquid to optimize TBT.
    {%- endcomment -%}
    <script>
      (function() {
        function loadThemeBasics() {
          // 1. Font Awesome — load only fontawesome-svg-core + solid + brands (~18KB vs 60KB full)
          var faBase = 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/';
          ['fontawesome.min.css', 'solid.min.css', 'brands.min.css'].forEach(function(f) {
            var l = document.createElement('link');
            l.href = faBase + f;
            l.rel = 'stylesheet';
            document.head.appendChild(l);
          });

          // 2. Usercentrics - Intercepted by manager
          const uc = document.createElement('script');
          uc.id = 'usercentrics-cmp';
          uc.src = 'https://web.cmp.usercentrics.eu/ui/loader.js';
          uc.dataset.settingsId = 'DDgih5qHx1UO7E';
          uc.async = true;
          document.head.appendChild(uc);
        }

        // Load basics after a short idle
        if ('requestIdleCallback' in window) {
           requestIdleCallback(loadThemeBasics, { timeout: 2000 });
        } else {
           setTimeout(loadThemeBasics, 2000);
        }
      })();
    </script>

