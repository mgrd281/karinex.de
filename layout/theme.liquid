  <head>
    {%- comment -%} ═══ GEO-LANGUAGE AUTO-REDIRECT — must be FIRST in <head> ═══ {%- endcomment -%}
    {%- unless request.design_mode -%}
      {%- assign _geo_country = localization.country.iso_code -%}
      {%- assign _cur_locale = request.locale.iso_code | downcase -%}

      {%- comment -%}
        Geo → language map (IP-based, from Shopify Markets):
        DE/AT/CH/LI/LU  → de   (German-speaking)
        PL              → pl   (Polish)
        SE              → sv   (Swedish)
        anywhere else   → en   (default fallback, incl. English-speaking
                                countries US/GB/IE/AU/NZ/CA + any country
                                we don't have a localised version for yet)
      {%- endcomment -%}
      {%- assign _expected = 'en' -%}
      {%- if _geo_country == 'DE' or _geo_country == 'AT' or _geo_country == 'CH' or _geo_country == 'LI' or _geo_country == 'LU' -%}
        {%- assign _expected = 'de' -%}
      {%- elsif _geo_country == 'PL' -%}
        {%- assign _expected = 'pl' -%}
      {%- elsif _geo_country == 'SE' -%}
        {%- assign _expected = 'sv' -%}
      {%- endif -%}

      {%- if _expected != _cur_locale -%}
        {%- assign _path = request.path -%}
        {%- comment -%}
          Strip ANY known locale prefix (en/pl/sv/da/nl/fr/it/es/cs/hu/ro/sk/fi/el/pt)
          from the front of the path before re-prepending the expected one.
          Without this, visiting /sv/products/x with _expected='en' produced
          /en/sv/products/x (404 → flooded the Ahrefs broken-link report).
        {%- endcomment -%}
        {%- assign _path_first = _path | split: '/' | first | append: '|' -%}
        {%- assign _path_seg = _path | split: '/' -%}
        {%- assign _path_locale = _path_seg[1] | default: '' -%}
        {%- assign _known_locales = 'en,pl,sv,da,nl,fr,it,es,cs,hu,ro,sk,fi,el,pt' | split: ',' -%}
        {%- if _known_locales contains _path_locale -%}
          {%- assign _strip = '/' | append: _path_locale -%}
          {%- assign _path = _path | remove_first: _strip -%}
        {%- endif -%}
        {%- if _path == blank -%}{%- assign _path = '/' -%}{%- endif -%}

        {%- if _expected == 'de' -%}
          {%- assign _redirect_url = _path -%}
        {%- elsif _path == '/' -%}
          {%- assign _redirect_url = '/' | append: _expected -%}
        {%- else -%}
          {%- assign _redirect_url = '/' | append: _expected | append: _path -%}
        {%- endif -%}

        <script>if(document.cookie.indexOf('karinex_lang_set')===-1){window.location.replace('{{ _redirect_url }}');}</script>
        <noscript><meta http-equiv="refresh" content="0;url={{ _redirect_url }}"></noscript>
      {%- endif -%}
    {%- endunless -%}

    {%- comment -%} ════ CORE PERFORMANCE PRECONNECTS (MAX 6) ════ {%- endcomment -%}
    {%- render 'affiliate-tracker' -%}
