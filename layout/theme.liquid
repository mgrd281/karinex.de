    <!-- 🟢 KARINEX Cart-Tracker — Browser-Tracking für Tab-Close + Inactivity -->
    {%- if template == 'cart' or request.page_type == 'cart' or template.name contains 'checkout' or request.path contains '/checkouts' -%}
    <script>
      (function() {
        function loadKarinexCartTracker() {
          var s = document.createElement('script');
          s.src = 'https://invoice-production-8cd6.up.railway.app/karinex-cart-tracker.js';
          s.defer = true;
