{%- comment -%}
  Renders one bestseller card for the mobile menu drawer.
  Required: product
{%- endcomment -%}
{%- if product != blank and product.handle != blank -%}
<a href="{{ product.url }}" class="kx-menu__bs-card" aria-label="{{ product.title | escape }}">
  <div class="kx-menu__bs-img-wrap">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 320 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        loading="lazy"
        class="kx-menu__bs-img">
    {%- endif -%}
  </div>
  <div class="kx-menu__bs-name">{{ product.title | truncate: 64 }}</div>
  <div class="kx-menu__bs-price">
    {%- if product.price_varies -%}ab {%- endif -%}
    {{ product.price | money }}
  </div>
</a>
{%- endif -%}
