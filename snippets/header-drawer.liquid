{%- doc -%}
  Renders a header drawer menu triggered by the top details element.

  @param {object} linklist - The linklist to render
  @param {string} [class] - Additional classes to add to the drawer
  @param {string} [data_header_drawer_type] - The type of header drawer to render
  @param {object} [block] - The block that can be used to provide settings
  @param {object} [section] - The section that can be used to provide settings

  @example
  {% render 'header-drawer', linklist: section.settings.menu, class: 'header-drawer--mobile' %}
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign max_featured_items = 4
  assign image_border_radius = block_settings.image_border_radius

  if block_settings.menu_style == 'featured_collections'
    assign ratio = block_settings.featured_collections_aspect_ratio
  elsif block_settings.menu_style == 'featured_products'
    assign ratio = block_settings.featured_products_aspect_ratio
  endif

  ##
  # We only eager load heavy elements of the page when rendering this template
  # through the Section Rendering API.
  #
  # This keeps the initial render lightweight, minimizing the impact on TTFB.
  # The second render then refreshes the page with additional content.
  #
  # At the moment, we check if the Section Rendering API is being used by
  # checking if section.index is blank.
  assign eager_loading = false
  if section.index == blank
    assign eager_loading = true
  endif
%}

<script
  src="{{ 'header-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<!-- Mobile Menu Fallback Script -->
<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var menuButton = document.querySelector('#Details-menu-drawer-container > summary');
    var menuDetails = document.getElementById('Details-menu-drawer-container');
    
    if (menuButton && menuDetails) {
      menuButton.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        var isOpen = menuDetails.classList.contains('menu-open');
        
        if (isOpen) {
          menuDetails.classList.remove('menu-open');
          menuDetails.removeAttribute('open');
          document.body.classList.remove('overflow-hidden-mobile');
        } else {
          menuDetails.classList.add('menu-open');
          menuDetails.setAttribute('open', '');
          document.body.classList.add('overflow-hidden-mobile');
        }
        
        return false;
      });
      
      // Close button handler
      var closeButtons = menuDetails.querySelectorAll('.menu-drawer__close-button, .close-button');
      closeButtons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          menuDetails.classList.remove('menu-open');
          menuDetails.removeAttribute('open');
          document.body.classList.remove('overflow-hidden-mobile');
        });
      });
    }
  });
})();
</script>

<header-drawer
  class="header-drawer {{ class }}"
  style="--menu-image-border-radius: {{ image_border_radius }}px; --resource-card-corner-radius: {{ image_border_radius }}px;"
>
  <details
    id="Details-menu-drawer-container"
    data-skip-node-update="true"
    class="menu-drawer-container"
    ref="details"
    scroll-lock
  >
    <summary
      class="header__icon header__icon--menu header__icon--summary"
      aria-label="{{ 'accessibility.menu' | t }}"
      on:click="/toggle"
      onclick="event.preventDefault(); var d = this.closest('details'); d.classList.toggle('menu-open'); if(d.classList.contains('menu-open')){d.setAttribute('open',''); document.body.classList.add('overflow-hidden-mobile');}else{d.removeAttribute('open'); document.body.classList.remove('overflow-hidden-mobile');} return false;"
    >
      <span class="svg-wrapper header-drawer-icon header-drawer-icon--open" style="display: flex !important;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </span>
      <span class="svg-wrapper header-drawer-icon header-drawer-icon--close" style="display: none !important;">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>
    <div
      data-header-drawer
      class="
        menu-drawer
        motion-reduce
        color-{{ block_settings.color_scheme }}
      "
    >
      <button
        class="button button-unstyled close-button menu-drawer__close-button"
        type="button"
        aria-label="{{ 'actions.close' | t }}"
        on:click="/close"
        onclick="event.preventDefault(); var d = document.getElementById('Details-menu-drawer-container'); d.classList.remove('menu-open'); d.removeAttribute('open'); return false;"
      >
        <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>

      <!-- Modern Mobile Menu CSS (Redesign) -->
      <style>
        .menu-drawer {
          position: fixed;
          top: 0;
          left: 0;
          width: 100vw;
          height: 100vh; /* Fullscreen */
          background-color: #fff !important;
          z-index: 2147483647; /* Max Z-Index */
          display: flex;
          flex-direction: column;
          transform: translateX(-100%);
          visibility: hidden;
          transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), visibility 0.3s ease;
        }

        /* Hide Announcement Bar/Timer when Menu is Open */
        body.overflow-hidden-mobile .announcement-bar-wrapper,
        details[open] > .menu-drawer ~ .announcement-bar-wrapper {
          visibility: hidden !important;
          opacity: 0 !important;
          z-index: -1 !important;
          height: 0 !important;
        }

        /* Show menu when details has menu-open class OR open attribute */
        .menu-drawer-container.menu-open > .menu-drawer,
        details[open] > .menu-drawer,
        .details[open] > .menu-drawer,
        .menu-drawer[open] {
          transform: translateX(0) !important;
          visibility: visible !important;
        }

        .menu-drawer__search-container {
          padding: 16px 20px;
          background: #fff;
          border-bottom: 1px solid #f0f0f0;
          flex-shrink: 0;
          position: relative;
          z-index: 50;
        }
        
        .drawer-search-form {
          position: relative;
          display: flex;
          align-items: center;
          cursor: pointer;
          -webkit-tap-highlight-color: transparent;
          touch-action: manipulation;
        }

        .drawer-search-input {
          width: 100%;
          height: 44px;
          padding: 0 16px 0 40px; 
          border: 1px solid #e0e0e0;
          border-radius: 8px;
          background-color: #f9f9f9;
          color: #666;
          font-size: 15px;
          outline: none;
          transition: border-color 0.2s, background-color 0.2s;
          display: flex;
          align-items: center;
          pointer-events: none;
        }
        .drawer-search-form:active .drawer-search-input {
          border-color: #000;
          background-color: #fff;
        }

        .drawer-search-icon {
          position: absolute;
          left: 12px;
          width: 18px;
          height: 18px;
          color: #888;
          pointer-events: none;
        }

        /* Navigation List */
        .menu-drawer__navigation {
          flex: 1;
          overflow-y: auto;
          overflow-x: hidden;
          padding: 10px 0;
          -webkit-overflow-scrolling: touch;
        }

        .menu-drawer__menu {
          list-style: none;
          padding: 0;
          margin: 0;
        }

        /* Menu Item Styling */
        .menu-drawer__menu-item {
          display: flex !important; /* Force flex */
          align-items: center;
          justify-content: space-between;
          padding: 16px 24px;
          border-bottom: 1px solid #f7f7f7;
          text-decoration: none;
          color: #000;
          font-size: 16px;
          font-weight: 500;
          transition: background-color 0.2s;
          background: #fff;
          width: 100%;
        }

        .menu-drawer__menu-item:active {
          background-color: #f5f5f5;
        }

        /* Clean List Item & Reset Grid Overrides */
        .menu-drawer__list-item,
        .menu-drawer__list-item--grid {
          display: block !important;
          width: 100% !important;
          margin: 0 !important;
          padding: 0 !important;
          border: none !important;
        }
        
        /* Remove Card Styles */
        .menu-drawer__card-item {
            background: transparent !important;
            box-shadow: none !important;
            padding: 16px 24px !important;
            border-radius: 0 !important;
            min-height: auto !important;
            height: auto !important;
            display: flex !important;
            flex-direction: row !important; /* Row, not column */
            align-items: center !important;
            justify-content: flex-start !important;
            border-bottom: 1px solid #f7f7f7 !important;
            width: 100%;
        }

        .card-text {
            font-size: 16px !important;
            font-weight: 500 !important;
            color: #000;
            margin-left: 12px; /* Space from icon */
        }
        
        /* Smaller Icons */
        .card-icon {
            font-size: 18px !important; /* Small icon */
            margin-bottom: 0 !important;
            color: #333;
            width: 20px;
            text-align: center;
        }
        
        /* Arrow for submenu */
        .icon-arrow-right {
             margin-left: auto;
             width: 14px;
             height: 14px;
             color: #999;
        }

        /* Submenu Headers */
        .menu-drawer__nav-buttons {
          padding: 16px 20px;
          border-bottom: 1px solid #eee;
          display: flex;
          align-items: center;
          background: #fff;
          position: sticky;
          top: 0;
          z-index: 10;
        }

        .menu-drawer__back-button {
           font-size: 15px;
           font-weight: 600;
           color: #000;
           text-decoration: none;
           display: flex;
           align-items: center;
           gap: 8px;
           padding: 0;
           border: none;
           background: transparent;
        }
        
        .menu-drawer__close-button {
           margin-left: auto;
           padding: 8px;
           /* Close button styling */
        }

        /* Prevent background scroll */
        body.overflow-hidden-mobile {
          overflow: hidden;
          position: fixed;
          width: 100%;
        }

        /* ═══ MOBILE SEARCH PANEL (OTTO-STYLE) ═══ */
        .menu-search-panel {
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          background: #fff;
          z-index: 100;
          display: none;
          flex-direction: column;
          overflow: hidden;
        }
        .menu-search-panel.active {
          display: flex;
        }
        .menu-search-panel__header {
          display: flex;
          align-items: center;
          padding: 12px 16px;
          border-bottom: 1px solid #f0f0f0;
          gap: 12px;
          background: #fff;
        }
        .menu-search-panel__back {
          background: none;
          border: none;
          padding: 8px;
          cursor: pointer;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .menu-search-panel__back svg {
          width: 20px;
          height: 20px;
          color: #333;
        }
        .menu-search-panel__form {
          flex: 1;
          position: relative;
          display: flex;
          align-items: center;
        }
        .menu-search-panel__input {
          width: 100%;
          height: 44px;
          padding: 0 40px 0 16px;
          border: 1px solid #e0e0e0;
          border-radius: 8px;
          background: #f9f9f9;
          font-size: 16px;
          outline: none;
          -webkit-appearance: none;
          appearance: none;
        }
        .menu-search-panel__input:focus {
          border-color: #000;
          background: #fff;
        }
        .menu-search-panel__clear {
          position: absolute;
          right: 8px;
          background: none;
          border: none;
          padding: 8px;
          cursor: pointer;
          display: none;
          align-items: center;
          justify-content: center;
        }
        .menu-search-panel__clear.visible {
          display: flex;
        }
        .menu-search-panel__clear svg {
          width: 18px;
          height: 18px;
          color: #666;
        }
        .menu-search-panel__content {
          flex: 1;
          overflow-y: auto;
          -webkit-overflow-scrolling: touch;
          padding: 16px;
        }
        .menu-search-panel__section {
          margin-bottom: 24px;
        }
        .menu-search-panel__title {
          font-size: 13px;
          font-weight: 600;
          color: #666;
          text-transform: uppercase;
          letter-spacing: 0.5px;
          margin-bottom: 12px;
        }
        .menu-search-panel__list {
          list-style: none;
          padding: 0;
          margin: 0;
        }
        .menu-search-panel__item {
          display: block;
          padding: 12px 0;
          color: #333;
          text-decoration: none;
          font-size: 15px;
          border-bottom: 1px solid #f5f5f5;
          cursor: pointer;
        }
        .menu-search-panel__item:last-child {
          border-bottom: none;
        }
        .menu-search-panel__item:hover,
        .menu-search-panel__item:active {
          color: #000;
        }
        /* Product suggestions */
        .menu-search-panel__product {
          display: flex;
          align-items: center;
          gap: 12px;
          padding: 10px 0;
          text-decoration: none;
          color: #333;
          border-bottom: 1px solid #f5f5f5;
        }
        .menu-search-panel__product-image {
          width: 50px;
          height: 50px;
          object-fit: contain;
          background: #f9f9f9;
          border-radius: 4px;
        }
        .menu-search-panel__product-info {
          flex: 1;
          min-width: 0;
        }
        .menu-search-panel__product-title {
          font-size: 14px;
          color: #333;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
        .menu-search-panel__product-price {
          font-size: 14px;
          font-weight: 600;
          color: #000;
        }
        /* Loading state */
        .menu-search-panel__loading {
          text-align: center;
          padding: 20px;
          color: #666;
        }
        /* No results */
        .menu-search-panel__empty {
          text-align: center;
          padding: 40px 20px;
          color: #666;
        }
      </style>

      <!-- Search Bar (triggers search panel) -->
      <div class="menu-drawer__search-container" id="MobileSearchContainer">
        <div class="drawer-search-form" id="DrawerSearchTriggerForm" role="button" tabindex="0" aria-label="Suche öffnen" onclick="window.openMobileSearchPanel && window.openMobileSearchPanel()">
          <svg class="drawer-search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <div class="drawer-search-input" style="cursor: pointer; user-select: none;">Wonach suchst du?</div>
        </div>
      </div>

      <!-- OTTO-Style Search Panel (fullscreen overlay inside menu) -->
      <div id="MenuSearchPanel" class="menu-search-panel">
        <div class="menu-search-panel__header">
          <button type="button" class="menu-search-panel__back" id="MenuSearchBack" aria-label="Zurück" onclick="window.closeMobileSearchPanel && window.closeMobileSearchPanel()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
          </button>
          <form action="{{ routes.search_url }}" method="get" role="search" class="menu-search-panel__form" id="MenuSearchForm">
            <input 
              type="search" 
              name="q" 
              id="MenuSearchInput"
              class="menu-search-panel__input" 
              placeholder="Wonach suchst du?"
              aria-label="Suche"
              autocomplete="off"
              autocapitalize="off"
              autocorrect="off"
              spellcheck="false"
              enterkeyhint="search">
            <input type="hidden" name="options[prefix]" value="last">
            <button type="button" class="menu-search-panel__clear" id="MenuSearchClear" aria-label="Löschen" onclick="window.clearMobileSearch && window.clearMobileSearch()">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </form>
        </div>
        <div class="menu-search-panel__content" id="MenuSearchContent">
          <!-- Default: Popular searches -->
          <div class="menu-search-panel__section" id="MenuSearchPopular">
            <div class="menu-search-panel__title">Beliebte Suchen</div>
            <ul class="menu-search-panel__list">
              <li><a href="/collections/software" class="menu-search-panel__item">Microsoft Office</a></li>
              <li><a href="/collections/software" class="menu-search-panel__item">Windows 11</a></li>
              <li><a href="/collections/microsoft-365" class="menu-search-panel__item">Office 365</a></li>
              <li><a href="/collections/software" class="menu-search-panel__item">Windows 10</a></li>
              <li><a href="/collections/software" class="menu-search-panel__item">Antivirus</a></li>
            </ul>
          </div>
          <!-- Live suggestions will be injected here -->
          <div id="MenuSearchResults" style="display:none;"></div>
        </div>
      </div>

      <!-- Mobile Menu Search JavaScript (Global Functions) -->
      <script>
      (function() {
        var debounceTimer;
        
        // Global functions for onclick handlers
        window.openMobileSearchPanel = function() {
          var panel = document.getElementById('MenuSearchPanel');
          var input = document.getElementById('MenuSearchInput');
          if (panel) {
            panel.classList.add('active');
            if (input) {
              setTimeout(function() {
                input.focus();
                input.click();
              }, 100);
            }
          }
        };
        
        window.closeMobileSearchPanel = function() {
          var panel = document.getElementById('MenuSearchPanel');
          var input = document.getElementById('MenuSearchInput');
          var clearBtn = document.getElementById('MenuSearchClear');
          var results = document.getElementById('MenuSearchResults');
          var popular = document.getElementById('MenuSearchPopular');
          
          if (panel) panel.classList.remove('active');
          if (input) input.value = '';
          if (clearBtn) clearBtn.classList.remove('visible');
          if (results) results.style.display = 'none';
          if (popular) popular.style.display = 'block';
        };
        
        window.clearMobileSearch = function() {
          var input = document.getElementById('MenuSearchInput');
          var clearBtn = document.getElementById('MenuSearchClear');
          var results = document.getElementById('MenuSearchResults');
          var popular = document.getElementById('MenuSearchPopular');
          
          if (input) {
            input.value = '';
            input.focus();
          }
          if (clearBtn) clearBtn.classList.remove('visible');
          if (results) results.style.display = 'none';
          if (popular) popular.style.display = 'block';
        };
        
        function setupSearchInput() {
          var input = document.getElementById('MenuSearchInput');
          var clearBtn = document.getElementById('MenuSearchClear');
          var results = document.getElementById('MenuSearchResults');
          var popular = document.getElementById('MenuSearchPopular');
          var form = document.getElementById('MenuSearchForm');
          
          if (!input) return;
          
          input.removeEventListener('input', handleInput);
          input.addEventListener('input', handleInput);
          
          if (form) {
            form.removeEventListener('submit', handleSubmit);
            form.addEventListener('submit', handleSubmit);
          }
          
          function handleInput() {
            var query = input.value.trim();
            
            if (query.length > 0) {
              clearBtn.classList.add('visible');
            } else {
              clearBtn.classList.remove('visible');
            }
            
            clearTimeout(debounceTimer);
            if (query.length >= 2) {
              debounceTimer = setTimeout(function() {
                fetchSuggestions(query);
              }, 300);
            } else {
              results.style.display = 'none';
              popular.style.display = 'block';
            }
          }
          
          function handleSubmit(e) {
            if (input.value.trim().length === 0) {
              e.preventDefault();
              input.focus();
            }
          }
        }
        
        function fetchSuggestions(query) {
          var results = document.getElementById('MenuSearchResults');
          var popular = document.getElementById('MenuSearchPopular');
          
          results.innerHTML = '<div class="menu-search-panel__loading">Suche...</div>';
          results.style.display = 'block';
          popular.style.display = 'none';
          
          fetch('/search/suggest.json?q=' + encodeURIComponent(query) + '&resources[type]=product,query,collection&resources[limit]=8&resources[options][unavailable_products]=hide')
            .then(function(r) { return r.json(); })
            .then(function(data) {
              renderSuggestions(data, query);
            })
            .catch(function() {
              results.innerHTML = '<div class="menu-search-panel__empty">Suche fehlgeschlagen</div>';
            });
        }
        
        function renderSuggestions(data, query) {
          var results = document.getElementById('MenuSearchResults');
          var res = data.resources.results;
          var html = '';
          
          if (res.queries && res.queries.length > 0) {
            html += '<div class="menu-search-panel__section"><div class="menu-search-panel__title">Suchvorschläge</div><ul class="menu-search-panel__list">';
            res.queries.forEach(function(q) {
              html += '<li><a href="' + q.url + '" class="menu-search-panel__item">' + q.styled_text + '</a></li>';
            });
            html += '</ul></div>';
          }
          
          if (res.products && res.products.length > 0) {
            html += '<div class="menu-search-panel__section"><div class="menu-search-panel__title">Produkte</div>';
            res.products.forEach(function(p) {
              var img = p.featured_image ? p.featured_image.url + '&width=100' : '';
              var price = p.price ? (parseFloat(p.price) / 100).toFixed(2).replace('.', ',') + ' €' : '';
              html += '<a href="' + p.url + '" class="menu-search-panel__product">';
              if (img) html += '<img src="' + img + '" alt="' + p.title.replace(/"/g,'&quot;') + '" class="menu-search-panel__product-image" loading="lazy" width="100" height="100">';
              html += '<div class="menu-search-panel__product-info"><div class="menu-search-panel__product-title">' + p.title + '</div>';
              if (price) html += '<div class="menu-search-panel__product-price">' + price + '</div>';
              html += '</div></a>';
            });
            html += '</div>';
          }
          
          if (res.collections && res.collections.length > 0) {
            html += '<div class="menu-search-panel__section"><div class="menu-search-panel__title">Kategorien</div><ul class="menu-search-panel__list">';
            res.collections.forEach(function(c) {
              html += '<li><a href="' + c.url + '" class="menu-search-panel__item">' + c.title + '</a></li>';
            });
            html += '</ul></div>';
          }
          
          if (html === '') {
            html = '<div class="menu-search-panel__empty">Keine Ergebnisse für "' + query + '"</div>';
          }
          
          results.innerHTML = html;
        }
        
        // Initialize
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setupSearchInput);
        } else {
          setupSearchInput();
        }
        
        // Re-init on menu open
        var observer = new MutationObserver(function() {
          setTimeout(setupSearchInput, 150);
        });
        var menuEl = document.getElementById('Details-menu-drawer-container');
        if (menuEl) observer.observe(menuEl, { attributes: true, attributeFilter: ['open', 'class'] });
      })();
      </script>

      <nav
        class="menu-drawer__navigation"
        style="
          {%- render 'menu-font-styles', settings: block_settings, menu_type: 'drawer' %}
          {%- render 'submenu-font-styles', settings: block_settings %}
        "
      >
        <ul
          class="menu-drawer__menu has-submenu menu-drawer__menu--grid-layout"
          role="list"
        >
          {%- comment -%}
            Handle menus with fewer than 3 levels of links
          {%- endcomment -%}
          {% if linklist.levels < 3 %}
            {% assign first_accordion_open = false %}
            {% assign animation_index = 0 %}
            {%- for link in linklist.links -%}
              {% assign animation_index = animation_index | plus: 1 %}
              
              {%- comment -%} Determine Icon based on Title {%- endcomment -%}
              {% assign icon_class = "fa-solid fa-list" %}
              {% assign title_down = link.title | downcase %}
              {% if title_down contains 'damen' or title_down contains 'woman' %}{% assign icon_class = "fa-solid fa-person-dress" %}
              {% elsif title_down contains 'herren' or title_down contains 'men' %}{% assign icon_class = "fa-solid fa-user-tie" %}
              {% elsif title_down contains 'kinder' or title_down contains 'kid' %}{% assign icon_class = "fa-solid fa-child" %}
              {% elsif title_down contains 'technik' or title_down contains 'tech' %}{% assign icon_class = "fa-solid fa-laptop" %}
              {% elsif title_down contains 'wohnen' or title_down contains 'home' %}{% assign icon_class = "fa-solid fa-couch" %}
              {% elsif title_down contains 'sport' %}{% assign icon_class = "fa-solid fa-person-running" %}
              {% elsif title_down contains 'beauty' %}{% assign icon_class = "fa-solid fa-wand-magic-sparkles" %}
              {% elsif title_down contains 'software' %}{% assign icon_class = "fa-brands fa-windows" %}
              {% elsif title_down contains 'sale' or title_down contains 'aktion' %}{% assign icon_class = "fa-solid fa-percent" %}
              {% endif %}

              <li
                style="--menu-drawer-animation-index: {{ animation_index }};"
                class="menu-drawer__list-item"
              >
                {% if link.links != blank %}
                    <details
                      id="Details-menu-drawer-{{ link.handle }}"
                      style="width: 100%;"
                    >
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="menu-drawer__card-item"
                        style="list-style: none;"
                        on:click="header-drawer/open"
                      >
                         <div style="display: flex; align-items: center; width: 100%;">
                           <i class="{{ icon_class }} card-icon"></i>
                           <span class="card-text">{{ link.title | escape }}</span>
                           <svg class="icon-arrow-right" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                         </div>
                      </summary>
                      {% liquid
                        assign render_link_image = false
                      %}
                      <div class="menu-drawer__submenu has-submenu gradient motion-reduce" tabindex="-1" style="background:#fff !important;">
                           <div class="menu-drawer__inner-submenu">
                                <div class="menu-drawer__nav-buttons">
                                  <button class="button menu-drawer__back-button focus-inset" aria-expanded="true" on:click="header-drawer/back">
                                    <span class="svg-wrapper icon-caret icon-caret--backward">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                                    <span class="menu-drawer__menu-item-text wrap-text" style="font-weight: 700;">{{ link.title | escape }}</span>
                                  </button>
                                  <button class="button button-unstyled close-button menu-drawer__close-button" type="button" on:click="header-drawer/close">
                                    <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">{{- 'icon-close.svg' | inline_asset_content -}}</span>
                                  </button>
                                </div>
                                <ul class="menu-drawer__menu menu-drawer__menu--childlist" role="list" tabindex="-1" style="padding: 0;">
                                    {%- for childlink in link.links -%}
                                      <li class="menu-drawer__list-item">
                                        <a href="{{ childlink.url }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset">
                                          <span class="menu-drawer__menu-item-text wrap-text" style="font-weight: 500;">{{ childlink.title | escape }}</span>
                                          {% if childlink.links != blank %}<svg class="icon-arrow-right" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>{% endif %}
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                </ul>
                           </div>
                      </div>
                    </details>
                {% else %}
                  <a
                    id="HeaderDrawer-{{ link.handle }}"
                    href="{{ link.url }}"
                    class="menu-drawer__card-item"
                  >
                    <div style="display: flex; align-items: center; width: 100%;">
                        <i class="{{ icon_class }} card-icon"></i>
                        <span class="card-text">{{ link.title | escape }}</span>
                    </div>
                  </a>
                {% endif %}
              </li>
            {%- endfor -%}
          {% else %}
            {%- comment -%}
              Handle menus with 3 levels... (Apply same grid logic)
            {%- endcomment -%}
             {% assign animation_index = 0 %}
             {%- for link in linklist.links -%}
              {% assign animation_index = animation_index | plus: 1 %}
              
              {%- comment -%} Determine Icon {%- endcomment -%}
              {% assign icon_class = "fa-solid fa-box" %}
              {% assign title_down = link.title | downcase %}
              {% if title_down contains 'damen' %}{% assign icon_class = "fa-solid fa-person-dress" %}
              {% elsif title_down contains 'herren' %}{% assign icon_class = "fa-solid fa-user-tie" %}
              {% elsif title_down contains 'technik' %}{% assign icon_class = "fa-solid fa-laptop" %}
              {% elsif title_down contains 'software' %}{% assign icon_class = "fa-brands fa-windows" %}
              {% elsif title_down contains 'sale' %}{% assign icon_class = "fa-solid fa-percent" %}
              {% endif %}

              <li class="menu-drawer__list-item--grid" style="--menu-drawer-animation-index: {{ animation_index }}; display:flex !important;">
                 {%- if link.links != blank -%}
                   <details id="Details-menu-drawer-menu-item-{{ forloop.index }}" class="menu-drawer__menu-container" style="width:100%;">
                     <summary id="HeaderDrawer-{{ link.handle }}" class="menu-drawer__card-item" on:click="header-drawer/open">
                       <i class="{{ icon_class }} card-icon"></i>
                       <span class="card-text">{{ link.title | escape }}</span>
                     </summary>
                    <div
                      id="link-{{ link.handle | escape }}"
                      class="menu-drawer__submenu has-submenu gradient motion-reduce"
                      tabindex="-1"
                      style="--menu-drawer-animation-index: {{ animation_index }};"
                    >
                      <div class="menu-drawer__inner-submenu">
                        <div class="menu-drawer__nav-buttons">
                          <button
                            class="button menu-drawer__back-button focus-inset"
                            aria-expanded="true"
                            on:click="header-drawer/back"
                            aria-label="{{ 'actions.back' | t }}"
                          >
                            <span class="svg-wrapper icon-caret icon-caret--backward">
                              {{- 'icon-caret.svg' | inline_asset_content -}}
                            </span>
                            <span class="menu-drawer__menu-item-text wrap-text">{{ link.title | escape }}</span>
                          </button>
                          <button
                            class="button button-unstyled close-button menu-drawer__close-button"
                            type="button"
                            aria-label="{{ 'actions.close' | t }}"
                            on:click="header-drawer/close"
                          >
                            <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">
                              {{- 'icon-close.svg' | inline_asset_content -}}
                            </span>
                          </button>
                        </div>
                        {% liquid
                          assign render_link_image = false
                          comment
                          if block_settings.menu_style == 'collection_images'
                            assign catalog_links = link.links | where: 'type', 'catalog_link'
                            assign collection_list_links = link.links | where: 'type', 'collections_link'
                            assign collection_links = link.links | where: 'type', 'collection_link'
                            if catalog_links.size > 0 or collection_list_links.size > 0 or collection_links.size > 0
                              assign render_link_image = true
                            endif
                          endif
                          endcomment
                        %}
                        <ul
                          class="menu-drawer__menu menu-drawer__menu--childlist{% if render_link_image and link.levels == 1 %} menu-drawer__menu--grid{% endif %}"
                          role="list"
                          tabindex="-1"
                        >
                          {% assign first_accordion_open = false -%}
                          {%- for childlink in link.links -%}
                            <li
                              class="
                                menu-drawer__list-item
                                {% if childlink.links != blank -%}
                                  {% if block_settings.drawer_accordion -%} menu-drawer__list-item--deep{% else -%} menu-drawer__list-item--flat{%- endif -%}
                                {%- endif -%}
                                {% if block_settings.drawer_dividers %} menu-drawer__list-item--divider{% endif %}
                              "
                            >
                              {%- if childlink.links == blank -%}
                                {%- comment -%}
                                  Simple links for links with no children (regardless of accordion setting), in menus with 3 levels of links
                                  This link is currently using --parent class style but --child would match the pattern on desktop
                                {%- endcomment -%}
                                <a
                                  id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                  href="{{ childlink.url }}"
                                  class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                  {% if childlink.current %}
                                    aria-current="page"
                                  {% endif %}
                                >
                                  {% comment %}
                                  {% if render_link_image and link.levels == 1 %}
                                    {% render 'link-featured-image',
                                      link: childlink,
                                      class: 'menu-drawer__link-image',
                                      sizes: 'auto, 400px'
                                    %}
                                  {% endif %}
                                  {% endcomment %}
                                  <span class="menu-drawer__menu-item-text wrap-text">
                                    {{- childlink.title | escape -}}
                                  </span>
                                </a>
                              {%- else -%}
                                {% liquid
                                  assign accordion_state = ''
                                  if first_accordion_open == false and block_settings.drawer_accordion and block_settings.drawer_accordion_expand_first
                                    assign first_accordion_open = true
                                    assign accordion_state = 'open-by-default-on-mobile'
                                  endif
                                %}
                                {% if block_settings.drawer_accordion %}
                                  {%- comment -%}
                                    Accordion for links with children, in menus with 3 levels of links
                                  {%- endcomment -%}
                                  <accordion-custom {{ accordion_state }}>
                                    <details
                                      id="Details-menu-drawer-{{ link.handle }}-{{ childlink.handle }}"
                                    >
                                      <summary
                                        id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                        class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset"
                                      >
                                        <span class="menu-drawer__menu-item-text wrap-text">
                                          {{- childlink.title | escape -}}
                                        </span>
                                        <span class="svg-wrapper icon-plus">
                                          {{- 'icon-plus.svg' | inline_asset_content -}}
                                        </span>
                                      </summary>
                                      {% liquid
                                        assign render_link_image = false
                                        if block_settings.menu_style == 'collection_images'
                                          assign catalog_links = childlink.links | where: 'type', 'catalog_link'
                                          assign collection_list_links = childlink.links | where: 'type', 'collections_link'
                                          assign collection_links = childlink.links | where: 'type', 'collection_link'
                                          if catalog_links.size > 0 or collection_list_links.size > 0 or collection_links.size > 0
                                            assign render_link_image = true
                                          endif
                                        endif
                                      %}
                                      <ul
                                        class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content{% if render_link_image %} menu-drawer__menu--grid{% endif %}"
                                        role="list"
                                        tabindex="-1"
                                      >
                                        {%- for grandchildlink in childlink.links -%}
                                          <li
                                            class="menu-drawer__list-item"
                                            style="--menu-drawer-animation-index: {{ forloop.index }};"
                                          >
                                            <a
                                              id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                              href="{{ grandchildlink.url }}"
                                              class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                              {% if grandchildlink.current %}
                                                aria-current="page"
                                              {% endif %}
                                            >
                                              {% comment %}
                                              {% if render_link_image %}
                                                {% render 'link-featured-image',
                                                  link: grandchildlink,
                                                  class: 'menu-drawer__link-image',
                                                  sizes: 'auto, 400px'
                                                %}
                                              {% endif %}
                                              {% endcomment %}
                                              <span class="menu-drawer__menu-item-text wrap-text">
                                                {{- grandchildlink.title | escape -}}
                                              </span>
                                            </a>
                                          </li>
                                        {%- endfor -%}
                                      </ul>
                                    </details>
                                  </accordion-custom>
                                {% else %}
                                  {%- comment -%}
                                    Flat menus for links with children, in menus with 3 levels of links
                                  {%- endcomment -%}
                                  <a
                                    id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                    href="{{ childlink.url }}"
                                    class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                  >
                                    <span class="menu-drawer__menu-item-text wrap-text">
                                      {{- childlink.title | escape -}}
                                    </span>
                                  </a>
                                  {% liquid
                                    assign render_link_image = false
                                    if block_settings.menu_style == 'collection_images'
                                      assign catalog_links = childlink.links | where: 'type', 'catalog_link'
                                      assign collection_list_links = childlink.links | where: 'type', 'collections_link'
                                      assign collection_links = childlink.links | where: 'type', 'collection_link'
                                      if catalog_links.size > 0 or collection_list_links.size > 0 or collection_links.size > 0
                                        assign render_link_image = true
                                      endif
                                    endif
                                  %}
                                  <ul
                                    class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content{% if render_link_image %} menu-drawer__menu--grid{% endif %}"
                                    role="list"
                                    tabindex="-1"
                                  >
                                    {%- for grandchildlink in childlink.links -%}
                                      <li
                                        class="menu-drawer__list-item"
                                        style="--menu-drawer-animation-index: {{ forloop.index }};"
                                      >
                                        <a
                                          id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                          href="{{ grandchildlink.url }}"
                                          class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                          {% if grandchildlink.current %}
                                            aria-current="page"
                                          {% endif %}
                                        >
                                          {% if render_link_image %}
                                            {% render 'link-featured-image',
                                              link: grandchildlink,
                                              class: 'menu-drawer__link-image',
                                              sizes: 'auto, 400px'
                                            %}
                                          {% endif %}
                                          <span class="menu-drawer__menu-item-text wrap-text">
                                            {{- grandchildlink.title | escape -}}
                                          </span>
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                {%- endif -%}
                              {%- endif -%}
                            </li>
                          {%- endfor -%}
                        </ul>
                        {% liquid
                          if eager_loading
                            if block_settings.menu_style == 'featured_collections'
                              assign featured_collections = link.links | where: 'type', 'collection_link'
                            endif

                            if block_settings.menu_style == 'featured_products'
                              assign collection_linklist = link.links | where: 'type', 'collection_link' | first
                              assign featured_products_collection = collection_linklist.object
                            endif
                          else
                            assign featured_collections = null | sort
                            assign featured_products_collection = null | sort
                          endif
                        -%}

                        {% comment %}
                        {% if featured_collections.size > 0 or featured_products_collection.products_count > 0 %}
                          <div
                            class="menu-drawer__featured-content menu-drawer__featured-content--childlist"
                            style="--menu-drawer-animation-index: {{ linklist.links.size | plus: 1 }};"
                          >
                            <ul class="menu-drawer__featured-content-list list-unstyled">
                              {% if featured_collections.size > 0 %}
                                {%- for collection in featured_collections limit: max_featured_items -%}
                                  <li class="menu-drawer__featured-content-list-item menu-drawer__featured-content-list-item--collection">
                                    {% render 'resource-card',
                                      resource: collection.object,
                                      resource_type: 'collection',
                                      style: 'overlay',
                                      image_aspect_ratio: ratio,
                                      image_sizes: 'auto, 400px'
                                    %}
                                  </li>
                                {%- endfor -%}
                              {% else %}
                                {% paginate featured_products_collection.products by max_featured_items %}
                                  {%- for product in featured_products_collection.products limit: max_featured_items -%}
                                    <li class="menu-drawer__featured-content-list-item menu-drawer__featured-content-list-item--product">
                                      {% render 'resource-card',
                                        resource: product,
                                        resource_type: 'product',
                                        image_aspect_ratio: ratio,
                                        image_sizes: 'auto, 400px'
                                      %}
                                    </li>
                                  {%- endfor -%}
                                {% endpaginate %}
                              {% endif %}
                            </ul>
                          </div>
                        {% endif %}
                        {% endcomment %}
                      </div>
                    </div>
                  </details>
                {%- else -%}
                  {%- comment -%}
                    Simple links for links with no children (regardless of accordion setting), in menus with 3 levels of links
                  {%- endcomment -%}
                  <a
                    id="HeaderDrawer-{{ link.handle }}"
                    href="{{ link.url }}"
                    class="menu-drawer__menu-item menu-drawer__menu-item--mainlist menu-drawer__animated-element focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
                    {% if link.current %}
                      aria-current="page"
                    {% endif %}
                  >
                    <span class="menu-drawer__menu-item-text wrap-text">{{ link.title | escape }}</span>
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          {% endif %}
        </ul>
      </nav>
      <div
        class="menu-drawer__utility-links menu-drawer__animated-element"
        style="--menu-drawer-animation-index: {{ linklist.links.size }};"
      >
        {% liquid
          assign show_language = section.settings.show_language
          if localization.available_languages.size <= 1
            assign show_language = false
          endif

          assign show_country = section.settings.show_country
          if localization.available_countries.size <= 1
            assign show_country = false
          endif
        %}
        {% if data_header_drawer_type == 'mobile-drawer' and show_country or show_language %}
          {% liquid
            assign background_brightness = block.settings.color_scheme.settings.background | color_brightness
            if background_brightness < 64
              assign flag_shadow_size = 4
            else
              assign flag_shadow_size = 2
            endif

            assign localization_font = '--menu-localization-font: var(--font-[localization_font]--family); ' | replace: '[localization_font]', section.settings.localization_font
            assign color_shadow = '--color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));'
            assign form_style = localization_font | append: color_shadow
          %}
          {% if show_language and show_country == false %}
            <div class="menu-drawer__localization color-{{ settings.popover_color_scheme }}">
              {% render 'localization-form',
                show_country: show_country,
                show_language: show_language,
                block_id: block.id,
                form_style: form_style
              %}
            </div>
          {% else %}
            <drawer-localization-component class="menu-drawer__localization">
              <details
                id="drawer-localization"
                class="drawer-localization"
                on:toggle="/toggle"
              >
                <summary
                  id="HeaderDrawer-localization"
                  class="drawer-localization__button h3 link link--text focus-inset"
                  aria-expanded="false"
                  on:click="header-drawer/open"
                  style="{{ form_style }}"
                >
                  <div class="drawer-localization__button--label h6">
                    {%- if show_country -%}
                      <div class="mobile-localization mobile-localization--country link link--text">
                        {%- if section.settings.country_selector_style == true -%}
                          <span
                            class="icon-flag"
                            style="
                              background-image: url({{- localization.country | image_url: width: 32 }});
                              --size-shadow: {{ flag_shadow_size }}px;
                              --color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-30-60));
                            "
                          ></span>
                        {%- endif -%}
                        <span class="currency-code">
                          {{- localization.country.currency.iso_code -}}
                        </span>
                      </div>
                    {%- endif -%}

                    {%- if show_country and show_language -%}
                      <span>/</span>
                    {%- endif -%}

                    {%- if show_language -%}
                      <div class="mobile-localization mobile-localization--country link link--text">
                        <span>
                          {{ localization.language.iso_code | upcase }}
                        </span>
                      </div>
                    {%- endif -%}
                  </div>
                  <span class="svg-wrapper icon-caret icon-caret--forward">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </summary>

                <div
                  class="menu-drawer__submenu has-submenu gradient motion-reduce color-{{ settings.drawer_color_scheme }}"
                  style=""
                >
                  <div
                    class="menu-drawer__nav-buttons"
                    ref="navButtons"
                  >
                    <button
                      class="button menu-drawer__back-button link link--text focus-inset"
                      aria-expanded="true"
                      on:click="header-drawer/back"
                    >
                      <span class="svg-wrapper icon-caret icon-caret--backward">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                      {{ 'content.localization_region_and_language' | t }}
                    </button>
                    <button
                      class="button close-button menu-drawer__close-button"
                      type="button"
                      aria-label="{{ 'actions.close' | t }}"
                      on:click="header-drawer/close"
                    >
                      <span class="svg-wrapper header-drawer-icon header-drawer-icon--close">
                        {{- 'icon-close.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  </div>

                  {% render 'localization-form',
                    show_country: show_country,
                    show_language: show_language,
                    localization_style: 'drawer',
                    form_style: form_style,
                    block_id: block.id
                  %}
                </div>
              </details>
            </drawer-localization-component>
          {% endif %}
        {%- endif -%}
      </div>

      {% liquid
        if block_settings.menu_style == 'featured_collections'
          assign top_level_featured_collections = linklist.links | where: 'type', 'collection_link'
        endif

        if eager_loading and block_settings.menu_style == 'featured_products'
          for link in linklist.links
            if link.type == 'collection_link'
              assign collection_linklist = link
              assign top_level_featured_products_collection = collection_linklist.object
              break
            elsif link.type == 'catalog_link' or link.type == 'collections_link'
              assign top_level_featured_products_collection = collections.all
              break
            endif
          endfor
        endif
      -%}
      {% comment %}
      {% if top_level_featured_collections.size > 0 or top_level_featured_products_collection.products_count > 0 %}
        <div
          class="menu-drawer__featured-content"
          style="--menu-drawer-animation-index: {{ linklist.links.size | plus: 1 }};"
        >
          <ul class="menu-drawer__featured-content-list menu-drawer__animated-element list-unstyled">
            {% if top_level_featured_collections.size > 0 %}
              {%- for collection in top_level_featured_collections limit: max_featured_items -%}
                <li class="menu-drawer__featured-content-list-item menu-drawer__featured-content-list-item--collection">
                  {% render 'resource-card',
                    resource: collection.object,
                    resource_type: 'collection',
                    style: 'overlay',
                    image_aspect_ratio: ratio,
                    image_sizes: 'auto, 400px'
                  %}
                </li>
              {%- endfor -%}
            {% elsif top_level_featured_products_collection.products_count > 0 %}
              {% paginate top_level_featured_products_collection.products by max_featured_items %}
                {%- for product in top_level_featured_products_collection.products limit: max_featured_items -%}
                  <li class="menu-drawer__featured-content-list-item menu-drawer__featured-content-list-item--product">
                    {% render 'resource-card',
                      resource: product,
                      resource_type: 'product',
                      image_aspect_ratio: ratio,
                      image_sizes: 'auto, 400px'
                    %}
                  </li>
                {%- endfor -%}
              {% endpaginate %}
            {% endif %}
          </ul>
        </div>
      {% endif %}
      {% endcomment %}
    </div>
    <div
      class="menu-drawer__backdrop"
      on:click="header-drawer/close"
    >
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const details = document.getElementById('Details-menu-drawer-container');
          const announcementBars = document.querySelectorAll('.announcement-bar-wrapper');

          if (details && announcementBars.length > 0) {
            const observer = new MutationObserver((mutations) => {
              mutations.forEach((mutation) => {
                if (mutation.type === 'attributes' && mutation.attributeName === 'open') {
                  const isOpen = details.hasAttribute('open');
                  announcementBars.forEach(bar => {
                    if (isOpen) {
                        bar.style.setProperty('display', 'none', 'important');
                    } else {
                        bar.style.removeProperty('display');
                    }
                  });
                }
              });
            });

            observer.observe(details, { attributes: true });
            
            // Initial check
            if (details.hasAttribute('open')) {
                announcementBars.forEach(bar => bar.style.setProperty('display', 'none', 'important'));
            }
          }
        });
      </script>
    </div>
  </details>
</header-drawer>

