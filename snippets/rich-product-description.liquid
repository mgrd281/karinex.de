{% comment %}
  Rich Product Description Template
  - Designed for high conversion and SEO
  - Structure: Hook -> Features -> Benefits -> Tech Specs -> FAQ
  - Usage: {% render 'rich-product-description', product: product %}
{% endcomment %}

<div class="rich-description">
  <div class="rd-intro">
    <div class="rd-content" id="rd-content-area">
      {%- assign desc_clean = product.description -%}
      {%- comment -%} Strip inline style attributes {%- endcomment -%}
      {%- assign desc_clean = desc_clean | replace: ' style="', ' data-x="' -%}
      {%- assign desc_clean = desc_clean | replace: " style='", " data-x='" -%}
      {%- comment -%} Strip font tags {%- endcomment -%}
      {%- assign desc_clean = desc_clean | replace: '<font ', '<span ' -%}
      {%- assign desc_clean = desc_clean | replace: '</font>', '</span>' -%}
      {%- assign desc_clean = desc_clean | replace: '<FONT ', '<span ' -%}
      {%- assign desc_clean = desc_clean | replace: '</FONT>', '</span>' -%}
      {%- comment -%} Strip class attributes to prevent theme class font inheritance {%- endcomment -%}
      {%- assign desc_clean = desc_clean | replace: ' class="', ' data-cls="' -%}
      {%- assign desc_clean = desc_clean | replace: " class='", " data-cls='" -%}
      {{ desc_clean }}
    </div>
  </div>

  {% if product.metafields.custom.features %}
    <div class="rd-features">
      <h3>Ihre Vorteile auf einen Blick</h3>
      <div class="rd-grid">
        {% for feature in product.metafields.custom.features.value %}
          <div class="rd-card">
            <div class="rd-icon">✅</div>
            <p>{{ feature }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% comment %} 
    Dynamic content can be expanded here based on product type (e.g. Software vs Physical) 
  {% endcomment %}
</div>

<style>
  .rich-description,
  .rich-description *,
  .rd-content,
  .rd-content *,
  .rd-content span,
  .rd-content p,
  .rd-content div,
  .rd-content li,
  .rd-content ul,
  .rd-content ol,
  .rd-content a,
  .rd-content em,
  .rd-content strong,
  .rd-content b,
  .rd-content i {
    font-family: 'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
    font-size: 1rem !important;
    line-height: 1.8 !important;
    color: #333 !important;
  }
  .rd-content h1,
  .rd-content h2,
  .rd-content h3,
  .rd-content h4,
  .rd-content h5,
  .rd-content h6,
  .rich-description h1,
  .rich-description h2,
  .rich-description h3,
  .rich-description h4 {
    font-family: 'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
    font-size: 1.25rem !important;
    font-weight: 700 !important;
    color: #111 !important;
    line-height: 1.4 !important;
  }
  .rd-content strong,
  .rd-content b {
    font-weight: 700 !important;
  }
  .rd-content {
    margin-bottom: 2rem;
  }
  .rd-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .rd-card {
    background: #f9f9f9;
    padding: 1.25rem;
    border-radius: 8px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .rd-icon {
    font-size: 1.2rem !important;
    line-height: 1 !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var area = document.getElementById('rd-content-area');
    if (!area) return;
    var sysFont = "'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif";
    
    function forceFont(el) {
      el.style.setProperty('font-family', sysFont, 'important');
      var tag = el.tagName;
      if (tag === 'H1') el.style.setProperty('font-size', '1.6rem', 'important');
      else if (tag === 'H2') el.style.setProperty('font-size', '1.4rem', 'important');
      else if (tag === 'H3') el.style.setProperty('font-size', '1.25rem', 'important');
      else if (tag === 'H4') el.style.setProperty('font-size', '1.1rem', 'important');
      else el.style.setProperty('font-size', '1rem', 'important');
      el.removeAttribute('face');
      el.removeAttribute('color');
      el.removeAttribute('size');
    }
    
    // Remove any <style> blocks inside description
    area.querySelectorAll('style').forEach(function(s) { s.remove(); });
    
    // Force on all existing elements
    area.querySelectorAll('*').forEach(forceFont);
    area.style.setProperty('font-family', sysFont, 'important');
    
    // Watch for any future changes and re-apply
    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        if (m.type === 'childList') {
          m.addedNodes.forEach(function(n) {
            if (n.nodeType === 1) {
              forceFont(n);
              n.querySelectorAll('*').forEach(forceFont);
            }
          });
        }
        if (m.type === 'attributes' && m.attributeName === 'style') {
          var t = m.target;
          if (t.style.fontFamily && t.style.fontFamily.indexOf('apple-system') === -1) {
            forceFont(t);
          }
        }
      });
    });
    observer.observe(area, { childList: true, subtree: true, attributes: true, attributeFilter: ['style'] });
  });
</script>
