{% comment %}
  Rich Product Description — preserves admin formatting verbatim.

  Old behavior stripped inline styles, classes, font tags, and forced
  Cairo/!important on every element via CSS + a MutationObserver.
  This rewrite renders product.description AS-IS so styling written
  in Shopify Admin (colors, sizes, headings, custom classes) survives
  to the customer-facing page.

  Defaults below are intentionally low-specificity (no !important) so
  any inline style or class on the source element wins.
{% endcomment %}

<div class="rich-description">
  <div class="rd-intro">
    <div class="rd-content" id="rd-content-area">
      {{ product.description }}
    </div>
  </div>

  {% if product.metafields.custom.features %}
    <div class="rd-features">
      <h3>Ihre Vorteile auf einen Blick</h3>
      <div class="rd-grid">
        {% for feature in product.metafields.custom.features.value %}
          <div class="rd-card">
            <div class="rd-icon">✅</div>
            <p>{{ feature }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

<style>
  /* Defaults for un-styled elements only — NO !important so admin styles win */
  .rd-content {
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: #333;
    margin-bottom: 2rem;
  }

  /* Heading rhythm — gentle defaults, override-friendly */
  .rd-content h1 { font-size: 1.6rem; font-weight: 700; line-height: 1.3; margin: 1.5rem 0 0.75rem; color: #111; }
  .rd-content h2 { font-size: 1.4rem; font-weight: 700; line-height: 1.3; margin: 1.5rem 0 0.75rem; color: #111; }
  .rd-content h3 { font-size: 1.2rem; font-weight: 700; line-height: 1.4; margin: 1.25rem 0 0.5rem; color: #111; }
  .rd-content h4 { font-size: 1.05rem; font-weight: 700; line-height: 1.4; margin: 1rem 0 0.5rem; color: #111; }
  .rd-content p { margin: 0 0 1rem; }
  .rd-content ul, .rd-content ol { margin: 0 0 1rem 1.25rem; padding: 0; }
  .rd-content li { margin: 0 0 0.4rem; }
  .rd-content a { color: #1d4739; text-decoration: underline; }
  .rd-content img { max-width: 100%; height: auto; }
  .rd-content table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
  .rd-content th, .rd-content td { border: 1px solid #e5e5e5; padding: 0.5rem 0.75rem; text-align: left; }

  /* Features grid (metafield-driven, separate visual unit) */
  .rd-features { margin-top: 2rem; }
  .rd-features h3 {
    font-family: 'Outfit', -apple-system, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #111;
  }
  .rd-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .rd-card {
    background: #f9f9f9;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .rd-card .rd-icon { font-size: 1.1rem; }
  .rd-card p { margin: 0; font-size: 0.95rem; }
</style>
