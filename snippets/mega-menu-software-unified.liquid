  <style>
    /* === Karinex category dropdown — wide horizontal panel centered === */

    /* Keep theme's full-width strip but make it transparent so only our
       centered card is visible. Theme's clip-path animation still works. */
    .menu-list .menu-list__list-item:has(.kx-cat) > .menu-list__submenu,
    .overflow-menu::part(overflow):has(.kx-cat) {
      background: transparent !important;
      box-shadow: none !important;
      padding-inline: 0 !important;
    }
    /* Hide the animated white strip behind the dropdown */
    .overflow-menu:has(.kx-cat)::after { display: none !important; }

    /* Flatten the parent grid so our card can be centered naturally */
    .mega-menu__grid:has(.kx-cat) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      padding: 0 !important;
    }
    .mega-menu__list:has(.kx-cat) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    /* Center the card horizontally inside the full-width strip */
    .menu-list__submenu-inner:has(.kx-cat) {
      max-width: none !important;
      margin: 0 !important;
      padding: 0.6rem 1.5rem 1.25rem !important;
      display: flex !important;
      justify-content: center !important;
    }
    .kx-cat-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
      display: flex;
      justify-content: center;
      width: 100%;
    }

    /* === Card =========================================================== */
    .kx-cat {
      width: max-content;
      min-width: 560px;
      max-width: 1100px;
      background: #ffffff;
      border: 1px solid rgba(15, 25, 20, 0.04);
      border-radius: 16px;
      box-shadow:
        0 1px 2px rgba(0,0,0,0.04),
        0 24px 60px rgba(15, 25, 20, 0.12);
      padding: clamp(1.5rem, 2vw, 2rem) clamp(1.75rem, 2.5vw, 2.5rem);
      animation: kxCatIn 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes kxCatIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-cat { animation: none; }
    }

    .kx-cat,
    .kx-cat * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-cat ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    /* === Grid of columns ================================================ */
    .kx-cat__grid {
      display: grid;
      gap: clamp(1.5rem, 2.5vw, 2.5rem);
      align-items: start;
    }
    .kx-cat__grid--2 { grid-template-columns: repeat(2, minmax(170px, 1fr)); }
    .kx-cat__grid--3 { grid-template-columns: repeat(3, minmax(170px, 1fr)); }

    .kx-cat__col {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }
    .kx-cat__col-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #6e6e73;
      margin: 0 0 0.35rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid #ececec;
    }
    .kx-cat__col-list {
      display: flex;
      flex-direction: column;
      gap: 0.05rem;
    }
    .kx-cat__col-list a {
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0;
      font-size: 14.5px;
      line-height: 1.3;
      font-weight: 500;
      letter-spacing: -0.005em;
      color: #1d1d1f;
      text-decoration: none;
      transition: color 180ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-list a:hover,
    .kx-cat__col-list a:focus-visible {
      color: #1B3A2E;
      transform: translateX(3px);
      outline: none;
    }
    .kx-cat__col-list a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    /* "Alle X" footer link */
    .kx-cat__all-row {
      grid-column: 1 / -1;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid #ececec;
      display: flex;
      justify-content: flex-end;
    }
    .kx-cat__all {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 13.5px;
      font-weight: 600;
      color: #1B3A2E;
      text-decoration: none;
      transition: gap 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__all::after {
      content: '→';
      transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__all:hover::after,
    .kx-cat__all:focus-visible::after {
      transform: translateX(4px);
    }

    /* === SALE promo variant ============================================= */
    .kx-cat--sale .kx-cat__col-list a {
      color: #1d1d1f;
    }
    .kx-cat--sale .kx-cat__col-list a:hover,
    .kx-cat--sale .kx-cat__col-list a:focus-visible {
      color: #E60000;
    }
    .kx-cat--sale .kx-cat__col-list .kx-cat__sale-pill {
      color: #E60000;
      font-weight: 700;
    }
    .kx-cat__promo {
      grid-column: 1 / -1;
      margin-top: 0.5rem;
      padding: 1.1rem 1.25rem;
      border-radius: 12px;
      background: linear-gradient(135deg, #1B3A2E 0%, #11261E 100%);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__promo:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 24px rgba(27, 58, 46, 0.18);
    }
    .kx-cat__promo-text { display: flex; flex-direction: column; gap: 2px; }
    .kx-cat__promo-eyebrow {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
    }
    .kx-cat__promo-title {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: -0.005em;
    }
    .kx-cat__promo-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1rem;
      background: #fff;
      color: #11261E;
      border-radius: 999px;
      font-size: 12.5px;
      font-weight: 700;
      white-space: nowrap;
    }
    .kx-cat__promo-cta::after {
      content: '→';
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__promo:hover .kx-cat__promo-cta::after {
      transform: translateX(4px);
    }

    /* === Responsive ===================================================== */
    @media (max-width: 989px) {
      .kx-cat {
        min-width: 0;
        width: 100%;
      }
      .kx-cat__grid--2,
      .kx-cat__grid--3 {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
    }
  </style>

