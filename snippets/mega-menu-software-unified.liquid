{%- doc -%}
  Renders a category-specific Karinex software mega-menu. The Menüpunkte
  sidebar (the 7 top-level Hauptmenü items) is always shown on the left;
  the remaining columns vary based on the hovered top-level item, so each
  category (Office für Windows / Mac, Microsoft 365, Windows, Windows
  Server, Microsoft Tools, SALE & Bestseller) has its own panel.

  @param {string} _root - Theme root URL prefix, e.g. '/' or '/de/'.
  @param {object} parent_link - The top-level Hauptmenü link being hovered.
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_check = _root | slice: -1, 1
    unless _root_check == '/'
      assign _root = _root | append: '/'
    endunless
  endunless

  assign p_handle = parent_link.handle | default: '' | downcase
  assign p_title = parent_link.title | default: '' | downcase | replace: 'ü', 'u' | replace: 'ö', 'o' | replace: 'ä', 'a' | replace: 'ß', 'ss'

  comment
    Detect category. Order matters: Mac before generic Office, Server
    before generic Windows, Sale/Bestseller before generic keywords.
  endcomment
  assign category = 'default'
  if p_handle contains 'mac' or p_title contains 'mac'
    assign category = 'office-mac'
  elsif p_handle contains '365' or p_title contains '365'
    assign category = 'microsoft-365'
  elsif p_handle contains 'server' or p_title contains 'server'
    assign category = 'windows-server'
  elsif p_handle contains 'tools' or p_title contains 'tools'
    assign category = 'microsoft-tools'
  elsif p_handle contains 'sale' or p_handle contains 'bestseller' or p_title contains 'sale' or p_title contains 'bestseller'
    assign category = 'sale-bestseller'
  elsif p_handle contains 'office' or p_title contains 'office'
    assign category = 'office-windows'
  elsif p_handle contains 'windows' or p_title contains 'windows'
    assign category = 'windows'
  endif

  case category
    when 'office-windows'
      assign col_titles = 'Office 2024|Office 2021|Office 2019|Home & Student' | split: '|'
      assign col_hrefs = 'search?q=Office+2024+Professional+Plus|search?q=Office+2021+Professional+Plus|search?q=Office+2019+Professional+Plus|search?q=Office+Home+Student' | split: '|'
      assign sub_a = 'Office 2024 Pro Plus~search?q=Office+2024+Professional+Plus;;Office 2024 Standard~search?q=Office+2024+Standard;;Office 2024 Home & Business~search?q=Office+2024+Home+Business;;Alle 2024-Lizenzen~search?q=Office+2024'
      assign sub_b = 'Office 2021 Pro Plus~search?q=Office+2021+Professional+Plus;;Office 2021 Home & Business~search?q=Office+2021+Home+Business;;Office 2021 Standard~search?q=Office+2021+Standard;;Alle 2021-Lizenzen~search?q=Office+2021'
      assign sub_c = 'Office 2019 Pro Plus~search?q=Office+2019+Professional+Plus;;Office 2019 Home & Business~search?q=Office+2019+Home+Business;;Office 2019 Standard~search?q=Office+2019+Standard;;Alle 2019-Lizenzen~search?q=Office+2019'
      assign sub_d = 'Home & Student 2024~search?q=Office+2024+Home+Student;;Home & Student 2021~search?q=Office+2021+Home+Student;;Home & Student 2019~search?q=Office+2019+Home+Student;;Alle Office-Lizenzen~collections/microsoft-office'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c | append: '@@' | append: sub_d
    when 'office-mac'
      assign col_titles = 'Office 2024 Mac|Office 2021 Mac|Home & Student Mac' | split: '|'
      assign col_hrefs = 'search?q=Office+2024+Mac|search?q=Office+2021+Mac|search?q=Office+Mac+Home' | split: '|'
      assign sub_a = 'Office 2024 für Mac~search?q=Office+2024+Mac;;Office 2024 Home & Business Mac~search?q=Office+2024+Home+Business+Mac;;Alle 2024 Mac~search?q=Office+2024+Mac'
      assign sub_b = 'Office 2021 für Mac~search?q=Office+2021+Mac;;Office 2021 Home & Business Mac~search?q=Office+2021+Home+Business+Mac;;Alle 2021 Mac~search?q=Office+2021+Mac'
      assign sub_c = 'Home & Student 2024 Mac~search?q=Office+2024+Home+Student+Mac;;Home & Student 2021 Mac~search?q=Office+2021+Home+Student+Mac;;Alle Mac-Lizenzen~collections/microsoft-office-fur-mac'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c
    when 'microsoft-365'
      assign col_titles = '365 Personal|365 Family|365 Business' | split: '|'
      assign col_hrefs = 'search?q=Microsoft+365+Personal|search?q=Microsoft+365+Family|search?q=Microsoft+365+Business' | split: '|'
      assign sub_a = '365 Personal 1 Jahr~search?q=Microsoft+365+Personal+1+Jahr;;365 Personal 5 Jahre~search?q=Microsoft+365+Personal+5+Jahre;;Alle Personal-Abos~search?q=Microsoft+365+Personal'
      assign sub_b = '365 Family 1 Jahr~search?q=Microsoft+365+Family;;365 Home~search?q=Microsoft+365+Home;;Alle Family-Abos~search?q=Microsoft+365+Family'
      assign sub_c = '365 Business Standard~search?q=Microsoft+365+Business+Standard;;365 Business Premium~search?q=Microsoft+365+Business+Premium;;Alle 365-Abos~collections/microsoft-365-abonnement'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c
    when 'windows'
      assign col_titles = 'Windows 11|Windows 10|Windows 8|Windows 7 / XP' | split: '|'
      assign col_hrefs = 'search?q=Windows+11|search?q=Windows+10|search?q=Windows+8|search?q=Windows+7' | split: '|'
      assign sub_a = 'Windows 11 Pro~search?q=Windows+11+Pro;;Windows 11 Home~search?q=Windows+11+Home;;Windows 11 Enterprise~search?q=Windows+11+Enterprise;;Windows 11 Pro for Workstations~search?q=Windows+11+Pro+Workstations;;Windows 11 Pro DVD/OEM~search?q=Windows+11+Pro+DVD'
      assign sub_b = 'Windows 10 Pro~search?q=Windows+10+Pro;;Windows 10 Home OEM~search?q=Windows+10+Home+OEM;;Windows 10 Enterprise~search?q=Windows+10+Enterprise;;Windows 10 Education~search?q=Windows+10+Education'
      assign sub_c = 'Windows 8.1 Pro~search?q=Windows+8.1+Pro;;Windows 8 Pro~search?q=Windows+8+Pro;;Alle Windows-Versionen~collections/windows'
      assign sub_d = 'Windows 7 Ultimate OEM~search?q=Windows+7+Ultimate+OEM;;Windows 7 Home Premium OEM~search?q=Windows+7+Home+Premium+OEM;;Windows XP~search?q=Windows+XP'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c | append: '@@' | append: sub_d
    when 'windows-server'
      assign col_titles = 'Server 2022|Server 2019|Server 2016 / 2012' | split: '|'
      assign col_hrefs = 'search?q=Windows+Server+2022|search?q=Windows+Server+2019|search?q=Windows+Server+2016' | split: '|'
      assign sub_a = 'Server 2022 Standard~search?q=Windows+Server+2022+Standard;;Server 2022 Datacenter~search?q=Windows+Server+2022+Datacenter;;Server 2022 Essentials~search?q=Windows+Server+2022+Essentials;;Alle Server 2022~search?q=Windows+Server+2022'
      assign sub_b = 'Server 2019 Standard~search?q=Windows+Server+2019+Standard;;Server 2019 Datacenter~search?q=Windows+Server+2019+Datacenter;;Server 2019 Essentials~search?q=Windows+Server+2019+Essentials;;Alle Server 2019~search?q=Windows+Server+2019'
      assign sub_c = 'Server 2016 Standard~search?q=Windows+Server+2016+Standard;;Server 2016 Datacenter~search?q=Windows+Server+2016+Datacenter;;Server 2012 R2~search?q=Windows+Server+2012;;Alle Server-Lizenzen~collections/windows-server'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c
    when 'microsoft-tools'
      assign col_titles = 'Visual Studio|SQL Server|Project|Visio' | split: '|'
      assign col_hrefs = 'search?q=Visual+Studio|search?q=SQL+Server|search?q=Microsoft+Project|search?q=Microsoft+Visio' | split: '|'
      assign sub_a = 'Visual Studio 2022 Pro~search?q=Visual+Studio+2022+Professional;;Visual Studio 2022 Enterprise~search?q=Visual+Studio+2022+Enterprise;;Visual Studio 2019~search?q=Visual+Studio+2019;;Alle Visual Studio~search?q=Visual+Studio'
      assign sub_b = 'SQL Server 2022 Standard~search?q=SQL+Server+2022+Standard;;SQL Server 2019 Standard~search?q=SQL+Server+2019+Standard;;SQL Server 2017~search?q=SQL+Server+2017;;Alle SQL Server~search?q=SQL+Server'
      assign sub_c = 'Project 2024 Pro~search?q=Project+2024+Professional;;Project 2021 Pro~search?q=Project+2021+Professional;;Project 2019 Pro~search?q=Project+2019+Professional;;Alle Project~search?q=Microsoft+Project'
      assign sub_d = 'Visio 2024 Pro~search?q=Visio+2024+Professional;;Visio 2021 Pro~search?q=Visio+2021+Professional;;Visio 2019 Pro~search?q=Visio+2019+Professional;;Alle Visio~search?q=Microsoft+Visio'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c | append: '@@' | append: sub_d
    when 'sale-bestseller'
      assign col_titles = 'SALE|Bestseller' | split: '|'
      assign col_hrefs = 'collections/sale|collections/bestseller' | split: '|'
      assign sub_a = 'Office Angebote~search?q=Office+Sale;;Windows Angebote~search?q=Windows+Sale;;Microsoft 365 Angebote~search?q=365+Sale;;Server Angebote~search?q=Server+Sale;;Alle Angebote ansehen~collections/sale'
      assign sub_b = 'Bestseller Office~search?q=Office+Bestseller;;Bestseller Windows~search?q=Windows+Bestseller;;Bestseller 365~search?q=365+Bestseller;;Bestseller Tools~search?q=Tools+Bestseller;;Alle Bestseller~collections/bestseller'
      assign all_subs = sub_a | append: '@@' | append: sub_b
    else
      assign col_titles = 'Windows 11|Windows 10|Windows 8|Windows 7 / XP|Microsoft Office|Office für Mac' | split: '|'
      assign col_hrefs = 'search?q=Windows+11|search?q=Windows+10|search?q=Windows+8|search?q=Windows+7|collections/microsoft-office|collections/microsoft-office-fur-mac' | split: '|'
      assign sub_a = 'Windows 11 Pro~search?q=Windows+11+Pro;;Windows 11 Home~search?q=Windows+11+Home;;Windows 11 Enterprise~search?q=Windows+11+Enterprise;;Windows 11 Pro for Workstations~search?q=Windows+11+Pro+Workstations;;Windows 11 Pro DVD/OEM~search?q=Windows+11+Pro+DVD'
      assign sub_b = 'Windows 10 Pro~search?q=Windows+10+Pro;;Windows 10 Home OEM~search?q=Windows+10+Home+OEM;;Windows 10 Enterprise~search?q=Windows+10+Enterprise;;Windows 10 Education~search?q=Windows+10+Education'
      assign sub_c = 'Windows 8.1 Pro~search?q=Windows+8.1+Pro;;Windows 8 Pro~search?q=Windows+8+Pro;;Alle Windows-Versionen~collections/windows'
      assign sub_d = 'Windows 7 Ultimate OEM~search?q=Windows+7+Ultimate+OEM;;Windows 7 Home Premium OEM~search?q=Windows+7+Home+Premium+OEM;;Windows XP~search?q=Windows+XP'
      assign sub_e = 'Office 2024 Pro Plus~search?q=Office+2024+Professional+Plus;;Office 2021 Pro Plus~search?q=Office+2021+Professional+Plus;;Office 2019 Pro Plus~search?q=Office+2019+Professional+Plus;;Alle Office-Lizenzen~collections/microsoft-office'
      assign sub_f = 'Office 2024 für Mac~search?q=Office+2024+Mac;;Office 2021 für Mac~search?q=Office+2021+Mac;;Alle Mac-Lizenzen~collections/microsoft-office-fur-mac'
      assign all_subs = sub_a | append: '@@' | append: sub_b | append: '@@' | append: sub_c | append: '@@' | append: sub_d | append: '@@' | append: sub_e | append: '@@' | append: sub_f
  endcase

  assign cols_subs = all_subs | split: '@@'
  assign cols_count = col_titles.size
  assign total_cols = cols_count | plus: 1
  assign tablet_cols = 4
  if total_cols < 4
    assign tablet_cols = total_cols
  endif
-%}

{%- if mode == 'mobile' -%}
  <ul class="menu-drawer__menu menu-drawer__menu--childlist software-unified-mobile" role="list" tabindex="-1" style="padding: 0;">
    {%- comment -%} Menüpunkte sidebar at the top of every mobile accordion. {%- endcomment -%}
    <li class="menu-drawer__list-item software-unified-mobile__item">
      <accordion-custom open-by-default-on-mobile>
        <details open>
          <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
            <span class="menu-drawer__menu-item-text wrap-text" style="font-weight:700;">Menüpunkte</span>
            <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
          </summary>
          <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content" role="list" tabindex="-1">
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-office" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Office für Windows</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-office-fur-mac" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Office für Mac</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-365-abonnement" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Microsoft 365</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/windows" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Windows</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/windows-server" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Windows Server</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-tools" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Microsoft Tools</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/sale" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">SALE &amp; Bestseller</span></a></li>
          </ul>
        </details>
      </accordion-custom>
    </li>

    {%- for col_title in col_titles -%}
      {%- assign col_href = col_hrefs[forloop.index0] -%}
      {%- assign subs = cols_subs[forloop.index0] | split: ';;' -%}
      <li class="menu-drawer__list-item software-unified-mobile__item">
        <accordion-custom>
          <details>
            <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
              <span class="menu-drawer__menu-item-text wrap-text">{{ col_title }}</span>
              <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
            </summary>
            <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content" role="list" tabindex="-1">
              <li class="menu-drawer__list-item">
                <a href="{{ _root }}{{ col_href }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset" style="font-weight:600;">
                  <span class="menu-drawer__menu-item-text wrap-text">{{ col_title }} ansehen</span>
                </a>
              </li>
              {%- for sub in subs -%}
                {%- assign parts = sub | split: '~' -%}
                <li class="menu-drawer__list-item">
                  <a href="{{ _root }}{{ parts[1] }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset">
                    <span class="menu-drawer__menu-item-text wrap-text">{{ parts[0] }}</span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </details>
        </accordion-custom>
      </li>
    {%- endfor -%}
  </ul>
{%- else -%}
  <style>
    .mega-menu__grid:has(.mega-menu-software-unified--{{ category }}) {
      --menu-columns-desktop: {{ total_cols }} !important;
      --menu-columns-tablet: {{ tablet_cols }} !important;
    }
    .mega-menu__list:has(.mega-menu-software-unified--{{ category }}) {
      grid-column: span {{ total_cols }} !important;
    }
    .mega-menu-software-unified__sidebar {
      border-right: 1px solid #eeeeee;
      padding-right: 1.25rem;
    }
    @media (max-width: 1199px) {
      .mega-menu-software-unified__sidebar {
        border-right: 0;
        padding-right: 0;
      }
    }
  </style>

  <li class="mega-menu__column mega-menu__column--span-1 mega-menu-software-unified mega-menu-software-unified--{{ category }} mega-menu-software-unified__sidebar">
    <div class="mega-menu__item-wrapper">
      <span class="mega-menu__link mega-menu__link--parent">Menüpunkte</span>
      <ul class="list-unstyled mega-menu__submenu-list">
        <li><a href="{{ _root }}collections/microsoft-office" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Office für Windows</span></a></li>
        <li><a href="{{ _root }}collections/microsoft-office-fur-mac" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Office für Mac</span></a></li>
        <li><a href="{{ _root }}collections/microsoft-365-abonnement" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Microsoft 365</span></a></li>
        <li><a href="{{ _root }}collections/windows" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Windows</span></a></li>
        <li><a href="{{ _root }}collections/windows-server" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Windows Server</span></a></li>
        <li><a href="{{ _root }}collections/microsoft-tools" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Microsoft Tools</span></a></li>
        <li><a href="{{ _root }}collections/sale" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">SALE &amp; Bestseller</span></a></li>
      </ul>
    </div>
  </li>

  {%- for col_title in col_titles -%}
    {%- assign col_href = col_hrefs[forloop.index0] -%}
    {%- assign subs = cols_subs[forloop.index0] | split: ';;' -%}
    <li class="mega-menu__column mega-menu__column--span-1 mega-menu-software-unified mega-menu-software-unified--{{ category }}">
      <div class="mega-menu__item-wrapper">
        <a href="{{ _root }}{{ col_href }}" class="mega-menu__link mega-menu__link--parent">{{ col_title }}</a>
        <ul class="list-unstyled mega-menu__submenu-list">
          {%- for sub in subs -%}
            {%- assign parts = sub | split: '~' -%}
            <li>
              <a href="{{ _root }}{{ parts[1] }}" class="mega-menu__link">
                <span class="mega-menu__link-title wrap-text">{{ parts[0] }}</span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </li>
  {%- endfor -%}
{%- endif -%}
