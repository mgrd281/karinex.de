{%- doc -%}
  Karinex Category Dropdown — best-software.de style.

  Each top-level Hauptmenü item opens its OWN compact dropdown that
  shows only the sub-categories relevant to it. No unified panel, no
  cross-category content. Width adapts to the content.

  Category routing (parent_link.handle / parent_link.title):
    · office-mac           → Office für Mac links
    · 365                  → Microsoft 365 abos
    · server               → Windows Server editions
    · tools                → Visual Studio · SQL · Project · Visio
    · sale / bestseller    → SALE & Bestseller list
    · office               → Office (Windows) versions + apps
    · windows              → Windows OS versions

  @param {string} _root - Theme root URL prefix.
  @param {object} parent_link - The hovered top-level Hauptmenü link.
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_check = _root | slice: -1, 1
    unless _root_check == '/'
      assign _root = _root | append: '/'
    endunless
  endunless

  assign p_handle = parent_link.handle | default: '' | downcase
  assign p_title  = parent_link.title  | default: '' | downcase | replace: 'ü', 'u' | replace: 'ö', 'o' | replace: 'ä', 'a' | replace: 'ß', 'ss'

  # Order matters: mac before generic office, server before generic windows,
  # sale/bestseller before any generic keyword.
  assign cat = 'default'
  if p_handle contains 'mac' or p_title contains 'mac'
    assign cat = 'office-mac'
  elsif p_handle contains '365' or p_title contains '365'
    assign cat = '365'
  elsif p_handle contains 'server' or p_title contains 'server'
    assign cat = 'server'
  elsif p_handle contains 'tools' or p_title contains 'tools'
    assign cat = 'tools'
  elsif p_handle contains 'sale' or p_handle contains 'bestseller' or p_title contains 'sale' or p_title contains 'bestseller'
    assign cat = 'sale'
  elsif p_handle contains 'office' or p_title contains 'office'
    assign cat = 'office'
  elsif p_handle contains 'windows' or p_title contains 'windows'
    assign cat = 'windows'
  endif
-%}

