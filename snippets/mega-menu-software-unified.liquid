  <style>
    /* === Karinex Category Dropdown — compact, anchored under each item === */

    /* Make each top-level item a positioning context for its dropdown */
    .menu-list .menu-list__list-item:has(.kx-cat) {
      position: relative;
    }
    /* Compact dropdown: width fits content, anchored under the hovered item */
    .menu-list .menu-list__list-item:has(.kx-cat) > .menu-list__submenu,
    .overflow-menu::part(overflow):has(.kx-cat) {
      width: auto !important;
      min-width: 260px !important;
      max-width: 360px !important;
      left: 0 !important;
      right: auto !important;
      padding-inline: 0 !important;
      background: transparent !important;
      box-shadow: none !important;
      grid-template-columns: 1fr !important;
    }
    /* Kill the full-width animated white strip behind the panel */
    .overflow-menu:has(.kx-cat)::after {
      display: none !important;
    }
    /* Strip the parent grid */
    .mega-menu__grid:has(.kx-cat) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      padding: 0 !important;
    }
    .mega-menu__list:has(.kx-cat) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .menu-list__submenu-inner:has(.kx-cat) {
      padding: 0 !important;
      max-width: none !important;
      margin: 0 !important;
    }
    .kx-cat-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
    }

    /* === Compact dropdown card =========================================== */
    .kx-cat {
      width: max-content;
      min-width: 260px;
      max-width: 360px;
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 1px 2px rgba(0,0,0,0.04),
                  0 12px 32px rgba(15, 25, 20, 0.10);
      padding: 0.65rem 0;
      margin-top: 0.35rem;
      animation: kxCatIn 200ms cubic-bezier(0.16, 1, 0.3, 1) both;
      border: 1px solid rgba(15, 25, 20, 0.04);
    }
    @keyframes kxCatIn {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-cat { animation: none; }
    }

    .kx-cat,
    .kx-cat * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-cat ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .kx-cat a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.55rem 1.1rem;
      font-size: 14px;
      line-height: 1.3;
      font-weight: 500;
      color: #1d1d1f;
      text-decoration: none;
      letter-spacing: -0.005em;
      white-space: nowrap;
      transition: background-color 160ms cubic-bezier(0.16, 1, 0.3, 1),
                  color 160ms cubic-bezier(0.16, 1, 0.3, 1),
                  padding-left 160ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat a:hover,
    .kx-cat a:focus-visible {
      background: #f4f7f5;
      color: #1B3A2E;
      padding-left: 1.3rem;
      outline: none;
    }
    .kx-cat a:focus-visible {
      box-shadow: inset 3px 0 0 #1B3A2E;
    }

    .kx-cat__divider {
      height: 1px;
      background: #ececec;
      margin: 0.4rem 0.85rem;
    }

    .kx-cat__all {
      font-weight: 600 !important;
      color: #1B3A2E !important;
    }
    .kx-cat__all::after {
      content: '→';
      margin-left: auto;
      padding-left: 0.5rem;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__all:hover::after,
    .kx-cat__all:focus-visible::after {
      transform: translateX(3px);
    }

    .kx-cat__sale {
      color: #E60000 !important;
      font-weight: 600;
    }
    .kx-cat__sale:hover,
    .kx-cat__sale:focus-visible {
      color: #E60000 !important;
      background: rgba(230, 0, 0, 0.05);
    }
  </style>

