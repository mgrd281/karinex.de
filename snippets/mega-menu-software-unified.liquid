  <style>
    /* === Karinex category dropdown — flat full-width strip ============== */
    .menu-list .menu-list__list-item:has(.kx-cat) > .menu-list__submenu,
    .overflow-menu::part(overflow):has(.kx-cat) {
      background: #ffffff !important;
      box-shadow: 0 1px 0 rgba(15, 25, 20, 0.06) !important;
      border-bottom: 1px solid #ececec !important;
      padding-inline: 0 !important;
    }
    .overflow-menu:has(.kx-cat)::after { display: none !important; }

    .mega-menu__grid:has(.kx-cat) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      padding: 0 !important;
    }
    .mega-menu__list:has(.kx-cat) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .menu-list__submenu-inner:has(.kx-cat) {
      max-width: 1400px !important;
      margin: 0 auto !important;
      padding: clamp(1.75rem, 2.5vw, 2.25rem) clamp(1.5rem, 4vw, 3rem) !important;
      display: block !important;
    }
    .kx-cat-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
      width: 100%;
    }

    .kx-cat {
      width: 100%;
      background: transparent;
      border: 0;
      box-shadow: none;
      padding: 0;
      animation: kxCatIn 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes kxCatIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-cat { animation: none; }
    }

    .kx-cat,
    .kx-cat * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-cat ul { list-style: none; padding: 0; margin: 0; }

    /* === Grid ========================================================== */
    .kx-cat__grid {
      width: 100%;
      display: grid;
      gap: clamp(1rem, 2vw, 2rem);
      align-items: start;
    }
    .kx-cat__grid--2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .kx-cat__grid--3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .kx-cat__grid--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .kx-cat__grid--5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }

    /* === Column ======================================================== */
    .kx-cat__col {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .kx-cat__col-title {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      font-size: 14px;
      font-weight: 700;
      color: #1B3A2E;
      letter-spacing: -0.005em;
      margin: 0 0 0.65rem;
      padding-bottom: 0.55rem;
      border-bottom: 1px solid #ececec;
      white-space: nowrap;
    }
    .kx-cat__col-icon {
      flex: 0 0 18px;
      width: 18px;
      height: 18px;
      color: #1B3A2E;
      display: inline-flex;
    }
    .kx-cat__col-icon svg { width: 100%; height: 100%; }

    .kx-cat__col-list {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    /* === Link with chevron =============================================== */
    .kx-cat__col-list a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.6rem;
      border-radius: 6px;
      font-size: 13.5px;
      line-height: 1.35;
      font-weight: 500;
      letter-spacing: -0.003em;
      color: #2a2a2a;
      text-decoration: none;
      transition: background-color 180ms cubic-bezier(0.16, 1, 0.3, 1),
                  color 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-list a::before {
      content: '›';
      flex-shrink: 0;
      color: #b8bcbe;
      font-weight: 400;
      font-size: 16px;
      line-height: 1;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  color 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-list a::after {
      content: '→';
      margin-left: auto;
      flex-shrink: 0;
      color: #1B3A2E;
      opacity: 0;
      transform: translateX(-4px);
      font-size: 12.5px;
      font-weight: 600;
      transition: opacity 180ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
