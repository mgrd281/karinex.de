{%- doc -%}
  Renders the unified Karinex software mega-menu. Six fixed software
  columns (Windows 11, Windows 10, Windows 8/8.1, Windows 7/XP,
  Microsoft Office, Office für Mac) plus the Menüpunkte sidebar are
  shown for every top-level Hauptmenü item, so the visitor always sees
  the full software catalog regardless of which item they hovered or
  clicked.

  @param {string} _root - Theme root URL prefix, e.g. '/' or '/de/'.
  @param {object} [parent_link] - The hovered top-level Hauptmenü link
    (accepted for compatibility; the panel is the same for all items).
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_check = _root | slice: -1, 1
    unless _root_check == '/'
      assign _root = _root | append: '/'
    endunless
  endunless

  assign col_titles = 'Windows 11|Windows 10|Windows 8|Windows 7 / XP|Microsoft Office|Office für Mac' | split: '|'
  assign col_hrefs = 'search?q=Windows+11|search?q=Windows+10|search?q=Windows+8|search?q=Windows+7|collections/microsoft-office|collections/microsoft-office-fur-mac' | split: '|'

  assign sub_w11 = 'Windows 11 Pro~search?q=Windows+11+Pro;;Windows 11 Home~search?q=Windows+11+Home;;Windows 11 Enterprise~search?q=Windows+11+Enterprise;;Windows 11 Pro for Workstations~search?q=Windows+11+Pro+Workstations;;Windows 11 Pro DVD/OEM~search?q=Windows+11+Pro+DVD'
  assign sub_w10 = 'Windows 10 Pro~search?q=Windows+10+Pro;;Windows 10 Home OEM~search?q=Windows+10+Home+OEM;;Windows 10 Enterprise~search?q=Windows+10+Enterprise;;Windows 10 Education~search?q=Windows+10+Education'
  assign sub_w8 = 'Windows 8.1 Pro~search?q=Windows+8.1+Pro;;Windows 8 Pro~search?q=Windows+8+Pro;;Alle Windows-Versionen~collections/windows'
  assign sub_w7 = 'Windows 7 Ultimate OEM~search?q=Windows+7+Ultimate+OEM;;Windows 7 Home Premium OEM~search?q=Windows+7+Home+Premium+OEM;;Windows XP~search?q=Windows+XP'
  assign sub_mso = 'Office 2024 Pro Plus~search?q=Office+2024+Professional+Plus;;Office 2021 Pro Plus~search?q=Office+2021+Professional+Plus;;Office 2019 Pro Plus~search?q=Office+2019+Professional+Plus;;Alle Office-Lizenzen~collections/microsoft-office'
  assign sub_mac = 'Office 2024 für Mac~search?q=Office+2024+Mac;;Office 2021 für Mac~search?q=Office+2021+Mac;;Alle Mac-Lizenzen~collections/microsoft-office-fur-mac'

  assign all_subs = sub_w11 | append: '@@' | append: sub_w10 | append: '@@' | append: sub_w8 | append: '@@' | append: sub_w7 | append: '@@' | append: sub_mso | append: '@@' | append: sub_mac
  assign cols_subs = all_subs | split: '@@'
-%}

{%- if mode == 'mobile' -%}
  <ul class="menu-drawer__menu menu-drawer__menu--childlist software-unified-mobile" role="list" tabindex="-1" style="padding: 0;">
    {%- comment -%} Menüpunkte sidebar at the top of every mobile accordion. {%- endcomment -%}
    <li class="menu-drawer__list-item software-unified-mobile__item">
      <accordion-custom open-by-default-on-mobile>
        <details open>
          <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
            <span class="menu-drawer__menu-item-text wrap-text" style="font-weight:700;">Menüpunkte</span>
            <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
          </summary>
          <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content" role="list" tabindex="-1">
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-office" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Office für Windows</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-office-fur-mac" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Office für Mac</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-365-abonnement" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Microsoft 365</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/windows" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Windows</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/windows-server" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Windows Server</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/microsoft-tools" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Microsoft Tools</span></a></li>
            <li class="menu-drawer__list-item"><a href="{{ _root }}collections/sale" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">SALE &amp; Bestseller</span></a></li>
          </ul>
        </details>
      </accordion-custom>
    </li>

    {%- for col_title in col_titles -%}
      {%- assign col_href = col_hrefs[forloop.index0] -%}
      {%- assign subs = cols_subs[forloop.index0] | split: ';;' -%}
      <li class="menu-drawer__list-item software-unified-mobile__item">
        <accordion-custom>
          <details>
            <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
              <span class="menu-drawer__menu-item-text wrap-text">{{ col_title }}</span>
              <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
            </summary>
            <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content" role="list" tabindex="-1">
              <li class="menu-drawer__list-item">
                <a href="{{ _root }}{{ col_href }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset" style="font-weight:600;">
                  <span class="menu-drawer__menu-item-text wrap-text">{{ col_title }} ansehen</span>
                </a>
              </li>
              {%- for sub in subs -%}
                {%- assign parts = sub | split: '~' -%}
                <li class="menu-drawer__list-item">
                  <a href="{{ _root }}{{ parts[1] }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset">
                    <span class="menu-drawer__menu-item-text wrap-text">{{ parts[0] }}</span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </details>
        </accordion-custom>
      </li>
    {%- endfor -%}
  </ul>
{%- else -%}
  {%- comment -%}
    "Menüpunkte" sidebar — fixed list of all 7 top-level Hauptmenü items,
    shown as the first column of every dropdown so visitors always see
    the full navigation structure regardless of which item they hovered.
    Force a 7-column grid (sidebar + 6 software columns) on desktop.
  {%- endcomment -%}
  <style>
    .mega-menu__grid:has(.mega-menu-software-unified) {
      --menu-columns-desktop: 7 !important;
      --menu-columns-tablet: 4 !important;
      column-gap: 1.2rem !important;
    }
    .mega-menu__list:has(.mega-menu-software-unified) {
      grid-column: span 7 !important;
      column-gap: 1.2rem !important;
    }

    /* === Karinex unified mega-menu — visual polish === */
    .mega-menu-software-unified {
      padding-block: 0.25rem;
      min-width: 0;
    }
    .mega-menu-software-unified .mega-menu__item-wrapper {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      min-width: 0;
    }

    /*
      Kill German auto-hyphenation inside the mega-menu so "Windows",
      "Enterprise", "Education", "Premium" no longer split as
      Win-dows / Enterpri-se / Educati-on / Pre-mium. Long compound
      labels wrap on word boundaries only.
    */
    .mega-menu-software-unified,
    .mega-menu-software-unified *,
    .mega-menu-software-unified .wrap-text {
      hyphens: manual !important;
      -webkit-hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
    }

    /* Column titles: tighter so 2-word headings stay on one line */
    .mega-menu-software-unified .mega-menu__link--parent {
      font-size: 12px !important;
      letter-spacing: 0.06em !important;
      font-weight: 700 !important;
      color: #1B3A2E !important;
      margin-bottom: 0.4rem !important;
      white-space: nowrap;
      padding-bottom: 0.45rem;
      border-bottom: 1px solid #ececec;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Sub-link list */
    .mega-menu-software-unified .mega-menu__submenu-list {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      margin: 0;
      padding: 0;
      min-width: 0;
    }
    .mega-menu-software-unified .mega-menu__submenu-list li {
      min-width: 0;
    }
    .mega-menu-software-unified .mega-menu__submenu-list .mega-menu__link {
      padding: 0.28rem 0;
      line-height: 1.35;
      width: 100%;
    }
    .mega-menu-software-unified .mega-menu__submenu-list .mega-menu__link-title.wrap-text {
      font-size: 12.5px;
      color: #4a4a4a;
      letter-spacing: 0;
      line-height: 1.35;
      display: block;
    }
    .mega-menu-software-unified .mega-menu__submenu-list .mega-menu__link:hover .mega-menu__link-title.wrap-text {
      color: #1B3A2E;
      transform: translateX(2px);
    }

    .mega-menu-software-unified__sidebar {
      border-right: 1px solid #eeeeee;
      padding-right: 1.25rem;
    }
    .mega-menu-software-unified__sidebar .mega-menu__link--parent {
      border-bottom-color: #1B3A2E !important;
    }

    @media (max-width: 1199px) {
      .mega-menu__grid:has(.mega-menu-software-unified) {
        --menu-columns-desktop: 4 !important;
      }
      .mega-menu__list:has(.mega-menu-software-unified) {
        grid-column: span 4 !important;
      }
      .mega-menu-software-unified__sidebar {
        border-right: 0;
        padding-right: 0;
      }
    }
  </style>

  <li class="mega-menu__column mega-menu__column--span-1 mega-menu-software-unified mega-menu-software-unified__sidebar">
    <div class="mega-menu__item-wrapper">
      <span class="mega-menu__link mega-menu__link--parent">Menüpunkte</span>
      <ul class="list-unstyled mega-menu__submenu-list">
        <li><a href="{{ _root }}collections/microsoft-office" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Office für Windows</span></a></li>
        <li><a href="{{ _root }}collections/microsoft-office-fur-mac" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Office für Mac</span></a></li>
        <li><a href="{{ _root }}collections/microsoft-365-abonnement" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Microsoft 365</span></a></li>
        <li><a href="{{ _root }}collections/windows" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Windows</span></a></li>
        <li><a href="{{ _root }}collections/windows-server" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Windows Server</span></a></li>
        <li><a href="{{ _root }}collections/microsoft-tools" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">Microsoft Tools</span></a></li>
        <li><a href="{{ _root }}collections/sale" class="mega-menu__link"><span class="mega-menu__link-title wrap-text">SALE &amp; Bestseller</span></a></li>
      </ul>
    </div>
  </li>

  {%- for col_title in col_titles -%}
    {%- assign col_href = col_hrefs[forloop.index0] -%}
    {%- assign subs = cols_subs[forloop.index0] | split: ';;' -%}
    <li class="mega-menu__column mega-menu__column--span-1 mega-menu-software-unified">
      <div class="mega-menu__item-wrapper">
        <a href="{{ _root }}{{ col_href }}" class="mega-menu__link mega-menu__link--parent">{{ col_title }}</a>
        <ul class="list-unstyled mega-menu__submenu-list">
          {%- for sub in subs -%}
            {%- assign parts = sub | split: '~' -%}
            <li>
              <a href="{{ _root }}{{ parts[1] }}" class="mega-menu__link">
                <span class="mega-menu__link-title wrap-text">{{ parts[0] }}</span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </li>
  {%- endfor -%}
{%- endif -%}
