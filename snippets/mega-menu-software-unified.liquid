{%- else -%}

  <style>
    /* === Karinex Mega Menu — premium SaaS desktop panel ===================
       Scoped to .kx-mm. No styles leak into the rest of the theme.
       Uses CSS Grid + clamp() + :has() for fluid, modern layout.
    ========================================================================= */

    /* Make the theme's outer mega-menu grid a single full-width cell */
    .mega-menu__grid:has(.kx-mm) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .mega-menu__list:has(.kx-mm) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .kx-mm-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
    }

    /* Kill theme link defaults inside our panel */
    .kx-mm a,
    .kx-mm a:hover { text-decoration: none; color: inherit; }
    .kx-mm,
    .kx-mm * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-mm ul { list-style: none; padding: 0; margin: 0; }

    /* === Design tokens ================================================== */
    .kx-mm {
      --kx-brand: #1B3A2E;
      --kx-brand-soft: #E8F0EC;
      --kx-accent: #E60000;
      --kx-ink: #1a1a1a;
      --kx-ink-muted: #5a5a5a;
      --kx-line: #ececec;
      --kx-surface: #ffffff;
      --kx-surface-alt: #fafbfa;
      --kx-radius: 14px;
      --kx-radius-sm: 10px;
      --kx-shadow: 0 1px 2px rgba(15, 25, 20, 0.04),
                   0 10px 30px rgba(15, 25, 20, 0.06);
      --kx-ease: cubic-bezier(0.16, 1, 0.3, 1);

      --kx-pad-x: clamp(1.25rem, 2.5vw, 2.25rem);
      --kx-pad-y: clamp(1.5rem, 2.25vw, 2rem);
    }

    /* === Panel container ================================================ */
    .kx-mm {
      width: 100%;
      max-width: 1600px;
      margin-inline: auto;
      padding: var(--kx-pad-y) var(--kx-pad-x);

      display: grid;
      grid-template-columns: clamp(200px, 16vw, 240px) minmax(0, 1fr) clamp(240px, 18vw, 300px);
      gap: clamp(1.25rem, 2vw, 2.25rem);
      align-items: start;

      /* Lock vertical footprint so the panel never reflows */
      min-height: 420px;

      background: var(--kx-surface);
      animation: kxMmIn 260ms var(--kx-ease) both;
      will-change: opacity, transform;
    }

    @keyframes kxMmIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-mm { animation: none; }
    }

    /* === RAIL (left sidebar) ============================================ */
    .kx-mm__rail {
      border-right: 1px solid var(--kx-line);
      padding-right: clamp(0.75rem, 1.25vw, 1.25rem);
    }
    .kx-mm__rail-heading {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--kx-ink-muted);
      margin: 0 0 0.85rem;
    }
    .kx-mm__rail-list {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .kx-mm__rail-link {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.6rem 0.75rem;
      border-radius: var(--kx-radius-sm);
      font-size: 13.5px;
      font-weight: 500;
      color: var(--kx-ink);
      transition: background-color 180ms var(--kx-ease),
                  color 180ms var(--kx-ease),
                  transform 180ms var(--kx-ease);
      position: relative;
    }
    .kx-mm__rail-link::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 50%;
      width: 3px;
      height: 0;
      background: var(--kx-brand);
      border-radius: 2px;
      transform: translateY(-50%);
      transition: height 200ms var(--kx-ease);
    }
    .kx-mm__rail-link:hover,
    .kx-mm__rail-link:focus-visible {
      background: var(--kx-brand-soft);
      color: var(--kx-brand);
      outline: none;
    }
    .kx-mm__rail-link:hover::before,
    .kx-mm__rail-link:focus-visible::before {
      height: 60%;
    }
    .kx-mm__rail-icon {
      flex: 0 0 18px;
      width: 18px;
      height: 18px;
      color: var(--kx-brand);
      display: inline-flex;
    }
    .kx-mm__rail-icon svg { width: 100%; height: 100%; }
    .kx-mm__rail-link--sale {
      color: var(--kx-accent);
      font-weight: 700;
    }
    .kx-mm__rail-link--sale .kx-mm__rail-icon { color: var(--kx-accent); }
    .kx-mm__rail-link--sale:hover,
    .kx-mm__rail-link--sale:focus-visible {
      background: rgba(230, 0, 0, 0.06);
      color: var(--kx-accent);
    }
    .kx-mm__rail-link--sale:hover::before,
    .kx-mm__rail-link--sale:focus-visible::before {
      background: var(--kx-accent);
    }

    /* === Card grid (center) ============================================= */
    .kx-mm__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: clamp(0.75rem, 1vw, 1rem);
      align-content: start;
    }

    .kx-mm__card {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-areas:
        "icon title arrow"
        "icon desc  arrow";
      column-gap: 0.85rem;
      align-items: center;

      padding: 0.95rem 1rem;
      border: 1px solid var(--kx-line);
      border-radius: var(--kx-radius);
      background: var(--kx-surface);
      transition: border-color 200ms var(--kx-ease),
                  background-color 200ms var(--kx-ease),
                  box-shadow 200ms var(--kx-ease),
                  transform 200ms var(--kx-ease);
      min-width: 0;
    }
    .kx-mm__card:hover,
    .kx-mm__card:focus-visible {
      border-color: var(--kx-brand);
      background: var(--kx-surface-alt);
      box-shadow: 0 6px 18px rgba(27, 58, 46, 0.08);
      transform: translateY(-1px);
      outline: none;
    }
    .kx-mm__card-icon {
      grid-area: icon;
      align-self: center;
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: var(--kx-brand-soft);
      color: var(--kx-brand);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background-color 200ms var(--kx-ease),
                  color 200ms var(--kx-ease);
    }
    .kx-mm__card-icon svg { width: 20px; height: 20px; }
    .kx-mm__card:hover .kx-mm__card-icon,
    .kx-mm__card:focus-visible .kx-mm__card-icon {
      background: var(--kx-brand);
      color: #fff;
    }
    .kx-mm__card-title {
      grid-area: title;
      margin: 0;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--kx-ink);
      letter-spacing: 0.005em;
    }
    .kx-mm__card-desc {
      grid-area: desc;
      margin: 2px 0 0;
      font-size: 12px;
      line-height: 1.35;
      color: var(--kx-ink-muted);
    }
    .kx-mm__card-arrow {
      grid-area: arrow;
      width: 22px;
      height: 22px;
      color: var(--kx-ink-muted);
      align-self: center;
      transform: translateX(-2px);
      opacity: 0;
      transition: transform 220ms var(--kx-ease),
                  opacity 200ms var(--kx-ease),
                  color 200ms var(--kx-ease);
    }
    .kx-mm__card-arrow svg { width: 18px; height: 18px; }
    .kx-mm__card:hover .kx-mm__card-arrow,
    .kx-mm__card:focus-visible .kx-mm__card-arrow {
      opacity: 1;
      transform: translateX(0);
      color: var(--kx-brand);
    }

    /* === FEATURED (right rail) ========================================== */
    .kx-mm__featured {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    .kx-mm__featured-heading {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--kx-ink-muted);
      margin: 0 0 0.5rem;
    }

    .kx-mm__promo {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 1.1rem 1.15rem 1.25rem;
      border-radius: var(--kx-radius);
      overflow: hidden;
      isolation: isolate;
      transition: transform 220ms var(--kx-ease),
                  box-shadow 220ms var(--kx-ease);
    }
    .kx-mm__promo::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: -1;
      background: linear-gradient(135deg, var(--kx-brand) 0%, #0f2820 100%);
    }
    .kx-mm__promo::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: -1;
      background: radial-gradient(circle at 80% 0%, rgba(255,255,255,.12), transparent 55%);
    }
    .kx-mm__promo:hover,
    .kx-mm__promo:focus-visible {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(27, 58, 46, 0.18);
      outline: none;
    }
    .kx-mm__promo-badge {
      align-self: flex-start;
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      background: rgba(255, 255, 255, 0.16);
      backdrop-filter: blur(6px);
      padding: 3px 8px;
      border-radius: 999px;
    }
    .kx-mm__promo-title {
      margin: 0;
      font-size: 17px;
      font-weight: 700;
      line-height: 1.15;
      color: #fff;
      letter-spacing: -0.005em;
    }
    .kx-mm__promo-text {
      margin: 0;
      font-size: 12.5px;
      line-height: 1.35;
      color: rgba(255, 255, 255, 0.78);
    }
    .kx-mm__promo-cta {
      margin-top: 0.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 12.5px;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.02em;
    }
    .kx-mm__promo-cta::after {
      content: '→';
      transition: transform 200ms var(--kx-ease);
    }
    .kx-mm__promo:hover .kx-mm__promo-cta::after,
    .kx-mm__promo:focus-visible .kx-mm__promo-cta::after {
      transform: translateX(3px);
    }

    /* Secondary promo: light surface with brand accent */
    .kx-mm__promo--alt::before {
      background: linear-gradient(135deg, #f6faf8 0%, #ffffff 100%);
    }
    .kx-mm__promo--alt::after {
      background: radial-gradient(circle at 20% 100%, rgba(27,58,46,.06), transparent 60%);
    }
    .kx-mm__promo--alt .kx-mm__promo-badge {
      color: var(--kx-brand);
      background: var(--kx-brand-soft);
      backdrop-filter: none;
    }
    .kx-mm__promo--alt .kx-mm__promo-title { color: var(--kx-ink); }
    .kx-mm__promo--alt .kx-mm__promo-text  { color: var(--kx-ink-muted); }
    .kx-mm__promo--alt .kx-mm__promo-cta   { color: var(--kx-brand); }

    /* === Responsive ===================================================== */
    @media (max-width: 1399px) {
      .kx-mm {
        grid-template-columns: clamp(190px, 17vw, 220px) minmax(0, 1fr);
      }
      .kx-mm__featured {
        grid-column: 1 / -1;
        grid-row: 2;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.85rem;
        padding-top: 0.5rem;
        border-top: 1px solid var(--kx-line);
        margin-top: 0.25rem;
      }
      .kx-mm__featured-heading { width: 100%; margin: 0; }
      .kx-mm__promo {
        flex: 1 1 280px;
        min-width: 0;
      }
    }
    @media (max-width: 1199px) {
      .kx-mm {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .kx-mm__rail {
        border-right: 0;
        border-bottom: 1px solid var(--kx-line);
        padding-right: 0;
        padding-bottom: 1rem;
      }
      .kx-mm__rail-list {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.25rem 0.5rem;
      }
      .kx-mm__rail-link {
        padding: 0.45rem 0.65rem;
        font-size: 13px;
      }
    }
