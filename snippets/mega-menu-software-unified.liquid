{%- else -%}

  <style>
    /* === Karinex Mega Menu — Luxury Editorial Navigation =================
       3-column asymmetric layout: rail / editorial content / hero visual
       Scoped to .kx-mm. Modern CSS (clamp, :has, container queries).
    ========================================================================= */

    .mega-menu__grid:has(.kx-mm) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .mega-menu__list:has(.kx-mm) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .kx-mm-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
    }

    .kx-mm a,
    .kx-mm a:hover { text-decoration: none; color: inherit; }
    .kx-mm,
    .kx-mm * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-mm ul { list-style: none; padding: 0; margin: 0; }

    /* === Design tokens ================================================== */
    .kx-mm {
      --kx-brand: #1B3A2E;
      --kx-brand-deep: #0E2419;
      --kx-brand-soft: #EFF4F1;
      --kx-accent: #E60000;
      --kx-ink: #111418;
      --kx-ink-2: #2a2f33;
      --kx-ink-muted: #6a7378;
      --kx-line: #ececec;
      --kx-line-soft: #f4f4f4;
      --kx-surface: #ffffff;
      --kx-radius: 18px;
      --kx-radius-sm: 12px;
      --kx-ease: cubic-bezier(0.16, 1, 0.3, 1);

      --kx-pad-x: clamp(1.75rem, 4vw, 4rem);
      --kx-pad-y: clamp(2.25rem, 3.5vw, 3.25rem);
    }

    /* === Panel container ================================================ */
    .kx-mm {
      width: 100%;
      max-width: 1600px;
      margin-inline: auto;
      padding: var(--kx-pad-y) var(--kx-pad-x);

      display: grid;
      grid-template-columns:
        clamp(220px, 18vw, 260px)
        minmax(0, 1.5fr)
        clamp(300px, 24vw, 380px);
      column-gap: clamp(2rem, 4vw, 4rem);
      align-items: stretch;

      min-height: 520px;

      background: var(--kx-surface);
      animation: kxMmIn 320ms var(--kx-ease) both;
      will-change: opacity, transform;
    }

    @keyframes kxMmIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-mm { animation: none; }
    }

    /* === RAIL — left navigation ========================================= */
    .kx-mm__rail {
      border-right: 1px solid var(--kx-line);
      padding-right: clamp(1rem, 1.5vw, 1.5rem);
      align-self: stretch;
    }
    .kx-mm__eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--kx-ink-muted);
      margin: 0 0 1.5rem;
    }
    .kx-mm__rail-list {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .kx-mm__rail-link {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.72rem 0.9rem;
      border-radius: var(--kx-radius-sm);
      font-size: 14.5px;
      font-weight: 500;
      letter-spacing: -0.005em;
      color: var(--kx-ink-2);
      transition: background-color 220ms var(--kx-ease),
                  color 220ms var(--kx-ease),
                  padding-left 220ms var(--kx-ease);
    }
    .kx-mm__rail-link:hover,
    .kx-mm__rail-link:focus-visible {
      background: var(--kx-brand-soft);
      color: var(--kx-brand);
      padding-left: 1.1rem;
      outline: none;
    }
    .kx-mm__rail-icon {
      flex: 0 0 18px;
      width: 18px;
      height: 18px;
      color: var(--kx-brand);
      display: inline-flex;
      opacity: 0.75;
      transition: opacity 220ms var(--kx-ease);
    }
    .kx-mm__rail-icon svg { width: 100%; height: 100%; }
    .kx-mm__rail-link:hover .kx-mm__rail-icon,
    .kx-mm__rail-link:focus-visible .kx-mm__rail-icon { opacity: 1; }
    .kx-mm__rail-link--sale {
      color: var(--kx-accent);
      font-weight: 600;
    }
    .kx-mm__rail-link--sale .kx-mm__rail-icon { color: var(--kx-accent); opacity: 1; }
    .kx-mm__rail-link--sale:hover,
    .kx-mm__rail-link--sale:focus-visible {
      background: rgba(230, 0, 0, 0.06);
      color: var(--kx-accent);
    }

    /* === EDITORIAL CONTENT — center ==================================== */
    .kx-mm__content {
      display: flex;
      flex-direction: column;
      gap: clamp(1.75rem, 2.5vw, 2.5rem);
      min-width: 0;
    }

    .kx-mm__section {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
    }
    .kx-mm__section-head {
      padding-bottom: 0.85rem;
      border-bottom: 1px solid var(--kx-line);
    }
    .kx-mm__section-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--kx-brand);
      margin: 0 0 0.4rem;
    }
    .kx-mm__section-title {
      font-size: clamp(20px, 1.5vw, 24px);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.015em;
      color: var(--kx-ink);
      margin: 0 0 0.3rem;
    }
    .kx-mm__section-desc {
      font-size: 13.5px;
      line-height: 1.45;
      color: var(--kx-ink-muted);
      margin: 0;
      max-width: 52ch;
    }

    .kx-mm__section-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.25rem 1.5rem;
    }
    .kx-mm__row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 0.95rem;
      border-radius: 10px;
      transition: background-color 220ms var(--kx-ease),
                  padding-left 220ms var(--kx-ease),
                  color 220ms var(--kx-ease);
      position: relative;
    }
    .kx-mm__row::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 12%;
      bottom: 12%;
      width: 2px;
      background: var(--kx-brand);
      border-radius: 2px;
      opacity: 0;
      transform: scaleY(0.4);
      transform-origin: center;
      transition: opacity 220ms var(--kx-ease),
                  transform 220ms var(--kx-ease);
    }
    .kx-mm__row:hover,
    .kx-mm__row:focus-visible {
      background: var(--kx-brand-soft);
      padding-left: 1.2rem;
      outline: none;
    }
    .kx-mm__row:hover::before,
    .kx-mm__row:focus-visible::before {
      opacity: 1;
      transform: scaleY(1);
    }
    .kx-mm__row-title {
      font-size: 15.5px;
      font-weight: 600;
      letter-spacing: -0.005em;
      color: var(--kx-ink);
      line-height: 1.25;
      margin: 0;
    }
    .kx-mm__row-desc {
      display: block;
      margin-top: 3px;
      font-size: 12.5px;
      font-weight: 400;
      color: var(--kx-ink-muted);
      line-height: 1.35;
    }
    .kx-mm__row-arrow {
      width: 22px;
      height: 22px;
      color: var(--kx-ink-muted);
      opacity: 0;
      transform: translateX(-6px);
      transition: opacity 240ms var(--kx-ease),
                  transform 240ms var(--kx-ease),
                  color 220ms var(--kx-ease);
    }
    .kx-mm__row-arrow svg { width: 18px; height: 18px; }
    .kx-mm__row:hover .kx-mm__row-arrow,
    .kx-mm__row:focus-visible .kx-mm__row-arrow {
      opacity: 1;
      transform: translateX(0);
      color: var(--kx-brand);
    }

    /* === HERO — right visual ============================================ */
    .kx-mm__hero {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 1rem;
      padding: 1.75rem 1.75rem 1.85rem;
      border-radius: 20px;
      overflow: hidden;
      isolation: isolate;
      min-height: 100%;
      color: #fff;
      transition: transform 320ms var(--kx-ease),
                  box-shadow 320ms var(--kx-ease);
    }
    .kx-mm__hero::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: -2;
      background:
        radial-gradient(circle at 80% 0%, rgba(255,255,255,0.16), transparent 50%),
        linear-gradient(160deg, #234B3A 0%, #11261E 65%, #0A1A14 100%);
    }
    .kx-mm__hero::after {
      content: '';
      position: absolute;
      right: -80px;
      top: -40px;
      width: 280px;
      height: 280px;
      z-index: -1;
      background: radial-gradient(closest-side, rgba(120, 215, 170, 0.25), transparent 70%);
      filter: blur(8px);
    }
    .kx-mm__hero:hover,
    .kx-mm__hero:focus-visible {
      transform: translateY(-2px);
      box-shadow: 0 24px 48px rgba(11, 27, 21, 0.28);
      outline: none;
    }

    /* Decorative product mockup (CSS-only "license box") */
    .kx-mm__hero-mock {
      position: absolute;
      right: -28px;
      top: 28px;
      width: 180px;
      height: 220px;
      background: linear-gradient(155deg, #ffffff 0%, #f0f3f1 65%, #d9e0dc 100%);
      border-radius: 14px;
      box-shadow:
        0 1px 0 rgba(255,255,255,0.4) inset,
        0 20px 50px rgba(0,0,0,0.35),
        0 4px 12px rgba(0,0,0,0.18);
      transform: rotate(8deg);
      z-index: -1;
      overflow: hidden;
    }
    .kx-mm__hero-mock::before {
      content: '';
      position: absolute;
      left: 16px;
      top: 18px;
      width: 64px;
      height: 8px;
      background: var(--kx-brand);
      border-radius: 2px;
    }
    .kx-mm__hero-mock::after {
      content: '';
      position: absolute;
      left: 16px;
      top: 38px;
      width: 38px;
      height: 6px;
      background: rgba(27,58,46,0.45);
      border-radius: 2px;
    }
    .kx-mm__hero-mock-logo {
      position: absolute;
      left: 50%;
      top: 52%;
      transform: translate(-50%, -50%);
      width: 78px;
      height: 78px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 6px;
    }
    .kx-mm__hero-mock-logo span {
      border-radius: 4px;
    }
    .kx-mm__hero-mock-logo span:nth-child(1) { background: #D83B01; }
    .kx-mm__hero-mock-logo span:nth-child(2) { background: #107C41; }
    .kx-mm__hero-mock-logo span:nth-child(3) { background: #2B7CD3; }
    .kx-mm__hero-mock-logo span:nth-child(4) { background: #B7472A; }
    .kx-mm__hero-mock-foot {
      position: absolute;
      left: 16px;
      bottom: 16px;
      right: 16px;
