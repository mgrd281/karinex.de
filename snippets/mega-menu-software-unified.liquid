{%- doc -%}
  Karinex Mega Menu — Apple-minimal edition.

  Pure restraint. No mockups, no gradients, no sidebar, no icons in
  the dropdown. Five evenly-spaced typography columns on a clean
  white surface, with generous whitespace and a single subtle
  highlight column on the right.

  Every top-level Hauptmenü item opens the same panel — categories
  never disappear and the layout never reflows.

  @param {string} _root - Theme root URL prefix.
  @param {object} [parent_link] - Hovered top-level link (unused,
    kept for API compatibility).
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_check = _root | slice: -1, 1
    unless _root_check == '/'
      assign _root = _root | append: '/'
    endunless
  endunless
-%}

{%- if mode == 'mobile' -%}

  <ul class="kx-mm-mobile menu-drawer__menu menu-drawer__menu--childlist" role="list" tabindex="-1">
    {%- assign mob_groups = 'Windows|Office|Microsoft 365|Server &amp; Dev|Lizenzen' | split: '|' -%}

    <li class="menu-drawer__list-item kx-mm-mobile__item">
      <accordion-custom open-by-default-on-mobile>
        <details open>
          <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
            <span class="menu-drawer__menu-item-text wrap-text kx-mm-mobile__group">Menüpunkte</span>
            <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
          </summary>
          <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content kx-mm-mobile__sublist" role="list" tabindex="-1">
            <li><a href="{{ _root }}collections/microsoft-office" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Office für Windows</span></a></li>
            <li><a href="{{ _root }}collections/microsoft-office-fur-mac" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Office für Mac</span></a></li>
            <li><a href="{{ _root }}collections/microsoft-365-abonnement" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Microsoft 365</span></a></li>
            <li><a href="{{ _root }}collections/windows" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Windows</span></a></li>
            <li><a href="{{ _root }}collections/windows-server" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Windows Server</span></a></li>
            <li><a href="{{ _root }}collections/microsoft-tools" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">Microsoft Tools</span></a></li>
            <li><a href="{{ _root }}collections/sale" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset kx-mm-mobile__sale"><span class="menu-drawer__menu-item-text wrap-text">SALE &amp; Bestseller</span></a></li>
          </ul>
        </details>
      </accordion-custom>
    </li>

    {%- assign mob_full_groups = 'Windows 11|Windows 10|Windows 8|Windows 7 / XP|Microsoft Office|Office für Mac|Microsoft 365|Windows Server|Visual Studio|SQL Server|Microsoft Project|Microsoft Visio' | split: '|' -%}
    {%- assign mob_hrefs = 'search?q=Windows+11|search?q=Windows+10|search?q=Windows+8|search?q=Windows+7|collections/microsoft-office|collections/microsoft-office-fur-mac|collections/microsoft-365-abonnement|collections/windows-server|search?q=Visual+Studio|search?q=SQL+Server|search?q=Microsoft+Project|search?q=Microsoft+Visio' | split: '|' -%}
    {%- assign mob_subs = 'Pro~search?q=Windows+11+Pro;;Home~search?q=Windows+11+Home;;Enterprise~search?q=Windows+11+Enterprise;;Pro for Workstations~search?q=Windows+11+Pro+Workstations;;Pro DVD/OEM~search?q=Windows+11+Pro+DVD@@Pro~search?q=Windows+10+Pro;;Home OEM~search?q=Windows+10+Home+OEM;;Enterprise~search?q=Windows+10+Enterprise;;Education~search?q=Windows+10+Education@@8.1 Pro~search?q=Windows+8.1+Pro;;8 Pro~search?q=Windows+8+Pro;;Alle Windows-Versionen~collections/windows@@7 Ultimate OEM~search?q=Windows+7+Ultimate+OEM;;7 Home Premium OEM~search?q=Windows+7+Home+Premium+OEM;;XP~search?q=Windows+XP@@2024 Pro Plus~search?q=Office+2024+Professional+Plus;;2021 Pro Plus~search?q=Office+2021+Professional+Plus;;2019 Pro Plus~search?q=Office+2019+Professional+Plus;;Alle Office-Lizenzen~collections/microsoft-office@@2024 für Mac~search?q=Office+2024+Mac;;2021 für Mac~search?q=Office+2021+Mac;;Alle Mac-Lizenzen~collections/microsoft-office-fur-mac@@365 Personal~search?q=Microsoft+365+Personal;;365 Family~search?q=Microsoft+365+Family;;365 Business~search?q=Microsoft+365+Business;;Alle 365-Abos~collections/microsoft-365-abonnement@@Server 2022~search?q=Windows+Server+2022;;Server 2019~search?q=Windows+Server+2019;;Server 2016~search?q=Windows+Server+2016;;Alle Server~collections/windows-server@@VS 2022 Pro~search?q=Visual+Studio+2022+Professional;;VS 2022 Enterprise~search?q=Visual+Studio+2022+Enterprise;;VS 2019~search?q=Visual+Studio+2019;;Alle Visual Studio~search?q=Visual+Studio@@SQL 2022 Std~search?q=SQL+Server+2022+Standard;;SQL 2019 Std~search?q=SQL+Server+2019+Standard;;SQL 2017~search?q=SQL+Server+2017;;Alle SQL Server~search?q=SQL+Server@@Project 2024 Pro~search?q=Project+2024+Professional;;Project 2021 Pro~search?q=Project+2021+Professional;;Project 2019 Pro~search?q=Project+2019+Professional;;Alle Project~search?q=Microsoft+Project@@Visio 2024 Pro~search?q=Visio+2024+Professional;;Visio 2021 Pro~search?q=Visio+2021+Professional;;Visio 2019 Pro~search?q=Visio+2019+Professional;;Alle Visio~search?q=Microsoft+Visio' | split: '@@' -%}

    {%- for g_title in mob_full_groups -%}
      {%- assign g_href = mob_hrefs[forloop.index0] -%}
      {%- assign g_subs = mob_subs[forloop.index0] | split: ';;' -%}
      <li class="menu-drawer__list-item kx-mm-mobile__item">
        <accordion-custom>
          <details>
            <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
              <span class="menu-drawer__menu-item-text wrap-text">{{ g_title }}</span>
              <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
            </summary>
            <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content kx-mm-mobile__sublist" role="list" tabindex="-1">
              <li><a href="{{ _root }}{{ g_href }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset kx-mm-mobile__see-all"><span class="menu-drawer__menu-item-text wrap-text">{{ g_title }} ansehen</span></a></li>
              {%- for sub in g_subs -%}
                {%- assign parts = sub | split: '~' -%}
                <li><a href="{{ _root }}{{ parts[1] }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">{{ parts[0] }}</span></a></li>
              {%- endfor -%}
            </ul>
          </details>
        </accordion-custom>
      </li>
    {%- endfor -%}
  </ul>

  <style>
    .kx-mm-mobile { padding: 0; }
    .kx-mm-mobile__item { border-bottom: 1px solid #f0f0f0; }
    .kx-mm-mobile__item:last-child { border-bottom: 0; }
    .kx-mm-mobile__group { font-weight: 700; color: #1B3A2E; letter-spacing: 0.04em; }
    .kx-mm-mobile__sublist { padding-left: 0.75rem; }
    .kx-mm-mobile__see-all { font-weight: 600; color: #1B3A2E !important; }
    .kx-mm-mobile__sale { color: #E60000 !important; font-weight: 700; }
  </style>

{%- else -%}

  <style>
    /* === Karinex Mega Menu — Apple-minimal edition ====================== */

    .mega-menu__grid:has(.kx-mm) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .mega-menu__list:has(.kx-mm) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .kx-mm-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
    }

    .kx-mm a,
    .kx-mm a:hover { text-decoration: none; color: inherit; }
    .kx-mm,
    .kx-mm * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-mm ul { list-style: none; padding: 0; margin: 0; }

    /* Tokens */
    .kx-mm {
      --kx-brand: #1B3A2E;
      --kx-accent: #E60000;
      --kx-ink: #1d1d1f;
      --kx-ink-muted: #6e6e73;
      --kx-line: #f2f2f4;

      --kx-pad-x: clamp(2rem, 5vw, 5rem);
      --kx-pad-y: clamp(2.5rem, 4vw, 3.5rem);
    }

    /* Panel */
    .kx-mm {
      width: 100%;
      max-width: 1400px;
      margin-inline: auto;
      padding: var(--kx-pad-y) var(--kx-pad-x);

      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      column-gap: clamp(1.5rem, 3vw, 3rem);
      align-items: start;

      min-height: 360px;

      background: #ffffff;
      animation: kxMmIn 320ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes kxMmIn {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-mm { animation: none; }
    }

    /* Column */
    .kx-mm__col {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.95rem;
    }

    .kx-mm__col-title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--kx-ink-muted);
      margin: 0;
      padding-bottom: 0.4rem;
    }

    .kx-mm__col-list {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .kx-mm__col-list a {
      display: inline-block;
      font-size: 15px;
      line-height: 1.35;
      font-weight: 500;
      letter-spacing: -0.005em;
      color: var(--kx-ink);
      padding: 0.2rem 0;
      transition: color 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-mm__col-list a:hover,
    .kx-mm__col-list a:focus-visible {
      color: var(--kx-brand);
      outline: none;
    }
    .kx-mm__col-list a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    .kx-mm__col-all {
      margin-top: 0.5rem;
      font-size: 14px !important;
      font-weight: 600 !important;
      color: var(--kx-brand) !important;
      letter-spacing: 0 !important;
    }
    .kx-mm__col-all::after {
      content: ' →';
      display: inline-block;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-mm__col-all:hover::after,
    .kx-mm__col-all:focus-visible::after {
      transform: translateX(3px);
    }

    /* SALE link inside Lizenzen column */
    .kx-mm__sale-link {
      color: var(--kx-accent) !important;
      font-weight: 600;
    }
    .kx-mm__sale-link:hover,
    .kx-mm__sale-link:focus-visible {
      color: var(--kx-accent) !important;
    }

    /* Responsive */
    @media (max-width: 1199px) {
      .kx-mm {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        row-gap: 2rem;
        min-height: auto;
      }
    }
    @media (max-width: 749px) {
      .kx-mm {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>

  <li class="mega-menu__column kx-mm-cell">
    <div class="kx-mm" role="region" aria-label="Software-Navigation">

      <section class="kx-mm__col" aria-labelledby="kx-mm-c1">
        <h3 class="kx-mm__col-title" id="kx-mm-c1">Windows</h3>
        <div class="kx-mm__col-list">
          <a href="{{ _root }}search?q=Windows+11">Windows 11</a>
          <a href="{{ _root }}search?q=Windows+10">Windows 10</a>
          <a href="{{ _root }}search?q=Windows+8">Windows 8 / 8.1</a>
          <a href="{{ _root }}search?q=Windows+7">Windows 7</a>
          <a href="{{ _root }}search?q=Windows+XP">Windows XP</a>
          <a href="{{ _root }}collections/windows" class="kx-mm__col-all">Alle Versionen</a>
        </div>
      </section>

      <section class="kx-mm__col" aria-labelledby="kx-mm-c2">
        <h3 class="kx-mm__col-title" id="kx-mm-c2">Office</h3>
        <div class="kx-mm__col-list">
          <a href="{{ _root }}search?q=Office+2024+Professional+Plus">Office 2024</a>
          <a href="{{ _root }}search?q=Office+2021+Professional+Plus">Office 2021</a>
          <a href="{{ _root }}search?q=Office+2019+Professional+Plus">Office 2019</a>
          <a href="{{ _root }}collections/microsoft-office-fur-mac">Office für Mac</a>
          <a href="{{ _root }}collections/microsoft-office" class="kx-mm__col-all">Alle Office-Lizenzen</a>
        </div>
      </section>

      <section class="kx-mm__col" aria-labelledby="kx-mm-c3">
        <h3 class="kx-mm__col-title" id="kx-mm-c3">Microsoft 365</h3>
        <div class="kx-mm__col-list">
          <a href="{{ _root }}search?q=Microsoft+365+Personal">365 Personal</a>
          <a href="{{ _root }}search?q=Microsoft+365+Family">365 Family</a>
          <a href="{{ _root }}search?q=Microsoft+365+Business">365 Business</a>
          <a href="{{ _root }}collections/microsoft-365-abonnement" class="kx-mm__col-all">Alle 365-Abos</a>
        </div>
      </section>

      <section class="kx-mm__col" aria-labelledby="kx-mm-c4">
        <h3 class="kx-mm__col-title" id="kx-mm-c4">Server &amp; Dev</h3>
        <div class="kx-mm__col-list">
          <a href="{{ _root }}collections/windows-server">Windows Server</a>
          <a href="{{ _root }}search?q=Visual+Studio">Visual Studio</a>
          <a href="{{ _root }}search?q=SQL+Server">SQL Server</a>
          <a href="{{ _root }}search?q=Microsoft+Project">Microsoft Project</a>
          <a href="{{ _root }}search?q=Microsoft+Visio">Microsoft Visio</a>
          <a href="{{ _root }}collections/microsoft-tools" class="kx-mm__col-all">Alle Tools</a>
        </div>
      </section>

      <section class="kx-mm__col" aria-labelledby="kx-mm-c5">
        <h3 class="kx-mm__col-title" id="kx-mm-c5">Lizenzen</h3>
        <div class="kx-mm__col-list">
          <a href="{{ _root }}collections/microsoft-office">Office für Windows</a>
          <a href="{{ _root }}collections/microsoft-office-fur-mac">Office für Mac</a>
          <a href="{{ _root }}collections/microsoft-365-abonnement">Microsoft 365</a>
          <a href="{{ _root }}collections/windows">Windows</a>
          <a href="{{ _root }}collections/windows-server">Windows Server</a>
          <a href="{{ _root }}collections/microsoft-tools">Microsoft Tools</a>
          <a href="{{ _root }}collections/sale" class="kx-mm__sale-link">SALE &amp; Bestseller</a>
        </div>
      </section>

    </div>
  </li>

{%- endif -%}
