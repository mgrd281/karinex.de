{%- doc -%}
  Karinex Mega Menu — premium full-width navigation panel.

  Renders a stable, full-width professional dropdown that exposes the
  full software catalog at once. Identical content is shown for every
  top-level Hauptmenü item (Office, Mac, 365, Windows, Server, Tools,
  SALE & Bestseller), so categories never disappear and the panel
  never reflows when the visitor moves between top-level items.

  Layout
  ──────
    ┌──────────┬──────────────────────────────────────────────┐
    │ Sidebar  │  Row 1: Win 11 · Win 10 · Win 8 · Win 7/XP   │
    │ (7 top-  │          · Microsoft Office · Office für Mac │
    │  level   │  Row 2: Microsoft 365 · Server · Visual      │
    │  links)  │          Studio · SQL Server · Project       │
    │          │          · Visio                              │
    └──────────┴──────────────────────────────────────────────┘

  @param {string} _root - Theme root URL prefix, e.g. '/' or '/de/'.
  @param {object} [parent_link] - The hovered top-level link (accepted
    for API compatibility; the panel content is identical for all items).
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_check = _root | slice: -1, 1
    unless _root_check == '/'
      assign _root = _root | append: '/'
    endunless
  endunless
-%}

