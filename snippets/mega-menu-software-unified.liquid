{%- doc -%}
  Karinex Category Dropdown — driven by Shopify menu data.

  Each top-level Hauptmenü item opens a full-width flat strip under
  the navbar that renders THE EXACT sub-links the merchant has
  configured in Shopify Admin → Online Store → Navigation → Hauptmenü.

  Two rendering modes (auto-detected from the menu shape):
    1. NESTED — at least one child of `parent_link` has its own
       `.links`. Each child renders as its own column with a heading
       and the products inside it.
    2. FLAT — children are products, no grouping. They're auto-split
       into 1–4 even columns based on count.

  An SVG icon and a category-specific footer CTA are derived from the
  parent_link's handle/title.

  @param {string} _root - Theme root URL prefix.
  @param {object} parent_link - The hovered top-level Hauptmenü link.
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_last = _root | slice: -1
    unless _root_last == '/'
      assign _root = _root | append: '/'
    endunless
  endunless

  assign p_handle = parent_link.handle | default: '' | downcase
  assign p_title  = parent_link.title  | default: '' | downcase | replace: 'ü', 'u' | replace: 'ö', 'o' | replace: 'ä', 'a' | replace: 'ß', 'ss'

  # Category routing — used only to pick an icon, an accent and the "Alle X" CTA.
  assign cat = 'default'
  if p_handle contains 'mac' or p_title contains 'mac'
    assign cat = 'office-mac'
  elsif p_handle contains '365' or p_title contains '365'
    assign cat = '365'
  elsif p_handle contains 'server' or p_title contains 'server'
    assign cat = 'server'
  elsif p_handle contains 'tools' or p_title contains 'tools'
    assign cat = 'tools'
  elsif p_handle contains 'sale' or p_handle contains 'bestseller' or p_title contains 'sale' or p_title contains 'bestseller'
    assign cat = 'sale'
  elsif p_handle contains 'office' or p_title contains 'office'
    assign cat = 'office'
  elsif p_handle contains 'windows' or p_title contains 'windows'
    assign cat = 'windows'
  endif

  # Detect rendering mode: nested if ANY child has its own .links.
  assign render_mode = 'flat'
  for l in parent_link.links
    if l.links.size > 0
      assign render_mode = 'nested'
      break
    endif
  endfor

  assign child_count = parent_link.links.size

  # Flat layout — decide column count from child_count.
  if child_count > 16
    assign flat_cols = 4
  elsif child_count > 10
    assign flat_cols = 3
  elsif child_count > 5
    assign flat_cols = 2
  else
    assign flat_cols = 1
  endif
-%}

{%- capture svg_layers -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l9 5-9 5-9-5 9-5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M3 13l9 5 9-5M3 17.5l9 5 9-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture svg_doc -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 3h7l4 4v14H7V3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 3v4h4M9 12h6M9 16h6M9 8h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture svg_chart -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20V8M9 20V12M14 20v-6M19 20V4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture svg_nodes -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="5" cy="5" r="2" stroke="currentColor" stroke-width="1.6"/><circle cx="19" cy="5" r="2" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.6"/><circle cx="5" cy="19" r="2" stroke="currentColor" stroke-width="1.6"/><circle cx="19" cy="19" r="2" stroke="currentColor" stroke-width="1.6"/><path d="M6.5 6.5l4 4M17.5 6.5l-4 4M10.5 13.5l-4 4M13.5 13.5l4 4" stroke="currentColor" stroke-width="1.4"/></svg>{%- endcapture -%}
{%- capture svg_window -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.6"/></svg>{%- endcapture -%}
{%- capture svg_server -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="5" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="11" width="18" height="5" rx="1" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="18" width="18" height="2.5" rx="1" stroke="currentColor" stroke-width="1.6"/><circle cx="7" cy="6.5" r=".7" fill="currentColor"/><circle cx="7" cy="13.5" r=".7" fill="currentColor"/></svg>{%- endcapture -%}
{%- capture svg_code -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l-5 6 5 6M15 6l5 6-5 6M14 4l-4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture svg_tag -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 12l9-9 9 9-9 9-9-9Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="9" cy="9" r="1.2" fill="currentColor"/></svg>{%- endcapture -%}
{%- capture svg_cloud -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17a4 4 0 0 1-.5-7.97A6 6 0 0 1 18 9.5a3.5 3.5 0 0 1 0 7H7Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture svg_mac -%}<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="12" rx="1.5" stroke="currentColor" stroke-width="1.6"/><path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>{%- endcapture -%}

{%- liquid
  case cat
    when 'office'
      assign cat_icon = svg_layers
      assign cat_title = 'Office für Windows'
      assign cat_all_label = 'Alle Office-Lizenzen'
      assign cat_all_url = _root | append: 'collections/microsoft-office'
    when 'office-mac'
      assign cat_icon = svg_mac
      assign cat_title = 'Office für Mac'
      assign cat_all_label = 'Alle Mac-Lizenzen'
      assign cat_all_url = _root | append: 'collections/microsoft-office-fur-mac'
    when '365'
      assign cat_icon = svg_cloud
      assign cat_title = 'Microsoft 365'
      assign cat_all_label = 'Alle 365-Abos'
      assign cat_all_url = _root | append: 'collections/microsoft-365-abonnement'
    when 'windows'
      assign cat_icon = svg_window
      assign cat_title = 'Windows'
      assign cat_all_label = 'Alle Windows-Versionen'
      assign cat_all_url = _root | append: 'collections/windows'
    when 'server'
      assign cat_icon = svg_server
      assign cat_title = 'Windows Server'
      assign cat_all_label = 'Alle Server-Lizenzen'
      # /collections/windows-server does not exist on Shopify — land on
      # /collections/windows (which holds the server SKUs too), matching the
      # soft-redirect already configured in main-404.liquid line 786.
      assign cat_all_url = _root | append: 'collections/windows'
    when 'tools'
      assign cat_icon = svg_code
      assign cat_title = 'Microsoft Tools'
      assign cat_all_label = 'Alle Tools'
      assign cat_all_url = _root | append: 'collections/microsoft-tools'
    when 'sale'
      assign cat_icon = svg_tag
      assign cat_title = 'SALE & Bestseller'
      assign cat_all_label = 'Alle Angebote ansehen'
      assign cat_all_url = _root | append: 'collections/sale'
    else
      assign cat_icon = svg_layers
      assign cat_title = parent_link.title
      assign cat_all_label = 'Alle Produkte'
      assign cat_all_url = parent_link.url | default: _root
  endcase
-%}

{%- if mode == 'mobile' -%}

  <ul class="kx-cat-mobile menu-drawer__menu menu-drawer__menu--childlist" role="list" tabindex="-1">
    {%- if render_mode == 'nested' -%}
      {%- for group in parent_link.links -%}
        {%- if group.links.size > 0 -%}
          <li class="menu-drawer__list-item kx-cat-mobile__item">
            <accordion-custom>
              <details>
                <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
                  <span class="menu-drawer__menu-item-text wrap-text">{{ group.title }}</span>
                  <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                </summary>
                <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content kx-cat-mobile__sublist" role="list" tabindex="-1">
                  <li><a href="{{ group.url }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset kx-cat-mobile__see-all"><span class="menu-drawer__menu-item-text wrap-text">{{ group.title }} ansehen</span></a></li>
                  {%- for sub in group.links -%}
                    <li><a href="{{ sub.url }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">{{ sub.title }}</span></a></li>
                  {%- endfor -%}
                </ul>
              </details>
            </accordion-custom>
          </li>
        {%- else -%}
          <li class="menu-drawer__list-item kx-cat-mobile__item">
            <a href="{{ group.url }}" class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset"><span class="menu-drawer__menu-item-text wrap-text">{{ group.title }}</span></a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- for link in parent_link.links -%}
        <li><a href="{{ link.url }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset"><span class="menu-drawer__menu-item-text wrap-text">{{ link.title }}</span></a></li>
      {%- endfor -%}
    {%- endif -%}
    {%- if cat_all_url != blank -%}
      <li><a href="{{ cat_all_url }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset kx-cat-mobile__all"><span class="menu-drawer__menu-item-text wrap-text">{{ cat_all_label }}</span></a></li>
    {%- endif -%}
  </ul>

  <style>
    .kx-cat-mobile { padding: 0; }
    .kx-cat-mobile__see-all { font-weight: 600; color: #1B3A2E !important; }
    .kx-cat-mobile__all { font-weight: 700; color: #1B3A2E !important; }
  </style>

{%- else -%}

  <style>
    .menu-list .menu-list__list-item:has(.kx-cat) > .menu-list__submenu,
    .overflow-menu::part(overflow):has(.kx-cat) {
      background: #ffffff !important;
      box-shadow: 0 1px 0 rgba(15, 25, 20, 0.06) !important;
      border-bottom: 1px solid #ececec !important;
      padding-inline: 0 !important;
      z-index: 2147483647 !important;
    }
    .overflow-menu:has(.kx-cat)::after { display: none !important; }

    /* Lift the entire header stacking context to the absolute max while a
       desktop dropdown is open, so high-z product-page elements
       (back-in-stock pills, wishlist hearts, share toasts) can never
       bleed through the dropdown surface. */
    .header:has(.menu-list__list-item [aria-expanded='true']),
    .header-section:has(.menu-list__list-item [aria-expanded='true']),
    #header-group:has(.menu-list__list-item [aria-expanded='true']),
    header-menu:has([aria-expanded='true']) {
      z-index: 2147483647 !important;
      position: relative;
    }

    .mega-menu__grid:has(.kx-cat) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      padding: 0 !important;
    }
    .mega-menu__list:has(.kx-cat) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .menu-list__submenu-inner:has(.kx-cat) {
      max-width: 1600px !important;
      margin: 0 auto !important;
      padding: clamp(1.5rem, 2vw, 2rem) clamp(1rem, 2.5vw, 2rem) !important;
      display: block !important;
    }
    .kx-cat-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
      list-style: none;
      width: 100%;
    }

    .kx-cat {
      width: 100%;
      background: transparent;
      border: 0;
      box-shadow: none;
      padding: 0;
      animation: kxCatIn 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes kxCatIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .kx-cat { animation: none; }
    }

    .kx-cat,
    .kx-cat * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
      box-sizing: border-box;
    }
    .kx-cat ul { list-style: none; padding: 0; margin: 0; }

    /* === Header strip ================================================== */
    .kx-cat__head {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin: 0 0 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #ececec;
    }
    .kx-cat__head-title {
      flex: 1 1 auto;
      min-width: 0;
    }
    .kx-cat__head-all {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 12.5px;
      font-weight: 600;
      letter-spacing: 0;
      text-transform: none;
      color: #1B3A2E;
      text-decoration: none;
      white-space: nowrap;
      transition: color 180ms ease;
    }
    .kx-cat__head-all::after {
      content: '→';
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__head-all:hover,
    .kx-cat__head-all:focus-visible { color: #0f2a1f; }
    .kx-cat__head-all:hover::after,
    .kx-cat__head-all:focus-visible::after { transform: translateX(3px); }
    .kx-cat__head-icon {
      flex: 0 0 22px;
      width: 22px;
      height: 22px;
      color: #1B3A2E;
      display: inline-flex;
    }
    .kx-cat__head-icon svg { width: 100%; height: 100%; }
    .kx-cat__head-title {
      font-size: 14.5px;
      font-weight: 700;
      letter-spacing: -0.005em;
      color: #1B3A2E;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .kx-cat__head-hot {
      display: inline-flex;
      align-items: center;
      font-size: 9.5px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #fff;
      background: #E60000;
      padding: 2px 6px;
      border-radius: 999px;
      margin-left: 0.35rem;
      line-height: 1;
    }

    /* === Grid ========================================================== */
    .kx-cat__grid {
      width: 100%;
      display: grid;
      gap: clamp(1rem, 2vw, 2rem);
      align-items: start;
    }
    .kx-cat__grid--1 { grid-template-columns: minmax(0, 1fr); }
    .kx-cat__grid--2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .kx-cat__grid--3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .kx-cat__grid--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .kx-cat__grid--auto { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }

    /* === Column ======================================================== */
    .kx-cat__col {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .kx-cat__col-title {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      font-size: 12.5px;
      font-weight: 700;
      color: #1B3A2E;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin: 0 0 0.5rem;
      padding-bottom: 0.45rem;
      border-bottom: 1px solid #ececec;
      /* show full title — wrap onto a second line if needed instead of being clipped */
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      min-width: 0;
    }
    .kx-cat__col-title > span:not(.kx-cat__col-icon) {
      min-width: 0;
      flex: 1 1 auto;
    }
    .kx-cat__col-title-link {
      color: inherit;
      text-decoration: none;
      transition: color 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-title-link:hover,
    .kx-cat__col-title-link:focus-visible {
      color: #2d6b54;
      text-decoration: underline;
      text-underline-offset: 3px;
      outline: none;
    }
    .kx-cat__col-list {
      display: flex;
      flex-direction: column;
      gap: 0.05rem;
    }

    /* When flat list spans multiple columns, use CSS column-count for
       balanced fill instead of a fixed grid. */
    .kx-cat__flat {
      width: 100%;
      column-gap: clamp(1rem, 2vw, 2rem);
    }
    .kx-cat__flat--1 { column-count: 1; }
    .kx-cat__flat--2 { column-count: 2; }
    .kx-cat__flat--3 { column-count: 3; }
    .kx-cat__flat--4 { column-count: 4; }
    .kx-cat__flat .kx-cat__col-list-item {
      break-inside: avoid;
    }

    /* === Link with chevron =============================================== */
    .kx-cat__col-list a {
      display: flex;
      align-items: flex-start;
      gap: 0.4rem;
      padding: 0.32rem 0.45rem;
      border-radius: 6px;
      font-size: 12.5px;
      line-height: 1.4;
      font-weight: 500;
      letter-spacing: -0.005em;
      color: #2a2a2a;
      text-decoration: none;
      /* show FULL label — wrap onto a second line when too long instead of being clipped with "…" */
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      min-width: 0;
      transition: background-color 180ms cubic-bezier(0.16, 1, 0.3, 1),
                  color 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-list a::before,
    .kx-cat__col-list a::after {
      align-self: center;
    }
    .kx-cat__col-list a > span,
    .kx-cat__col-list a {
      min-width: 0;
    }
    .kx-cat__col-list a::before {
      content: '›';
      flex-shrink: 0;
      color: #b8bcbe;
      font-weight: 400;
      font-size: 16px;
      line-height: 1;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  color 180ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-list a::after {
      content: '→';
      margin-left: auto;
      flex-shrink: 0;
      color: #1B3A2E;
      opacity: 0;
      transform: translateX(-4px);
      font-size: 12.5px;
      font-weight: 600;
      transition: opacity 180ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__col-list a:hover,
    .kx-cat__col-list a:focus-visible {
      background: #eff4f1;
      color: #1B3A2E;
      outline: none;
    }
    .kx-cat__col-list a:hover::before,
    .kx-cat__col-list a:focus-visible::before {
      color: #1B3A2E;
      transform: translateX(3px);
    }
    .kx-cat__col-list a:hover::after,
    .kx-cat__col-list a:focus-visible::after {
      opacity: 1;
      transform: translateX(0);
    }

    /* === Footer CTA ==================================================== */
    .kx-cat__footer {
      margin-top: 1.1rem;
      padding-top: 1rem;
      border-top: 1px solid #ececec;
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .kx-cat__all {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 13.5px;
      font-weight: 600;
      color: #1B3A2E;
      text-decoration: none;
    }
    .kx-cat__all::after {
      content: '→';
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__all:hover::after,
    .kx-cat__all:focus-visible::after { transform: translateX(4px); }

    .kx-cat__sale-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1rem;
      background: #E60000;
      color: #fff !important;
      border-radius: 999px;
      font-size: 12.5px;
      font-weight: 700;
      letter-spacing: 0.01em;
      text-decoration: none;
      transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .kx-cat__sale-cta::after { content: '→'; transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1); }
    .kx-cat__sale-cta:hover { transform: translateY(-1px); box-shadow: 0 10px 20px rgba(230, 0, 0, 0.22); }
    .kx-cat__sale-cta:hover::after { transform: translateX(3px); }

    @media (max-width: 1199px) {
      .kx-cat__grid--4 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .kx-cat__flat--4 { column-count: 3; }
    }
    @media (max-width: 989px) {
      .kx-cat__grid--3,
      .kx-cat__grid--4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .kx-cat__flat--3,
      .kx-cat__flat--4 { column-count: 2; }
    }
  </style>

  <li class="mega-menu__column kx-cat-cell">
    <nav class="kx-cat" role="navigation" aria-label="{{ cat_title | escape }}">

      <div class="kx-cat__head">
        <span class="kx-cat__head-icon">{{ cat_icon }}</span>
        <h3 class="kx-cat__head-title">{{ cat_title }}</h3>
        {%- if cat == 'sale' -%}<span class="kx-cat__head-hot">HOT</span>{%- endif -%}
      </div>

      {%- if render_mode == 'nested' -%}

        {%- comment -%}
          Count only groups that actually have sub-links so empty
          category headers (e.g. "WINDOWS 8" with no products yet)
          don't reserve a whole grid column.
        {%- endcomment -%}
        {%- assign nested_count = 0 -%}
        {%- for group in parent_link.links -%}
          {%- if group.links.size > 0 -%}
            {%- assign nested_count = nested_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if nested_count == 0 -%}{%- assign nested_count = parent_link.links.size -%}{%- endif -%}
        {%- assign nested_cols = nested_count | at_most: 4 -%}
        <div class="kx-cat__grid kx-cat__grid--{{ nested_cols }}">
          {%- for group in parent_link.links -%}
            {%- if group.links.size == 0 -%}{%- continue -%}{%- endif -%}
            <div class="kx-cat__col">
              <h4 class="kx-cat__col-title">
                {% case forloop.index0 | modulo: 4 %}{% when 0 %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_layers }}</span>{% when 1 %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_doc }}</span>{% when 2 %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_chart }}</span>{% else %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_nodes }}</span>{% endcase %}
                {%- if group.url != blank -%}
                  <a href="{{ group.url }}" class="kx-cat__col-title-link">{{ group.title }}</a>
                {%- else -%}
                  {{ group.title }}
                {%- endif -%}
              </h4>
              {%- if group.links.size > 0 -%}
                <ul class="kx-cat__col-list" role="list">
                  {%- for sub in group.links -%}
                    <li><a href="{{ sub.url }}">{{ sub.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

      {%- else -%}

        {%- comment -%}
          Flat layout — but if the children are collection links, render
          them as columns showing the collection's actual products. This
          mirrors AY-style mega menus where every sub-category surfaces
          its inventory directly in the dropdown.
        {%- endcomment -%}

        {%- assign _has_collection_children = false -%}
        {%- assign _populated_count = 0 -%}
        {%- for link in parent_link.links -%}
          {%- if link.type == 'collection_link' and link.object.products_count > 0 -%}
            {%- assign _has_collection_children = true -%}
            {%- assign _populated_count = _populated_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if _has_collection_children -%}
          {%- assign _coll_cols = _populated_count | at_most: 4 -%}
          <div class="kx-cat__grid kx-cat__grid--{{ _coll_cols }}">
            {%- for link in parent_link.links -%}
              {%- comment -%} Skip non-collection links AND empty collections so e.g. WINDOWS 8 with 0 products does not reserve a column. {%- endcomment -%}
              {%- unless link.type == 'collection_link' and link.object.products_count > 0 -%}{%- continue -%}{%- endunless -%}
              <div class="kx-cat__col">
                <h4 class="kx-cat__col-title">
                  {% case forloop.index0 | modulo: 4 %}{% when 0 %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_layers }}</span>{% when 1 %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_doc }}</span>{% when 2 %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_chart }}</span>{% else %}<span class="kx-cat__col-icon" aria-hidden="true" style="color:#1B3A2E;display:inline-flex;width:16px;height:16px;">{{ svg_nodes }}</span>{% endcase %}
                  <a href="{{ link.url }}" style="color:inherit;text-decoration:none;">{{ link.title }}</a>
                </h4>
                <ul class="kx-cat__col-list" role="list">
                  {%- for product in link.object.products limit: 7 -%}
                    {%- assign _full = product.title -%}
                    {%- assign _short = _full | split: ' – ' | first | split: ' | ' | first | truncatewords: 5, '…' -%}
                    <li><a href="{{ product.url }}" title="{{ _full | escape }}">{{ _short }}</a></li>
                  {%- endfor -%}
                  {%- if link.object.products_count > 7 -%}
                    <li><a href="{{ link.url }}" style="font-weight:600;color:#1B3A2E;">{{ link.title }} →</a></li>
                  {%- endif -%}
                </ul>
              </div>
            {%- endfor -%}
          </div>
        {%- elsif parent_link.links.size > 0 -%}
          {%- comment -%} Pure flat — single-balanced CSS-column list. {%- endcomment -%}
          <div class="kx-cat__flat kx-cat__flat--{{ flat_cols }}">
            <ul class="kx-cat__col-list" role="list">
              {%- for link in parent_link.links -%}
                <li class="kx-cat__col-list-item"><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

      {%- endif -%}

      {%- comment -%}
        Footer "Alle X →" CTA. Lives at the bottom of every category
        dropdown so the head row stays purely a title and the product
        columns get the full horizontal width.
        Sale category keeps its distinctive red pill CTA.
      {%- endcomment -%}
      {%- if cat_all_url != blank -%}
        <div class="kx-cat__footer">
          {%- if cat == 'sale' -%}
            <a href="{{ cat_all_url }}" class="kx-cat__sale-cta">{{ cat_all_label }}</a>
          {%- else -%}
            <a href="{{ cat_all_url }}" class="kx-cat__all">{{ cat_all_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </nav>
  </li>

{%- endif -%}
