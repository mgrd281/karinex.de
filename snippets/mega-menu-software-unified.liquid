{%- else -%}

  <style>
    /* === Karinex Mega Menu — premium full-width grid (desktop) === */

    /* Force the theme's outer mega-menu grid to a single full-width cell
       so our panel can render its own layout. */
    .mega-menu__grid:has(.kx-mm-panel) {
      --menu-columns-desktop: 1 !important;
      --menu-columns-tablet: 1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    .mega-menu__list:has(.kx-mm-panel) {
      grid-column: 1 / -1 !important;
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      overflow: visible;
    }
    .kx-mm-panel-cell {
      grid-column: 1 / -1 !important;
      padding: 0 !important;
      min-width: 0;
    }

    /* Reset theme link defaults inside our panel so nothing leaks in */
    .kx-mm-panel a,
    .kx-mm-panel a:hover {
      text-decoration: none;
    }
    .kx-mm-panel,
    .kx-mm-panel * {
      -webkit-hyphens: manual !important;
      hyphens: manual !important;
      word-break: normal !important;
      overflow-wrap: break-word;
    }

    /* === Panel container === */
    .kx-mm-panel {
      width: 100%;
      max-width: var(--page-width, 1440px);
      margin-inline: auto;
      padding: 1.75rem 0 2rem;

      display: grid;
      grid-template-columns: minmax(180px, 220px) minmax(0, 1fr);
      gap: 2.25rem;

      /* Lock vertical footprint so the panel never reflows between items */
      min-height: 360px;

      animation: kxMmFadeIn 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes kxMmFadeIn {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0);    }
    }

    @media (prefers-reduced-motion: reduce) {
      .kx-mm-panel { animation: none; }
    }

    /* === Sidebar === */
    .kx-mm-panel__sidebar {
      border-right: 1px solid #ececec;
      padding-right: 1.5rem;
    }

    .kx-mm-panel__heading {
      font-family: var(--menu-parent-font-family, inherit);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #1B3A2E;
      margin: 0 0 0.85rem;
      padding-bottom: 0.55rem;
      border-bottom: 2px solid #1B3A2E;
      white-space: nowrap;
      display: block;
    }

    .kx-mm-panel__sidebar-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    .kx-mm-panel__sidebar-list a {
      display: block;
      padding: 0.42rem 0;
      font-size: 13px;
      line-height: 1.4;
      color: #444;
      transition: color 160ms ease, transform 160ms ease;
    }
    .kx-mm-panel__sidebar-list a:hover,
    .kx-mm-panel__sidebar-list a:focus-visible {
      color: #1B3A2E;
      transform: translateX(3px);
      outline: none;
    }
    .kx-mm-panel__sidebar-list a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    .kx-mm-panel__sidebar-sale {
      color: #E60000 !important;
      font-weight: 700;
      letter-spacing: 0.02em;
    }
    .kx-mm-panel__sidebar-sale:hover {
      color: #E60000 !important;
    }

    /* === Content grid (2 rows × 6 columns) === */
    .kx-mm-panel__content {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 1.75rem 1.5rem;
      align-content: start;
    }

    .kx-mm-panel__col {
      min-width: 0;
      display: flex;
      flex-direction: column;
    }

    .kx-mm-panel__col-title {
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #1B3A2E;
      margin: 0 0 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #e6e6e6;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: border-bottom-color 180ms ease;
    }
    .kx-mm-panel__col-title:hover {
      border-bottom-color: #1B3A2E;
    }

    .kx-mm-panel__col-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.05rem;
    }
    .kx-mm-panel__col-list li { min-width: 0; }

    .kx-mm-panel__col-list a {
      display: block;
      padding: 0.32rem 0;
      font-size: 12.5px;
      line-height: 1.4;
      color: #5a5a5a;
      transition: color 160ms ease, transform 160ms ease;
    }
    .kx-mm-panel__col-list a:hover,
    .kx-mm-panel__col-list a:focus-visible {
      color: #1B3A2E;
      transform: translateX(2px);
      outline: none;
    }
    .kx-mm-panel__col-list a:focus-visible {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .kx-mm-panel__col-all {
      margin-top: 0.4rem;
      padding-top: 0.4rem;
      border-top: 1px dashed #ececec;
    }
    .kx-mm-panel__col-all a {
      font-weight: 600;
      color: #1B3A2E !important;
    }
    .kx-mm-panel__col-all a::after {
      content: ' →';
      display: inline-block;
      transition: transform 160ms ease;
    }
    .kx-mm-panel__col-all a:hover::after {
      transform: translateX(3px);
    }

    /* === Responsive breakpoints === */
    @media (max-width: 1399px) {
      .kx-mm-panel { gap: 1.75rem; }
      .kx-mm-panel__content {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }
    }
    @media (max-width: 1199px) {
      .kx-mm-panel {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        min-height: auto;
      }
      .kx-mm-panel__sidebar {
        border-right: 0;
        border-bottom: 1px solid #ececec;
        padding-right: 0;
        padding-bottom: 1rem;
      }
      .kx-mm-panel__sidebar-list {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 0.35rem 1.5rem;
      }
      .kx-mm-panel__content {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }
    @media (max-width: 989px) {
      .kx-mm-panel__content {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>

