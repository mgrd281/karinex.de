{%- doc -%}
  Renders the unified Karinex mega-menu with 7 columns matching the actual
  Hauptmenü top-level items: Office für Windows, Office für Mac, Microsoft 365,
  Windows, Windows Server, Microsoft Tools, SALE & Bestseller.

  Triggered for any top-level item whose handle/title contains
  windows / office / microsoft / 365 / sale / bestseller — so the same panel
  shows regardless of which top-level item the visitor hovers.

  @param {string} _root - Theme root URL prefix, e.g. '/' or '/de/'.
  @param {string} [mode] - 'desktop' (default) | 'mobile'.
{%- enddoc -%}

{%- liquid
  assign mode = mode | default: 'desktop'

  if _root == blank
    assign _root = routes.root_url | default: '/'
  endif
  unless _root == '/'
    assign _root_check = _root | slice: -1, 1
    unless _root_check == '/'
      assign _root = _root | append: '/'
    endunless
  endunless

  assign col_titles = 'Office für Windows|Office für Mac|Microsoft 365|Windows|Windows Server|Microsoft Tools|SALE & Bestseller' | split: '|'
  assign col_hrefs = 'collections/microsoft-office|collections/microsoft-office-fur-mac|collections/microsoft-365-abonnement|collections/windows|collections/windows-server|collections/microsoft-tools|collections/sale' | split: '|'

  assign sub_office_win = 'Office 2024 Pro Plus~search?q=Office+2024+Professional+Plus;;Office 2021 Pro Plus~search?q=Office+2021+Professional+Plus;;Office 2019 Pro Plus~search?q=Office+2019+Professional+Plus;;Office Home & Business~search?q=Office+Home+Business;;Alle Office-Lizenzen~collections/microsoft-office'
  assign sub_office_mac = 'Office 2024 für Mac~search?q=Office+2024+Mac;;Office 2021 für Mac~search?q=Office+2021+Mac;;Office Home & Student Mac~search?q=Office+Home+Student+Mac;;Alle Mac-Lizenzen~collections/microsoft-office-fur-mac'
  assign sub_365 = 'Microsoft 365 Family~search?q=Microsoft+365+Family;;Microsoft 365 Personal~search?q=Microsoft+365+Personal;;Microsoft 365 Business Standard~search?q=Microsoft+365+Business+Standard;;Microsoft 365 Business Premium~search?q=Microsoft+365+Business+Premium;;Alle 365 Abos~collections/microsoft-365-abonnement'
  assign sub_windows = 'Windows 11 Pro~search?q=Windows+11+Pro;;Windows 11 Home~search?q=Windows+11+Home;;Windows 10 Pro~search?q=Windows+10+Pro;;Windows 10 Home~search?q=Windows+10+Home;;Windows 8.1 Pro~search?q=Windows+8.1+Pro;;Windows 7 Ultimate~search?q=Windows+7+Ultimate;;Alle Windows-Versionen~collections/windows'
  assign sub_server = 'Server 2025 Standard~search?q=Windows+Server+2025+Standard;;Server 2025 Datacenter~search?q=Windows+Server+2025+Datacenter;;Server 2022 Standard~search?q=Windows+Server+2022+Standard;;Server 2019 Standard~search?q=Windows+Server+2019+Standard;;Alle Server-Lizenzen~collections/windows-server'
  assign sub_tools = 'Project 2024~search?q=Microsoft+Project+2024;;Visio 2024~search?q=Microsoft+Visio+2024;;Visual Studio 2022~search?q=Visual+Studio+2022;;SQL Server~search?q=SQL+Server;;Exchange Server~search?q=Exchange+Server;;Alle Microsoft Tools~collections/microsoft-tools'
  assign sub_sale = 'Alle Deals~collections/sale;;Bis 90 % Rabatt~collections/sale;;Top 10 Bestseller~collections/bestseller;;Letzte Stück~collections/sale;;Alle Produkte~collections/all'

  assign all_subs = sub_office_win | append: '@@' | append: sub_office_mac | append: '@@' | append: sub_365 | append: '@@' | append: sub_windows | append: '@@' | append: sub_server | append: '@@' | append: sub_tools | append: '@@' | append: sub_sale
  assign cols_subs = all_subs | split: '@@'
-%}

{%- if mode == 'mobile' -%}
  <ul class="menu-drawer__menu menu-drawer__menu--childlist software-unified-mobile" role="list" tabindex="-1" style="padding: 0;">
    {%- for col_title in col_titles -%}
      {%- assign col_href = col_hrefs[forloop.index0] -%}
      {%- assign subs = cols_subs[forloop.index0] | split: ';;' -%}
      <li class="menu-drawer__list-item software-unified-mobile__item">
        <accordion-custom>
          <details>
            <summary class="menu-drawer__menu-item menu-drawer__menu-item--parent focus-inset">
              <span class="menu-drawer__menu-item-text wrap-text">{{ col_title }}</span>
              <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
            </summary>
            <ul class="menu-drawer__menu menu-drawer__menu--grandchildlist details-content" role="list" tabindex="-1">
              <li class="menu-drawer__list-item">
                <a href="{{ _root }}{{ col_href }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset" style="font-weight:600;">
                  <span class="menu-drawer__menu-item-text wrap-text">{{ col_title }} ansehen</span>
                </a>
              </li>
              {%- for sub in subs -%}
                {%- assign parts = sub | split: '~' -%}
                <li class="menu-drawer__list-item">
                  <a href="{{ _root }}{{ parts[1] }}" class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset">
                    <span class="menu-drawer__menu-item-text wrap-text">{{ parts[0] }}</span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </details>
        </accordion-custom>
      </li>
    {%- endfor -%}
  </ul>
{%- else -%}
  {%- comment -%} Force a 7-column grid on the parent .mega-menu__grid when this snippet is used. {%- endcomment -%}
  <style>
    .mega-menu__grid:has(.mega-menu-software-unified) {
      --menu-columns-desktop: 7 !important;
      --menu-columns-tablet: 4 !important;
    }
    .mega-menu__list:has(.mega-menu-software-unified) {
      grid-column: span 7 !important;
    }
    @media (max-width: 1199px) {
      .mega-menu__grid:has(.mega-menu-software-unified) {
        --menu-columns-desktop: 4 !important;
      }
      .mega-menu__list:has(.mega-menu-software-unified) {
        grid-column: span 4 !important;
      }
    }
    @media (max-width: 989px) {
      .mega-menu__grid:has(.mega-menu-software-unified) {
        --menu-columns-tablet: 3 !important;
      }
    }
  </style>

  {%- for col_title in col_titles -%}
    {%- assign col_href = col_hrefs[forloop.index0] -%}
    {%- assign subs = cols_subs[forloop.index0] | split: ';;' -%}
    <li class="mega-menu__column mega-menu__column--span-1 mega-menu-software-unified">
      <div class="mega-menu__item-wrapper">
        <a href="{{ _root }}{{ col_href }}" class="mega-menu__link mega-menu__link--parent">{{ col_title }}</a>
        <ul class="list-unstyled mega-menu__submenu-list">
          {%- for sub in subs -%}
            {%- assign parts = sub | split: '~' -%}
            <li>
              <a href="{{ _root }}{{ parts[1] }}" class="mega-menu__link">
                <span class="mega-menu__link-title wrap-text">{{ parts[0] }}</span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </li>
  {%- endfor -%}
{%- endif -%}
