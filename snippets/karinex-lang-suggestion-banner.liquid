{%- comment -%}
  Smart language suggestion banner — first-visit nudge.

  Compares the browser's preferred language against the current
  Shopify locale (request.locale.iso_code). If they differ AND the
  visitor hasn't dismissed/used the banner before, slides in a thin
  banner at the top of the page offering a one-click switch.

  Persists user choice via localStorage("karinex_lang_pref"):
    - "dismissed" | "<iso>" → never shown again
  Languages supported: de (default), en, pl, sv.
{%- endcomment -%}

{%- assign _cur_iso = request.locale.iso_code | downcase | default: 'de' -%}
{%- assign _root_x = routes.root_url | default: '/' -%}
{%- assign _path = request.path -%}
{%- comment -%} Build base path without locale prefix {%- endcomment -%}
{%- assign _path_seg = _path | split: '/' -%}
{%- assign _path_locale = _path_seg[1] | default: '' -%}
{%- assign _known_locales = 'en,pl,sv,da,nl,fr,it,es,cs,hu,ro,sk,fi,el,pt' | split: ',' -%}
{%- assign _base_path = _path -%}
{%- if _known_locales contains _path_locale -%}
  {%- assign _strip = '/' | append: _path_locale -%}
  {%- assign _base_path = _path | remove_first: _strip -%}
{%- endif -%}
{%- if _base_path == '' or _base_path == blank -%}{%- assign _base_path = '/' -%}{%- endif -%}

<style>
  .klb {
    position: sticky;
    top: 0;
    z-index: 9990;
    display: none;
    width: 100%;
    background: #1D4739;
    color: #faf7f0;
    font-family: inherit;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .klb.is-open { display: block; animation: klb-in .35s cubic-bezier(.22,.61,.36,1); }
  @keyframes klb-in { from { transform: translateY(-100%); } to { transform: translateY(0); } }
  .klb__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .klb__flag {
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
  }
  .klb__text {
    flex: 1;
    font-size: 13px;
    line-height: 1.45;
    color: #eef3f0;
    min-width: 0;
  }
  .klb__cta {
    background: #c9a84c;
    color: #1a1a1a;
    border: none;
    padding: 8px 16px;
    border-radius: 999px;
    font-family: inherit;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: background .2s ease, transform .2s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .klb__cta:hover { background: #d8b658; transform: translateY(-1px); }
  .klb__close {
    background: transparent;
    border: none;
    color: #eef3f0;
    width: 28px; height: 28px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background .2s ease, transform .25s ease;
  }
  .klb__close:hover { background: rgba(255,255,255,.12); transform: rotate(90deg); }
  .klb__close:focus-visible { outline: 2px solid #c9a84c; outline-offset: 1px; }
  @media (max-width: 520px) {
    .klb__inner { gap: 10px; padding: 9px 12px; }
    .klb__text { font-size: 12.5px; }
    .klb__cta { padding: 7px 12px; font-size: 10.5px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .klb.is-open { animation: none; }
    .klb__cta:hover, .klb__close:hover { transform: none; }
  }
</style>

<div class="klb" id="klangBanner" role="region" aria-label="Language suggestion" hidden>
  <div class="klb__inner">
    <span class="klb__flag" id="klangBannerFlag" aria-hidden="true">🌐</span>
    <span class="klb__text" id="klangBannerText"></span>
    <a href="#" class="klb__cta" id="klangBannerCta">Switch</a>
    <button type="button" class="klb__close" id="klangBannerClose" aria-label="Schließen">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</div>

<script>
  (function () {
    var CURRENT = {{ _cur_iso | json }};
    var BASE_PATH = {{ _base_path | json }};
    var KEY = 'karinex_lang_pref';

    // Languages we officially support (must match Shopify locales enabled)
    var SUPPORTED = {
      en: { code: 'en', flag: '🇬🇧', label: 'English',
            text: 'We noticed your browser is set to English.',
            cta:  'Switch to English' },
      pl: { code: 'pl', flag: '🇵🇱', label: 'Polski',
            text: 'Twoja przeglądarka jest ustawiona na polski.',
            cta:  'Przełącz na polski' },
      sv: { code: 'sv', flag: '🇸🇪', label: 'Svenska',
            text: 'Din webbläsare är inställd på svenska.',
            cta:  'Byt till svenska' },
      de: { code: 'de', flag: '🇩🇪', label: 'Deutsch',
            text: 'Ihr Browser ist auf Deutsch eingestellt.',
            cta:  'Auf Deutsch wechseln' }
    };

    // Already chosen / dismissed?
    var stored = null;
    try { stored = localStorage.getItem(KEY); } catch (_) {}
    if (stored) return;

    // Detect browser primary language
    var langs = (navigator.languages && navigator.languages.length)
      ? navigator.languages : [navigator.language || 'en'];
    var browser = null;
    for (var i = 0; i < langs.length; i++) {
      var two = String(langs[i] || '').slice(0, 2).toLowerCase();
      if (SUPPORTED[two]) { browser = two; break; }
    }
    if (!browser || browser === CURRENT) return;

    var t = SUPPORTED[browser];
    var bar     = document.getElementById('klangBanner');
    var flagEl  = document.getElementById('klangBannerFlag');
    var textEl  = document.getElementById('klangBannerText');
    var ctaEl   = document.getElementById('klangBannerCta');
    var closeEl = document.getElementById('klangBannerClose');
    if (!bar) return;

    flagEl.textContent = t.flag;
    textEl.textContent = t.text;
    ctaEl.textContent  = t.cta;
    // Build target URL: keep current base path (without locale), prepend new locale.
    var target;
    if (browser === 'de') {
      target = BASE_PATH; // DE is the default (no prefix)
    } else if (BASE_PATH === '/' || BASE_PATH === '') {
      target = '/' + browser;
    } else {
      target = '/' + browser + BASE_PATH;
    }
    ctaEl.setAttribute('href', target);

    function dismiss(saveValue) {
      try { localStorage.setItem(KEY, saveValue || 'dismissed'); } catch (_) {}
      bar.classList.remove('is-open');
    }

    ctaEl.addEventListener('click', function () {
      // Save preference so we don't re-prompt
      try { localStorage.setItem(KEY, browser); } catch (_) {}
    });
    closeEl.addEventListener('click', function () { dismiss('dismissed'); });

    // Show after a tiny delay so it animates after page paint
    bar.hidden = false;
    requestAnimationFrame(function () {
      setTimeout(function () { bar.classList.add('is-open'); }, 150);
    });

    // Auto-dismiss after 12s if user ignores it
    setTimeout(function () {
      if (bar.classList.contains('is-open')) dismiss('dismissed');
    }, 12000);
  })();
</script>
