<script>
  /* Widerrufsverzicht gate — disables checkout (and accelerated checkout)
     until the customer ticks the consent box. Mirrors state into a Shopify
     cart attribute (widerruf_consent) so the timestamped consent appears in
     the order details. Wires both the cart page and the cart drawer. */
  (function () {
    if (window.__kxWiderrufInit) return;
    window.__kxWiderrufInit = true;

    function boxes() {
      return Array.prototype.slice.call(
        document.querySelectorAll('[data-kx-widerruf-cb]')
      );
    }
    function buttons() {
      return Array.prototype.slice.call(
        document.querySelectorAll('button[name="checkout"]')
      );
    }
    function ctaContainers() {
      return Array.prototype.slice.call(
        document.querySelectorAll('.cart__ctas')
      );
    }
    function errs() {
      return Array.prototype.slice.call(
        document.querySelectorAll('[data-kx-widerruf-err]')
      );
    }
    function wrappers() {
      return Array.prototype.slice.call(
        document.querySelectorAll('[data-kx-widerruf]')
      );
    }

    function syncBoxes(state) {
      boxes().forEach(function (b) { if (b.checked !== state) b.checked = state; });
    }
    function setEnabled(on) {
      buttons().forEach(function (b) {
        if (b.dataset.kxwEmpty === '1') return; // empty cart stays disabled
        b.disabled = !on;
      });
      ctaContainers().forEach(function (c) {
        c.classList.toggle('kxw-locked', !on);
      });
    }
    function clearError() {
      errs().forEach(function (e) { e.hidden = true; });
      wrappers().forEach(function (w) { w.classList.remove('is-error'); });
    }
    function showError() {
      errs().forEach(function (e) { e.hidden = false; });
      wrappers().forEach(function (w) { w.classList.add('is-error'); });
      var first = boxes()[0];
      if (first) {
        var wrap = first.closest('[data-kx-widerruf]');
        if (wrap && wrap.scrollIntoView) {
          wrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        try { first.focus({ preventScroll: true }); } catch (e) { first.focus(); }
      }
    }

    function persist(state) {
      var value = state ? 'Ja (' + new Date().toISOString() + ')' : '';
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ attributes: { widerruf_consent: value } })
      }).catch(function () { /* ignore network errors */ });
    }

    function onChange(e) {
      var state = !!(e.target && e.target.checked);
      clearError();
      syncBoxes(state);
      setEnabled(state);
      persist(state);
    }

    function wire() {
      var bs = boxes();
      // Gate disabled by merchant via theme settings → nothing to wire,
      // and don't disable the checkout button.
      if (bs.length === 0) return;
      bs.forEach(function (b) {
        if (b.dataset.kxwWired === '1') return;
        b.dataset.kxwWired = '1';
        b.addEventListener('change', onChange);
      });
      // Initial state — reflect whatever the server pre-rendered
      setEnabled(!!bs[0].checked);
    }

    // Defensive: block any checkout click while unchecked, even for buttons
    // injected after our wire pass (drawer re-renders, etc.)
    document.addEventListener('click', function (e) {
      var t = e.target;
      if (!t) return;
      var btn = t.closest ? t.closest('button[name="checkout"]') : null;
      if (!btn) return;
      if (boxes().length === 0) return; // no consent UI on this page
      var ok = boxes().some(function (b) { return b.checked; });
      if (!ok) {
        e.preventDefault();
        e.stopPropagation();
        showError();
      }
    }, true);

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wire);
    } else {
      wire();
    }

    // Re-wire when sections morph (cart drawer open, cart line update, etc.)
    try {
      new MutationObserver(function () { wire(); })
        .observe(document.body, { childList: true, subtree: true });
    } catch (e) { /* old browsers — initial wire is enough */ }
  })();
</script>
