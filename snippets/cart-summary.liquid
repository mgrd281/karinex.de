    transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
  }
  .kx-widerruf__cb:focus-visible + .kx-widerruf__box {
    border-color: #1D4739;
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.35);
  }
  .kx-widerruf__cb:checked + .kx-widerruf__box {
    background: #1D4739;
    border-color: #1D4739;
  }
  .kx-widerruf__cb:checked + .kx-widerruf__box::after {
    content: '';
    width: 6px;
    height: 11px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) translate(-1px, -1px);
  }
  .kx-widerruf__text {
    font-size: 12.5px;
    line-height: 1.45;
    color: #2b2b2b;
    letter-spacing: 0;
  }
  .kx-widerruf__err {
