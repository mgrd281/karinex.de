{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
{%- enddoc -%}

{%- case request.locale.iso_code -%}
  {%- when 'en' -%}
    {%- assign T_ssl_label = 'Secure payment' -%}
    {%- assign T_ssl_detail = '256-bit SSL encryption' -%}
  {%- when 'pl' -%}
    {%- assign T_ssl_label = 'Bezpieczna płatność' -%}
    {%- assign T_ssl_detail = 'Szyfrowanie SSL 256-bit' -%}
  {%- when 'sv' -%}
    {%- assign T_ssl_label = 'Säker betalning' -%}
    {%- assign T_ssl_detail = '256-bitars SSL-kryptering' -%}
  {%- else -%}
    {%- assign T_ssl_label = 'Sichere Zahlung' -%}
    {%- assign T_ssl_detail = '256-Bit SSL-Verschlüsselung' -%}
{%- endcase -%}

{% comment %} --- FREE SHIPPING PROGRESS BAR --- {% endcomment %}
{% assign free_shipping_threshold = settings.cart_free_shipping_threshold | default: 5000 %} {% comment %} Default 50.00 {% endcomment %}
{% assign cart_total = cart.total_price %}
{% assign remaining_amount = free_shipping_threshold | minus: cart_total %}
{% assign progress_percentage = cart_total | times: 100 | divided_by: free_shipping_threshold %}
{% if progress_percentage > 100 %}
  {% assign progress_percentage = 100 %}
{% endif %}



<div class="cart__summary-totals">
  
  {% render 'cart-loyalty-redeem' %}

  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart__original-total-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <div class="cart__summary-item cart__original-total">
        <div class="cart__original-total-label">{{ 'content.cart_subtotal' | t }}</div>
        <div class="cart__original-total-value cart-secondary-typography">
          {{- cart.original_total_price | money_without_currency -}} EUR
        </div>
      </div>
      <div class="cart__summary-discounts">
        <ul
          class="discounts list-unstyled"
          role="list"
          aria-label="{{ 'content.discounts' | t }}"
        >
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="cart__summary-item cart__discount">
              <span class="cart__discount-label">
                {{- 'icon-discount.svg' | inline_asset_content -}}
                {{ discount.title | escape }}
              </span>
              <span class="cart__discount-value cart-secondary-typography"
                >-{{ discount.total_allocated_amount | money_without_currency -}} EUR
              </span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        <script
          type="module"
          src="{{ 'cart-note.js' | asset_url }}"
        ></script>

        <cart-note style="display: flex;">
          <accordion-custom
            class="cart-note"
            {% if settings.cart_note_open_by_default %}
              open-by-default-on-desktop
              open-by-default-on-mobile
            {% endif %}
          >
            <details
              class="details"
              {% if settings.cart_note_open_by_default %}
                open
              {% endif %}
            >
              <summary class="cart-note__summary">
                <span class="cart-note__label cart-primary-typography">
                  {{ 'content.seller_note' | t }}
                </span>

                <span class="svg-wrapper icon-plus">
                  {{- 'icon-plus.svg' | inline_asset_content -}}
                </span>
              </summary>

              <div class="details-content cart-note__inner">
                <label
                  for="cart-note"
                  class="visually-hidden"
                >
                  {{- 'content.seller_note' | t -}}
                </label>
                <textarea
                  form="cart-form"
                  on:input="/updateCartNote"
                  id="cart-note"
                  class="cart-note__instructions"
                  name="note"
                >{{ cart.note }}</textarea>
              </div>
            </details>
          </accordion-custom>
        </cart-note>
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% liquid
          assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
          for item in cart.items
            for allocation in item.line_level_discount_allocations
              if allocation.discount_application.type == 'discount_code'
                assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
              endif
            endfor
          endfor

          assign discount_codes = discount_codes | uniq

          # Evaluate the boolean expression for the disclosure state
          if discount_codes.size == 0
            assign disclosure_expanded = false
          else
            assign disclosure_expanded = true
          endif
        %}

        <disclosure-custom class="cart-discount">
          <button
            aria-controls="cart-discount-disclosure"
            aria-expanded="{% if disclosure_expanded %}true{% else %}false{% endif %}"
            aria-label="{% if disclosure_expanded %}{{ 'actions.close' | t }}{% else %}{{ 'actions.open' | t }}{% endif %} {{ 'accessibility.discount_menu' | t }}"
            class="disclosure-trigger"
            data-disclosure-open="{{ 'actions.open' | t }} {{ 'accessibility.discount_menu' | t }}"
            data-disclosure-close="{{ 'actions.close' | t }} {{ 'accessibility.discount_menu' | t }}"
            on:click="/toggleDisclosure"
            ref="disclosureTrigger"
            type="button"
          >
            <span class="disclosure-trigger__label cart-primary-typography">{{ 'content.discount' | t }}</span>

            <span class="svg-wrapper icon-plus">
              {{- 'icon-plus.svg' | inline_asset_content -}}
            </span>
          </button>

          <div
            class="disclosure-content"
            {% unless disclosure_expanded %}
              inert
            {% endunless %}
            ref="disclosureContent"
          >
            <div id="cart-discount-disclosure">
              <cart-discount-component
                data-section-id="{{ section.id }}"
              >
                <div class="cart-discount__content">
                  <form
                    on:submit="/applyDiscount"
                    onsubmit="return false;"
                    class="cart-discount__form"
                  >
                    <label
                      for="cart-discount"
                      class="visually-hidden"
                    >
                      {{- 'accessibility.discount' | t -}}
                    </label>
                    <input
                      id="cart-discount"
                      class="cart-discount__input"
                      type="text"
                      name="discount"
                      size="8"
                      placeholder="{{ 'content.discount_code' | t }}"
                      required
                    >
                    <button
                      type="submit"
                      class="button button--primary cart-discount__button"
                    >
                      {{ 'actions.apply' | t }}
                    </button>
                  </form>
                </div>
                <div
                  class="cart-discount__error hidden"
                  role="alert"
                  ref="cartDiscountError"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-error.svg' | inline_asset_content -}}
                  </span>
                  <small
                    class="cart-discount__error-text cart-primary-typography hidden"
                    ref="cartDiscountErrorDiscountCode"
                  >
                    {{ 'content.discount_code_error' | t: code: 'test' }}
                  </small>
                  <small
                    class="cart-discount__error-text cart-primary-typography hidden"
                    ref="cartDiscountErrorShipping"
                  >
                    {{ 'content.shipping_discount_error' | t }}
                  </small>
                </div>
                <ul class="cart-discount__codes">
                  {% for discount_code in discount_codes %}
                    <li
                      class="cart-discount__pill"
                      data-discount-code="{{ discount_code }}"
                      aria-label="{{ 'accessibility.discount_applied' | t: code: discount_code }}"
                    >
                      <p class="cart-discount__pill-code">
                        {{ discount_code }}
                      </p>
                      <button
                        type="button"
                        on:click="/removeDiscount"
                        class="cart-discount__pill-remove svg-wrapper svg-wrapper--smaller button-unstyled"
                        aria-label="{{ 'actions.remove_discount' | t: code: discount_code }}"
                      >
                        {{- 'icon-filters-close.svg' | inline_asset_content -}}
                      </button>
                    </li>
                  {% endfor %}
                </ul>
              </cart-discount-component>
            </div>
          </div>
        </disclosure-custom>
      {% endif %}
    </div>
  {% endif %}

  

  {%- liquid
    assign market_currency_symbol = localization.country.currency.iso_code
    assign total_price = cart.total_price | money_without_currency | append: ' ' | append: market_currency_symbol
  -%}


  <div class="cart__total-container{% if settings.show_installments %} cart__total-container--has-installments{% endif %}">
    <span
      class="cart__summary-item cart__total"
      role="status"
    >
      <span class="cart__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price }}"
        class="cart__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-cart-subtotal
        style="font-size: 1.25em;"
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart__summary-item cart__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    
    {%- liquid
      assign vat_rate = 0.19
      assign total_without_vat = cart.total_price | divided_by: 1.19
      assign vat_amount = cart.total_price | minus: total_without_vat
    -%}
    
    {% unless is_drawer %}
    <div class="cart__summary-item cart__net cart-summary-detail-row" style="display: flex; justify-content: space-between; font-size: 13px; padding: 6px 0 2px 0; border-top: 1px solid #e5e5e5; margin-top: 8px;">
      <span>Summe (Netto)</span>
      <span>{{ total_without_vat | money_without_currency | append: ' ' | append: market_currency_symbol }}</span>
    </div>
    
    <div class="cart__summary-item cart__vat cart-summary-detail-row" style="display: flex; justify-content: space-between; font-size: 13px; padding: 2px 0 8px 0;">
      <span>Mehrwertsteuer (19%)</span>
      <span>{{ vat_amount | money_without_currency | append: ' ' | append: market_currency_symbol }}</span>
    </div>
    
    <div class="cart__summary-item tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
    {% endunless %}
  </div>
</div>

{%- comment -%}
  ============================================================
  WIDERRUFSVERZICHT (§ 356 (5) BGB) — required consent for
  digital goods. Without this explicit checkbox, the customer
  keeps the right of withdrawal even after key delivery →
  refund risk. Consent is mirrored to a cart attribute so it
  appears in the Shopify order details with a timestamp.
  Hidden when the cart is empty OR when the merchant disabled
  the gate from Theme Settings → Cart → Widerrufsverzicht.
  Defaults to ON (legal safety): we only hide on explicit OFF.
  ============================================================
{%- endcomment -%}
{%- assign _kxw_enabled = true -%}
{%- if settings.show_widerruf_consent == false -%}{%- assign _kxw_enabled = false -%}{%- endif -%}
{%- if cart != empty and _kxw_enabled -%}
  {%- assign _kxw_ctx = 'page' -%}
  {%- if is_drawer -%}{%- assign _kxw_ctx = 'drawer' -%}{%- endif -%}
  {%- assign _kxw_val = cart.attributes.widerruf_consent | default: '' -%}
  <div class="kx-widerruf" data-kx-widerruf data-kxw-context="{{ _kxw_ctx }}">
    <label class="kx-widerruf__label" for="kx-widerruf-cb-{{ _kxw_ctx }}">
      <input
        type="checkbox"
        id="kx-widerruf-cb-{{ _kxw_ctx }}"
        class="kx-widerruf__cb"
        data-kx-widerruf-cb
        {% if _kxw_val != blank %}checked{% endif %}
        required
        aria-describedby="kx-widerruf-text-{{ _kxw_ctx }}"
      />
      <span class="kx-widerruf__box" aria-hidden="true"></span>
      <span class="kx-widerruf__text" id="kx-widerruf-text-{{ _kxw_ctx }}">
        {{ 'karinex.widerruf.consent' | t }}
      </span>
    </label>
    <p class="kx-widerruf__err" data-kx-widerruf-err role="alert" hidden>
      {{ 'karinex.widerruf.required' | t }}
    </p>
  </div>
{%- endif -%}

<div class="cart__ctas">
  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button"
    name="checkout"
    {% if cart == empty %}
      disabled
    {% elsif _kxw_enabled and cart.attributes.widerruf_consent == blank %}
      disabled
    {% endif %}
    {% if cart == empty %}data-kxw-empty="1"{% endif %}
    form="cart-form"
    style="display: flex; justify-content: space-between; align-items: center; padding: 0 24px;"
  >
    <span style="font-size: 16px; font-weight: 600; letter-spacing: 0.3px;">{{ 'karinex.cart.checkout' | t }}</span>
    <span style="font-size: 16px; font-weight: 600;">{{ total_price }}</span>
  </button>

  {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
    <div
      class="
        additional-checkout-buttons
        {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
      "
      id="smart-payment-buttons"
    >
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}

  {%- if cart != empty -%}
    <div class="cart__ssl-trust" aria-hidden="true">
      <svg class="cart__ssl-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="11" width="16" height="10" rx="2"/>
        <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
      </svg>
      <span class="cart__ssl-trust-text">{{ T_ssl_label }}</span>
      <span class="cart__ssl-trust-sep" aria-hidden="true">|</span>
      <span class="cart__ssl-trust-text">{{ T_ssl_detail }}</span>
    </div>
  {%- endif -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Determine if the user is on an Apple device (Mac/iOS)
    var isAppleDevice = /Mac|iPod|iPhone|iPad/.test(navigator.platform) || /Macintosh|iPhone|iPad|iPod/.test(navigator.userAgent);
    var container = document.getElementById('smart-payment-buttons');
    if (container) {
      if (isAppleDevice) {
        container.classList.add('is-apple-device');
      } else {
        container.classList.add('is-non-apple-device');
      }
    }
  });

  // Also run when cart drawer is re-rendered (if applicable via mutation observer or custom event)
  document.addEventListener('cart:updated', function() {
    var isAppleDevice = /Mac|iPod|iPhone|iPad/.test(navigator.platform) || /Macintosh|iPhone|iPad|iPod/.test(navigator.userAgent);
    var container = document.getElementById('smart-payment-buttons');
    if (container) {
      if (isAppleDevice) {
        container.classList.add('is-apple-device');
        container.classList.remove('is-non-apple-device');
      } else {
        container.classList.add('is-non-apple-device');
        container.classList.remove('is-apple-device');
      }
    }
  });
</script>

<style>
  /* ============================
     ORDER SUMMARY — WORLD-CLASS
     ============================ */
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-block: 1px solid var(--color-border);
    padding-block: 0;
    margin-block-start: var(--margin-3xs);
  }

  .cart-actions__divider {
    border-block-start: 1px solid var(--color-border);
  }

  .cart-drawer .cart__summary-totals {
    padding: 14px 20px !important;
    border-top: 1px solid #f0f0f0 !important;
    margin-top: 0 !important;
  }

  .cart__summary-totals:not(:has(.cart-actions)) {
    margin-block-start: var(--margin-3xs);
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--margin-xl);
  }

  /* Summary rows */
  .cart__summary-item {
    padding: 0 0 14px 0 !important;
  }
  .cart__summary-item:last-of-type {
    padding-bottom: 0 !important;
  }
  
  .cart__original-total-label,
  .cart__original-total-label * {
    font-size: 14px !important;
    color: #7a7a7a !important;
    font-weight: 400;
  }
  .cart__original-total-value,
  .cart__original-total-value * {
    font-size: 14px !important;
    font-weight: 500 !important;
  }

  /* Total row */
  .cart__total-label {
    font-size: 16px !important;
    font-weight: 600 !important;
    color: #000 !important;
  }
  .cart__total-value {
    font-size: 16px !important;
    font-weight: 600 !important;
    color: #000 !important;
  }

  .cart__installments {
    color: var(--color-foreground);
    font-size: var(--cart-font-size--2xs);
  }

  .cart-discount__input {
    background-color: var(--color-input-background);
    color: var(--color-input-text);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    border-style: solid;
    border-radius: var(--style-border-radius-inputs);
    padding: var(--padding-sm) var(--padding-md);
    height: 100%;
    flex-grow: 1;
    min-width: 0;
    font-size: var(--cart-font-size--sm);
  }

  .cart-discount__input::placeholder {
    color: rgb(var(--color-input-text-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__pill-code {
    overflow: hidden;
    max-width: 100px;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  .cart-discount {
    width: 100%;
  }

  .cart-discount .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .cart-discount__codes {
    display: none;
    gap: var(--padding-xs);
    flex-wrap: wrap;
    list-style: none;
    padding-inline: 0;
    margin: 0;
  }

  .cart-discount__codes:has(.cart-discount__pill) {
    display: flex;
  }

  .cart-discount__button {
    height: 100%;
  }

  .cart-discount__content {
    height: calc(var(--button-size) + var(--padding-2xs) + var(--padding-sm));
  }

  .cart-discount__pill {
    display: flex;
    color: var(--color-foreground);
    gap: var(--padding-xs);
    align-items: center;
    padding: var(--padding-xs) var(--padding-sm);
    border-radius: var(--style-border-radius-pills);
    background-color: var(--color-input-background);
    text-transform: uppercase;
  }

  .cart-discount__form {
    display: flex;
    gap: var(--padding-md);
    align-items: center;
    height: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  :is(.cart-discount__pill-remove, .cart-discount__pill-remove:hover) {
    --close-icon-opacity: 0.4;

    color: var(--color-foreground);
    background-color: transparent;
    pointer-events: all;
    cursor: pointer;
    height: 100%;
  }

  .cart-discount__error {
    display: flex;
    align-items: center;
    width: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-discount__error .svg-wrapper {
    flex-shrink: 0;
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
    margin-inline: var(--margin-3xs) var(--margin-xs);
  }

  .cart-discount__error-text {
    margin-block-start: var(--margin-3xs);
  }

  .disclosure-trigger {
    cursor: pointer;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 4px;
    padding-inline: 0;
    width: 100%;
    border: none;
    background: #0000;

    &[aria-expanded='true'] .horizontal {
      rotate: 90deg;
    }

    &:is(:hover, :focus-visible) {
      color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    }

    .horizontal {
      transform-box: fill-box;
      transform-origin: center;
    }

    svg {
      aspect-ratio: 1;
      width: var(--icon-size-xs);
      height: var(--icon-size-xs);
    }
  }

  .disclosure-trigger__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--cart-font-size--2xs);
    font-weight: 500;
  }

  @media (prefers-reduced-motion: no-preference) {
    .disclosure-trigger .horizontal {
      transition: rotate var(--surface-transition-duration) var(--surface-transition-timing);
    }
  }

  .disclosure-content {
    display: grid;
    grid-template-rows: 1fr;
    /* stylelint-disable-next-line plugin/no-unsupported-browser-features */
    clip-path: inset(-5% -5% 0 -5%);
    opacity: 1;

    &[inert] {
      grid-template-rows: 0fr;
      opacity: 0;
    }

    & > * {
      min-height: 0;
    }
  }

    @media (prefers-reduced-motion: no-preference) {
    .disclosure-content {
      transition-property: grid-template-rows, opacity;
      transition-duration: var(--surface-transition-duration);
      transition-timing-function: var(--surface-transition-timing);
    }
  }

  /* Cart Summary Details Colors */
  .cart-summary-detail-row {
    color: var(--color-foreground);
  }
  
  /* Force white text on Cart Page (Dark Background Context) */
  .cart-page .cart-summary-detail-row,
  .cart-page .cart-summary-detail-row span {
    color: #ffffff !important;
  }

  /* ============================
     CHECKOUT BUTTON — HIGH CONVERSION
     ============================ */
  .cart__ctas .cart__checkout-button {
    height: 52px !important;
    border-radius: 0 !important;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: #1D4739 !important;
    color: #fff !important;
    border: none !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    box-shadow: none !important;
    transition: background 0.25s ease !important;
    cursor: pointer;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 0 28px !important;
    width: 100% !important;
  }
  .cart__ctas .cart__checkout-button:hover {
    background: #163830 !important;
    box-shadow: none !important;
    transform: none;
  }
  .cart__ctas .cart__checkout-button:active {
    background: #0f2922 !important;
    transform: none;
    box-shadow: none !important;
  }

  /* ============================
     EXPRESS PAYMENTS — SMART DISPLAY (APPLE/GOOGLE PAY)
     ============================ */
  .cart__ctas .additional-checkout-buttons {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    flex-wrap: nowrap !important;
    width: 100%;
    margin-top: 8px !important;
  }

  /* Handle if Shopify injects buttons inside an unordered list */
  .cart__ctas .additional-checkout-buttons ul,
  .cart__ctas .additional-checkout-buttons .shopify-cleanslate > div {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 10px !important;
    flex-wrap: nowrap !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  /* Force all direct children and li elements to flex evenly */
  .cart__ctas .additional-checkout-buttons > *,
