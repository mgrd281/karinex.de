{%- comment -%}
  Critical CSS - Above-the-fold styles
  Inline in <head> for instant rendering
{%- endcomment -%}

<style>
  /* Critical CSS - Minimal styles for above-the-fold content */
  
  /* Reset & Base */
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Roboto',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;line-height:1.6;color:#333;background:#fff;-webkit-font-smoothing:antialiased}
  
  /* Skip to Content Link - Hidden by default, visible on focus only */
  .skip-to-content-link{position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999}
  .skip-to-content-link:focus{position:fixed;top:1rem;left:1rem;width:auto;height:auto;padding:1rem 2rem;background:#1D4739;color:#fff;text-decoration:none;border-radius:8px;font-weight:700;z-index:10001}
  
  /* Announcement Bar - Prevent FOUC */
  .announcement-message{visibility:hidden;opacity:0}
  .announcement-message.active{visibility:visible;opacity:1}
  .announcement-message:first-child{visibility:visible;opacity:1}
  
  /* Sales/SALE elements - Hidden initially, shown by JS */
  .sales-compact{visibility:hidden;opacity:0}
  .sales-compact.loaded{visibility:visible;opacity:1;transition:opacity 0.3s ease}
  
  /* Header – sticky, z-index aligned with theme --layer-menu-drawer scale */
  header{background:#fff;position:sticky;top:0;z-index:200;padding-top:env(safe-area-inset-top);box-shadow:0 2px 4px rgba(0,0,0,.1)}
  .header-wrapper{max-width:1400px;margin:0 auto;padding:1rem;display:flex;align-items:center;justify-content:space-between}
  
  /* Logo */
  .header-logo{max-width:180px;height:auto}
  
  /* Navigation */
  nav{display:flex;gap:2rem}
  nav a{text-decoration:none;color:#333;font-weight:500}
  
  /* Hero Section */
  .hero{min-height:400px;display:flex;align-items:center;justify-content:center;background:#f9f9f9}
  
  /* Container */
  .container{max-width:1200px;margin:0 auto;padding:0 1rem}
  
  /* Buttons */
  .btn{display:inline-block;padding:1rem 2rem;background:#1D4739;color:#fff;text-decoration:none;border-radius:8px;font-weight:700;border:none;cursor:pointer}
  
  /* Product Grid */
  .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:2rem;margin:2rem 0}
  
  /* Hide non-critical content initially */
  .below-fold{visibility:hidden}
  
  /* Loading state */
  .loading{opacity:0;transition:opacity .3s}
  .loaded{opacity:1}
  
  /* Performance: Below-fold content optimization */
  footer,#footer-group-wrapper{content-visibility:auto;contain-intrinsic-size:0 500px}
  .product-recommendations{content-visibility:auto;contain-intrinsic-size:0 400px}
</style>
