{%- doc -%}
  Karinex Cookie-Consent Banner — Thalia-style.

  Slides up from the bottom of the viewport on first visit, persists the
  customer's choice via Shopify's Customer Privacy API and a fallback
  localStorage key (`karinex_cookie_consent`). Hides Shopify's default
  consent banner via CSS so only this one is visible.

  States stored: 'accepted' | 'rejected'
{%- enddoc -%}

<style>
  /* Hide Shopify's default consent banner — we render our own */
  shopify-privacy-banner,
  .privacy-banner,
  #shopify-pc__banner {
    display: none !important;
  }

  /* Backdrop — only visible on desktop where the banner is a centered modal */
  .kx-cookie-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 25, 20, 0.4);
    z-index: 2147483639;
    opacity: 0;
    transition: opacity 280ms ease;
    pointer-events: none;
  }
  .kx-cookie-backdrop[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }
  @media (min-width: 768px) {
    .kx-cookie-backdrop { display: block; }
  }

  .kx-cookie {
    --kx-c-brand: #1B3A2E;
    --kx-c-brand-hover: #11261E;
    --kx-c-ink: #1d1d1f;
    --kx-c-ink-muted: #555;
    --kx-c-surface: #ffffff;
    --kx-c-line: #e5e5e5;
    --kx-c-grey: #f2f2f3;
    --kx-c-grey-hover: #e6e6e7;

    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 2147483640;
    background: var(--kx-c-surface);
    border-top: 1px solid var(--kx-c-line);
    box-shadow: 0 -8px 32px rgba(15, 25, 20, 0.12);
    padding: 0.9rem clamp(0.85rem, 4vw, 1.25rem) 0.85rem;
    max-height: 82vh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    transform: translateY(100%);
    opacity: 0;
    visibility: hidden;
    transition: transform 360ms cubic-bezier(0.16, 1, 0.3, 1),
                opacity 320ms ease,
                visibility 0s linear 360ms;
    font-family: inherit;
  }
  .kx-cookie[data-open="true"] {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    transition: transform 360ms cubic-bezier(0.16, 1, 0.3, 1),
                opacity 320ms ease,
                visibility 0s linear 0s;
  }

  /* Desktop: centered modal with rounded corners + backdrop */
  @media (min-width: 768px) {
    .kx-cookie {
      inset-inline: auto;
      bottom: auto;
      top: 50%;
      left: 50%;
      width: calc(100vw - 2rem);
      max-width: 640px;
      max-height: min(86vh, 720px);
      border: 1px solid rgba(15, 25, 20, 0.04);
      border-top: 1px solid rgba(15, 25, 20, 0.04);
      border-radius: 18px;
      padding: 2rem 2.25rem 1.75rem;
      box-shadow: 0 24px 80px rgba(15, 25, 20, 0.24),
                  0 4px 12px rgba(15, 25, 20, 0.08);
      transform: translate(-50%, -50%) scale(0.96);
      transform-origin: center;
    }
    .kx-cookie[data-open="true"] {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kx-cookie { transition: opacity 200ms ease; transform: none; }
    .kx-cookie[data-open="true"] { transform: none; }
    @media (min-width: 768px) {
      .kx-cookie {
        transform: translate(-50%, -50%);
      }
      .kx-cookie[data-open="true"] {
        transform: translate(-50%, -50%);
      }
    }
  }

  .kx-cookie__inner {
    max-width: 720px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  @media (min-width: 768px) {
    .kx-cookie__inner { gap: 0.85rem; }
    .kx-cookie__logo { font-size: 22px; margin-bottom: 0.25rem; }
    .kx-cookie__title { font-size: 17px; }
    .kx-cookie__text { font-size: 13.5px; line-height: 1.5; }
    .kx-cookie__more { font-size: 13px; }
    .kx-cookie__links { font-size: 13px; }
    .kx-cookie__settings-link { font-size: 13px; }
    .kx-cookie__btn { min-height: 44px; font-size: 14px; padding: 0.6rem 1.5rem; }
  }

  .kx-cookie__logo {
    display: inline-flex;
    align-items: center;
    font-family: inherit;
    font-size: 17px;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--kx-c-ink);
    line-height: 1;
    margin-bottom: 0.05rem;
  }

  .kx-cookie__title {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: var(--kx-c-ink);
    letter-spacing: -0.005em;
    line-height: 1.25;
  }

  .kx-cookie__text {
    margin: 0;
    font-size: 12px;
    line-height: 1.45;
    color: var(--kx-c-ink-muted);
  }
  .kx-cookie__text + .kx-cookie__text { margin-top: -0.05rem; }

  .kx-cookie__more {
    background: transparent;
    border: 0;
    padding: 0;
    margin: -0.15rem 0 0;
    color: var(--kx-c-ink);
    font-family: inherit;
    font-size: 12.5px;
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    text-align: left;
    align-self: flex-start;
  }
  .kx-cookie__more:hover { color: var(--kx-c-brand); }

  .kx-cookie__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
    font-size: 12px;
  }
  .kx-cookie__links a {
    color: var(--kx-c-ink-muted);
    text-decoration: none;
    transition: color 180ms ease;
  }
  .kx-cookie__links a:hover { color: var(--kx-c-brand); text-decoration: underline; text-underline-offset: 3px; }

  .kx-cookie__settings-link {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--kx-c-ink-muted);
    font-family: inherit;
    font-size: 12px;
    cursor: pointer;
    text-align: left;
    align-self: flex-start;
    text-decoration: none;
  }
  .kx-cookie__settings-link:hover { color: var(--kx-c-brand); }

  .kx-cookie__actions {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.1rem;
  }
  @media (min-width: 768px) {
    .kx-cookie__actions {
      flex-direction: row;
      justify-content: flex-end;
      gap: 0.6rem;
      margin-top: 0.5rem;
    }
    .kx-cookie__btn {
      width: auto;
      min-width: 200px;
      flex: 0 1 auto;
    }
  }
  .kx-cookie__btn {
    appearance: none;
    border: 0;
    width: 100%;
    min-height: 38px;
    padding: 0.45rem 1.25rem;
    border-radius: 999px;
    font-family: inherit;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.005em;
    cursor: pointer;
    transition: background-color 180ms ease, transform 180ms ease;
  }
  .kx-cookie__btn--primary {
    background: var(--kx-c-brand);
    color: #fff;
  }
  .kx-cookie__btn--primary:hover,
  .kx-cookie__btn--primary:focus-visible {
    background: var(--kx-c-brand-hover);
    outline: none;
  }
  .kx-cookie__btn--secondary {
    background: var(--kx-c-grey);
    color: var(--kx-c-ink);
  }
  .kx-cookie__btn--secondary:hover,
  .kx-cookie__btn--secondary:focus-visible {
    background: var(--kx-c-grey-hover);
    outline: none;
  }

  .kx-cookie__powered {
    text-align: center;
    font-size: 10.5px;
    color: #999;
    letter-spacing: 0.02em;
    margin: 0.3rem 0 0;
  }

  /* Additional text revealed via "Mehr lesen…" */
  .kx-cookie__more-text {
    display: none;
  }
  .kx-cookie[data-expanded="true"] .kx-cookie__more-text {
    display: block;
  }
</style>

<div class="kx-cookie-backdrop" id="kxCookieBackdrop" aria-hidden="true"></div>
<aside class="kx-cookie" id="kxCookieBanner" role="dialog" aria-modal="false" aria-labelledby="kxCookieTitle" aria-describedby="kxCookieDesc">
  <div class="kx-cookie__inner">
    <span class="kx-cookie__logo" aria-label="Karinex">KARINEX</span>
    <h3 class="kx-cookie__title" id="kxCookieTitle">Helfen Sie uns, Ihr Karinex Erlebnis zu verbessern!</h3>
    <p class="kx-cookie__text" id="kxCookieDesc">
      Wir möchten Ihr Shopping-Erlebnis einzigartig und persönlich machen. Dafür verwenden wir und unsere Partner (auch Dritte) Cookies, Pixel und ähnliche Dienste („Services“), die Informationen und Daten speichern und/oder von Ihrem Endgerät abrufen.
    </p>
    <p class="kx-cookie__text">
      Diese Informationen und Daten werden von uns z.B. zur Identifikation auf Drittseiten, zur Personalisierung, Marktforschung, Analyse und zur Produktentwicklung genutzt und können auch im EU-Ausland (Drittstaaten) verarbeitet werden.
    </p>
    <div class="kx-cookie__more-text">
      <p class="kx-cookie__text">
        Eine Auflistung aller eingesetzten Services finden Sie unter „Einstellungen“. Dort können Sie Ihre Auswahl jederzeit anpassen oder Ihre Zustimmung widerrufen. Bitte beachten Sie, dass die Bereitstellung der Services dazu führt, dass Daten in Drittstaaten verarbeitet werden, in denen kein vergleichbares Datenschutzniveau wie in der EU gilt.
      </p>
    </div>
    <button type="button" class="kx-cookie__more" id="kxCookieMore" aria-expanded="false" aria-controls="kxCookieMoreText">Mehr lesen…</button>
    <div class="kx-cookie__links">
      <a href="{{ routes.root_url }}policies/privacy-policy">Datenschutzerklärung</a>
      <a href="{{ routes.root_url }}pages/impressum">Impressum</a>
    </div>
    <button type="button" class="kx-cookie__settings-link" data-kx-cookie-action="settings">Einstellungen / Mehr Informationen</button>
    <div class="kx-cookie__actions">
      <button type="button" class="kx-cookie__btn kx-cookie__btn--primary" data-kx-cookie-action="accept">Alles akzeptieren</button>
      <button type="button" class="kx-cookie__btn kx-cookie__btn--secondary" data-kx-cookie-action="reject">Nur technisch Erforderliches akzeptieren</button>
    </div>
    <p class="kx-cookie__powered">Powered by Karinex Consent Management</p>
  </div>
</aside>

<script>
  (function () {
    var STORAGE_KEY = 'karinex_cookie_consent';
    var banner = document.getElementById('kxCookieBanner');
    var backdrop = document.getElementById('kxCookieBackdrop');
    if (!banner) return;

    function alreadyAnswered() {
      try { return !!localStorage.getItem(STORAGE_KEY); } catch (e) { return false; }
    }
    function save(value) {
      try { localStorage.setItem(STORAGE_KEY, value); } catch (e) {}
    }
    function notifyShopify(value) {
      var consented = value === 'accepted';
      try {
        if (window.Shopify && window.Shopify.customerPrivacy && typeof window.Shopify.customerPrivacy.setTrackingConsent === 'function') {
          window.Shopify.customerPrivacy.setTrackingConsent({
            analytics: consented,
            marketing: consented,
            preferences: consented,
            sale_of_data: consented
          }, function () {});
        }
      } catch (e) {}
    }
    function hide() {
      banner.setAttribute('data-open', 'false');
      banner.dataset.open = 'false';
      if (backdrop) backdrop.setAttribute('data-open', 'false');
      setTimeout(function () {
        banner.style.display = 'none';
        if (backdrop) backdrop.style.display = 'none';
      }, 400);
    }
    function show() {
      banner.style.display = '';
      if (backdrop) backdrop.style.display = '';
      requestAnimationFrame(function () {
        banner.setAttribute('data-open', 'true');
        if (backdrop) backdrop.setAttribute('data-open', 'true');
      });
    }

    if (!alreadyAnswered()) {
      setTimeout(show, 600);
    }

    banner.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-kx-cookie-action]');
      if (!btn) return;
      var action = btn.getAttribute('data-kx-cookie-action');
      if (action === 'accept') {
        save('accepted');
        notifyShopify('accepted');
        hide();
      } else if (action === 'reject') {
        save('rejected');
        notifyShopify('rejected');
        hide();
      } else if (action === 'settings') {
        window.location.href = '{{ routes.root_url }}pages/cookie-einstellungen';
      }
    });

    var moreBtn = document.getElementById('kxCookieMore');
    if (moreBtn) {
      moreBtn.addEventListener('click', function () {
        var expanded = banner.getAttribute('data-expanded') === 'true';
        banner.setAttribute('data-expanded', expanded ? 'false' : 'true');
        moreBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        moreBtn.textContent = expanded ? 'Mehr lesen…' : 'Weniger anzeigen';
      });
    }

    // Public hook: window.kxCookieBanner.show() to re-open later (e.g. from footer link)
    window.kxCookieBanner = { show: function () { try { localStorage.removeItem(STORAGE_KEY); } catch(e) {} show(); }, hide: hide };
  })();
</script>
