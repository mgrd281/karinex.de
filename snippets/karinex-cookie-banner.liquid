        </span>
        <span class="kx-cset__sidebar-btn-label">Analyse</span>
        <span class="kx-cset__sidebar-btn-badge">2</span>
      </button>
      <button type="button" class="kx-cset__sidebar-btn" data-cset-tab="other">
        <span class="kx-cset__sidebar-btn-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2"/></svg>
        </span>
        <span class="kx-cset__sidebar-btn-label">Andere Services</span>
        <span class="kx-cset__sidebar-btn-badge">4</span>
