<div class="kx-cookie-backdrop" id="kxCookieBackdrop" aria-hidden="true"></div>
<aside class="kx-cookie" id="kxCookieBanner" role="dialog" aria-modal="false" aria-labelledby="kxCookieTitle" aria-describedby="kxCookieDesc">
  <div class="kx-cookie__inner">
    <span class="kx-cookie__logo kx-cookie__logo--img" aria-label="{{ shop.name | escape | default: 'Karinex' }}">
      <img src="https://cdn.shopify.com/s/files/1/0917/5328/3851/files/karinex-software-store-logo..jpg?v=1778520099" alt="{{ shop.name | escape | default: 'Karinex' }}" loading="lazy" width="320" height="64">
    </span>
    <h3 class="kx-cookie__title" id="kxCookieTitle">Helfen Sie uns, Ihr Karinex Erlebnis zu verbessern!</h3>
    <p class="kx-cookie__text" id="kxCookieDesc">
      Wir möchten Ihr Shopping-Erlebnis einzigartig und persönlich machen. Dafür verwenden wir und unsere Partner (auch Dritte) Cookies, Pixel und ähnliche Dienste („Services“), die Informationen und Daten speichern und/oder von Ihrem Endgerät abrufen.
    </p>
    <p class="kx-cookie__text">
      Diese Informationen und Daten werden von uns z.B. zur Identifikation auf Drittseiten, zur Personalisierung, Marktforschung, Analyse und zur Produktentwicklung genutzt und können auch im EU-Ausland (Drittstaaten) verarbeitet werden.
    </p>
    <div class="kx-cookie__more-text">
      <p class="kx-cookie__text">
        Eine Auflistung aller eingesetzten Services finden Sie unter „Einstellungen“. Dort können Sie Ihre Auswahl jederzeit anpassen oder Ihre Zustimmung widerrufen. Bitte beachten Sie, dass die Bereitstellung der Services dazu führt, dass Daten in Drittstaaten verarbeitet werden, in denen kein vergleichbares Datenschutzniveau wie in der EU gilt.
      </p>
    </div>
    <button type="button" class="kx-cookie__more" id="kxCookieMore" aria-expanded="false" aria-controls="kxCookieMoreText">Mehr lesen…</button>
    <div class="kx-cookie__links">
      <a href="{{ routes.root_url }}policies/privacy-policy">Datenschutzerklärung</a>
      <a href="{{ routes.root_url }}pages/impressum">Impressum</a>
    </div>
    <button type="button" class="kx-cookie__settings-link" data-kx-cookie-action="settings">Einstellungen / Mehr Informationen</button>
    <div class="kx-cookie__actions">
      <button type="button" class="kx-cookie__btn kx-cookie__btn--primary" data-kx-cookie-action="accept">Alles akzeptieren</button>
      <button type="button" class="kx-cookie__btn kx-cookie__btn--secondary" data-kx-cookie-action="reject">Nur technisch Erforderliches akzeptieren</button>
    </div>
    <p class="kx-cookie__powered">Powered by Karinex Consent Management</p>
  </div>
</aside>

<script>
  (function () {
    var STORAGE_KEY = 'karinex_cookie_consent';
    var banner = document.getElementById('kxCookieBanner');
    var backdrop = document.getElementById('kxCookieBackdrop');
    if (!banner) return;

    function alreadyAnswered() {
      try { return !!localStorage.getItem(STORAGE_KEY); } catch (e) { return false; }
    }
    function save(value) {
      try { localStorage.setItem(STORAGE_KEY, value); } catch (e) {}
    }
    function notifyShopify(value) {
      var consented = value === 'accepted';
      try {
        if (window.Shopify && window.Shopify.customerPrivacy && typeof window.Shopify.customerPrivacy.setTrackingConsent === 'function') {
          window.Shopify.customerPrivacy.setTrackingConsent({
            analytics: consented,
            marketing: consented,
            preferences: consented,
            sale_of_data: consented
          }, function () {});
        }
      } catch (e) {}
    }
    function hide() {
      banner.setAttribute('data-open', 'false');
      banner.dataset.open = 'false';
      if (backdrop) backdrop.setAttribute('data-open', 'false');
      setTimeout(function () {
        banner.style.display = 'none';
        if (backdrop) backdrop.style.display = 'none';
      }, 400);
    }
    function show() {
      banner.style.display = '';
      if (backdrop) backdrop.style.display = '';
      requestAnimationFrame(function () {
        banner.setAttribute('data-open', 'true');
        if (backdrop) backdrop.setAttribute('data-open', 'true');
      });
    }

    if (!alreadyAnswered()) {
      setTimeout(show, 600);
    }

    banner.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-kx-cookie-action]');
      if (!btn) return;
      var action = btn.getAttribute('data-kx-cookie-action');
      if (action === 'accept') {
        save('accepted');
        notifyShopify('accepted');
        hide();
      } else if (action === 'reject') {
        save('rejected');
        notifyShopify('rejected');
        hide();
      } else if (action === 'settings') {
        openSettings();
      }
    });

    // === Erweiterte Einstellungen modal ==============================
    var cset = document.getElementById('kxCookieSettingsModal');
    var SETTINGS_KEY = 'karinex_cookie_settings';

    function readSettings() {
      try {
        var raw = localStorage.getItem(SETTINGS_KEY);
        return raw ? JSON.parse(raw) : {};
      } catch (e) { return {}; }
    }
    function writeSettings(obj) {
      try { localStorage.setItem(SETTINGS_KEY, JSON.stringify(obj)); } catch (e) {}
    }
    function applySettingsToUI() {
      if (!cset) return;
      var settings = readSettings();
      cset.querySelectorAll('[data-cset-toggle]').forEach(function (sw) {
        var key = sw.getAttribute('data-cset-toggle');
        var on = !!getValue(settings, key);
        sw.setAttribute('aria-checked', on ? 'true' : 'false');
      });
      cset.querySelectorAll('[data-cset-master]').forEach(function (sw) {
        var group = sw.getAttribute('data-cset-master');
        var allOn = true;
        cset.querySelectorAll('[data-cset-toggle^="' + group + '."]').forEach(function (child) {
          if (child.getAttribute('aria-checked') !== 'true') allOn = false;
        });
        sw.setAttribute('aria-checked', allOn ? 'true' : 'false');
      });
    }
    function getValue(obj, dotted) {
      var parts = dotted.split('.');
      var cur = obj;
      for (var i = 0; i < parts.length; i++) { cur = cur ? cur[parts[i]] : undefined; }
      return cur;
    }
    function setValue(obj, dotted, val) {
      var parts = dotted.split('.');
      var cur = obj;
      for (var i = 0; i < parts.length - 1; i++) {
        cur[parts[i]] = cur[parts[i]] || {};
        cur = cur[parts[i]];
      }
      cur[parts[parts.length - 1]] = val;
    }

    function openSettings() {
      if (!cset) return;
      applySettingsToUI();
      cset.setAttribute('data-open', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeSettings() {
      if (!cset) return;
      cset.setAttribute('data-open', 'false');
      document.body.style.overflow = '';
    }

    if (cset) {
      cset.addEventListener('click', function (e) {
        if (e.target === cset) closeSettings();
        var closeBtn = e.target.closest('[data-cset-close]');
        if (closeBtn) closeSettings();

        var tabBtn = e.target.closest('[data-cset-tab]');
        if (tabBtn) {
          var tab = tabBtn.getAttribute('data-cset-tab');
          cset.querySelectorAll('[data-cset-tab]').forEach(function (b) {
            b.setAttribute('data-active', b === tabBtn ? 'true' : 'false');
          });
          cset.querySelectorAll('[data-cset-panel]').forEach(function (p) {
            p.setAttribute('data-active', p.getAttribute('data-cset-panel') === tab ? 'true' : 'false');
          });
        }

        var toggle = e.target.closest('[data-cset-toggle]');
        if (toggle && !toggle.hasAttribute('disabled')) {
          var on = toggle.getAttribute('aria-checked') !== 'true';
          toggle.setAttribute('aria-checked', on ? 'true' : 'false');
          // Re-sync master switches
          var key = toggle.getAttribute('data-cset-toggle');
          var group = key.split('.')[0];
          var master = cset.querySelector('[data-cset-master="' + group + '"]');
          if (master) {
            var allOn = true;
            cset.querySelectorAll('[data-cset-toggle^="' + group + '."]').forEach(function (child) {
              if (child.getAttribute('aria-checked') !== 'true') allOn = false;
            });
            master.setAttribute('aria-checked', allOn ? 'true' : 'false');
          }
        }

        var masterBtn = e.target.closest('[data-cset-master]');
        if (masterBtn && !masterBtn.hasAttribute('disabled') && !e.target.closest('[data-cset-toggle]')) {
          var grp = masterBtn.getAttribute('data-cset-master');
          var newState = masterBtn.getAttribute('aria-checked') !== 'true';
          masterBtn.setAttribute('aria-checked', newState ? 'true' : 'false');
          cset.querySelectorAll('[data-cset-toggle^="' + grp + '."]').forEach(function (child) {
            child.setAttribute('aria-checked', newState ? 'true' : 'false');
          });
        }
      });

      var saveBtn = document.getElementById('kxCsetSave');
      if (saveBtn) {
        saveBtn.addEventListener('click', function () {
          var settings = {};
          cset.querySelectorAll('[data-cset-toggle]').forEach(function (sw) {
            setValue(settings, sw.getAttribute('data-cset-toggle'), sw.getAttribute('aria-checked') === 'true');
          });
          writeSettings(settings);

          // Map categories to Shopify Customer Privacy flags
          var anyMarketing = (settings.marketing && Object.values(settings.marketing).some(Boolean)) || false;
          var anyAnalytics = (settings.analytics && Object.values(settings.analytics).some(Boolean)) || false;
          var anyOther = (settings.other && Object.values(settings.other).some(Boolean)) || false;

          save(anyMarketing || anyAnalytics || anyOther ? 'accepted' : 'rejected');
          try {
            if (window.Shopify && window.Shopify.customerPrivacy && window.Shopify.customerPrivacy.setTrackingConsent) {
              window.Shopify.customerPrivacy.setTrackingConsent({
                analytics: anyAnalytics,
                marketing: anyMarketing,
                preferences: anyOther,
                sale_of_data: anyMarketing
              }, function () {});
            }
          } catch (e) {}

          closeSettings();
          hide();
        });
      }
    }

    var moreBtn = document.getElementById('kxCookieMore');
    if (moreBtn) {
      moreBtn.addEventListener('click', function () {
        var expanded = banner.getAttribute('data-expanded') === 'true';
        banner.setAttribute('data-expanded', expanded ? 'false' : 'true');
        moreBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        moreBtn.textContent = expanded ? 'Mehr lesen…' : 'Weniger anzeigen';
      });
    }

    // Public hook: window.kxCookieBanner.show() to re-open later (e.g. from footer link)
    window.kxCookieBanner = {
      show: function () { try { localStorage.removeItem(STORAGE_KEY); } catch(e) {} show(); },
      hide: hide,
      openSettings: openSettings,
      closeSettings: closeSettings
    };
  })();
</script>
