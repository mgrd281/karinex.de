{%- comment -%}
  snippets/shipping-countdown.liquid
  Kaufland-style shipping countdown for physical products.
  Variables expected from caller:
    is_digital  — boolean (set by product-information.liquid)
    product     — Shopify product object
{%- endcomment -%}

{%- comment -%} Only render for physical, in-stock products {%- endcomment -%}
{%- assign _sc_eligible = true -%}
{%- if is_digital -%}
  {%- assign _sc_eligible = false -%}
{%- endif -%}
{%- unless product.available -%}
  {%- assign _sc_eligible = false -%}
{%- endunless -%}
{%- if product.requires_shipping == false -%}
  {%- assign _sc_eligible = false -%}
{%- endif -%}

{%- comment -%} Check inventory for pre-orders (selling when out of stock) {%- endcomment -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'continue' and current_variant.inventory_quantity <= 0 -%}
  {%- assign _sc_eligible = false -%}
{%- endif -%}

{%- comment -%} Check variant shipping date (versand_datum) {%- endcomment -%}
{%- assign ship_date_raw = current_variant.metafields.custom.versand_datum
  | default: current_variant.metafields.custom.versanddatum
  | default: current_variant.metafields.custom.datum_und_uhrzeit_versand
  | default: current_variant.metafields.custom.shipping_date
-%}
{%- if ship_date_raw != blank -%}
  {%- assign ship_date_ts = ship_date_raw | date: "%s" | times: 1 -%}
  {%- assign today_midnight_ts = "now" | date: "%Y-%m-%d" | date: "%s" | times: 1 -%}
  {%- if ship_date_ts >= today_midnight_ts -%}
    {%- assign _sc_eligible = false -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} Check custom delivery time metafields {%- endcomment -%}
{%- assign lieferzeit = product.metafields.custom.lieferzeit | downcase | default: '' -%}
{%- assign liefer_type = product.metafields.custom.delivery_type | downcase | default: '' -%}
{%- assign tags_str = product.tags | join: ' ' | downcase -%}
{%- assign combined_liefer_info = lieferzeit | append: ' ' | append: liefer_type | append: ' ' | append: tags_str -%}

{%- if combined_liefer_info != blank -%}
  {%- if combined_liefer_info contains 'vorbestell' or combined_liefer_info contains 'preorder' or combined_liefer_info contains 'pre-order' -%}
    {%- assign _sc_eligible = false -%}
  {%- endif -%}
  {%- if combined_liefer_info contains '3 tage' or combined_liefer_info contains '4 tage' or combined_liefer_info contains '5 tage' or combined_liefer_info contains 'wochen' or combined_liefer_info contains 'monat' -%}
    {%- assign _sc_eligible = false -%}
  {%- endif -%}
  {%- if combined_liefer_info contains 'werktagen' -%}
    {%- unless combined_liefer_info contains '1-2' or combined_liefer_info contains '1-3' -%}
      {%- assign _sc_eligible = false -%}
    {%- endunless -%}
  {%- endif -%}
{%- endif -%}

<link rel="preload" href="{{ 'shipping-countdown.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'shipping-countdown.css' | asset_url }}"></noscript>

<div
  class="kx-ship-cd"
  data-shipping-cutoff="14:30"
  data-shipping-eligible="{{ _sc_eligible }}"
  data-shipping-tz="Europe/Berlin"
  aria-live="polite"
  aria-atomic="false"
>
  {%- if _sc_eligible -%}
