    </span>
    <span class="kx-ship-cd__body">
      <span class="kx-ship-cd__main">
        Versand-Info wird geladen&hellip;
      </span>
      <span class="kx-ship-cd__sub">
        Versand aus Deutschland &middot; Kostenlose Retoure
      </span>
    </span>
  {%- else -%}
