<!-- Block C: Variants, Price, Drawer Scripts -->
<script>
  (function(){
    /* === Drawer === */
    const drawer = document.getElementById('returnPolicyDrawer');
    if(drawer){
      const panel = drawer.querySelector('.krx-drawer__panel');
      const backdrop = drawer.querySelector('.krx-drawer__backdrop');
      const openers = document.querySelectorAll('.open-return-drawer');
      const closeSel = '[data-close-drawer]';
      const closeEls = drawer.querySelectorAll(closeSel);
      let lastFocused = null;
      function openDrawer(e){ if(e) e.preventDefault(); lastFocused=document.activeElement; drawer.hidden=false; requestAnimationFrame(()=>drawer.classList.add('is-open')); panel&&panel.focus(); openers.forEach(o=>o.setAttribute('aria-expanded','true')); document.addEventListener('keydown', onKeydown); }
      function closeDrawer(){ drawer.classList.remove('is-open'); setTimeout(()=>{ drawer.hidden=true; },220); openers.forEach(o=>o.setAttribute('aria-expanded','false')); if(lastFocused){ try{ lastFocused.focus(); }catch(e){} } document.removeEventListener('keydown', onKeydown); }
      function onKeydown(ev){
        if(ev.key==='Escape') closeDrawer();
        if(ev.key==='Tab'){
          const focusables = drawer.querySelectorAll('a,button,input,select,textarea,[tabindex]:not([tabindex="-1"])');
          if(!focusables.length) return;
          const first = focusables[0], last = focusables[focusables.length-1];
          if(ev.shiftKey && document.activeElement===first){ ev.preventDefault(); last.focus(); }
          else if(!ev.shiftKey && document.activeElement===last){ ev.preventDefault(); first.focus(); }
        }
      }
      openers.forEach(btn=>btn.addEventListener('click', openDrawer));
      closeEls.forEach(el=>el.addEventListener('click', closeDrawer));
      drawer.addEventListener('click', e=>{ if(e.target===backdrop) return closeDrawer(); if(e.target.closest && e.target.closest(closeSel)) return closeDrawer(); });
    }
    /* === Varianten === */
    const hasVariants = {{ product.variants.size | json }} > 1;
    const variantPickers = document.querySelectorAll('[id^="variantPicker-"]');
    const legendValues = document.querySelectorAll('.variantLegendValue');
    const eanEl = document.getElementById('eanValue');
    const availEl = document.getElementById('availabilityValue');
    const shipEl = document.getElementById('shippingDateValue');
    const variants   = {{ product.variants | json }};
    const selectedId = {{ product.selected_or_first_available_variant.id }};
    const isDigital  = {{ is_digital | json }};
    
    // Track selected options for each dimension
    let currentOptions = {{ product.selected_or_first_available_variant.options | json }} || [];
    const allFilterOptions = [
      {%- for option in product.options_with_values -%}
        {%- assign name = option.name | downcase -%}
        {%- if name == 'farbe' or name == 'color' or name == 'modell' or name == 'model' or name == 'stil' or name == 'style' or name == 'größe' or name == 'size' -%}
          {%- for value in option.values -%}"{{ value | downcase }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{% unless forloop.last %},{% endunless %}
        {%- endif -%}
      {%- endfor -%}
    ];

    const shippingByVariantId = {
      {%- for v in product.variants -%}
      "{{ v.id }}": "{{ v.metafields.custom.versand_datum
        | default: v.metafields.custom.versanddatum
        | default: v.metafields.custom.datum_und_uhrzeit_versand
        | default: v.metafields.custom.shipping_date
      }}"{% if forloop.last == false %},{% endif %}
      {%- endfor -%}
    };
    
    const variantFeaturedMedia = {
      {%- for v in product.variants -%}
        "{{ v.id }}": {{ v.featured_media.id | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    };

    const variantTitleOverrides = {
      {%- for v in product.variants -%}
        "{{ v.id }}": {
          "full_title": {{ v.metafields.custom.display_title | json }},
          "sku": {{ v.sku | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    };
    const moneyFormat = (function(){
      const cartMoneyFormat = "{{ cart.currency.money_format | escape }}";
      if (window.Shopify && typeof Shopify.formatMoney === 'function') {
        return function(cents){ return Shopify.formatMoney(cents, cartMoneyFormat); };
      }
      const currencySymbol = "{{ cart.currency.symbol | escape }}";
      return function(cents){
        try { return (Number(cents)/100).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + currencySymbol; }
        catch(e){ return (Number(cents)/100).toFixed(2) + currencySymbol; }
      };
    })();
    function renderPriceForVariant(variant){
      const el = document.querySelector('.kvp-pro__price[data-variant-id="'+ variant.id +'"]');
      if(!el) return;
      const price = Number(variant.price);
      const cap   = Number(variant.compare_at_price || 0);
      if (cap && cap > price){ el.innerHTML = '<span>'+ moneyFormat(price) +'</span> <del>'+ moneyFormat(cap) +'</del>'; }
      else { el.textContent = moneyFormat(price); }
    }
    if (hasVariants) { (variants || []).forEach(renderPriceForVariant); }
    function formatDateDE(iso){
      if(!iso) return '';
      const d = new Date(iso);
      if(isNaN(d)) return '';
      const monthsDE = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
      return d.getDate() + '. ' + monthsDE[d.getMonth()];
    }
    function updateUI(variant){
      if(!variant) return;
      currentOptions = [...variant.options];
      variantPickers.forEach(picker => {
        const optionIndex = parseInt(picker.getAttribute('id').split('-')[1]);
        picker.querySelectorAll('.kvp-pro__card').forEach(card => {
          const isActive = card.getAttribute('data-option-value') === variant.options[optionIndex];
          card.classList.toggle('is-active', isActive);
          const input = card.querySelector('input[type="radio"]');
          if(input) input.checked = isActive;
        });
      });
      legendValues.forEach(legend => {
        const optionIndex = parseInt(legend.getAttribute('data-option-index'));
        legend.textContent = variant.options[optionIndex] || '';
      });
      if(eanEl) eanEl.textContent = variant.barcode || '—';
      const shipRaw = shippingByVariantId[String(variant.id)];
      const shipTxt = (shipRaw && shipRaw.indexOf('T') !== -1) ? formatDateDE(shipRaw) : formatDateDE(shipRaw);
      if(shipEl && shipRaw){ shipEl.textContent = shipTxt; }
      if(availEl){
        const isFutureDate = (function(){
          if(!shipRaw) return false;
          const shipDate = new Date(shipRaw);
          if(isNaN(shipDate)) return false;
          const today = new Date();
          today.setHours(0,0,0,0);
          return shipDate >= today;
        })();
        const isPreorder = (function(){
          if(!shipRaw) return false;
          const shipDate = new Date(shipRaw);
          if(isNaN(shipDate)) return false;
          const today = new Date();
          today.setHours(0,0,0,0);
          const diffDays = Math.floor((shipDate - today) / 86400000);
          return diffDays > 15;
        })();
        if(isDigital){
          availEl.innerHTML = '<span class="in-stock">Versand per E-Mail sofort nach Zahlung</span>';
        }else if(!variant.available){
          availEl.innerHTML = '<span class="out-of-stock">Zurzeit nicht verfügbar</span>';
        }else if(isFutureDate && shipRaw){
          const preorderPrefix = isPreorder ? '<span style="font-weight:700;">Vorbestellung</span> ' : '';
          availEl.innerHTML = '<span class="status-delayed" id="shipping-date-display">' + preorderPrefix + 'Versand am ' + shipTxt + '</span>';
        }else{
          availEl.innerHTML = '<span class="in-stock" id="delivery-status-text">in 1–3 Werktagen bei dir</span>';
        }
      }
      if(window.history && window.history.replaceState){
        const url = new URL(window.location.href);
        url.searchParams.delete('variant');
        window.history.replaceState({}, '', url.toString());
      }
      const select = document.querySelector('form [name="id"]');
      if(select){
        const opt = select.querySelector('option[value="'+variant.id+'"]');
        if(opt){ select.value = String(variant.id); select.dispatchEvent(new Event('change', {bubbles:true})); }
      }
      const buyContainer = document.getElementById('buyButtonsContainer');
      const bisForm = document.getElementById('backInStockForm');
      if (buyContainer && bisForm) {
        if (variant.available) { buyContainer.style.display = 'block'; bisForm.style.display = 'none'; }
        else { buyContainer.style.display = 'none'; bisForm.style.display = 'block'; }
      }
      document.dispatchEvent(new CustomEvent('variant:change', { detail:{ variant } }));
      const mainTitleEl = document.querySelector('.product-title');
      if (mainTitleEl && variant) {
        const overrides = variantTitleOverrides[String(variant.id)];
        let newTitle = {{ product.title | json }};
        if (overrides && overrides.full_title) { newTitle = overrides.full_title; } 
        else {
          const currentSku = variant.sku;
          if (currentSku) {
            variants.forEach(v => {
              if (v.sku && v.sku.length > 3 && newTitle.includes(v.sku)) { newTitle = newTitle.replace(v.sku, currentSku); }
            });
          }
          // Skip appending variant title if it contains gender/age descriptors
          const genderAgePattern = /(Männlich|Weiblich|Erwachsene|Kinder|Kind|Jungen|Mädchen)/i;
          if (variant.title && variant.title !== "Default Title" && !genderAgePattern.test(variant.title)) { 
            newTitle += " - " + variant.title; 
          }
        }
        mainTitleEl.textContent = newTitle;
      }
      const selectedFilterValues = (variant.options || []).map(opt => opt.toLowerCase());
      let firstVisibleIndex = -1;
      const thumbs = document.querySelectorAll('.thumb-item');
      thumbs.forEach(thumb => {
        const alt = (thumb.getAttribute('data-variant-alt') || '').toLowerCase();
        let shouldShow = true;
        const mentionedFilterValue = allFilterOptions.find(val => alt.includes(val));
        if (mentionedFilterValue) {
          const isCurrentMatch = selectedFilterValues.some(val => alt.includes(val));
          if (!isCurrentMatch) shouldShow = false;
        }
        thumb.style.display = shouldShow ? 'block' : 'none';
        if (shouldShow && firstVisibleIndex === -1) firstVisibleIndex = parseInt(thumb.getAttribute('data-index'));
      });
      if (variant && window.updateMainImage) {
        const mediaId = variantFeaturedMedia[String(variant.id)];
        if (mediaId) {
          const thumb = document.querySelector(`.thumb-item[data-media-id="${mediaId}"]`);
          if (thumb) window.updateMainImage(parseInt(thumb.getAttribute('data-index')));
          else if (firstVisibleIndex !== -1) window.updateMainImage(firstVisibleIndex);
        } else if (firstVisibleIndex !== -1) window.updateMainImage(firstVisibleIndex);
      }
    }
    function updateForms(variantId){
      document.querySelectorAll('#add-to-cart-form input[name="id"], #buy-now-form input[name="id"]').forEach(el => el.value = String(variantId));
    }
    function renderMainPrice(variant){
      var priceBox = document.querySelector('.price-container');
      if(!priceBox || !variant) return;
      var curEl  = priceBox.querySelector('.current-price');
      var oldEl  = priceBox.querySelector('.old-price');
      var subRow = priceBox.querySelector('.price-sub-row');
      var saveFullTextEl = priceBox.querySelector('.savings-text');
      var pillEl = priceBox.querySelector('.discount-pill-simple');
      var saleBadge = priceBox.querySelector('.sale-badge');
      var hasStaticBadge = saleBadge && saleBadge.getAttribute('data-static-badge') === 'true';
      var price = Number(variant.price);
      var cap   = Number(variant.compare_at_price || 0);
      if(curEl) curEl.textContent = moneyFormat(price);
      if(cap && cap > price){
        if(subRow) subRow.style.display = 'flex';
        if(oldEl) oldEl.textContent = moneyFormat(cap);
        var save = cap - price;
        if(saveFullTextEl) saveFullTextEl.textContent = 'Preisvorteil: ' + moneyFormat(save);
        if(pillEl){
          var pct = Math.round(((cap - price) / cap) * 100);
          pillEl.textContent = '-' + pct + '%';
          pillEl.style.display = 'inline-block';
        }
        if(saleBadge) saleBadge.style.display = 'inline-flex';
      } else {
        if(subRow) subRow.style.display = 'none';
        if(pillEl) pillEl.style.display = 'none';
        if(saleBadge) saleBadge.style.display = hasStaticBadge ? 'inline-flex' : 'none';
      }
    }
    document.addEventListener('variant:change', function(e){
      var v = e.detail && e.detail.variant;
      if(v) { renderMainPrice(v); updateForms(v.id); }
    });
    const mainContainer = document.querySelector('.kx-selection-group');
    if (mainContainer) {
      mainContainer.addEventListener('click', function(e){
        const card = e.target.closest('.kvp-pro__card');
        if(!card) return;
        const optionIndex = parseInt(card.getAttribute('data-option-index'));
        const optionValue = card.getAttribute('data-option-value');
        const newOptions = [...currentOptions];
        newOptions[optionIndex] = optionValue;
        const variant = (variants || []).find(v => v.options.every((opt, index) => opt === newOptions[index])) || null;
        if(variant) updateUI(variant);
        else {
          const fallback = (variants || []).find(v => v.options[optionIndex] === optionValue && v.available) || (variants || []).find(v => v.options[optionIndex] === optionValue);
          if (fallback) updateUI(fallback);
        }
      });
    }
    const initial = (variants || []).find(v => v.id === selectedId) || (variants || [])[0] || null;
    if(initial) updateUI(initial);
  })();
</script>

<!-- Block D: Description Toggle, Tabs, FAQ, Mobile Logic Scripts -->
<script>
function toggleDesc() {
  var t = document.getElementById('watchDescText');
  var g = document.getElementById('watchDescGradient');
  var b = document.getElementById('watchMehrBtn');
  var isDesktop = window.innerWidth >= 990;
  var maxHeight = isDesktop ? 380 : 250;

  if (t.classList.contains('open')) {
    t.classList.remove('open');
    t.style.maxHeight = maxHeight + 'px';
    g.classList.remove('hide');
    b.classList.remove('open');
    b.innerHTML = 'Mehr anzeigen <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>';
    t.closest('.watch-layout').scrollIntoView({ behavior: 'smooth', block: 'start' });
  } else {
    t.classList.add('open');
    t.style.maxHeight = t.scrollHeight + 'px';
    g.classList.add('hide');
    b.classList.add('open');
    b.innerHTML = 'Weniger anzeigen <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>';
    setTimeout(function() { if(t.classList.contains('open')) t.style.maxHeight = 'none'; }, 550);
  }
}

// Auto-init for physical layout
(function() {
  function initWatchDesc() {
    var t = document.getElementById('watchDescText');
    var b = document.getElementById('watchMehrBtn');
    if(!t || !b) return;
    var isDesktop = window.innerWidth >= 990;
    var maxHeight = isDesktop ? 380 : 250;
    
    if(t.scrollHeight > maxHeight + 60) {
      b.style.display = 'inline-flex';
      if(!t.classList.contains('open')) t.style.maxHeight = maxHeight + 'px';
    } else {
      b.style.display = 'none';
      t.style.maxHeight = 'none';
      t.classList.add('open');
      var g = document.getElementById('watchDescGradient');
      if(g) g.classList.add('hide');
    }
  }
  setTimeout(initWatchDesc, 600);
  window.addEventListener('resize', initWatchDesc);
})();

function openWatchTab(evt, tabName) {
  var contents = document.getElementsByClassName("w-tab-content");
  for (var i = 0; i < contents.length; i++) contents[i].style.display = "none";
  var tablinks = document.getElementsByClassName("w-tab-btn");
  for (var i = 0; i < tablinks.length; i++) tablinks[i].className = tablinks[i].className.replace(" active", "");
  document.getElementById(tabName).style.display = "block";
  evt.currentTarget.className += " active";
}

function toggleMobileAccordion(header) {
  const item = header.parentElement;
  const content = item.querySelector('.w-accordion-content');
  const isActive = item.classList.contains('active');
  const scrollY = window.scrollY;
  
  document.querySelectorAll('.w-accordion-container .w-accordion-item').forEach(el => {
    if (el !== item && el.classList.contains('active')) {
      const otherContent = el.querySelector('.w-accordion-content');
      if (otherContent) {
        otherContent.style.maxHeight = otherContent.scrollHeight + 'px';
        requestAnimationFrame(() => { otherContent.style.maxHeight = '0px'; });
      }
      el.classList.remove('active');
    }
  });
  
  if (isActive) {
    content.style.maxHeight = content.scrollHeight + 'px';
    requestAnimationFrame(() => { content.style.maxHeight = '0px'; });
    item.classList.remove('active');
  } else {
    item.classList.add('active');
    content.style.maxHeight = '0px';
    requestAnimationFrame(() => {
      content.style.maxHeight = content.scrollHeight + 'px';
      content.addEventListener('transitionend', function handler() {
        if (item.classList.contains('active')) content.style.maxHeight = 'none';
        content.removeEventListener('transitionend', handler);
      });
    });
  }
  requestAnimationFrame(() => { window.scrollTo(0, scrollY); });
}

// FAQ Logic
document.addEventListener('click', (e) => {
  const summary = e.target.closest('.kx-faq__btn');
  if (!summary) return;
  const details = summary.parentElement;
  const content = details ? details.querySelector('.kx-faq__panel') : null;
  if (!details || details.tagName !== 'DETAILS' || !content) return;

  const container = details.closest('.kx-faq__list');
  if (container) {
    container.querySelectorAll('details[open]').forEach(other => {
      if (other !== details) {
        const oc = other.querySelector('.kx-faq__panel');
        if (oc) {
          oc.style.maxHeight = oc.scrollHeight + "px";
          requestAnimationFrame(() => { requestAnimationFrame(() => { oc.style.maxHeight = '0px'; }); });
          setTimeout(() => { other.open = false; }, 300);
        } else other.open = false;
      }
    });
  }

  if (details.open) {
    e.preventDefault();
    content.style.maxHeight = content.scrollHeight + "px";
    requestAnimationFrame(() => { requestAnimationFrame(() => { content.style.maxHeight = '0px'; }); });
    setTimeout(() => { details.open = false; content.style.maxHeight = ''; }, 300);
  } else {
    e.preventDefault();
    details.open = true;
    content.style.maxHeight = '0px';
    requestAnimationFrame(() => { requestAnimationFrame(() => { content.style.maxHeight = content.scrollHeight + "px"; }); });
    setTimeout(() => { content.style.maxHeight = 'none'; }, 350);
  }
});
</script>
