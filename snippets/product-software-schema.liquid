{%- comment -%}
  JSON-LD structured data for the software product template.
  Includes Product, Offer, Brand. AggregateRating only when reviews exist
  via product metafield. MPN read from custom.mpn (optional).
{%- endcomment -%}
{%- liquid
  assign img = product.featured_image | image_url: width: 1200
  assign offer_price = product.selected_or_first_available_variant.price | divided_by: 100.0
  assign offer_currency = cart.currency.iso_code
  assign mpn = product.metafields.custom.mpn
  assign brand_name = product.vendor | default: 'Microsoft'
  assign rating_avg = product.metafields.reviews.rating.value
  assign rating_count = product.metafields.reviews.rating_count
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "image": {{ img | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }}{% if mpn != blank %},
  "mpn": {{ mpn | json }}{% endif %},
  "brand": {
    "@type": "Brand",
    "name": {{ brand_name | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": {{ offer_currency | json }},
    "price": "{{ offer_price | round: 2 }}",
    "availability": "{% if product.selected_or_first_available_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }{% if rating_avg and rating_count and rating_count > 0 %},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ rating_avg }}",
    "reviewCount": "{{ rating_count }}"
  }{% endif %}
}
</script>
