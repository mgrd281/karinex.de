{% comment %}
  ═══════════════════════════════════════════════════════
  ELITE META TAGS - GLOBAL COMPETITION LEVEL
  Version: 2.0 Elite | Updated: 20.01.2026
  Competing with: Amazon, eBay, Otto, MediaMarkt
  ═══════════════════════════════════════════════════════
{% endcomment %}

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5,user-scalable=yes">

{%- comment -%} ═══ THEME & BRAND COLOR ═══ {%- endcomment -%}
<meta name="theme-color" content="#1D4739">
<meta name="msapplication-TileColor" content="#1D4739">

{%- comment -%} ═══ CORE LOGIC ═══ {%- endcomment -%}
{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_image = page_image
  
  if request.page_type == 'product'
    assign og_type = 'product.item'
    if og_image == blank
      if product.selected_or_first_available_variant.featured_image
        assign og_image = product.selected_or_first_available_variant.featured_image
      elsif product.featured_image
        assign og_image = product.featured_image
      endif
    endif
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  if og_image == blank and request.page_type == 'collection' and collection.image
    assign og_image = collection.image
  endif
  if og_image == blank and settings.logo
    assign og_image = settings.logo
  endif
%}

{%- comment -%} ═══ ADVANCED META DESCRIPTION ═══ {%- endcomment -%}
{%- liquid
  # Meta description should be 150-160 chars (~1000 pixels) maximum
  assign meta_description = page_description | strip_html | strip_newlines | truncate: 155
  
  # Fallback descriptions for pages without custom SEO description
  if meta_description == blank
    assign meta_description = shop.description | default: shop.name | truncate: 155
  endif

  # Override descriptions for specific pages with missing/bad descriptions
  if request.page_type == 'page' and page.handle == 'cookie-policy'
    assign meta_description = 'Erfahren Sie, welche Cookies karinex.de verwendet, warum wir sie nutzen und wie Sie Ihre Cookie-Einstellungen verwalten können.'
  endif
  
  # Final safety: always truncate to max 155 chars
  assign meta_description = meta_description | truncate: 155
-%}

{%- comment -%} ═══ PAGE TITLE (SEO OPTIMIZED - 55-65 chars) ═══ {%- endcomment -%}
{%- liquid
  assign seo_title = page_title
  
  # For collections: truncate at first comma
  if request.page_type == 'collection'
    if seo_title contains ','
      assign seo_title = seo_title | split: ',' | first
    endif
  endif
  
  # Short suffix - "karinex" appears in footer/header, avoiding "Online Shop" keyword mismatch
  assign title_suffix = ' | karinex'
  
  # Check if this is a vendor filter page
  assign is_vendor_page = false
  if request.path contains '/vendors'
    assign is_vendor_page = true
  endif
  
  # Enhanced titles for collections
  if request.page_type == 'collection'
    if is_vendor_page
      # Vendor pages - add "Produkte von" prefix to make unique
      assign vendor_name = collection.title | default: 'Hersteller'
      assign seo_title = vendor_name | append: ' Produkte - Alle Artikel'
    elsif collection.handle == 'software'
      assign seo_title = 'Software kaufen - Windows, Office & mehr'
    elsif collection.handle == 'games'
      assign seo_title = 'Games & Spiele - PC, PlayStation, Xbox'
    elsif collection.handle == 'lego' or collection.handle == 'lego®'
      assign seo_title = 'LEGO® Sets - Spielzeug & Bausteine'
    elsif collection.handle == 'sale'
      assign seo_title = 'SALE - Angebote & Rabatte'
    elsif collection.handle == 'all'
      assign seo_title = 'Alle Produkte - Software, Games, Uhren'
    elsif collection.handle == 'microsoft'
      assign seo_title = 'Microsoft Produkte - Windows, Office, 365'
    elsif collection.handle == 'uhren'
      assign seo_title = 'Uhren - Boss, Michael Kors & mehr'
    elsif collection.handle == 'boss-uhren'
      assign seo_title = 'Boss Uhren - Herren & Damen Armbanduhren'
    elsif collection.handle == 'michael-kors-uhren'
      assign seo_title = 'Michael Kors Uhren - Luxus Armbanduhren'
    elsif collection.handle == 'unsere-bestseller'
      assign seo_title = 'Bestseller - Top Produkte bei karinex'
    elsif collection.handle == 'spielzeug'
      assign seo_title = 'Spielzeug - LEGO, Games & mehr'
    elsif collection.handle == 'controller'
      assign seo_title = 'Controller - PlayStation, Xbox, PC Gaming'
    elsif collection.handle == 'playstation'
      assign seo_title = 'PlayStation - Spiele, Controller & Zubehör'
    elsif collection.handle == 'xbox'
      assign seo_title = 'Xbox - Spiele, Controller & Zubehör'
    elsif collection.handle == 'antivirus'
      assign seo_title = 'Antivirus Software - Schutz für PC & Mac'
    elsif collection.handle == 'adobe'
      assign seo_title = 'Adobe Software - Photoshop, Acrobat & mehr'
    elsif collection.handle == 'adobe-1'
      assign seo_title = 'Adobe Creative Suite - Software & Apps'
    elsif collection.handle == 'damenuhren'
      assign seo_title = 'Damenuhren - Elegante Armbanduhren kaufen'
    elsif collection.handle == 'herrenuhren'
      assign seo_title = 'Herrenuhren - Stilvolle Armbanduhren kaufen'
    elsif collection.handle == 'alle'
      assign seo_title = 'Alle Produkte - Software, Games & Uhren'
    elsif collection.handle == 'lego-1'
      assign seo_title = 'Toys & Spielzeug - LEGO Sets & mehr'
    endif
  
  # Enhanced titles for pages
  elsif request.page_type == 'page'
    if page.handle == 'agb'
      assign seo_title = 'AGB - Allgemeine Geschäftsbedingungen'
    elsif page.handle == 'cookie-policy'
      assign seo_title = 'Cookie-Richtlinie - Cookies & Datenschutz'
    elsif page.handle == 'uber-uns' or page.handle == 'about-us'
      assign seo_title = 'Über uns - Ihr Partner für Software'
    elsif page.handle == 'kontakt' or page.handle == 'contact'
      assign seo_title = 'Kontakt - Kundenservice & Support'
    elsif page.handle == 'faq'
      assign seo_title = 'FAQ - Häufig gestellte Fragen'
    elsif page.handle == 'retouren'
      assign seo_title = 'Retouren & Rückgabe - So funktioniert es'
    elsif page.handle == 'live-chat'
      assign seo_title = 'Live-Chat - Sofort Hilfe erhalten'
    elsif page.handle == 'newsletter'
      assign seo_title = 'Newsletter - Angebote & Neuheiten'
    elsif page.handle == 'datenschutz'
      assign seo_title = 'Datenschutz - Ihre Daten sind sicher'
    elsif page.handle == 'wishlist'
      assign seo_title = 'Wunschliste - Ihre Favoriten'
    elsif page.handle == 'rechnungen'
      assign seo_title = 'Rechnungen - Download & Übersicht'
    elsif page.handle == 'coupons'
      assign seo_title = 'Gutscheine & Coupons - Sparen Sie jetzt'
    elsif page.handle contains 'download'
      assign seo_title = page.title | truncate: 50, '…'
    elsif page.handle contains 'microsoft-office'
      assign seo_title = 'Office für Mac - Info & Download'
    else
      # Fallback for pages with empty or generic titles
      if seo_title == blank or seo_title == '– karinex' or seo_title == 'karinex'
        assign seo_title = page.title | default: page.handle | replace: '-', ' ' | capitalize
      endif
    endif
  
  # Enhanced titles for blogs
  elsif request.page_type == 'blog'
    assign seo_title = blog.title | default: 'Blog' | append: ' - Tipps & Neuigkeiten'
  
  # Articles: use article title as-is (truncated below)
  elsif request.page_type == 'article'
    assign seo_title = article.title | default: page_title
  endif

  # Enhanced titles for policy pages
  if request.page_type == 'policy'
    if page_title == 'AGB'
      assign seo_title = 'AGB - Allgemeine Geschäftsbedingungen'
    elsif page_title contains 'Datenschutz' or page_title contains 'Privacy'
      assign seo_title = 'Datenschutzerklärung'
    elsif page_title contains 'Widerruf' or page_title contains 'Refund'
      assign seo_title = 'Widerrufsbelehrung & Rückgaberecht'
    elsif page_title contains 'Versand' or page_title contains 'Shipping'
      assign seo_title = 'Versand & Lieferung'
    elsif page_title contains 'Impressum' or page_title contains 'Legal'
      assign seo_title = 'Impressum - Rechtliche Angaben'
    endif
  endif

  # Search page: include query
  if request.page_type == 'search'
    if search.terms != blank
      assign seo_title = 'Suche: "' | append: search.terms | append: '"'
    else
      assign seo_title = 'Suche'
    endif
  endif

  # Cart page
  if request.page_type == 'cart'
    assign seo_title = 'Warenkorb'
  endif

  # 404 page
  if request.page_type == '404'
    assign seo_title = 'Seite nicht gefunden (404)'
  endif
  
  # Product page titles - use the exact product title without any modifications
  if request.page_type == 'product'
    # Keep the original page_title as-is, no modifications
    assign seo_title = page_title
    # No suffix for product pages
    assign title_suffix = ''
  endif
  
  # Truncate blog article titles
  if request.page_type == 'article'
    assign seo_title = seo_title | truncate: 55, '…'
    assign title_suffix = ' | karinex'
  endif
  
  # Truncate collection titles
  if request.page_type == 'collection'
    if seo_title.size > 50
      assign seo_title = seo_title | truncate: 50, '…'
    endif
  endif
  
  # Final fallback - ensure no empty titles
  if seo_title == blank or seo_title == '–' or seo_title == '– karinex'
    assign seo_title = page_title | default: shop.name
  endif

  # Enforce max 50 chars for page titles (60 total with suffix)
  if request.page_type == 'page'
    if seo_title.size > 50
      assign seo_title = seo_title | truncate: 50, '…'
    endif
  endif
-%}
<title>
  {%- if request.page_type == 'product' -%}
    {{- seo_title -}}
  {%- else -%}
    {%- liquid
      assign _title_parts = seo_title
      if current_tags
        assign _tag_str = current_tags | join: ', ' | truncate: 25
        assign _title_parts = _title_parts | append: ' – ' | append: _tag_str
      endif
      if current_page != 1
        assign _title_parts = _title_parts | append: ' – Seite ' | append: current_page
      endif
      # Only add suffix if total stays under 60 chars
      assign _total_with_suffix = _title_parts.size | plus: title_suffix.size
      assign _should_add_suffix = true
      if _title_parts contains shop.name or _title_parts contains 'karinex' or _title_parts contains 'Karinex'
        assign _should_add_suffix = false
      endif
      if _total_with_suffix > 60
        assign _should_add_suffix = false
      endif
    -%}
    {{- _title_parts -}}{%- if _should_add_suffix -%}{{ title_suffix }}{%- endif -%}
  {%- endif -%}
</title>

{%- comment -%} ═══ CANONICAL & ALTERNATE LANGUAGES ═══ {%- endcomment -%}
{%- liquid
  # Normalize canonical URL
  # For vendor pages: point to the main collections page (vendors are blocked by robots.txt)
  # For search pages: convert %20 to + for consistent query parameters
  # For pagination: point to page 1 to avoid duplicate content issues
  assign clean_canonical = canonical_url
  
  if canonical_url contains '/collections/vendors?q='
    # Vendor filter pages are blocked by robots.txt
    # Point canonical to main collections page instead
    assign clean_canonical = shop.url | append: '/collections/all'
  elsif canonical_url contains '/search?q='
    assign clean_canonical = canonical_url | replace: '%20', '+'
  elsif canonical_url contains '?page='
    # Pagination pages should point to page 1
    assign clean_canonical = canonical_url | split: '?page=' | first
  elsif canonical_url contains '&page='
    assign clean_canonical = canonical_url | split: '&page=' | first
  endif
-%}
{%- comment -%}
  CANONICAL OVERRIDE
  We output our own canonical tag here. The default Shopify canonical tag in
  content_for_header is stripped out in layout/theme.liquid to avoid duplicates.
{%- endcomment -%}
<link rel="canonical" href="{{ clean_canonical }}">

{%- comment -%} 
  Hreflang: Multi-language site (DE default, EN, PL)
  Required for Google to discover and index alternate locale versions.
  Only output on indexable pages — skip search, cart, 404, account pages.
{%- endcomment -%}
{%- unless request.page_type == 'search' or request.page_type == 'cart' or request.page_type == '404' or request.page_type == 'customers/account' or request.page_type == 'customers/order' or request.page_type == 'customers/register' or request.page_type == 'customers/login' or is_vendor_page -%}
{%- liquid
  assign _hreflang_path = request.path
  if _hreflang_path == '/en' or _hreflang_path == '/pl'
    assign _hreflang_path = '/'
  elsif _hreflang_path contains '/en/'
    assign _hreflang_path = _hreflang_path | slice: 3, 9999
  elsif _hreflang_path contains '/pl/'
    assign _hreflang_path = _hreflang_path | slice: 3, 9999
  endif
-%}
<link rel="alternate" hreflang="de" href="{{ shop.url }}{{ _hreflang_path }}">
<link rel="alternate" hreflang="en" href="{{ shop.url }}/en{{ _hreflang_path }}">
<link rel="alternate" hreflang="pl" href="{{ shop.url }}/pl{{ _hreflang_path }}">
<link rel="alternate" hreflang="x-default" href="{{ shop.url }}{{ _hreflang_path }}">
{%- endunless -%}

{%- comment -%} ═══ PAGINATION (PREV/NEXT) ═══ {%- endcomment -%}
{%- if paginate -%}
  {%- if paginate.previous -%}
    <link rel="prev" href="{{ paginate.previous.url }}">
  {%- endif -%}
  {%- if paginate.next -%}
    <link rel="next" href="{{ paginate.next.url }}">
  {%- endif -%}
{%- endif -%}

{%- comment -%} ═══ BASIC META ═══ {%- endcomment -%}
<meta name="description" content="{{ meta_description | escape }}">

{%- comment -%} Author {%- endcomment -%}
{%- if request.page_type == 'article' and article.author -%}
  <meta name="author" content="{{ article.author }}">
{%- else -%}
  <meta name="author" content="{{ shop.name }}">
{%- endif -%}

{%- comment -%} ═══ ROBOTS META (ADVANCED) ═══ {%- endcomment -%}
{%- liquid
  assign is_paginated = false
  if canonical_url contains '?page=' or canonical_url contains '&page='
    assign is_paginated = true
  endif
-%}
{%- if request.page_type == 'search' or request.page_type == 'cart' or request.page_type == '404' or request.page_type == 'customers/account' or request.page_type == 'customers/order' or request.page_type == 'customers/register' or request.page_type == 'customers/login' or is_vendor_page -%}
  <meta name="robots" content="noindex, follow">
{%- elsif is_paginated -%}
  {%- comment -%} Pagination pages: index but don't use for snippets to avoid duplicate content {%- endcomment -%}
  <meta name="robots" content="index, follow, max-snippet:0, max-image-preview:large">
{%- else -%}
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
{%- endif -%}


{%- comment -%} ═══ OPEN GRAPH (FACEBOOK/LINKEDIN) ═══ {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
{%- liquid
  case request.locale.iso_code
    when 'en'
      assign _og_locale = 'en_GB'
    when 'pl'
      assign _og_locale = 'pl_PL'
    else
      assign _og_locale = 'de_DE'
  endcase
-%}
<meta property="og:locale" content="{{ _og_locale }}">
{%- if _og_locale != 'de_DE' -%}<meta property="og:locale:alternate" content="de_DE">{%- endif -%}
{%- if _og_locale != 'en_GB' -%}<meta property="og:locale:alternate" content="en_GB">{%- endif -%}
{%- if _og_locale != 'pl_PL' -%}<meta property="og:locale:alternate" content="pl_PL">{%- endif -%}

{%- if og_image -%}
  {%- assign og_image_aspect = og_image.aspect_ratio | default: 1.91 -%}
  {%- assign og_image_height = 1200.0 | divided_by: og_image_aspect | round -%}
  <meta property="og:image" content="https:{{ og_image | image_url: width: 1200, format: 'jpg' }}">
  <meta property="og:image:secure_url" content="https:{{ og_image | image_url: width: 1200, format: 'jpg' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ og_image_height }}">
  <meta property="og:image:alt" content="{{ og_image.alt | default: og_title | escape }}">
  <meta property="og:image:type" content="image/jpeg">
{%- endif -%}

{%- comment -%} ═══ PRODUCT-SPECIFIC OG TAGS ═══ {%- endcomment -%}
{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | divided_by: 100.0 }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:price:amount" content="{{ product.price | divided_by: 100.0 }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  
  {%- if product.selected_or_first_available_variant.available -%}
    <meta property="product:availability" content="in stock">
    <meta property="og:availability" content="instock">
  {%- else -%}
    <meta property="product:availability" content="out of stock">
    <meta property="og:availability" content="oos">
  {%- endif -%}
  
  <meta property="product:condition" content="new">
  <meta property="product:retailer_item_id" content="{{ product.id }}">
  
  {%- if product.vendor -%}
    <meta property="product:brand" content="{{ product.vendor | escape }}">
  {%- endif -%}
  
  {%- if product.type -%}
    <meta property="product:category" content="{{ product.type | escape }}">
  {%- endif -%}
  
  {%- if product.compare_at_price > product.price -%}
    <meta property="product:sale_price:amount" content="{{ product.price | divided_by: 100.0 }}">
    <meta property="product:sale_price:currency" content="{{ cart.currency.iso_code }}">
  {%- endif -%}
{%- endif -%}

{%- comment -%} ═══ ARTICLE-SPECIFIC OG TAGS ═══ {%- endcomment -%}
{%- if request.page_type == 'article' -%}
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:modified_time" content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:author" content="{{ article.author }}">
  <meta property="article:section" content="{{ blog.title | escape }}">
  {%- for tag in article.tags limit: 5 -%}
    <meta property="article:tag" content="{{ tag | escape }}">
  {%- endfor -%}
{%- endif -%}

{%- comment -%} ═══ TWITTER CARDS (ENHANCED) ═══ {%- endcomment -%}
{%- if settings.social_twitter_link != blank -%}
  {%- assign _tw_handle = settings.social_twitter_link | split: 'twitter.com/' | last | split: 'x.com/' | last | split: '/' | first | prepend: '@' -%}
  <meta name="twitter:site" content="{{ _tw_handle }}">
  <meta name="twitter:creator" content="{{ _tw_handle }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
<meta name="twitter:domain" content="{{ shop.domain }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200, format: 'jpg' }}">
  <meta name="twitter:image:alt" content="{{ og_image.alt | default: og_title | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta name="twitter:label1" content="Preis">
  <meta name="twitter:data1" content="{{ product.price | money }}">
  <meta name="twitter:label2" content="Verfügbarkeit">
  <meta name="twitter:data2" content="{% if product.available %}Auf Lager{% else %}Ausverkauft{% endif %}">
{%- endif -%}

{%- comment -%} ═══ PINTEREST RICH PINS ═══ {%- endcomment -%}
{%- if request.page_type == 'product' -%}
  <meta name="pinterest-rich-pin" content="true">
{%- endif -%}

{%- comment -%} ═══ MOBILE APP META ═══ {%- endcomment -%}
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="{{ shop.name }}">
<meta name="mobile-web-app-capable" content="yes">
<meta name="application-name" content="{{ shop.name }}">

{%- comment -%} ═══ MICROSOFT META ═══ {%- endcomment -%}
<meta name="msapplication-starturl" content="{{ shop.url }}">
<meta name="msapplication-tooltip" content="{{ shop.name }} - {{ shop.description | truncate: 50 | escape }}">
<meta name="msapplication-tap-highlight" content="no">

{%- comment -%} ═══ CONTENT SECURITY & COPYRIGHT ═══ {%- endcomment -%}
<meta name="copyright" content="© {{ 'now' | date: '%Y' }} {{ shop.name }}. Alle Rechte vorbehalten.">

{%- comment -%} ═══ REFERRER POLICY ═══ {%- endcomment -%}
<meta name="referrer" content="origin-when-cross-origin">

{%- comment -%} ═══ FORMAT DETECTION ═══ {%- endcomment -%}
<meta name="format-detection" content="telephone=yes, date=no, address=no, email=no">

