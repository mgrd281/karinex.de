{%- doc -%}
  Zubehörstyp (Accessory Type) filter for collection pages.
  Works entirely client-side via JavaScript — no Search & Discovery app needed.
  Reads data-zubehoerstyp attributes from product grid items and hides/shows them.
  Shown on Uhren collections.

  @param {string} filter_style - 'horizontal' or 'vertical'
  @param {string} sectionId - The section ID
{%- enddoc -%}

{%- capture zubehoer_list -%}
  {%- for product in collection.products limit: 1000 -%}
    {%- capture raw_zt -%}{%- render 'product-zubehoerstyp-value', product: product -%}{%- endcapture -%}
    {%- assign p_zt = raw_zt | strip -%}
    {%- if p_zt != '' -%}|{{ p_zt }}|,{%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- assign zt_entries = zubehoer_list | split: ',' -%}
{%- assign unique_zts = zt_entries | uniq | sort -%}

{%- comment -%} Remove blank entries and count {%- endcomment -%}
{%- assign clean_zts = '' -%}
{%- assign zt_count = 0 -%}
{%- for z in unique_zts -%}
  {%- assign z_stripped = z | strip -%}
  {%- if z_stripped != '' -%}
    {%- assign z_value = z_stripped | remove: '|' -%}
    {%- if z_value != '' -%}
      {%- assign z_product_count = 0 -%}
      {%- for entry in zt_entries -%}
        {%- assign entry_stripped = entry | strip -%}
        {%- if entry_stripped == z_stripped -%}
          {%- assign z_product_count = z_product_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign zt_count = zt_count | plus: 1 -%}
      {%- assign zt_with_count = z_value | append: ':' | append: z_product_count -%}
      {%- if clean_zts == '' -%}
        {%- assign clean_zts = zt_with_count -%}
      {%- else -%}
        {%- assign clean_zts = clean_zts | append: '|||' | append: zt_with_count -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- assign final_zts = clean_zts | split: '|||' -%}

{%- if zt_count > 1 -%}
<accordion-custom
  class="facets__item zubehoerstyp-filter-accordion"
  {% if filter_style == 'horizontal' %}
    data-disable-animation-on-desktop="true"
    data-close-with-escape="true"
  {% endif %}
  {% if filter_style == 'vertical' %}
  {% endif %}
>
  <details
    id="Facet-Details-{{ sectionId }}-zubehoerstyp-{{ filter_style }}"
    class="facets__panel"
    {% if filter_style == 'horizontal' %}
      data-auto-close-details="desktop"
    {% endif %}
  >
    <summary class="facets__summary">
      <span class="facets__label" style="font-weight: 700; font-size: 14px;">Zubehörstyp</span>
      <div class="facets__status-wrapper">
        <span class="zubehoerstyp-filter-count" style="display: none;"></span>
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </div>
    </summary>
    <floating-panel-component
      {% unless filter_style == 'vertical' %}data-close-on-resize{% endunless %}
      class="facets__inputs facets__panel-content details-content{% if filter_style == 'horizontal' %} color-{{ settings.popover_color_scheme }}{% endif %}"
    >
      <div class="facets__inputs-wrapper">
        <ul class="facets__inputs-list list-unstyled">
          {%- for zt in final_zts -%}
            {%- assign zt_parts = zt | split: ':' -%}
            {%- assign zt_stripped = zt_parts[0] | strip -%}
            {%- assign zt_product_count = zt_parts[1] | strip -%}
            {%- if zt_stripped != '' -%}
              {%- assign zt_id = 'zubehoerstyp-filter-' | append: forloop.index | append: '-' | append: filter_style -%}
              <li class="facets__inputs-list-item" data-skip-node-update="true">
                <div class="checkbox zubehoerstyp-filter-item">
                  <input
                    type="checkbox"
                    id="{{ zt_id }}"
                    class="checkbox__input js-zubehoerstyp-checkbox"
                    data-zubehoerstyp-value="{{ zt_stripped | escape }}"
                    value="{{ zt_stripped | escape }}"
                  >
                  <label class="checkbox__label" for="{{ zt_id }}" role="checkbox">
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                    <span class="checkbox__label-text">{{ zt_stripped }} <span style="color: #767676;">({{ zt_product_count }})</span></span>
                  </label>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </floating-panel-component>
  </details>
</accordion-custom>
{%- endif -%}
