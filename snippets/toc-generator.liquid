{% comment %}
Generiert ein Inhaltsverzeichnis (TOC) aus den Überschriften (H2/H3) im Artikelinhalt.
{% endcomment %}
{% assign headings = content | split: '<' %}
<nav aria-label="Inhaltsverzeichnis">
  <ul class="toc-list">
    {% for h in headings %}
      {% if h contains 'h2' or h contains 'h3' %}
        {% assign tag = h | slice: 0, 2 %}
        {% assign text = h | split: '>' | last | split: '<' | first | strip %}
        {% if text != blank %}
          <li class="toc-{{ tag }}"><a href="#{{ text | handleize }}">{{ text }}</a></li>
        {% endif %}
      {% endif %}
    {% endfor %}
  </ul>
</nav>
<style>
.toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.toc-list li {
  margin-bottom: 2px;
}
.toc-h2 {
  margin-left: 0;
}
.toc-h3 {
  margin-left: 16px;
}
.toc-list a {
  color: #444;
  text-decoration: none;
  font-size: 0.92rem;
  line-height: 1.4;
  display: block;
  padding: 5px 8px;
  border-radius: 6px;
  border-left: 2px solid transparent;
  transition: all 0.2s;
}
.toc-h2 > a {
  font-weight: 600;
  color: #23272f;
}
.toc-h3 > a {
  font-weight: 400;
  color: #5a6270;
  font-size: 0.87rem;
}
.toc-list a:hover {
  background: #eef0f3;
  border-left-color: #c8102e;
  color: #1a1a1a;
}
.toc-list a.active {
  background: #fef2f2;
  border-left-color: #c8102e;
  color: #c8102e;
  font-weight: 600;
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Add IDs to headings in article content
  var content = document.getElementById('article-content');
  if (!content) return;
  content.querySelectorAll('h2, h3').forEach(function(heading) {
    if (!heading.id) {
      heading.id = heading.textContent.trim().toLowerCase()
        .replace(/[äÄ]/g,'ae').replace(/[öÖ]/g,'oe').replace(/[üÜ]/g,'ue').replace(/ß/g,'ss')
        .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
  });

  // Smooth scroll
  document.querySelectorAll('.toc-list a').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var id = this.getAttribute('href').substring(1);
      var target = document.getElementById(id);
      if (target) {
        window.scrollTo({ top: target.offsetTop - 60, behavior: 'smooth' });
      }
    });
  });

  // Highlight active TOC item on scroll
  var tocLinks = document.querySelectorAll('.toc-list a');
  var headings = [];
  tocLinks.forEach(function(link) {
    var id = link.getAttribute('href').substring(1);
    var el = document.getElementById(id);
    if (el) headings.push({ el: el, link: link });
  });

  function highlightToc() {
    var scrollTop = window.scrollY + 100;
    var active = null;
    headings.forEach(function(h) {
      if (h.el.offsetTop <= scrollTop) active = h;
    });
    tocLinks.forEach(function(l) { l.classList.remove('active'); });
    if (active) active.link.classList.add('active');
  }
  window.addEventListener('scroll', highlightToc, { passive: true });
  highlightToc();
});
</script>
