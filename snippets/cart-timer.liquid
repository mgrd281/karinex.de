{%- unless hide_html -%}
<cart-timer data-product-ids='{{ cart.items | map: "product_id" | uniq | json | escape }}'>
  <div class="cart-session-timer" id="cartSessionTimer" style="display: none;">
    <div class="timer-content">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="timer-icon">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
        <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="timer-text">
        {{ 'karinex.cart.reserved_for' | t }} <span class="time-display">15:00</span>
      </span>
    </div>
  </div>
</cart-timer>
{%- endunless -%}

<style>
  /* ==== STANDALONE TIMER (e.g. cart page) ==== */
  .cart-session-timer {
    background-color: #f5f7f6;
    border: none;
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 20px;
    color: #4a4a4a;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--font-body-family);
    animation: timerSlideIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    transition: background-color 0.6s ease, color 0.6s ease;
  }

  /* Soft sheen that drifts left→right across the pill — pure CSS,
     GPU-friendly, ignored when the user prefers reduced motion. */
  .cart-session-timer::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg,
      transparent 25%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 75%);
    transform: translateX(-100%);
    animation: timerSheen 6s ease-in-out infinite;
    pointer-events: none;
  }

  .timer-content {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .timer-icon {
    color: #0f3b2e;
    flex-shrink: 0;
    animation: timerPulse 2.4s ease-in-out infinite;
    transform-origin: center;
  }

  .time-display {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: #0f3b2e;
    transition: color 0.6s ease;
  }

  /* The .time-display--tick class is toggled by JS each time the
     seconds digit changes, giving a gentle "heartbeat" cue. */
  .time-display.time-display--tick {
    animation: timerTick 0.55s ease-out;
  }

  @keyframes timerSlideIn {
    from { opacity: 0; transform: translateY(-6px) scale(0.985); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }

  @keyframes timerPulse {
    0%, 100% { transform: scale(1);    opacity: 0.85; }
    50%      { transform: scale(1.09); opacity: 1; }
  }

  @keyframes timerTick {
    0%   { transform: translateY(0)    scale(1); }
    35%  { transform: translateY(-1px) scale(1.04); }
    100% { transform: translateY(0)    scale(1); }
  }

  @keyframes timerSheen {
    0%       { transform: translateX(-100%); }
    55%, 100% { transform: translateX(100%); }
  }

  /* ── URGENT STATE — last 2 minutes ── */
  .cart-session-timer.timer-urgent {
    background-color: #fbf2e2 !important;
    color: #8a5a14 !important;
  }
  .cart-session-timer.timer-urgent .timer-icon {
    color: #c97a18 !important;
    animation: timerPulse 1.1s ease-in-out infinite;
  }
  .cart-session-timer.timer-urgent .time-display {
    color: #8a5a14 !important;
  }

  /* Honour reduced-motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .cart-session-timer,
    .cart-session-timer::before,
    .timer-icon,
    .time-display {
      animation: none !important;
    }
  }

  @media (max-width: 600px) {
    .cart-session-timer {
      font-size: 13px;
      padding: 10px 14px;
    }
  }

  /* ==== DRAWER CONTEXT — pill bar override ==== */
  .cart-drawer .cart-session-timer {
    background: #f2f5f3 !important;
    border: none !important;
    border-radius: 10px !important;
    padding: 9px 14px !important;
    /* Narrower pill, anchored to the right so it sits flush with
       the cart drawer's 20px inner padding on the right edge. */
    width: 65% !important;
    margin: 14px 20px 14px auto !important;
    color: #3a5248 !important;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.01em;
    box-sizing: border-box;
  }

  .cart-drawer .cart-session-timer.timer-urgent {
    background: #fbf2e2 !important;
    color: #8a5a14 !important;
  }

  .cart-drawer .timer-content {
    justify-content: center !important;
    gap: 8px;
  }

  .cart-drawer .timer-icon {
    width: 14px;
    height: 14px;
    color: #2c6b53 !important;
    opacity: 0.85;
  }

  .cart-drawer .cart-session-timer.timer-urgent .timer-icon {
    color: #c97a18 !important;
    opacity: 1;
  }

  .cart-drawer .time-display {
    font-weight: 600 !important;
    font-variant-numeric: tabular-nums;
    color: #2c5a44 !important;
    letter-spacing: 0.03em;
  }

  .cart-drawer .cart-session-timer.timer-urgent .time-display {
    color: #8a5a14 !important;
  }
</style>

<script>
  if (!customElements.get('cart-timer')) {
    class CartTimer extends HTMLElement {
      constructor() {
        super();
        this.durationMinutes = 15;
        this.storageKey = 'cart_session_start_v1';
        this.seenKey = 'cart_session_seen_products_v1';
        this.animationFrameId = null;
      }

      connectedCallback() {
        this.initTimer();
      }
      
      disconnectedCallback() {
        if (this.animationFrameId) {
          cancelAnimationFrame(this.animationFrameId);
        }
      }

      initTimer() {
        const display = this.querySelector('.time-display');
        const container = this.querySelector('#cartSessionTimer');
        
        if (!display || !container) return;

        // Get IDs passed via data attribute
        let currentCartIds = [];
        try {
          currentCartIds = JSON.parse(this.dataset.productIds || '[]');
        } catch (e) {
          console.error('Error parsing cart product IDs', e);
        }

        let startTime = localStorage.getItem(this.storageKey);
        let seenProducts = JSON.parse(localStorage.getItem(this.seenKey) || '[]');
        
        const now = Date.now();
        
        // Smart Reset Check
        const hasNewProducts = currentCartIds.some(id => !seenProducts.includes(id));
        let shouldReset = false;

        if (hasNewProducts) {
            shouldReset = true;
            seenProducts = [...new Set([...seenProducts, ...currentCartIds])];
            localStorage.setItem(this.seenKey, JSON.stringify(seenProducts));
        } else if (!startTime) {
            shouldReset = true;
        } else {
            // Check expiry
            const elapsed = now - parseInt(startTime);
            const maxDuration = this.durationMinutes * 60 * 1000 + 600000; // Buffer
            if (elapsed > maxDuration) {
                shouldReset = true;
            }
        }

        if (shouldReset) {
            startTime = now;
            localStorage.setItem(this.storageKey, startTime);
        }

        this.startTime = parseInt(startTime);
        this.display = display;
        this.container = container;
        
        // Show immediately
        container.style.display = 'block';
        
        // Start Loop
        this.update();
      }

      update() {
        if (!this.startTime) return;

        let lastSecond = -1;
        const URGENT_THRESHOLD_MS = 2 * 60 * 1000; // last 2 minutes

        const updateFrame = () => {
            if (!this.isConnected) return; // Stop if removed from DOM

            const currentTime = Date.now();
            const elapsed = currentTime - this.startTime;
            const remaining = (this.durationMinutes * 60 * 1000) - elapsed;

            if (remaining <= 0) {
                // Reset loop
                this.startTime = Date.now();
                localStorage.setItem(this.storageKey, this.startTime);
                lastSecond = -1;
                this.container.classList.remove('timer-urgent');
                this.animationFrameId = requestAnimationFrame(updateFrame);
                return;
            }

            const m = Math.floor(remaining / 60000);
            const s = Math.floor((remaining % 60000) / 1000);

            // Only update DOM when the second actually changes — keeps
            // RAF cheap and gives us a clean hook for the "tick" cue.
            if (s !== lastSecond) {
                const timeStr = m + ':' + (s < 10 ? '0' + s : s);
                this.display.textContent = timeStr;

                if (lastSecond !== -1) {
                    this.display.classList.remove('time-display--tick');
                    // Force reflow so the animation re-triggers
                    void this.display.offsetWidth;
                    this.display.classList.add('time-display--tick');
                }
                lastSecond = s;

                // Toggle urgency state once we cross the threshold,
                // toggle it off again on reset.
                const urgent = remaining <= URGENT_THRESHOLD_MS;
                this.container.classList.toggle('timer-urgent', urgent);
            }

            this.container.style.display = 'block';

            this.animationFrameId = requestAnimationFrame(updateFrame);
        };
        this.animationFrameId = requestAnimationFrame(updateFrame);
      }
    }
    customElements.define('cart-timer', CartTimer);
  }
  
  // Global function to reinitialize cart timer when drawer opens
  window.initCartTimer = function() {
    const timer = document.querySelector('cart-timer');
    if (timer) {
      // Reset and reinitialize
      const container = timer.querySelector('#cartSessionTimer');
      if (container) {
        container.style.display = 'block';
      }
      // Force reinitialization by calling initTimer if exposed, or recreate
      if (timer.initTimer) {
        timer.initTimer();
      }
    }
  };
  
  // Auto-detect when cart drawer opens and reinitialize
  (function() {
    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        for (const node of mutation.addedNodes) {
          if (node.nodeType === 1) {
            // Check if cart-timer was added
            if (node.matches && node.matches('cart-timer')) {
              // Timer added, will auto-init via connectedCallback
            }
            // Check if drawer opened (dialog open attribute)
            if (node.querySelector && node.querySelector('cart-timer')) {
              const timer = node.querySelector('cart-timer');
              const container = timer.querySelector('#cartSessionTimer');
              if (container) container.style.display = 'block';
            }
          }
        }
        // Also check attribute changes for dialog[open]
        if (mutation.type === 'attributes' && mutation.attributeName === 'open') {
          if (mutation.target.matches && mutation.target.matches('.cart-drawer__dialog[open]')) {
            const timer = mutation.target.querySelector('cart-timer');
            if (timer) {
              const container = timer.querySelector('#cartSessionTimer');
              if (container) container.style.display = 'block';
            }
          }
        }
      }
    });
    
    observer.observe(document.body, { 
      childList: true, 
      subtree: true,
      attributes: true,
      attributeFilter: ['open']
    });
    
    // Also listen for cart:refresh events
    document.addEventListener('cart:refresh', () => {
      setTimeout(window.initCartTimer, 100);
    });
  })();
</script>
