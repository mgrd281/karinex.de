{%- comment -%}
  Karinex — Custom metafield accordion tabs (Apple-premium style).

  Renders 3 collapsible <details> tabs below the product description:
    1. Produktdetails    (custom.details_content   + custom.details_heading)
    2. Versand & Lieferung (custom.shipping_content + custom.shipping_heading)
    3. Rückgabe & Garantie (custom.warranty_content  + custom.warranty_heading)

  Each tab is rendered ONLY when its content metafield is non-blank.
  Heading falls back to a sensible default when the heading metafield
  is missing, so a partial set still works gracefully.

  Rich-text fields use Shopify's `metafield_tag` filter so JSON-encoded
  rich text becomes proper HTML automatically.

  No external JS or CSS — pure HTML5 <details>/<summary> with scoped
  styles via the .pmt wrapper.

  Usage:  {% render 'product-meta-tabs' %}
{%- endcomment -%}

{%- liquid
  assign mf_details   = product.metafields.custom.details_content
  assign mf_shipping  = product.metafields.custom.shipping_content
  assign mf_warranty  = product.metafields.custom.warranty_content

  assign h_details  = product.metafields.custom.details_heading | default: 'Produktdetails'
  assign h_shipping = product.metafields.custom.shipping_heading | default: 'Versand & Lieferung'
  assign h_warranty = product.metafields.custom.warranty_heading | default: 'Rückgabe & Garantie'

  assign has_any = false
  if mf_details != blank or mf_shipping != blank or mf_warranty != blank
    assign has_any = true
  endif
-%}

{%- if has_any -%}
<section class="pmt" aria-label="Produktinformationen">

  {%- if mf_details != blank -%}
    <details class="pmt__item" data-pmt-item>
      <summary class="pmt__summary">
        <span class="pmt__heading">{{ h_details }}</span>
        <span class="pmt__icon" aria-hidden="true"></span>
      </summary>
      <div class="pmt__content">{{ mf_details | metafield_tag }}</div>
    </details>
  {%- endif -%}

  {%- if mf_shipping != blank -%}
    <details class="pmt__item" data-pmt-item>
      <summary class="pmt__summary">
        <span class="pmt__heading">{{ h_shipping }}</span>
        <span class="pmt__icon" aria-hidden="true"></span>
      </summary>
      <div class="pmt__content">{{ mf_shipping | metafield_tag }}</div>
    </details>
  {%- endif -%}

  {%- if mf_warranty != blank -%}
    <details class="pmt__item" data-pmt-item>
      <summary class="pmt__summary">
        <span class="pmt__heading">{{ h_warranty }}</span>
        <span class="pmt__icon" aria-hidden="true"></span>
      </summary>
      <div class="pmt__content">{{ mf_warranty | metafield_tag }}</div>
    </details>
  {%- endif -%}

</section>

<style>
  .pmt {
    max-width: 760px;
    margin: 48px auto 0;
    padding: 0 16px;
    border-top: 1px solid #d2d2d7;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Inter", "Segoe UI", system-ui, sans-serif;
    font-feature-settings: 'cv11','ss01','ss03';
  }
  .pmt__item {
    border-bottom: 1px solid #d2d2d7;
  }
  .pmt__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #1d1d1f;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .pmt__summary::-webkit-details-marker { display: none; }
  .pmt__summary::marker { display: none; content: ''; }
  .pmt__summary:hover { color: #06c; }
  .pmt__summary:focus-visible {
    outline: 2px solid #06c;
    outline-offset: 2px;
    border-radius: 4px;
  }
  .pmt__heading { flex: 1 1 auto; }
  .pmt__icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    position: relative;
  }
  .pmt__icon::before,
  .pmt__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background: currentColor;
    border-radius: 1px;
    transform: translate(-50%, -50%);
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
  }
  .pmt__icon::before { width: 12px; height: 1.5px; }
  .pmt__icon::after  { width: 1.5px; height: 12px; }
  .pmt__item[open] .pmt__icon::after {
    transform: translate(-50%, -50%) scaleY(0);
    opacity: 0;
  }
  .pmt__content {
    padding: 0 0 22px;
    font-size: 15px;
    line-height: 1.6;
    color: #424245;
    white-space: pre-line;
  }
  .pmt__content > *:first-child { margin-top: 0; }
  .pmt__content > *:last-child  { margin-bottom: 0; }
  .pmt__content p { margin: 0 0 0.75em; }
  .pmt__content ul,
  .pmt__content ol { margin: 0 0 0.75em 1.25em; padding: 0; }
  .pmt__content li { margin: 0 0 0.35em; }
  .pmt__content a { color: #06c; text-decoration: none; border-bottom: 1px solid rgba(0,102,204,0.3); }
  .pmt__content a:hover { border-bottom-color: #06c; }
  .pmt__content strong { color: #1d1d1f; font-weight: 600; }
  @media (prefers-reduced-motion: reduce) {
    .pmt__summary,
    .pmt__icon::before,
    .pmt__icon::after { transition: none; }
  }
</style>
{%- endif -%}
