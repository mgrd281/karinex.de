{%- comment -%}
  SEO-Optimized Alt Text Helper
  Usage: {% render 'seo-alt-text', image: product.featured_image, title: product.title %}
{%- endcomment -%}

{%- liquid
  assign alt_text = ''
  
  if image.alt != blank
    assign alt_text = image.alt
  elsif title != blank
    assign alt_text = title | append: ' - ' | append: shop.name
  else
    assign alt_text = shop.name | append: ' Product Image'
  endif
  
  echo alt_text | escape
-%}
