{%- doc -%}
  Gender (Geschlecht) filter for collection pages.
  Works entirely client-side via JavaScript — no Search & Discovery app needed.
  Reads data-gender attributes from product grid items and hides/shows them.
  Shown on Uhren and Schuhe collections.

  @param {string} filter_style - 'horizontal' or 'vertical'
  @param {string} sectionId - The section ID
{%- enddoc -%}

{%- capture gender_list -%}
  {%- for product in collection.products limit: 1000 -%}
    {%- capture raw_gender -%}{%- render 'product-gender-value', product: product -%}{%- endcapture -%}
    {%- assign p_gender = raw_gender | strip -%}
    {%- if p_gender != '' -%}|{{ p_gender }}|,{%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- assign gender_entries = gender_list | split: ',' -%}
{%- assign gender_array = gender_list | split: ',' -%}
{%- assign unique_genders = gender_array | uniq | sort -%}

{%- comment -%} Remove blank entries and count {%- endcomment -%}
{%- assign clean_genders = '' -%}
{%- assign gender_count = 0 -%}
{%- for g in unique_genders -%}
  {%- assign g_stripped = g | strip -%}
  {%- if g_stripped != '' -%}
    {%- assign g_value = g_stripped | remove: '|' -%}
    {%- if g_value != '' -%}
      {%- assign g_product_count = 0 -%}
      {%- for entry in gender_entries -%}
        {%- assign entry_stripped = entry | strip -%}
        {%- if entry_stripped == g_stripped -%}
          {%- assign g_product_count = g_product_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign gender_count = gender_count | plus: 1 -%}
      {%- assign gender_with_count = g_value | append: ':' | append: g_product_count -%}
      {%- if clean_genders == '' -%}
        {%- assign clean_genders = gender_with_count -%}
      {%- else -%}
        {%- assign clean_genders = clean_genders | append: '|||' | append: gender_with_count -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- assign final_genders = clean_genders | split: '|||' -%}

{%- if gender_count > 1 -%}
<accordion-custom
  class="facets__item gender-filter-accordion"
  {% if filter_style == 'horizontal' %}
    data-disable-animation-on-desktop="true"
    data-close-with-escape="true"
  {% endif %}
  {% if filter_style == 'vertical' %}
  {% endif %}
>
  <details
    id="Facet-Details-{{ sectionId }}-gender-{{ filter_style }}"
    class="facets__panel"
    {% if filter_style == 'horizontal' %}
      data-auto-close-details="desktop"
    {% endif %}
  >
    <summary class="facets__summary">
      <span class="facets__label" style="font-weight: 700; font-size: 14px;">Geschlecht</span>
      <div class="facets__status-wrapper">
        <span class="gender-filter-count" style="display: none;"></span>
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </div>
    </summary>
    <floating-panel-component
      {% unless filter_style == 'vertical' %}data-close-on-resize{% endunless %}
      class="facets__inputs facets__panel-content details-content{% if filter_style == 'horizontal' %} color-{{ settings.popover_color_scheme }}{% endif %}"
    >
      <div class="facets__inputs-wrapper">
        <ul class="facets__inputs-list list-unstyled">
          {%- for gender in final_genders -%}
            {%- assign gender_parts = gender | split: ':' -%}
            {%- assign gender_stripped = gender_parts[0] | strip -%}
            {%- assign gender_product_count = gender_parts[1] | strip -%}
            {%- if gender_stripped != '' -%}
              {%- assign gender_id = 'gender-filter-' | append: forloop.index | append: '-' | append: filter_style -%}
              {%- if gender_stripped == 'Männlich' -%}
                {%- assign gender_label = 'Herren' -%}
              {%- elsif gender_stripped == 'Weiblich' -%}
                {%- assign gender_label = 'Damen' -%}
              {%- else -%}
                {%- assign gender_label = gender_stripped -%}
              {%- endif -%}
              <li class="facets__inputs-list-item" data-skip-node-update="true">
                <div class="checkbox gender-filter-item">
                  <input
                    type="checkbox"
                    id="{{ gender_id }}"
                    class="checkbox__input js-gender-checkbox"
                    data-gender-value="{{ gender_stripped | escape }}"
                    value="{{ gender_stripped | escape }}"
                  >
                  <label class="checkbox__label" for="{{ gender_id }}" role="checkbox">
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                    <span class="checkbox__label-text">{{ gender_label }} <span style="color: #767676;">({{ gender_product_count }})</span></span>
                  </label>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </floating-panel-component>
  </details>
</accordion-custom>
{%- endif -%}
