{% comment %} --- SUPER SMART UPSELL LOGIC (ENHANCED) --- {% endcomment %}
{% assign upsell_product = nil %}
{% assign reference_item = cart.items.first %}

{% if reference_item %}
  {% assign ref_title = reference_item.product.title | downcase %}
  {% assign target_keyword = nil %}
  {% assign preferred_match = nil %}
  
  {% comment %} Intelligent Mapping {% endcomment %}
  {% if ref_title contains 'office' %}
    {% assign target_keyword = 'windows' %}
    {% assign preferred_match = '11 professional' %}
  {% elsif ref_title contains 'windows' %}
    {% assign target_keyword = 'office' %}
    {% assign preferred_match = '2021' %}
  {% elsif ref_title contains 'server' %}
    {% assign target_keyword = 'cal' %}
  {% elsif ref_title contains 'visio' %}
    {% assign target_keyword = 'project' %}
  {% elsif ref_title contains 'project' %}
    {% assign target_keyword = 'visio' %}
  {% endif %}

  {% comment %} Priority Search: Specific Match {% endcomment %}
  {% if target_keyword and preferred_match %}
      {% for product in collections['all'].products limit: 50 %}
         {% assign p_title = product.title | downcase %}
         {% if p_title contains target_keyword and p_title contains preferred_match and product.available and product.id != reference_item.product.id %}
              {% assign in_cart = false %}
              {% for item in cart.items %}
                  {% if item.product.id == product.id %}{% assign in_cart = true %}{% endif %}
              {% endfor %}
              {% if in_cart == false %}
                  {% assign upsell_product = product %}
                  {% break %}
              {% endif %}
         {% endif %}
      {% endfor %}
  {% endif %}

  {% comment %} Secondary Search: General Keyword Match {% endcomment %}
  {% if upsell_product == nil and target_keyword %}
      {% for product in collections['all'].products limit: 50 %}
         {% assign p_title = product.title | downcase %}
         {% if p_title contains target_keyword and product.available and product.id != reference_item.product.id %}
            {% assign in_cart = false %}
            {% for item in cart.items %}
              {% if item.product.id == product.id %}{% assign in_cart = true %}{% endif %}
            {% endfor %}
            {% if in_cart == false %}
               {% assign upsell_product = product %}
               {% break %}
            {% endif %}
         {% endif %}
      {% endfor %}
  {% endif %}
  
  {% comment %} Fallback: Recommendation from same collection {% endcomment %}
  {% if upsell_product == nil %}
      {% for col in reference_item.product.collections %}
          {% if col.handle != 'all' and col.handle != 'frontpage' %}
              {% for product in col.products limit: 5 %}
                  {% if product.available and product.id != reference_item.product.id %}
                      {% assign in_cart = false %}
                      {% for item in cart.items %}
                          {% if item.product.id == product.id %}{% assign in_cart = true %}{% endif %}
                      {% endfor %}
                      {% if in_cart == false %}
                          {% assign upsell_product = product %}
                          {% break %}
                      {% endif %}
                  {% endif %}
              {% endfor %}
              {% if upsell_product %}{% break %}{% endif %}
          {% endif %}
      {% endfor %}
  {% endif %}
{% endif %}

{% if upsell_product %}
  <div class="cart-upsell" style="border: 1px solid var(--color-border); border-radius: 8px; padding: 15px; margin-bottom: 20px; background-color: rgba(var(--color-foreground-rgb), 0.02);">

    <div style="display: flex; gap: 12px; align-items: center;">
      <a href="{{ upsell_product.url }}" style="width: 64px; height: 64px; flex-shrink: 0; border-radius: 8px; overflow: hidden; background: #fff; border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center;">
        <img src="{{ upsell_product.featured_image | image_url: width: 128 }}" alt="{{ upsell_product.title | escape }}" width="64" height="64" loading="lazy" decoding="async" style="max-width: 100%; max-height: 100%; object-fit: contain;">
      </a>
      <div style="flex-grow: 1; min-width: 0;">
        <a href="{{ upsell_product.url }}" style="text-decoration: none; color: var(--color-foreground); font-size: 13px; font-weight: 600; display: block; line-height: 1.3; margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{ upsell_product.title }}</a>
        <p style="font-size: 13px; color: var(--color-foreground); margin: 0; font-weight: 500;">
           {% if upsell_product.compare_at_price > upsell_product.price %}
              <span style="color: #ef4444; margin-right: 4px;">{{ upsell_product.price | money }}</span>
              <s style="color: #9ca3af; font-size: 11px;">{{ upsell_product.compare_at_price | money }}</s>
           {% else %}
              {{ upsell_product.price | money }}
           {% endif %}
        </p>
      </div>
      <form method="post" action="/cart/add" style="flex-shrink: 0;" data-submit-cart-form>
        <input type="hidden" name="id" value="{{ upsell_product.selected_or_first_available_variant.id }}">
        <button type="submit" class="button button--secondary" style="padding: 0 16px; height: 36px; font-size: 12px; border-radius: 6px; white-space: nowrap; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
          Hinzufügen
        </button>
      </form>
    </div>
  </div>
{% endif %}
{% comment %} --- END SMART UPSELL --- {% endcomment %}
