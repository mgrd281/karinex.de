{%- comment -%}
  Trust Badges Snippet
  Displays trust indicators (SSL, Money-Back, Support, Shipping)
  Usage: {% render 'trust-badges' %}
{%- endcomment -%}

<div class="product-trust-badges">
  <div class="trust-badge-item">
    <div class="trust-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>
    <span class="trust-text">SSL Verschlüsselt</span>
  </div>

  <div class="trust-badge-item">
    <div class="trust-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        <path d="M9 12l2 2 4-4"></path>
      </svg>
    </div>
    <span class="trust-text">100% Originalware</span>
  </div>

  <div class="trust-badge-item">
    <div class="trust-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
      </svg>
    </div>
    <span class="trust-text">Käuferschutz & Support</span>
  </div>

  <div class="trust-badge-item">
    <div class="trust-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 13h-4v-2l-6-5H2v12h3"></path>
        <path d="M22 13v5h-3"></path>
        <path d="M5 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path>
        <path d="M20 21a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path>
        <path d="M15 13H2"></path>
      </svg>
    </div>
    {% if is_digital %}
      <span class="trust-text">Blitzversand per E-Mail</span>
    {% else %}
      <span class="trust-text">Sicherer Versand aus DE</span>
    {% endif %}
  </div>
</div>

<style>
  .product-trust-badges {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 20px;
    margin-bottom: 20px;
    padding: 15px;
    background-color: #f8f9fa; /* Light grey background */
    border-radius: 8px;
    border: 1px solid #e9ecef;
  }

  .trust-badge-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1D4739; /* Brand Primary Color */
    width: 24px;
    height: 24px;
    min-width: 24px;
  }

  .trust-icon svg {
    width: 20px;
    height: 20px;
  }

  .trust-text {
    font-size: 13px;
    font-weight: 500;
    color: #495057;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .product-trust-badges {
      grid-template-columns: repeat(2, 1fr); /* Keep 2x2 grid on desktop for compactness under buttons */
    }
  }
</style>
