        </div>
        <p class="klc-chat-foot">{{ T_secure_strip }}</p>
      </div>
    </div>
  </aside>

  <div class="klc-lightbox" id="klcLightbox" role="dialog" aria-modal="true" aria-label="{{ T_aria_close }}" aria-hidden="true">
    <button type="button" class="klc-lightbox__close" id="klcLightboxClose" aria-label="{{ T_aria_close }}">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <img id="klcLightboxImg" alt="">
  </div>
</div>

<script>
  (function () {
    // Desktop-only widget. On mobile/tablet we bail out before any
    // listener / Crisp loader runs. Reason: Crisp's client script
    // injects inline styles that override our hide-CSS and goes
    // into mobile full-screen mode, which the user saw as a blank
    // white page seconds after the real content rendered.
    try {
      if (window.matchMedia && window.matchMedia('(max-width: 768px)').matches) {
        return;
      }
    } catch (_) {}

    var launcher    = document.getElementById('klcLauncher');
    var panel       = document.getElementById('klcPanel');
    var closeBtn    = document.getElementById('klcClose');
    var backdrop    = document.getElementById('klcBackdrop');
    var liveChatBtn = document.getElementById('klcLiveChatBtn');
    var ctaChat     = document.getElementById('klcCtaChat');
    var chatBack    = document.getElementById('klcChatBack');
    var headerBack  = document.getElementById('klcHeaderBack');
    var chatStream  = document.getElementById('klcChatStream');
    var chatEmpty   = document.getElementById('klcChatEmpty');
    var chatInput   = document.getElementById('klcChatInput');
    var chatSend    = document.getElementById('klcChatSend');
    var chatAttach  = document.getElementById('klcChatAttach');
    var chatFile    = document.getElementById('klcChatFile');
    var lightbox    = document.getElementById('klcLightbox');
    var lightboxImg = document.getElementById('klcLightboxImg');
    var lightboxX   = document.getElementById('klcLightboxClose');
    if (!launcher || !panel) return;

    var CRISP_ID = {{ klc_crisp_id | json }};
    var crispLoaded = false;
    var crispReady  = false;
    var typingEl    = null;
    var hasMessages = false;

    /* ── Helpers ─────────────────────────────────────────── */
    function fmtTime(ts) {
      try {
        var d = ts ? new Date(ts) : new Date();
        return d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
      } catch (_) { return ''; }
    }
    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
      });
    }
    function appendMessage(from, text, ts) {
      if (!chatStream) return;
      if (!hasMessages && chatEmpty) { chatEmpty.remove(); hasMessages = true; }
      removeTyping();
      var div = document.createElement('div');
      div.className = 'klc-msg klc-msg--' + from;
      div.innerHTML = escapeHtml(text || '') +
        '<span class="klc-msg__time">' + fmtTime(ts) + '</span>';
      chatStream.appendChild(div);
      chatStream.scrollTop = chatStream.scrollHeight;
    }

    function appendImage(from, src, ts) {
      if (!chatStream) return null;
      if (!hasMessages && chatEmpty) { chatEmpty.remove(); hasMessages = true; }
      removeTyping();
      var div = document.createElement('div');
      div.className = 'klc-msg klc-msg--' + from + ' klc-msg--image';
      var img = document.createElement('img');
      img.alt = 'Bild';
      img.loading = 'lazy';
      img.src = src;
      img.addEventListener('click', function () { openLightbox(img.src); });
      div.appendChild(img);
      var time = document.createElement('span');
      time.className = 'klc-msg__time';
      time.textContent = fmtTime(ts);
      div.appendChild(time);
      chatStream.appendChild(div);
      chatStream.scrollTop = chatStream.scrollHeight;
      return div;
    }

    function openLightbox(src) {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = src;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
    }
    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
    }
    function showTyping() {
      if (typingEl || !chatStream) return;
      typingEl = document.createElement('div');
      typingEl.className = 'klc-typing';
      typingEl.innerHTML = '<span></span><span></span><span></span>';
      chatStream.appendChild(typingEl);
      chatStream.scrollTop = chatStream.scrollHeight;
    }
    function removeTyping() {
      if (typingEl) { typingEl.remove(); typingEl = null; }
    }

    /* ── Crisp loader (silent — UI hidden via CSS) ───────── */
    var KLC_DEBUG = false; // set true in console: window.KLC_DEBUG = true
    var _seenFingerprints = {};
    function _isSeen(fp) {
      if (!fp) return false;
      if (_seenFingerprints[fp]) return true;
      _seenFingerprints[fp] = true;
      return false;
    }
    function _handleOperatorMessage(msg) {
      if (!msg) return;
      var from = (msg.from || msg.user && msg.user.type || '').toString().toLowerCase();
      // Skip our own outgoing
      if (from === 'user' || from === 'visitor') return;
      // De-dupe via Crisp fingerprint
      if (_isSeen(msg.fingerprint)) return;
      if (KLC_DEBUG) console.log('[KLC] operator message', msg);
      var type = (msg.type || '').toLowerCase();
      if (type === 'file' && msg.content && msg.content.url) {
        var t = (msg.content.type || '').toLowerCase();
        if (t.indexOf('video') === 0) appendVideo('agent', msg.content.url, msg.timestamp);
        else                          appendImage('agent', msg.content.url, msg.timestamp);
        return;
      }
      var content = (typeof msg.content === 'string') ? msg.content
                  : (msg.content && msg.content.text) ? msg.content.text
                  : '';
      if (!content) return;
      appendMessage('agent', content, msg.timestamp);
    }

    var _pollTimer = null;
    function _startPollingFallback() {
      if (_pollTimer) return;
      _pollTimer = setInterval(function () {
        if (!window.$crisp || !window.$crisp.get) return;
        try {
          var messages = window.$crisp.get('chat:messages');
          if (!Array.isArray(messages)) return;
          messages.forEach(_handleOperatorMessage);
        } catch (e) {
          if (KLC_DEBUG) console.warn('[KLC] poll failed', e);
        }
      }, 3500);
    }

    function loadCrisp(cb) {
      if (crispLoaded) { cb && cb(); return; }
      crispLoaded = true;
      window.$crisp = [];
      window.CRISP_WEBSITE_ID = CRISP_ID;
      window.$crisp.push(['safe', true]);
      // Receive — register against multiple lifecycle hooks for robustness
      window.$crisp.push(['on', 'message:received', _handleOperatorMessage]);
      window.$crisp.push(['on', 'message:composer:started', function () { showTyping(); }]);
      window.$crisp.push(['on', 'message:composer:stopped', function () { removeTyping(); }]);
      window.$crisp.push(['on', 'session:loaded', function () {
        if (KLC_DEBUG) console.log('[KLC] crisp session:loaded');
        // Re-register receive after session is loaded (defensive)
        try { window.$crisp.push(['on', 'message:received', _handleOperatorMessage]); } catch (_) {}
      }]);
      var s = document.createElement('script');
      s.src = 'https://client.crisp.chat/l.js';
      s.async = 1;
      s.onload = function () {
        crispReady = true;
        if (KLC_DEBUG) console.log('[KLC] crisp script loaded');
        try { window.$crisp.push(['do', 'chat:open']); } catch (_) {}
        // Polling fallback in case events don't fire reliably
        _startPollingFallback();
        cb && cb();
      };
      document.head.appendChild(s);
    }

    function openChatView() {
      panel.classList.remove('is-pre');
      panel.classList.add('is-chat');
      loadCrisp(function () {
        setTimeout(function () { chatInput && chatInput.focus(); }, 250);
      });
    }
    function closeChatView() {
      panel.classList.remove('is-chat');
    }

    /* ── Pre-chat wizard ───────────────────────────────────── */
    var TOPIC_LABEL = {
      order:   {{ T_topic_order   | json }},
      license: {{ T_topic_license | json }},
      invoice: {{ T_topic_invoice | json }},
      consult: {{ T_topic_consult | json }},
      other:   {{ T_topic_other   | json }}
    };
    var KLC_I18N = {
      formTitle:     {{ T_form_title   | json }},
      formTitleC:    {{ T_form_title_c | json }},
      ctxHeader:     {{ T_ctx_header   | json }},
      ctxTopic:      {{ T_ctx_topic    | json }},
      ctxStatus:     {{ T_ctx_status   | json }},
      ctxReturning:  {{ T_ctx_returning| json }},
      ctxNew:        {{ T_ctx_new      | json }},
      ctxOrder:      {{ T_ctx_order    | json }},
      ctxSoftware:   {{ T_ctx_software | json }},
      ctxPlatform:   {{ T_ctx_platform | json }},
      ctxUsage:      {{ T_ctx_usage    | json }},
      ctxPage:       {{ T_ctx_page     | json }},
      ctxDevice:     {{ T_ctx_device   | json }},
      errImageVideo: {{ T_err_image_video | json }}
    };
    var klcContext = { customerType: '', topic: '', topicLabel: '' };

    function getPreSteps() {
      return document.querySelectorAll('.klc-view--prechat .klc-pre');
    }
    function showPreStep(name) {
      getPreSteps().forEach(function (el) {
        var match = el.getAttribute('data-pre-step') === name;
        el.classList.toggle('is-active', match);
        // Re-trigger entry animation
        if (match) {
          el.style.animation = 'none';
          // eslint-disable-next-line no-unused-expressions
          el.offsetHeight;
          el.style.animation = '';
        }
      });
    }
    function openPrechat() {
      panel.classList.remove('is-chat');
      panel.classList.add('is-pre');
      klcContext = { customerType: '', topic: '', topicLabel: '' };
      // Reset any previously-picked attachments
      klcFormAttachments.forEach(function (a) { try { URL.revokeObjectURL(a.url); } catch (_) {} });
      klcFormAttachments = [];
      if (typeof renderFormAttachments === 'function') renderFormAttachments();
      showPreStep('welcome');
      loadCrisp();
    }
    function closePrechat() {
      panel.classList.remove('is-pre');
    }
    function preBack() {
      var current = document.querySelector('.klc-view--prechat .klc-pre.is-active');
      var step = current && current.getAttribute('data-pre-step');
      if (step === 'form') {
        // form → topic (or welcome if "new" path)
        if (klcContext.customerType === 'new') showPreStep('welcome');
        else showPreStep('topic');
      } else if (step === 'topic') {
        showPreStep('welcome');
      } else {
        closePrechat();
      }
    }

    function applyFieldsForTopic(topic) {
      var fields = document.querySelectorAll('.klc-view--prechat [data-show-for]');
      fields.forEach(function (f) {
        var topics = (f.getAttribute('data-show-for') || '').split(',');
        var show = topics.indexOf(topic) !== -1;
        f.classList.toggle('klc-field--hidden', !show);
        // Required state on visible inputs (only Name + Email + consent are required)
        var inp = f.querySelector('input,textarea');
        if (inp) inp.required = false; // optional secondary fields
      });
    }

    function getDeviceType() {
      var ua = navigator.userAgent || '';
      if (/Mobi|Android|iPhone|iPad/.test(ua)) return /iPad|Tablet/.test(ua) ? 'tablet' : 'mobile';
      return 'desktop';
    }

    /* ── Form attachments (collected, then uploaded after submit) ── */
    var klcFormAttachments = [];   // [{ file, url (local objectURL), type }]
    var formFileInput   = document.getElementById('klcFormFile');
    var formAttachList  = document.getElementById('klcFormAttachList');
    var formDropZone    = formFileInput && formFileInput.closest('.klc-drop');

    function renderFormAttachments() {
      if (!formAttachList) return;
      formAttachList.innerHTML = '';
      formAttachList.hidden = klcFormAttachments.length === 0;
      klcFormAttachments.forEach(function (a, idx) {
        var item = document.createElement('div');
        item.className = 'klc-attach-item';
        var media;
        if (/^video\//.test(a.file.type)) {
          media = document.createElement('video');
          media.muted = true; media.playsInline = true; media.preload = 'metadata';
        } else {
          media = document.createElement('img');
          media.alt = a.file.name;
        }
        media.src = a.url;
        item.appendChild(media);

        if (/^video\//.test(a.file.type)) {
          var badge = document.createElement('span');
          badge.className = 'klc-attach-item__badge';
          badge.textContent = 'Video';
          item.appendChild(badge);
        }

        var rm = document.createElement('button');
        rm.type = 'button';
        rm.className = 'klc-attach-item__remove';
        rm.setAttribute('aria-label', 'Entfernen');
        rm.innerHTML = '&times;';
        rm.addEventListener('click', function (e) {
          e.stopPropagation();
          URL.revokeObjectURL(a.url);
          klcFormAttachments.splice(idx, 1);
          renderFormAttachments();
        });
        item.appendChild(rm);

        formAttachList.appendChild(item);
      });
    }

    function addFormFiles(fileList) {
      Array.prototype.forEach.call(fileList || [], function (f) {
        if (!/^image\/|^video\//.test(f.type)) return;
        klcFormAttachments.push({
          file: f,
          url: URL.createObjectURL(f),
          type: f.type
        });
      });
      renderFormAttachments();
    }

    if (formFileInput) {
      formFileInput.addEventListener('change', function () {
        addFormFiles(formFileInput.files);
        formFileInput.value = '';
      });
    }
    if (formDropZone) {
      ['dragenter','dragover'].forEach(function (ev) {
        formDropZone.addEventListener(ev, function (e) {
          e.preventDefault(); e.stopPropagation();
          formDropZone.classList.add('is-drag');
        });
      });
      ['dragleave','drop'].forEach(function (ev) {
        formDropZone.addEventListener(ev, function (e) {
          e.preventDefault(); e.stopPropagation();
          formDropZone.classList.remove('is-drag');
        });
      });
      formDropZone.addEventListener('drop', function (e) {
        var dt = e.dataTransfer;
        if (dt && dt.files) addFormFiles(dt.files);
      });
    }

    function uploadFormAttachments() {
      if (!klcFormAttachments.length) return;
      // Send each attachment as its own chat bubble + Crisp file message
      klcFormAttachments.forEach(function (a) {
        var isVideo = /^video\//.test(a.file.type);
        var bubble = isVideo
          ? appendVideo('user', a.url, Date.now())
          : appendImage('user', a.url, Date.now());
        if (bubble) bubble.classList.add('klc-msg--uploading');
        uploadFile(a.file).then(function (info) {
          if (bubble) bubble.classList.remove('klc-msg--uploading');
          var tries = 0;
          (function trySend() {
            if (window.$crisp && window.$crisp.push) {
              try {
                window.$crisp.push(['do', 'message:send', ['file', {
                  name: info.name, url: info.url, type: info.type
                }]]);
              } catch (e) { console.warn('Crisp file send failed', e); }
            } else if (tries++ < 60) {
              setTimeout(trySend, 100);
            }
          })();
        }).catch(function () {
          if (bubble) {
            bubble.classList.remove('klc-msg--uploading');
            bubble.classList.add('klc-msg--failed');
          }
        });
      });
      // clear collected list (object URLs are kept alive by the bubbles)
      klcFormAttachments = [];
      renderFormAttachments();
    }

    function pushContextToCrisp(ctx) {
      loadCrisp(function () {
        var tries = 0;
        (function ready() {
          if (window.$crisp && window.$crisp.push) {
            try {
              if (ctx.email) window.$crisp.push(['set', 'user:email', [ctx.email]]);
              if (ctx.name)  window.$crisp.push(['set', 'user:nickname', [ctx.name]]);
              var data = [];
              if (ctx.topicLabel)   data.push(['topic', ctx.topicLabel]);
              if (ctx.orderNumber)  data.push(['order_number', ctx.orderNumber]);
              if (ctx.software)     data.push(['software', ctx.software]);
              if (ctx.platform)     data.push(['platform', ctx.platform]);
              if (ctx.usage)        data.push(['usage', ctx.usage]);
              if (ctx.customerType) data.push(['customer_type', ctx.customerType]);
              data.push(['page_url', ctx.pageUrl]);
              data.push(['device',   ctx.device]);
              data.push(['timestamp', ctx.timestamp]);
              if (data.length) window.$crisp.push(['set', 'session:data', [data]]);
              var seg = ctx.topic ? ['pre-chat', ctx.topic] : ['pre-chat'];
              window.$crisp.push(['set', 'session:segments', [seg, false]]);
              // Compose context message for the agent
              var lines = [];
              lines.push(KLC_I18N.ctxHeader);
              if (ctx.topicLabel)   lines.push(KLC_I18N.ctxTopic    + ': ' + ctx.topicLabel);
              if (ctx.customerType) lines.push(KLC_I18N.ctxStatus   + ': ' + (ctx.customerType === 'returning' ? KLC_I18N.ctxReturning : KLC_I18N.ctxNew));
              if (ctx.orderNumber)  lines.push(KLC_I18N.ctxOrder    + ': ' + ctx.orderNumber);
              if (ctx.software)     lines.push(KLC_I18N.ctxSoftware + ': ' + ctx.software);
              if (ctx.platform)     lines.push(KLC_I18N.ctxPlatform + ': ' + ctx.platform);
              if (ctx.usage)        lines.push(KLC_I18N.ctxUsage    + ': ' + ctx.usage);
              lines.push(KLC_I18N.ctxPage   + ': ' + ctx.pageUrl);
              lines.push(KLC_I18N.ctxDevice + ': ' + ctx.device);
              if (ctx.message) { lines.push(''); lines.push(ctx.message); }
              var text = lines.join('\n');
              // Show in our local chat as a "user" message, then send to Crisp
              appendMessage('user', text, Date.now());
              try { window.$crisp.push(['do', 'message:send', ['text', text]]); }
              catch (e) { console.warn('Crisp context send failed', e); }
            } catch (e) { console.warn('Crisp context push failed', e); }
          } else if (tries++ < 60) {
            setTimeout(ready, 100);
          }
        })();
      });
    }

    function startChatFromContext() {
      panel.classList.remove('is-pre');
      panel.classList.add('is-chat');
      // tiny delay so the chat view is mounted before pushing the context bubble
      setTimeout(function () {
        pushContextToCrisp(klcContext);
        // Send any pre-chat attachments shortly after the context message
        setTimeout(uploadFormAttachments, 600);
        chatInput && chatInput.focus();
      }, 200);
    }

    // Bind welcome step
    document.querySelectorAll('.klc-view--prechat [data-pre-action]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        klcContext.customerType = btn.getAttribute('data-pre-action');
        if (klcContext.customerType === 'new') {
          // Skip topic step — straight into product consultation
          klcContext.topic = 'consult';
          klcContext.topicLabel = TOPIC_LABEL.consult;
          applyFieldsForTopic('consult');
          var eyebrow = document.getElementById('klcFormEyebrow');
          var title   = document.getElementById('klcFormTitle');
          if (eyebrow) eyebrow.textContent = TOPIC_LABEL.consult;
          if (title)   title.textContent   = KLC_I18N.formTitleC;
          showPreStep('form');
        } else {
          showPreStep('topic');
        }
      });
    });

    // Bind topic step
    document.querySelectorAll('.klc-view--prechat [data-pre-topic]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var topic = btn.getAttribute('data-pre-topic');
        klcContext.topic = topic;
        klcContext.topicLabel = TOPIC_LABEL[topic] || topic;
        applyFieldsForTopic(topic);
        var eyebrow = document.getElementById('klcFormEyebrow');
        var title   = document.getElementById('klcFormTitle');
        if (eyebrow) eyebrow.textContent = klcContext.topicLabel;
        if (title)   title.textContent   = topic === 'consult' ? KLC_I18N.formTitleC : KLC_I18N.formTitle;
        showPreStep('form');
      });
    });

    // Bind form submit
    /* Auto-fill the "Welche Software?" field from page context:
       - On a product page, the .klc root carries data-klc-product;
         use it and remember it for later.
       - On any other page (e.g. home), fall back to the last product
         the visitor looked at, so the consult form is pre-described
         without them typing the product name. */
    (function () {
      var LAST_KEY = 'klc_last_product';
      var PLAT_KEY = 'klc_last_platform';
      var root = document.querySelector('.klc');
      var current = root ? (root.getAttribute('data-klc-product') || '').trim() : '';
      var platform = root ? (root.getAttribute('data-klc-platform') || '').trim() : '';
      if (current) {
        try { localStorage.setItem(LAST_KEY, current); } catch (e) {}
      }
      if (platform) {
        try { localStorage.setItem(PLAT_KEY, platform); } catch (e) {}
      }
      var sw = document.getElementById('klcFieldSoftware');
      if (sw && !sw.value) {
        var suggestion = current;
        if (!suggestion) {
          try { suggestion = (localStorage.getItem(LAST_KEY) || '').trim(); } catch (e) { suggestion = ''; }
        }
        if (suggestion) sw.value = suggestion;
      }
      // Pre-select the platform chip that matches the product (or the
      // last product viewed), unless the visitor already picked one.
      var plat = platform;
      if (!plat) {
        try { plat = (localStorage.getItem(PLAT_KEY) || '').trim(); } catch (e) { plat = ''; }
      }
      if (plat) {
        var radios = document.querySelectorAll('input[name="platform"]');
        var anyChecked = false;
        for (var i = 0; i < radios.length; i++) { if (radios[i].checked) { anyChecked = true; break; } }
        if (!anyChecked) {
          for (var j = 0; j < radios.length; j++) {
            if (radios[j].value === plat) { radios[j].checked = true; break; }
          }
        }
      }
    })();

    var preForm = document.getElementById('klcPreForm');
    if (preForm) {
      preForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var fd = new FormData(preForm);
        var name    = (fd.get('name')    || '').toString().trim();
        var email   = (fd.get('email')   || '').toString().trim();
        var consent = !!fd.get('consent');
        var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        var fields = preForm.querySelectorAll('.klc-field');
        fields.forEach(function (f) { f.classList.remove('klc-field--error'); });
        var firstError = null;
        // Only email + consent are required; name is optional now.
        if (!emailOk) { var ef = preForm.querySelector('#klcFieldEmail').closest('.klc-field'); ef.classList.add('klc-field--error'); firstError = firstError || ef; }
        if (!consent) {
          var cl = preForm.querySelector('.klc-consent');
          cl.style.color = '#c62828';
          firstError = firstError || cl;
        }
        if (firstError) { firstError.scrollIntoView({ behavior: 'smooth', block: 'center' }); return; }

        // Build context object
        klcContext.name        = name;
        klcContext.email       = email;
        klcContext.orderNumber = (fd.get('order_number') || '').toString().trim();
        klcContext.software    = (fd.get('software')     || '').toString().trim();
        klcContext.platform    = (fd.get('platform')     || '').toString().trim();
        klcContext.usage       = (fd.get('usage')        || '').toString().trim();
        klcContext.message     = (fd.get('message')      || '').toString().trim();
        klcContext.pageUrl     = window.location.href;
        klcContext.device      = getDeviceType();
        klcContext.timestamp   = new Date().toISOString();

        showPreStep('connecting');
        setTimeout(startChatFromContext, 1100);
      });
    }

    function sendMessage() {
      if (!chatInput) return;
      var text = chatInput.value.trim();
      if (!text) return;
      appendMessage('user', text, Date.now());
      chatInput.value = '';
      autoSize();
      chatSend.disabled = true;

      loadCrisp(function () {
        var tries = 0;
        (function trySend() {
          if (window.$crisp && window.$crisp.push) {
            try { window.$crisp.push(['do', 'message:send', ['text', text]]); }
            catch (e) { console.warn('Crisp send failed', e); }
          } else if (tries++ < 40) {
            setTimeout(trySend, 100);
          }
        })();
      });
    }

    function autoSize() {
      if (!chatInput) return;
      chatInput.style.height = 'auto';
      chatInput.style.height = Math.min(chatInput.scrollHeight, 96) + 'px';
    }

    /* ── Image upload ─────────────────────────────────────
       Default uploader: tmpfiles.org (free, no auth, 60-min retention).
       To use your own backend, define:
         window.KARINEX_CHAT_UPLOADER = function (file) {
           return fetch('/upload', { method:'POST', body: file })
             .then(r => r.json())   // { url, name, type }
         }
    */
    /* tmpfiles.org tops out around 100 MB per file. We do NOT enforce a
       client-side cap — files that exceed the host's limit will simply
       fall into the failure path and the user will see "Upload fehlgeschlagen". */
    function defaultUploader(file) {
      var fd = new FormData();
      fd.append('file', file);
      return fetch('https://tmpfiles.org/api/v1/upload', { method: 'POST', body: fd })
        .then(function (r) {
          if (!r.ok) throw new Error('upload-http-' + r.status);
          return r.json();
        })
        .then(function (j) {
          var u = j && j.data && j.data.url;
          if (!u) throw new Error('upload-no-url');
          // tmpfiles returns viewer URL like https://tmpfiles.org/12345/name.jpg
          // direct download URL: https://tmpfiles.org/dl/12345/name.jpg
          var direct = u.replace('tmpfiles.org/', 'tmpfiles.org/dl/');
          return { url: direct, name: file.name, type: file.type };
        });
    }

    function uploadFile(file) {
      var uploader = window.KARINEX_CHAT_UPLOADER || defaultUploader;
      return Promise.resolve().then(function () { return uploader(file); });
    }

    function appendVideo(from, src, ts) {
      if (!chatStream) return null;
      if (!hasMessages && chatEmpty) { chatEmpty.remove(); hasMessages = true; }
      removeTyping();
      var div = document.createElement('div');
      div.className = 'klc-msg klc-msg--' + from + ' klc-msg--video';
      var v = document.createElement('video');
      v.src = src;
      v.controls = true;
      v.playsInline = true;
      v.preload = 'metadata';
      div.appendChild(v);
      var time = document.createElement('span');
      time.className = 'klc-msg__time';
      time.textContent = fmtTime(ts);
      div.appendChild(time);
      chatStream.appendChild(div);
      chatStream.scrollTop = chatStream.scrollHeight;
      return div;
    }

    function handleFilePick(file) {
      if (!file || !chatStream) return;
      var isImage = /^image\//.test(file.type);
      var isVideo = /^video\//.test(file.type);
      if (!isImage && !isVideo) {
        alert(KLC_I18N.errImageVideo);
        return;
      }
      // optimistic preview
      var localUrl = URL.createObjectURL(file);
      var bubble = isVideo
        ? appendVideo('user', localUrl, Date.now())
        : appendImage('user', localUrl, Date.now());
      if (bubble) bubble.classList.add('klc-msg--uploading');

      loadCrisp(function () {
        uploadFile(file).then(function (info) {
          if (bubble) bubble.classList.remove('klc-msg--uploading');
          // Send to Crisp
          var tries = 0;
          (function trySend() {
            if (window.$crisp && window.$crisp.push) {
              try {
                window.$crisp.push(['do', 'message:send', ['file', {
                  name: info.name,
                  url:  info.url,
                  type: info.type
                }]]);
              } catch (e) { console.warn('Crisp file send failed', e); }
            } else if (tries++ < 40) {
              setTimeout(trySend, 100);
            }
          })();
        }).catch(function (err) {
          console.warn('Karinex chat: image upload failed', err);
          if (bubble) {
            bubble.classList.remove('klc-msg--uploading');
            bubble.classList.add('klc-msg--failed');
          }
        });
      });
    }

    /* ── Panel open/close ────────────────────────────────── */
    function openPanel()  {
      panel.classList.add('is-open');
      backdrop.classList.add('is-open');
      launcher.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
    }
    function closePanel() {
      panel.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      launcher.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
    }
    function togglePanel() {
      panel.classList.contains('is-open') ? closePanel() : openPanel();
    }

    /* ── Wiring ──────────────────────────────────────────── */
    launcher.addEventListener('click', togglePanel);
    closeBtn.addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);
    if (liveChatBtn) liveChatBtn.addEventListener('click', openPrechat);
    if (ctaChat)     ctaChat.addEventListener('click', openPrechat);
    if (chatBack)    chatBack.addEventListener('click', closeChatView);
    if (headerBack)  headerBack.addEventListener('click', function () {
      if (panel.classList.contains('is-pre')) preBack();
      else closeChatView();
    });

    if (chatInput) {
      chatInput.addEventListener('input', function () {
        chatSend.disabled = !chatInput.value.trim();
        autoSize();
      });
      chatInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      });
    }
    if (chatSend) chatSend.addEventListener('click', sendMessage);

    if (chatAttach && chatFile) {
      chatAttach.addEventListener('click', function () { chatFile.click(); });
      chatFile.addEventListener('change', function () {
        var files = chatFile.files ? Array.prototype.slice.call(chatFile.files) : [];
        files.forEach(handleFilePick);
        chatFile.value = ''; // allow re-select of same files
      });
    }

    // Lightbox controls
    if (lightboxX) lightboxX.addEventListener('click', closeLightbox);
    if (lightbox)  lightbox.addEventListener('click', function (e) {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      if (lightbox && lightbox.classList.contains('is-open')) { closeLightbox(); return; }
      if (panel.classList.contains('is-open')) {
        if (panel.classList.contains('is-chat'))      closeChatView();
        else if (panel.classList.contains('is-pre')) preBack();
        else closePanel();
      }
    });

    // Teaser briefly after load
    setTimeout(function () {
      if (!panel.classList.contains('is-open')) {
        launcher.classList.add('klc-show-teaser');
        setTimeout(function () { launcher.classList.remove('klc-show-teaser'); }, 4200);
      }
    }, 2500);

    // Pre-warm Crisp on idle so first send is instant
    var idlePrewarm = function () {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(function () { loadCrisp(); }, { timeout: 8000 });
      } else {
        setTimeout(function () { loadCrisp(); }, 6000);
      }
    };
    if (document.readyState === 'complete') idlePrewarm();
    else window.addEventListener('load', idlePrewarm);

    window.KarinexChat = {
      open:         openPanel,
      close:        closePanel,
      toggle:       togglePanel,
      openLiveChat: function () { openPanel(); openPrechat(); },
      openChatDirect: function () { openPanel(); openChatView(); }
    };
  })();
</script>
