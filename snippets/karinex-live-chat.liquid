<script>
  (function () {
    var launcher    = document.getElementById('klcLauncher');
    var panel       = document.getElementById('klcPanel');
    var closeBtn    = document.getElementById('klcClose');
    var backdrop    = document.getElementById('klcBackdrop');
    var liveChatBtn = document.getElementById('klcLiveChatBtn');
    var ctaChat     = document.getElementById('klcCtaChat');
    var chatBack    = document.getElementById('klcChatBack');
    var headerBack  = document.getElementById('klcHeaderBack');
    var chatStream  = document.getElementById('klcChatStream');
    var chatEmpty   = document.getElementById('klcChatEmpty');
    var chatInput   = document.getElementById('klcChatInput');
    var chatSend    = document.getElementById('klcChatSend');
    var chatAttach  = document.getElementById('klcChatAttach');
    var chatFile    = document.getElementById('klcChatFile');
    var lightbox    = document.getElementById('klcLightbox');
    var lightboxImg = document.getElementById('klcLightboxImg');
    var lightboxX   = document.getElementById('klcLightboxClose');
    if (!launcher || !panel) return;

    var CRISP_ID = {{ klc_crisp_id | json }};
    var crispLoaded = false;
    var crispReady  = false;
    var typingEl    = null;
    var hasMessages = false;

    /* ── Helpers ─────────────────────────────────────────── */
    function fmtTime(ts) {
      try {
        var d = ts ? new Date(ts) : new Date();
        return d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
      } catch (_) { return ''; }
    }
    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
      });
    }
    function appendMessage(from, text, ts) {
      if (!chatStream) return;
      if (!hasMessages && chatEmpty) { chatEmpty.remove(); hasMessages = true; }
      removeTyping();
      var div = document.createElement('div');
      div.className = 'klc-msg klc-msg--' + from;
      div.innerHTML = escapeHtml(text || '') +
        '<span class="klc-msg__time">' + fmtTime(ts) + '</span>';
      chatStream.appendChild(div);
      chatStream.scrollTop = chatStream.scrollHeight;
    }

    function appendImage(from, src, ts) {
      if (!chatStream) return null;
      if (!hasMessages && chatEmpty) { chatEmpty.remove(); hasMessages = true; }
      removeTyping();
      var div = document.createElement('div');
      div.className = 'klc-msg klc-msg--' + from + ' klc-msg--image';
      var img = document.createElement('img');
      img.alt = 'Bild';
      img.loading = 'lazy';
      img.src = src;
      img.addEventListener('click', function () { openLightbox(img.src); });
      div.appendChild(img);
      var time = document.createElement('span');
      time.className = 'klc-msg__time';
      time.textContent = fmtTime(ts);
      div.appendChild(time);
      chatStream.appendChild(div);
      chatStream.scrollTop = chatStream.scrollHeight;
      return div;
    }

    function openLightbox(src) {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = src;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
    }
    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
    }
    function showTyping() {
      if (typingEl || !chatStream) return;
      typingEl = document.createElement('div');
      typingEl.className = 'klc-typing';
      typingEl.innerHTML = '<span></span><span></span><span></span>';
      chatStream.appendChild(typingEl);
      chatStream.scrollTop = chatStream.scrollHeight;
    }
    function removeTyping() {
      if (typingEl) { typingEl.remove(); typingEl = null; }
    }

    /* ── Crisp loader (silent — UI hidden via CSS) ───────── */
    function loadCrisp(cb) {
      if (crispLoaded) { cb && cb(); return; }
      crispLoaded = true;
      window.$crisp = [];
      window.CRISP_WEBSITE_ID = CRISP_ID;
      // run before script loads — these get queued
      window.$crisp.push(['safe', true]);
      window.$crisp.push(['do', 'chat:hide']);
      // wire receive
      window.$crisp.push(['on', 'message:received', function (msg) {
        if (msg && msg.type === 'file') return; // handled by file listener below
        var content = (msg && typeof msg.content === 'string') ? msg.content
                    : (msg && msg.content && msg.content.text) ? msg.content.text
                    : '';
        if (!content) return;
        appendMessage('agent', content, msg && msg.timestamp);
      }]);
      window.$crisp.push(['on', 'message:composer:started', function () { showTyping(); }]);
      window.$crisp.push(['on', 'message:composer:stopped', function () { removeTyping(); }]);
      // Agent-sent file
      try {
        window.$crisp.push(['on', 'message:received', function (msg) {
          if (msg && msg.type === 'file' && msg.content && msg.content.url) {
            appendImage('agent', msg.content.url, msg.timestamp);
          }
        }]);
      } catch (_) {}
      var s = document.createElement('script');
      s.src = 'https://client.crisp.chat/l.js';
      s.async = 1;
      s.onload = function () {
        crispReady = true;
        // Always keep their UI hidden
        try { window.$crisp.push(['do', 'chat:hide']); } catch (_) {}
        cb && cb();
      };
      document.head.appendChild(s);
    }

    function openChatView() {
      panel.classList.add('is-chat');
      loadCrisp(function () {
        setTimeout(function () { chatInput && chatInput.focus(); }, 250);
      });
    }
    function closeChatView() {
      panel.classList.remove('is-chat');
    }

    function sendMessage() {
      if (!chatInput) return;
      var text = chatInput.value.trim();
      if (!text) return;
      appendMessage('user', text, Date.now());
      chatInput.value = '';
      autoSize();
      chatSend.disabled = true;

      loadCrisp(function () {
        var tries = 0;
        (function trySend() {
          if (window.$crisp && window.$crisp.push) {
            try { window.$crisp.push(['do', 'message:send', ['text', text]]); }
            catch (e) { console.warn('Crisp send failed', e); }
          } else if (tries++ < 40) {
            setTimeout(trySend, 100);
          }
        })();
      });
    }

    function autoSize() {
      if (!chatInput) return;
      chatInput.style.height = 'auto';
      chatInput.style.height = Math.min(chatInput.scrollHeight, 96) + 'px';
    }

    /* ── Image upload ─────────────────────────────────────
       Default uploader: tmpfiles.org (free, no auth, 60-min retention).
       To use your own backend, define:
         window.KARINEX_CHAT_UPLOADER = function (file) {
           return fetch('/upload', { method:'POST', body: file })
             .then(r => r.json())   // { url, name, type }
         }
    */
    var MAX_FILE_BYTES = 8 * 1024 * 1024; // 8 MB
    function defaultUploader(file) {
      var fd = new FormData();
      fd.append('file', file);
      return fetch('https://tmpfiles.org/api/v1/upload', { method: 'POST', body: fd })
        .then(function (r) {
          if (!r.ok) throw new Error('upload-http-' + r.status);
          return r.json();
        })
        .then(function (j) {
          var u = j && j.data && j.data.url;
          if (!u) throw new Error('upload-no-url');
          // tmpfiles returns viewer URL like https://tmpfiles.org/12345/name.jpg
          // direct download URL: https://tmpfiles.org/dl/12345/name.jpg
          var direct = u.replace('tmpfiles.org/', 'tmpfiles.org/dl/');
          return { url: direct, name: file.name, type: file.type };
        });
    }

    function uploadFile(file) {
      var uploader = window.KARINEX_CHAT_UPLOADER || defaultUploader;
      return Promise.resolve().then(function () { return uploader(file); });
    }

    function handleFilePick(file) {
      if (!file || !chatStream) return;
      if (!/^image\//.test(file.type)) {
        alert('Bitte wählen Sie ein Bild aus.');
        return;
      }
      if (file.size > MAX_FILE_BYTES) {
        alert('Datei ist zu groß (max. 8 MB).');
        return;
      }
      // optimistic preview
      var localUrl = URL.createObjectURL(file);
      var bubble = appendImage('user', localUrl, Date.now());
      if (bubble) bubble.classList.add('klc-msg--uploading');

      loadCrisp(function () {
        uploadFile(file).then(function (info) {
          if (bubble) bubble.classList.remove('klc-msg--uploading');
          // Send to Crisp
          var tries = 0;
          (function trySend() {
            if (window.$crisp && window.$crisp.push) {
              try {
                window.$crisp.push(['do', 'message:send', ['file', {
                  name: info.name,
                  url:  info.url,
                  type: info.type
                }]]);
              } catch (e) { console.warn('Crisp file send failed', e); }
            } else if (tries++ < 40) {
              setTimeout(trySend, 100);
            }
          })();
        }).catch(function (err) {
          console.warn('Karinex chat: image upload failed', err);
          if (bubble) {
            bubble.classList.remove('klc-msg--uploading');
            bubble.classList.add('klc-msg--failed');
          }
        });
      });
    }

    /* ── Panel open/close ────────────────────────────────── */
    function openPanel()  {
      panel.classList.add('is-open');
      backdrop.classList.add('is-open');
      launcher.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
    }
    function closePanel() {
      panel.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      launcher.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
    }
    function togglePanel() {
      panel.classList.contains('is-open') ? closePanel() : openPanel();
    }

    /* ── Wiring ──────────────────────────────────────────── */
    launcher.addEventListener('click', togglePanel);
    closeBtn.addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);
    if (liveChatBtn) liveChatBtn.addEventListener('click', openChatView);
    if (ctaChat)     ctaChat.addEventListener('click', openChatView);
    if (chatBack)    chatBack.addEventListener('click', closeChatView);
    if (headerBack)  headerBack.addEventListener('click', closeChatView);

    if (chatInput) {
      chatInput.addEventListener('input', function () {
        chatSend.disabled = !chatInput.value.trim();
        autoSize();
      });
      chatInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      });
    }
    if (chatSend) chatSend.addEventListener('click', sendMessage);

    if (chatAttach && chatFile) {
      chatAttach.addEventListener('click', function () { chatFile.click(); });
      chatFile.addEventListener('change', function () {
        var f = chatFile.files && chatFile.files[0];
        if (f) handleFilePick(f);
        chatFile.value = ''; // allow re-select of same file
      });
    }

    // Lightbox controls
    if (lightboxX) lightboxX.addEventListener('click', closeLightbox);
    if (lightbox)  lightbox.addEventListener('click', function (e) {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      if (lightbox && lightbox.classList.contains('is-open')) { closeLightbox(); return; }
      if (panel.classList.contains('is-open')) {
        if (panel.classList.contains('is-chat')) closeChatView();
        else closePanel();
      }
    });

    // Teaser briefly after load
    setTimeout(function () {
      if (!panel.classList.contains('is-open')) {
        launcher.classList.add('klc-show-teaser');
        setTimeout(function () { launcher.classList.remove('klc-show-teaser'); }, 4200);
      }
    }, 2500);

    // Pre-warm Crisp on idle so first send is instant
    var idlePrewarm = function () {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(function () { loadCrisp(); }, { timeout: 8000 });
      } else {
        setTimeout(function () { loadCrisp(); }, 6000);
      }
    };
    if (document.readyState === 'complete') idlePrewarm();
    else window.addEventListener('load', idlePrewarm);

    window.KarinexChat = {
      open:         openPanel,
      close:        closePanel,
      toggle:       togglePanel,
      openLiveChat: function () { openPanel(); openChatView(); }
    };
  })();
</script>
