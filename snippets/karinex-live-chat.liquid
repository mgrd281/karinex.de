{%- comment -%}
  Karinex Live Chat Widget
  Floating, brand-matched launcher + panel.
  Aesthetic: luxury ecommerce, Karinex deep-green palette (#1D4739),
  Newsreader serif, soft green shadows, champagne-gold pin-stripe accents.
  Backend: Crisp Chat (live chat) — default UI hidden, transport only.
  Render globally from layout/theme.liquid (before </body>).
{%- endcomment -%}

{%- assign klc_crisp_id = '3dc17a60-f1b3-4b84-9cb5-2998ab31396a' -%}

<style>
  /* Completely hide Crisp's UI — we use only our native Karinex green panel as the chat surface */
  #crisp-chatbox,
  .crisp-client { display: none !important; visibility: hidden !important; pointer-events: none !important; }
</style>

<style>
  .klc {
    /* Karinex brand green palette */
    --klc-green:       #1D4739;
    --klc-green-hi:    #2d6b54;
    --klc-green-deep:  #0d2e22;
    --klc-green-dark:  #0a2118;
    --klc-green-soft:  #e6efeb;
    /* Subtle champagne-gold accent — used only as a thin underline / line */
    --klc-accent:      #c9a84c;
    --klc-cream:       #faf7f0;
    --klc-surface:     #ffffff;
    --klc-surface-2:   #f4f1ea;
    --klc-ink:         #0d2e22;
    --klc-ink-soft:    #2a4a3f;
    --klc-ink-mute:    #6b8079;
    --klc-line:       rgba(29,71,57,0.18);
    --klc-line-soft:  rgba(26,26,26,0.06);
    --klc-online:     #2e9c5c;
    --klc-shadow-bubble: 0 10px 28px rgba(29,71,57,0.40), 0 4px 10px rgba(0,0,0,0.10);
    --klc-shadow-panel:  0 24px 70px rgba(26,26,26,0.22), 0 6px 18px rgba(29,71,57,0.10);
    --klc-radius-panel: 20px;
    --klc-radius-row:   14px;
    --klc-ease:         cubic-bezier(.22,.61,.36,1);
    --klc-ease-spring:  cubic-bezier(.34,1.56,.64,1);
    --klc-font-serif:   'Newsreader', Georgia, 'Times New Roman', serif;
    --klc-font-accent:  'Red Hat Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* ── Launcher Bubble ────────────────────────────────────────── */
  .klc-launcher {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 9998;
    width: 62px;
    height: 62px;
    border: 1px solid rgba(201,168,76,.35);
    border-radius: 50%;
    cursor: pointer;
    background:
      radial-gradient(120% 120% at 30% 20%, #ffffff 0%, var(--klc-cream) 70%, #f1ebd8 100%);
    box-shadow:
      0 14px 32px rgba(29,71,57,.18),
      0 4px 10px rgba(0,0,0,.06),
      inset 0 1px 0 rgba(255,255,255,.9);
    color: var(--klc-green-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .35s var(--klc-ease-spring), box-shadow .3s var(--klc-ease);
    -webkit-tap-highlight-color: transparent;
  }
  .klc-launcher::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(201,168,76,.30), transparent 70%);
    opacity: 0;
    transition: opacity .35s var(--klc-ease);
    z-index: -1;
  }
  .klc-launcher:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow:
      0 18px 40px rgba(29,71,57,.22),
      0 6px 14px rgba(0,0,0,.08),
      inset 0 1px 0 rgba(255,255,255,.95);
  }
  .klc-launcher:hover::after { opacity: 1; }
  .klc-launcher:active { transform: translateY(-1px) scale(.98); }
  .klc-launcher:focus-visible { outline: none; box-shadow:
    0 14px 32px rgba(29,71,57,.18),
    0 0 0 4px rgba(201,168,76,.45),
    inset 0 1px 0 rgba(255,255,255,.9); }

  .klc-launcher__icon { width: 26px; height: 26px; transition: transform .4s var(--klc-ease-spring); }
  .klc-launcher[aria-expanded="true"] .klc-launcher__icon--chat { transform: scale(0) rotate(-45deg); position: absolute; }
  .klc-launcher[aria-expanded="false"] .klc-launcher__icon--close { transform: scale(0) rotate(45deg); position: absolute; }
  .klc-launcher__icon--close { transform: scale(0) rotate(45deg); position: absolute; }
  .klc-launcher[aria-expanded="true"] .klc-launcher__icon--close { transform: scale(1) rotate(0); position: static; }

  /* online pulse dot on launcher */
  .klc-launcher__pulse {
    position: absolute;
    top: 6px; right: 6px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--klc-online);
    border: 2px solid #fff;
    box-shadow: 0 0 0 0 rgba(46,156,92,.6);
    animation: klc-pulse 2.2s ease-out infinite;
  }
  @keyframes klc-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(46,156,92,.55); }
    70%  { box-shadow: 0 0 0 10px rgba(46,156,92,0); }
    100% { box-shadow: 0 0 0 0 rgba(46,156,92,0); }
  }

  /* tooltip teaser */
  .klc-launcher__teaser {
    position: absolute;
    right: 72px;
    top: 50%;
    transform: translateY(-50%) translateX(8px);
    background: var(--klc-ink);
    color: #fff;
    font-family: var(--klc-font-accent);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-radius: 999px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s var(--klc-ease), transform .35s var(--klc-ease-spring);
    box-shadow: 0 8px 24px rgba(0,0,0,.18);
  }
  .klc-launcher__teaser::after {
    content: '';
    position: absolute;
    right: -5px; top: 50%;
    transform: translateY(-50%) rotate(45deg);
    width: 10px; height: 10px;
    background: var(--klc-ink);
  }
  .klc-launcher:hover .klc-launcher__teaser,
  .klc-show-teaser .klc-launcher__teaser { opacity: 1; transform: translateY(-50%) translateX(0); }
  .klc-launcher[aria-expanded="true"] .klc-launcher__teaser { opacity: 0 !important; }

  /* ── Panel ──────────────────────────────────────────────────── */
  .klc-panel {
    position: fixed;
    right: 22px;
    bottom: 100px;
    z-index: 9999;
    width: min(380px, calc(100vw - 32px));
    max-height: min(640px, calc(100vh - 130px));
    background: var(--klc-surface);
    border-radius: var(--klc-radius-panel);
    box-shadow: var(--klc-shadow-panel);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px) scale(.96);
    transform-origin: bottom right;
    pointer-events: none;
    transition: opacity .28s var(--klc-ease), transform .35s var(--klc-ease-spring);
    font-family: var(--klc-font-serif);
    color: var(--klc-ink);
  }
  .klc-panel.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Header */
  .klc-header {
    position: relative;
    padding: 28px 22px 26px;
    background:
      radial-gradient(80% 90% at 50% 0%, rgba(45,107,84,.40) 0%, transparent 65%),
      linear-gradient(135deg, #0a2118 0%, #1D4739 55%, #0a2118 100%);
    color: #eef3f0;
    overflow: hidden;
  }
  .klc-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(29,71,57,.10) 50%, transparent 100%);
    pointer-events: none;
  }
  /* ── Wordmark header — minimal luxury concierge stationery ── */
  .klc-header__brand {
    position: relative;
    text-align: center;
    padding: 4px 56px;
    pointer-events: none;
  }
  .klc-header__wordmark {
    margin: 0;
    font-family: var(--klc-font-accent);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1;
    text-indent: .32em;
    text-shadow:
      0 0 18px rgba(201,168,76,.28),
      0 0 40px rgba(201,168,76,.14),
      0 2px 6px rgba(0,0,0,.35);
  }
  .klc-header__rule {
    display: block;
    width: 38px;
    height: 1px;
    margin: 11px auto 9px;
    background: linear-gradient(90deg, transparent, var(--klc-accent), transparent);
    opacity: .85;
  }
  .klc-header__tagline {
    margin: 0;
    font-family: var(--klc-font-accent);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .26em;
    text-transform: uppercase;
    color: var(--klc-accent);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .klc-header__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--klc-online);
    box-shadow: 0 0 0 0 rgba(46,156,92,.6), 0 0 10px rgba(46,156,92,.55);
    animation: klc-pulse 2.2s ease-out infinite;
  }
  .klc-header__close {
    position: absolute;
    top: 16px; right: 16px;
    z-index: 2;
    width: 30px; height: 30px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.10);
    color: #eef3f0;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s var(--klc-ease), transform .25s var(--klc-ease-spring);
  }
  .klc-header__close:hover { background: rgba(255,255,255,.18); transform: rotate(90deg); }
  .klc-header__close:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(29,71,57,.55); }

  /* Back button inside header — only shown in chat view */
  .klc-header__back {
    position: absolute;
    top: 16px; left: 16px;
    z-index: 2;
    width: 30px; height: 30px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.10);
    color: #eef3f0;
    cursor: pointer;
    display: none;
    align-items: center; justify-content: center;
    transition: background .2s var(--klc-ease), transform .25s var(--klc-ease-spring);
    opacity: 0;
  }
  .klc-header__back:hover { background: rgba(255,255,255,.18); }
  .klc-header__back:hover svg { transform: translateX(-2px); }
  .klc-header__back svg { transition: transform .25s var(--klc-ease-spring); }
  .klc-header__back:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(29,71,57,.55); }

  .klc-panel.is-chat .klc-header__back { display: flex; opacity: 1; }
  .klc-panel.is-chat .klc-header { padding-bottom: 18px; transition: padding .3s var(--klc-ease); }
  .klc-panel.is-chat .klc-header__welcome,
  .klc-panel.is-chat .klc-chat-bar,
  .klc-panel.is-chat .klc-divider { display: none; }

  .klc-header__welcome {
    margin: 22px 0 0;
    font-family: var(--klc-font-serif);
    font-weight: 400;
    font-size: 13.5px;
    line-height: 1.6;
    color: #c5d3cc;
    text-align: center;
    max-width: 280px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
  }

  /* divider strip */
  .klc-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--klc-accent) 50%, transparent);
    opacity: .55;
  }

  /* Body */
  .klc-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 16px 8px;
    background: linear-gradient(180deg, var(--klc-cream) 0%, var(--klc-surface) 35%);
    scrollbar-width: thin;
    scrollbar-color: var(--klc-green-hi) transparent;
  }
  .klc-body::-webkit-scrollbar { width: 6px; }
  .klc-body::-webkit-scrollbar-thumb { background: var(--klc-green-hi); border-radius: 6px; }

  .klc-section-label {
    margin: 6px 4px 8px;
    font-family: var(--klc-font-accent);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--klc-ink-mute);
  }

  /* Quick-action rows — flat, no fill, no shadow */
  .klc-row {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 6px;
    border: none;
    background: transparent;
    text-decoration: none;
    color: var(--klc-ink);
    cursor: pointer;
    width: 100%;
    text-align: left;
    border-bottom: 1px solid var(--klc-line-soft);
    transition: color .2s var(--klc-ease);
    -webkit-tap-highlight-color: transparent;
  }
  .klc-row:last-child { border-bottom: none; }
  .klc-row:hover { color: var(--klc-green); }
  .klc-row:focus-visible { outline: none; box-shadow: 0 0 0 2px rgba(29,71,57,.35); border-radius: 4px; }

  .klc-row__icon {
    width: 36px; height: 36px;
    border-radius: 0;
    background: transparent;
    border: none;
    display: flex; align-items: center; justify-content: center;
    color: var(--klc-green);
    flex-shrink: 0;
    transition: transform .3s var(--klc-ease-spring);
  }
  .klc-row:hover .klc-row__icon { transform: translateX(1px); }
  .klc-row__icon svg { width: 22px; height: 22px; }

  .klc-row__txt { flex: 1; min-width: 0; }
  .klc-row__title {
    font-family: var(--klc-font-serif);
    font-weight: 500;
    font-size: 15px;
    line-height: 1.25;
    color: var(--klc-ink);
    display: block;
  }
  .klc-row__meta {
    font-family: var(--klc-font-accent);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--klc-ink-mute);
    margin-top: 3px;
    display: block;
  }
  .klc-row__chev {
    color: var(--klc-ink-mute);
    transition: transform .3s var(--klc-ease-spring), color .25s var(--klc-ease);
  }
  .klc-row:hover .klc-row__chev { transform: translateX(4px); color: var(--klc-green-dark); }

  .klc-row--accent .klc-row__title { color: var(--klc-green); font-weight: 600; }
  .klc-row--accent .klc-row__icon { color: var(--klc-green); }

  /* Footer CTA */
  .klc-foot {
    padding: 14px 16px 18px;
    background: var(--klc-surface);
    border-top: 1px solid var(--klc-line-soft);
  }
  .klc-cta {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%;
    padding: 15px 18px;
    border: none;
    border-radius: 10px;
    background: var(--klc-green);
    color: #faf7f0;
    font-family: var(--klc-font-accent);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: .2em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: none;
    transition: background .25s var(--klc-ease);
    text-decoration: none;
  }
  .klc-cta:hover { background: var(--klc-green-deep); }
  .klc-cta:active { background: var(--klc-green-dark); }
  .klc-cta:focus-visible { outline: none; box-shadow: 0 0 0 2px rgba(201,168,76,.55); }
  .klc-cta svg { width: 16px; height: 16px; }

  .klc-foot__legal {
    margin: 10px 0 0;
    font-family: var(--klc-font-accent);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--klc-ink-mute);
    text-align: center;
  }
  .klc-foot__legal b { color: var(--klc-green-dark); font-weight: 700; }

  /* Backdrop on mobile */
  .klc-backdrop {
    position: fixed; inset: 0;
    background: rgba(10,10,15,.35);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s var(--klc-ease);
    z-index: 9997;
  }
  .klc-backdrop.is-open { opacity: 1; pointer-events: auto; }

  /* Mobile responsive */
  @media (max-width: 520px) {
    .klc-launcher { right: 16px; bottom: 16px; width: 56px; height: 56px; }
    .klc-panel {
      right: 12px; left: 12px; bottom: 86px;
      width: auto;
      max-height: calc(100vh - 110px);
    }
    .klc-launcher__teaser { display: none; }
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .klc-launcher, .klc-panel, .klc-row, .klc-cta, .klc-header__close, .klc-row__chev, .klc-row__icon, .klc-launcher__icon { transition: none; animation: none; }
    .klc-launcher__pulse, .klc-header__dot { animation: none; }
  }

  /* Hide entirely in theme editor section preview if needed */
  .shopify-design-mode .klc-launcher { /* keep visible */ }

  /* ── Native Chat View (inside the same gold panel) ─────────── */
  .klc-view { display: flex; flex-direction: column; flex: 1; min-height: 0; }
  .klc-view--chat { display: none; }
  .klc-panel.is-chat .klc-view--menu { display: none; }
  .klc-panel.is-chat .klc-view--chat { display: flex; }

  .klc-chat-bar {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: var(--klc-surface);
    border-bottom: 1px solid var(--klc-line-soft);
  }
  .klc-chat-back {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1px solid var(--klc-line);
    background: var(--klc-cream);
    color: var(--klc-ink);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s var(--klc-ease), transform .25s var(--klc-ease-spring);
  }
  .klc-chat-back:hover { background: var(--klc-green-hi); transform: translateX(-2px); }
  .klc-chat-back:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(29,71,57,.45); }

  .klc-chat-bar__title {
    font-family: var(--klc-font-serif);
    font-size: 14.5px;
    font-weight: 500;
    color: var(--klc-ink);
    flex: 1;
  }
  .klc-chat-bar__status {
    font-family: var(--klc-font-accent);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--klc-green-dark);
    display: flex; align-items: center; gap: 6px;
  }
  .klc-chat-bar__status::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--klc-online);
    box-shadow: 0 0 0 0 rgba(46,156,92,.6);
    animation: klc-pulse 2.2s ease-out infinite;
  }

  .klc-chat-stream {
    flex: 1;
    overflow-y: auto;
    padding: 18px 16px 12px;
    background: linear-gradient(180deg, var(--klc-cream) 0%, var(--klc-surface) 60%);
    display: flex; flex-direction: column; gap: 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--klc-green-hi) transparent;
  }
  .klc-chat-stream::-webkit-scrollbar { width: 6px; }
  .klc-chat-stream::-webkit-scrollbar-thumb { background: var(--klc-green-hi); border-radius: 6px; }

  .klc-msg {
    max-width: 82%;
    padding: 10px 14px;
    border-radius: 16px;
    font-family: var(--klc-font-serif);
    font-size: 14px;
    line-height: 1.5;
    word-wrap: break-word;
    opacity: 0;
    animation: klc-msg-in .35s var(--klc-ease-spring) forwards;
  }
  @keyframes klc-msg-in {
    from { opacity: 0; transform: translateY(8px) scale(.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .klc-msg--agent {
    align-self: flex-start;
    background: var(--klc-surface);
    color: var(--klc-ink);
    border: 1px solid var(--klc-line);
    border-bottom-left-radius: 6px;
    box-shadow: 0 4px 14px rgba(29,71,57,.08);
  }
  .klc-msg--user {
    align-self: flex-end;
    background: linear-gradient(135deg, var(--klc-green-hi) 0%, var(--klc-green) 100%);
    color: #faf7f0;
    border-bottom-right-radius: 6px;
    box-shadow: 0 6px 18px rgba(29,71,57,.30);
  }
  .klc-msg--system {
    align-self: center;
    background: transparent;
    color: var(--klc-ink-mute);
    font-family: var(--klc-font-accent);
    font-size: 10.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 4px 8px;
    border: none;
  }
  .klc-msg__time {
    display: block;
    margin-top: 4px;
    font-family: var(--klc-font-accent);
    font-size: 9.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    opacity: .7;
  }
  .klc-msg--user .klc-msg__time { color: rgba(26,26,26,.65); }
  .klc-msg--agent .klc-msg__time { color: var(--klc-ink-mute); }

  .klc-typing {
    align-self: flex-start;
    display: inline-flex; gap: 4px;
    padding: 12px 14px;
    background: var(--klc-surface);
    border: 1px solid var(--klc-line);
    border-radius: 16px;
    border-bottom-left-radius: 6px;
  }
  .klc-typing span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--klc-green);
    animation: klc-bounce 1.4s ease-in-out infinite;
  }
  .klc-typing span:nth-child(2) { animation-delay: .15s; }
  .klc-typing span:nth-child(3) { animation-delay: .3s; }
  @keyframes klc-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: .4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  .klc-chat-empty {
    margin: auto;
    text-align: center;
    padding: 20px 12px;
  }
  .klc-chat-empty__icon {
    width: 52px; height: 52px;
    margin: 0 auto 16px;
    border-radius: 50%;
    background: var(--klc-surface);
    border: 1px solid var(--klc-line);
    color: var(--klc-green-dark);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 22px rgba(29,71,57,.14), inset 0 1px 0 rgba(255,255,255,.6);
    position: relative;
  }
  .klc-chat-empty__icon::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--klc-line);
    opacity: .6;
  }
  .klc-chat-empty__title {
    font-family: var(--klc-font-serif);
    font-size: 19px;
    font-weight: 500;
    color: var(--klc-ink);
    margin: 0 0 8px;
    letter-spacing: .005em;
  }
  .klc-chat-empty__title::after {
    content: '';
    display: block;
    width: 28px; height: 1px;
    margin: 12px auto 0;
    background: linear-gradient(90deg, transparent, var(--klc-accent), transparent);
  }
  .klc-chat-empty__sub {
    font-family: var(--klc-font-serif);
    font-size: 13.5px;
    color: var(--klc-ink-soft);
    margin: 12px 0 0;
    line-height: 1.55;
    max-width: 240px;
    margin-left: auto;
    margin-right: auto;
  }

  .klc-chat-input-wrap {
    padding: 12px 14px 14px;
    background: var(--klc-surface);
    border-top: 1px solid var(--klc-line-soft);
  }
  .klc-chat-input-row {
    display: flex; align-items: flex-end; gap: 8px;
    background: var(--klc-cream);
    border: 1px solid var(--klc-line);
    border-radius: 14px;
    padding: 6px 6px 6px 14px;
    transition: border-color .2s var(--klc-ease), box-shadow .25s var(--klc-ease);
  }
  .klc-chat-input-row:focus-within {
    border-color: var(--klc-green);
    box-shadow: 0 0 0 3px rgba(29,71,57,.18);
  }
  .klc-chat-input {
    flex: 1;
    border: none; background: transparent;
    resize: none;
    outline: none;
    font-family: var(--klc-font-serif);
    font-size: 14.5px;
    line-height: 1.45;
    color: var(--klc-ink);
    padding: 8px 0;
    max-height: 96px;
    min-height: 22px;
  }
  .klc-chat-input::placeholder { color: var(--klc-ink-mute); }
  .klc-chat-send {
    width: 36px; height: 36px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--klc-green-hi), var(--klc-green) 55%, var(--klc-green-deep));
    color: #faf7f0;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform .25s var(--klc-ease-spring), box-shadow .3s var(--klc-ease), opacity .2s var(--klc-ease);
    box-shadow: 0 6px 16px rgba(29,71,57,.35), inset 0 1px 0 rgba(255,255,255,.4);
    flex-shrink: 0;
  }
  .klc-chat-send:hover { transform: translateY(-1px); box-shadow: 0 10px 22px rgba(29,71,57,.45), inset 0 1px 0 rgba(255,255,255,.55); }
  .klc-chat-send:disabled { opacity: .35; cursor: not-allowed; transform: none; box-shadow: none; }
  .klc-chat-send:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(29,71,57,.55), 0 6px 16px rgba(29,71,57,.35); }
  .klc-chat-send svg { width: 16px; height: 16px; transform: translateX(1px); }

  /* Attach (paperclip) button — matches send button styling */
  .klc-chat-attach {
    width: 36px; height: 36px;
    border: none;
    border-radius: 10px;
    background: transparent;
    color: var(--klc-green-dark);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s var(--klc-ease), color .2s var(--klc-ease), transform .25s var(--klc-ease-spring);
    flex-shrink: 0;
  }
  .klc-chat-attach:hover { background: var(--klc-cream); color: var(--klc-ink); transform: translateY(-1px); }
  .klc-chat-attach:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(29,71,57,.45); }
  .klc-chat-attach svg { width: 19px; height: 19px; }
  .klc-chat-attach[disabled] { opacity: .4; cursor: not-allowed; }

  /* Image bubble */
  .klc-msg--image {
    padding: 6px;
    overflow: hidden;
    max-width: 220px;
  }
  .klc-msg--image img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    cursor: zoom-in;
    transition: transform .35s var(--klc-ease-spring);
  }
  .klc-msg--image img:hover { transform: scale(1.02); }
  .klc-msg--image .klc-msg__time {
    padding: 4px 6px 2px;
    margin-top: 0;
  }

  /* Upload progress overlay on image bubble */
  .klc-msg--uploading { position: relative; }
  .klc-msg--uploading img { opacity: .55; filter: blur(1px); }
  .klc-msg--uploading::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 28px; height: 28px;
    margin: -14px 0 0 -14px;
    border: 2.5px solid rgba(29,71,57,.25);
    border-top-color: var(--klc-green);
    border-radius: 50%;
    animation: klc-spin .9s linear infinite;
  }
  @keyframes klc-spin { to { transform: rotate(360deg); } }

  .klc-msg--failed { border: 1px solid #e57373; }
  .klc-msg--failed::after {
    content: 'Upload fehlgeschlagen';
    display: block;
    padding: 6px 8px 2px;
    font-family: var(--klc-font-accent);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #c62828;
  }

  /* Lightbox */
  .klc-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10001;
    background: rgba(10,10,15,.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s var(--klc-ease);
  }
  .klc-lightbox.is-open { opacity: 1; pointer-events: auto; }
  .klc-lightbox img {
    max-width: 100%;
    max-height: 100%;
    border-radius: 10px;
    box-shadow: 0 30px 80px rgba(0,0,0,.5);
    transform: scale(.96);
    transition: transform .35s var(--klc-ease-spring);
  }
  .klc-lightbox.is-open img { transform: scale(1); }
  .klc-lightbox__close {
    position: absolute;
    top: 18px; right: 18px;
    width: 40px; height: 40px;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,.12);
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s var(--klc-ease), transform .25s var(--klc-ease-spring);
  }
  .klc-lightbox__close:hover { background: rgba(255,255,255,.22); transform: rotate(90deg); }

  .klc-chat-foot {
    margin: 8px 0 0;
    font-family: var(--klc-font-accent);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--klc-ink-mute);
    text-align: center;
  }
</style>

