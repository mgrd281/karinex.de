<script>
  (function () {
    var launcher    = document.getElementById('klcLauncher');
    var panel       = document.getElementById('klcPanel');
    var closeBtn    = document.getElementById('klcClose');
    var backdrop    = document.getElementById('klcBackdrop');
    var liveChatBtn = document.getElementById('klcLiveChatBtn');
    var ctaChat     = document.getElementById('klcCtaChat');
    if (!launcher || !panel) return;

    var CRISP_ID = {{ klc_crisp_id | json }};
    var crispLoaded = false;

    function loadCrisp(cb) {
      if (crispLoaded) { cb && cb(); return; }
      crispLoaded = true;
      window.$crisp = [];
      window.CRISP_WEBSITE_ID = CRISP_ID;
      // Crisp's own launcher is hidden via CSS; we control visibility ourselves
      window.$crisp.push(['safe', true]);
      var s = document.createElement('script');
      s.src = 'https://client.crisp.chat/l.js';
      s.async = 1;
      s.onload = function () { cb && cb(); };
      document.head.appendChild(s);
    }

    function openCrisp() {
      // Close our panel first, then open Crisp
      closePanel();
      loadCrisp(function () {
        // wait until $crisp is ready
        var tries = 0;
        (function ping() {
          if (window.$crisp && window.$crisp.push) {
            window.$crisp.push(['do', 'chat:open']);
            window.$crisp.push(['do', 'chat:show']);
          } else if (tries++ < 40) {
            setTimeout(ping, 100);
          }
        })();
      });
    }

    function openPanel()  {
      panel.classList.add('is-open');
      backdrop.classList.add('is-open');
      launcher.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
    }
    function closePanel() {
      panel.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      launcher.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
    }
    function togglePanel() {
      panel.classList.contains('is-open') ? closePanel() : openPanel();
    }

    launcher.addEventListener('click', togglePanel);
    closeBtn.addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);
    if (liveChatBtn) liveChatBtn.addEventListener('click', openCrisp);
    if (ctaChat)     ctaChat.addEventListener('click', openCrisp);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && panel.classList.contains('is-open')) closePanel();
    });

    // Show teaser briefly after page load
    setTimeout(function () {
      if (!panel.classList.contains('is-open')) {
        launcher.classList.add('klc-show-teaser');
        setTimeout(function () { launcher.classList.remove('klc-show-teaser'); }, 4200);
      }
    }, 2500);

    // Pre-warm Crisp after user idle (faster first-chat open)
    var idlePrewarm = function () {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(function () { loadCrisp(); }, { timeout: 8000 });
      } else {
        setTimeout(function () { loadCrisp(); }, 6000);
      }
    };
    if (document.readyState === 'complete') idlePrewarm();
    else window.addEventListener('load', idlePrewarm);

    // Public API
    window.KarinexChat = {
      open:    openPanel,
      close:   closePanel,
      toggle:  togglePanel,
      openLiveChat: openCrisp
    };
  })();
</script>
