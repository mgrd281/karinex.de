<!-- Trigger Button (Font Awesome question-circle) -->
<button id="frage-btn" class="frage-btn" type="button" aria-label="Frage zum Artikel" onclick="openFrageModal(); return false;">
  <i class="fa-solid fa-circle-question frage-icon" aria-hidden="true"></i>
  <span>Frage zum Artikel</span>
</button>

<script>
  function openFrageModal() {
    var overlay = document.getElementById('frage-modal');
    if(overlay) {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
    }
    
    document.body.classList.add('modal-open');
    
    // Focus panel
    var panel = document.getElementById('fzaModalPanel');
    if(panel) setTimeout(function(){ panel.focus(); }, 100);
    
    document.addEventListener('keydown', handleFrageEscape);
  }
  
  function closeFrageModal() {
    var overlay = document.getElementById('frage-modal');
    
    if(overlay) {
      overlay.classList.remove('is-open');
      setTimeout(function() {
        overlay.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modal-open');
      }, 300);
    } else {
      document.body.classList.remove('modal-open');
    }
    
    document.removeEventListener('keydown', handleFrageEscape);
  }
  
  function handleFrageEscape(e) {
    if(e.key === 'Escape') closeFrageModal();
  }
</script>

<!-- New Bottom Sheet Modal -->
<div id="frage-modal" class="fza-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="fzaTitle">
  <div class="fza-modal" id="fzaModalPanel" tabindex="-1">
    <!-- Drag Indicator -->
    <div class="fza-drag-indicator"></div>

    <div class="fza-modal-content">
      <!-- Header -->
      <div class="fza-modal__header">
      <div class="fza-modal__title-group">
        <h2 class="fza-modal__title" id="fzaTitle">Frage zum Artikel</h2>
        <p class="fza-modal__sub" id="fzaSub">Art.-Nr: {{ product.metafields.custom.artikelnummer | default: product.id | slice: -6, 6 }} &middot; {{ product.title | truncate: 30 }}</p>
      </div>
      <!-- Close -->
      <button class="fza-modal__close" type="button" aria-label="Schließen" onclick="closeFrageModal(); return false;">
        <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Form -->
    <form method="post" action="/contact#contact_form" id="contact_form" class="contact-form" enctype="multipart/form-data" novalidate>
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[produkt_title]" value="{{ product.title }}">
      <input type="hidden" name="contact[produkt_url]" value="{{ shop.url }}{{ product.url }}">
      <input type="hidden" name="contact[gtin]" value="{{ product.selected_or_first_available_variant.barcode }}">
      <input type="hidden" name="contact[Artikelnummer]" value="{{ product.metafields.custom.artikelnummer | default: product.id | slice: -6, 6 }}">

      <!-- Anrede + Vorname -->
      <div class="fza-row">
        <div class="fza-field">
          <select class="fza-select" name="contact[anrede]" aria-label="Anrede">
            <option value="" disabled selected>Anrede</option>
            <option value="Frau">Frau</option>
            <option value="Herr">Herr</option>
            <option value="Divers">Divers</option>
          </select>
        </div>
        <div class="fza-field">
          <input class="fza-input" name="contact[vorname]" type="text" placeholder="Vorname *" required aria-label="Vorname">
        </div>
      </div>

      <!-- Nachname -->
      <div class="fza-field">
        <input class="fza-input" name="contact[nachname]" type="text" placeholder="Nachname *" required aria-label="Nachname">
      </div>

      <!-- E-Mail -->
      <div class="fza-field">
        <input class="fza-input" name="contact[email]" type="email" placeholder="E-Mail Adresse *" required aria-label="E-Mail Adresse">
      </div>

      <!-- Schnellvorlagen -->
      <span class="fza-chips-label">Schnellvorlagen:</span>
      <div class="fza-chips" id="fzaChips">
        <button type="button" class="fza-chip" data-text="Kompatibilität?">Kompatibilität?</button>
        <button type="button" class="fza-chip" data-text="Lieferzeit?">Lieferzeit?</button>
        <button type="button" class="fza-chip" data-text="Aktivierung?">Aktivierung?</button>
        <button type="button" class="fza-chip" data-text="Rechnung?">Rechnung?</button>
      </div>

      <!-- Nachricht -->
      <div class="fza-field">
        <textarea class="fza-textarea" name="contact[body]" placeholder="Ihre Nachricht..." id="fzaBody" aria-label="Nachricht" maxlength="500" required></textarea>
        <span class="fza-char-count" id="fzaCharCount">0 / 500</span>
      </div>

      <!-- Datei anhängen -->
      <label class="fza-file-area" for="fzaFileInput" id="fzaFileArea">
        <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
        </svg>
        <span id="fzaFileLabel">Foto oder Video hinzufügen</span>
        <span class="fza-file-subtext">Optional (JPG, PNG, PDF)</span>
        <input type="file" id="fzaFileInput" name="contact[attachment]" accept="image/*,video/*,.pdf" aria-label="Datei anhängen" multiple>
      </label>
      
      <!-- Preview Grid -->
      <div class="fza-file-preview-grid" id="fzaFilePreviewGrid"></div>

      <!-- Datenschutz -->
      <p class="fza-legal">
        Mit dem Absenden akzeptieren Sie unsere <a href="/policies/privacy-policy" target="_blank" rel="noopener">Datenschutzerklärung</a>.
      </p>

      <!-- Submit (Sticky) -->
      <div class="fza-submit-wrapper">
        <button type="submit" class="fza-submit" id="fzaSubmit">Anfrage senden</button>
      </div>
    </form>
    </div>
    
    <div id="frage-success" style="display:none; text-align:center; padding:20px;">
      <div class="fza-success-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" stroke="#1D4739" stroke-width="2">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h3 style="margin:15px 0 8px; font:600 18px/1.4 Inter,system-ui;">Vielen Dank!</h3>
      <p style="color:#444; font:400 15px/1.5 Inter,system-ui;">
        Ihre Nachricht wurde erfolgreich versendet.<br>
        Wir antworten Ihnen innerhalb von <strong>24 Stunden</strong>.
      </p>
    </div>
  </div>
</div>

