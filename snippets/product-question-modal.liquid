<script>
document.addEventListener('DOMContentLoaded', function() {
  
  // Close on outside click
  var overlay = document.getElementById('frage-modal');
  if(overlay) {
    overlay.addEventListener('click', function(e) {
      if(e.target === overlay) closeFrageModal();
    });
  }

  /* ── Schnellvorlagen chips ── */
  var chips = document.querySelectorAll('#fzaChips .fza-chip');
  var bodyInput = document.getElementById('fzaBody');
  
  if(chips && bodyInput) {
    chips.forEach(function(chip){
      chip.addEventListener('click', function(){
        var text = chip.getAttribute('data-text') || '';
        var current = bodyInput.value.trim();
        if(bodyInput){
          bodyInput.value = current ? current + (current.endsWith('?') || current.endsWith('.') ? ' ' : '\n') + text : text;
          bodyInput.focus();
          updateCharCount();
        }
        
        chip.classList.toggle('is-active');
        
        // Haptic feedback
        if (window.navigator && window.navigator.vibrate) {
          window.navigator.vibrate(10);
        }
      });
    });
  }

  /* ── Textarea Character Count ── */
  var charCountSpan = document.getElementById('fzaCharCount');
  function updateCharCount() {
    if(!bodyInput || !charCountSpan) return;
    var len = bodyInput.value.length;
    var max = bodyInput.getAttribute('maxlength') || 500;
    charCountSpan.textContent = len + ' / ' + max;
  }
  if(bodyInput) {
    bodyInput.addEventListener('input', updateCharCount);
    updateCharCount(); // Init
  }

  /* ── File input & Drag n Drop with Previews ── */
  var fileInput = document.getElementById('fzaFileInput');
  var dropZone = document.getElementById('fzaFileArea');
  var previewGrid = document.getElementById('fzaFilePreviewGrid');
  var fileLabel = document.getElementById('fzaFileLabel');
  var selectedFiles = []; // Keep track of files

  function updateFilePreview() {
    if(!previewGrid || !dropZone) return;
    previewGrid.innerHTML = '';
    
    if(selectedFiles.length === 0) {
      previewGrid.style.display = 'none';
      if(fileLabel) fileLabel.textContent = 'Foto oder Video hinzufügen';
      return;
    }
    
    previewGrid.style.display = 'grid';
    // Update label to show count
    if(fileLabel) fileLabel.textContent = selectedFiles.length + ' Datei' + (selectedFiles.length > 1 ? 'en' : '') + ' ausgewählt';

    selectedFiles.forEach((file, index) => {
      var item = document.createElement('div');
      item.className = 'fza-file-preview-item';
      
      var innerExt = file.name.split('.').pop().toUpperCase();
      
      var removeBtn = document.createElement('button');
      removeBtn.className = 'remove-file';
      removeBtn.type = 'button';
      removeBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>';
      removeBtn.onclick = function(e) {
        e.preventDefault();
        e.stopPropagation();
        selectedFiles.splice(index, 1);
        updateInputFiles();
        updateFilePreview();
      };

      if(file.type.startsWith('image/')) {
        var img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.onload = function() { URL.revokeObjectURL(img.src); } 
        item.appendChild(img);
      } else if (file.type.startsWith('video/')) {
        var video = document.createElement('video');
        video.src = URL.createObjectURL(file);
        video.muted = true;
        item.appendChild(video);
      } else {
        var text = document.createElement('div');
        text.style.color = '#1D4739';
        text.style.fontWeight = '700';
        text.style.fontSize = '18px';
        text.textContent = innerExt.substring(0,4);
        item.appendChild(text);
      }
      
      item.appendChild(removeBtn);
      previewGrid.appendChild(item);
    });
  }

  function updateInputFiles() {
    if(!fileInput) return;
    var dt = new DataTransfer();
    selectedFiles.forEach(file => dt.items.add(file));
    fileInput.files = dt.files;
  }

  if(fileInput && dropZone){
    fileInput.addEventListener('change', function(e){
      var files = Array.from(e.target.files);
      selectedFiles = selectedFiles.concat(files).slice(0, 4); // Max 4 files
      updateInputFiles();
      updateFilePreview();
    });

    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropZone.classList.add('is-dragover');
    });
    
    dropZone.addEventListener('dragleave', function(e) {
      e.preventDefault();
      dropZone.classList.remove('is-dragover');
    });
    
    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropZone.classList.remove('is-dragover');
      
      if(e.dataTransfer.files && e.dataTransfer.files.length) {
        var newFiles = Array.from(e.dataTransfer.files);
        // filter accepted types manually if needed, but for now just accept
        selectedFiles = selectedFiles.concat(newFiles).slice(0, 4); 
        updateInputFiles();
        updateFilePreview();
      }
    });
  }

  // Hide the old modal if needed
  var oldModal = document.querySelector('.frage-modal[aria-hidden="false"]');
  if (oldModal && oldModal.id !== 'frage-modal') {
      oldModal.style.display = 'none';
  }
});

if (window.location.href.indexOf('?contact_posted=true') > -1) {
  var overlay = document.getElementById('frage-modal');
  var form = document.getElementById('contact_form');
  var success = document.getElementById('frage-success');
  var titleGroup = document.querySelector('.fza-modal__title-group');
  if(overlay && form && success) {
    if(form) form.style.display = 'none';
    if(titleGroup) titleGroup.style.display = 'none';
    if(success) success.style.display = 'block';
    openFrageModal();
  }
}
</script>
