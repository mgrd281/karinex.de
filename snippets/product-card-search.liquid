{%- comment -%}
Product card for search results grid (modern, sales-focused, OTTO style)
{%- endcomment -%}
<div class="product-card-search">
  <div style="position:relative;">
    {% if product.compare_at_price > product.price %}
      <span style="position:absolute;top:12px;left:12px;background:#f5f5f5;color:#d32f2f;font-weight:700;padding:4px 14px;border-radius:16px;font-size:0.98rem;box-shadow:0 1px 4px #0001;letter-spacing:0.5px;">SALE</span>
    {% endif %}
    <img src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title | escape }}" width="400" height="400" loading="lazy" decoding="async">
  </div>
  <div style="margin-top:14px;font-size:1.08rem;font-weight:600;line-height:1.3;min-height:2.5em;">{{ product.title }}</div>
  <div style="margin-top:6px;">
    <span style="font-size:1.15rem;font-weight:700;color:#222;">{{ product.price | money }}</span>
    {% if product.compare_at_price > product.price %}
      <span style="font-size:0.98rem;color:#888;text-decoration:line-through;margin-left:8px;">{{ product.compare_at_price | money }}</span>
    {% endif %}
  </div>
  <div style="margin-top:8px;font-size:0.97rem;color:#388e3c;font-weight:500;">
    {% if product.available %}Sofort verfügbar{% else %}Nicht verfügbar{% endif %}
  </div>
</div>
