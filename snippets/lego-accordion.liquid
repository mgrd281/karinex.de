</div><!-- End .lego-accordion -->

<!-- ════════════════════════════════════════════════
     DESKTOP: Uhren-Stil Layout für LEGO-Produkte
     Beschreibung + Tabs (Zusatzinfo / Lieferung / Marke)
     ════════════════════════════════════════════════ -->
<div class="lego-desktop" data-nosnippet>

  <!-- ── Artikelbeschreibung (expandierbar) ── -->
  <div class="lego-dk-desc-box">
    <h3 class="lego-dk-desc-title">Artikelbeschreibung</h3>
    <div class="lego-dk-desc-wrap">
      <div class="lego-dk-desc-text" id="legoDescText"></div>
      <div class="lego-dk-desc-gradient" id="legoDescGradient"></div>
    </div>
    <button class="lego-dk-mehr-btn" id="legoMehrBtn" type="button">weiterlesen &raquo;</button>
  </div>

  <!-- ── Alterswarnung / Safety Badge ── -->
  <div class="lego-age-badge" id="legoAgeBadge" style="display:none;"></div>

  <!-- ── Tab-Navigation ── -->
  <div class="lego-dk-tab-nav">
    <button class="lego-tab-btn active" data-tab="lego-tab-specs" type="button">Zusatzinformation</button>
    <button class="lego-tab-btn" data-tab="lego-tab-delivery" type="button">Lieferung</button>
    <button class="lego-tab-btn" data-tab="lego-tab-brand" type="button">Über die Marke</button>
  </div>

  <!-- ── Tab-Panels ── -->
  <div class="lego-dk-panels">

    <!-- Zusatzinformation: Specs-Grid (JS füllt) -->
    <div id="lego-tab-specs" class="lego-tab-content" style="display:block;">
      <div class="lego-dk-specs-grid"></div>
    </div>

    <!-- Lieferung -->
    <div id="lego-tab-delivery" class="lego-tab-content">
      <div class="lego-dk-delivery-inner">
        <p class="lego-delivery-highlight">📦 Kostenloser Versand &amp; Rückversand</p>
        <p>Ihre Bestellung wird sicher verpackt und versichert mit DHL versendet. Die Lieferzeit beträgt in der Regel <strong>1–3 Werktage</strong> innerhalb Deutschlands.</p>
        <p>Rücksendungen sind 30 Tage lang kostenlos möglich.</p>
      </div>
    </div>

    <!-- Über die Marke -->
    <div id="lego-tab-brand" class="lego-tab-content">
      <div class="lego-dk-brand-inner">
        <span class="lego-brand-label">Über die Marke</span>
        <h2 class="lego-brand-title">LEGO</h2>
        <div class="lego-brand-divider"></div>
        <div class="lego-brand-text">
          {%- if product.metafields.custom.brand_description != blank -%}
            {{ product.metafields.custom.brand_description }}
          {%- else -%}
            <p>Seit 1932 inspiriert <strong>LEGO</strong> Kinder und Erwachsene weltweit zum kreativen Bauen. Vom kleinen Stein zur ganzen Welt – LEGO steht für Qualität, Fantasie und grenzenlosen Spielspaß. Jedes Set wird in Dänemark entwickelt und erfüllt höchste Sicherheitsstandards.</p>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div><!-- End .lego-dk-panels -->
</div><!-- End .lego-desktop -->

<script src="{{ 'lego-accordion.js' | asset_url }}" defer></script>
