<!-- Shipping/Return Info (About You Style) -->
<div class="shipping-cards-mobile" data-nosnippet>
  <!-- Row 1: Free Shipping -->
  <div class="ship-row">
    <div class="ship-row__icon">
      {% if is_digital %}
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2H3a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1Z"></path>
          <path d="M14 7h3l3 3v4a1 1 0 0 1-1 1h-1"></path>
          <path d="M14 14H6"></path>
          <circle cx="5" cy="17" r="2"></circle>
          <circle cx="17" cy="17" r="2"></circle>
          <path d="M7 17h8"></path>
        </svg>
      {% endif %}
    </div>
    <div class="ship-row__text">
      {% if is_digital %}Blitzversand per E-Mail{% else %}Kostenloser Versand<span style="display:block;font-size:12px;font-weight:400;color:#555;margin-top:1px;">Mit DHL-Express</span>{% endif %}
    </div>
    <span class="ship-row__badge">Kostenlos</span>
  </div>

  <!-- Row 2: Delivery Time -->
  <div class="ship-row">
    <div class="ship-row__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
    </div>
    <div class="ship-row__text">
      {% if is_digital %}
        Sofort verfügbar
      {% else %}
        {% assign current_hour = "now" | date: "%H" | plus: 0 %}
        {% assign day_of_week = "now" | date: "%u" | plus: 0 %}
        {% assign shipping_day = "Morgen" %}
        {% if day_of_week == 5 and current_hour >= 14 %}
          {% assign shipping_day = "Montag" %}
        {% elsif day_of_week == 6 or day_of_week == 7 %}
          {% assign shipping_day = "Montag" %}
        {% endif %}
        2-3 Werktage
      {% endif %}
    </div>
    {% unless is_digital %}<span class="ship-row__badge">Schnelle Lieferung</span>{% endunless %}
  </div>

  <!-- Subtitle -->
  {% unless is_digital %}
  <div class="ship-row ship-row--note">
    <div class="ship-row__note-text">Die finale, erwartete Lieferzeit wird in Deinem Warenkorb angezeigt.</div>
    <div class="ship-row__note-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
    </div>
  </div>
  {% endunless %}

  <!-- Row 3: Return Policy -->
  <div class="ship-row ship-row--last">
    <div class="ship-row__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="1 4 1 10 7 10"></polyline>
        <polyline points="23 20 23 14 17 14"></polyline>
        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"></path>
      </svg>
    </div>
    <div class="ship-row__text">
      {% if is_digital %}100 Tage Rückgaberecht{% else %}14 Tage Rückgaberecht{% endif %}
    </div>
  </div>
</div>

<style>
  .shipping-cards-mobile { display: none; }

  @media (max-width: 768px) {
    .shipping-cards-mobile {
      display: block;
      margin-top: 16px;
      margin-bottom: 12px;
      border: 1px solid #e5e5e5;
      border-radius: 12px;
      background: #fff;
      overflow: hidden;
    }

    .ship-row {
      display: flex;
      align-items: center;
      padding: 14px 16px;
      gap: 14px;
      border-bottom: 1px solid #f0f0f0;
    }

    .ship-row--last {
      border-bottom: none;
    }

    .ship-row--note {
      padding: 10px 16px;
      background: #f7f7f7;
      gap: 10px;
    }

    .ship-row__icon {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      color: #1D4739;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ship-row__text {
      flex: 1;
      font-size: 15px;
      font-weight: 700;
      color: #1a1a1a;
      line-height: 1.3;
    }

    .ship-row__badge {
      flex-shrink: 0;
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
      background-color: #1D4739;
      color: #fff;
    }

    .ship-row__note-text {
      flex: 1;
      font-size: 13px;
      color: #555;
      line-height: 1.4;
    }

    .ship-row__note-icon {
      flex-shrink: 0;
      color: #999;
      display: flex;
      align-items: center;
    }
  }
</style>
