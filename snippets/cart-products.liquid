<!-- ═══════════════════════════════════════════════════════
     WIRD OFT ZUSAMMEN GEKAUFT — add-to-cart from drawer
     Handles "Hinzufügen" buttons in .cart-reco-wrapper.
     After add: updates cart items, badge, summary, and reco
     strip from the fresh server-rendered section HTML.
     Listens for cart:refresh to sync when items are removed.
     ═══════════════════════════════════════════════════════ -->
<script>
(function () {
  function _recoSectionId() {
    var c = document.querySelector('.cart-drawer cart-items-component');
    return c && c.dataset ? c.dataset.sectionId : null;
  }

  /** Re-render the cart items <tbody> from fresh section HTML so the
   *  newly added product appears instantly without a page reload. */
  function _updateCartItemsFromHTML(sectionHTML) {
    try {
      var doc = new DOMParser().parseFromString(sectionHTML, 'text/html');
      var newTbody = doc.querySelector('tbody[role="rowgroup"]');
      var oldTbody = document.querySelector('.cart-drawer tbody[role="rowgroup"]');
      if (newTbody && oldTbody) {
        oldTbody.replaceWith(newTbody);
      }
    } catch (e) {}
  }

  /** Update all cart badge elements from the rendered section HTML */
  function _updateBadgeFromHTML(sectionHTML) {
    try {
      var doc = new DOMParser().parseFromString(sectionHTML, 'text/html');
      var countEl = doc.querySelector('.cart-drawer__count');
      var n = countEl ? parseInt(countEl.textContent.trim(), 10) : NaN;
      if (isNaN(n)) return;
      document.querySelectorAll('cart-icon').forEach(function (icon) {
        var refs = icon.refs;
        var bc = refs ? refs.cartBubbleCount : icon.querySelector('[ref="cartBubbleCount"]');
        var bb = refs ? refs.cartBubble : icon.querySelector('[ref="cartBubble"]');
        if (!bc || !bb) return;
        bc.textContent = (n > 0 && n < 100) ? String(n) : '';
        bc.classList.toggle('hidden', n === 0);
        bb.classList.toggle('visually-hidden', n === 0);
        bb.setAttribute('data-count', String(n));
        icon.classList.toggle('header-actions__cart-icon--has-cart', n > 0);
      });
      var floatBadge = document.querySelector('.DISABLED-cart-count-badge');
      if (floatBadge) floatBadge.textContent = n > 0 ? String(n) : '';
      var mmBadge = document.querySelector('.cmm-cart-count');
      if (mmBadge) { mmBadge.textContent = String(n); mmBadge.style.display = n > 0 ? 'flex' : 'none'; }
    } catch (e) {}
  }

  /** Replace summary footer + heading count from fresh section HTML */
  function _updateSummaryFromHTML(sectionId, sectionHTML) {
    try {
      var doc = new DOMParser().parseFromString(sectionHTML, 'text/html');
      var newSummary = doc.querySelector('.cart-drawer__summary');
      var oldSummary = document.querySelector('.cart-drawer__summary');
      if (newSummary && oldSummary) oldSummary.innerHTML = newSummary.innerHTML;
      var countEl = doc.querySelector('.cart-drawer__count');
      var n = countEl ? parseInt(countEl.textContent.trim(), 10) : NaN;
      if (!isNaN(n)) {
        var liveCount = document.querySelector('.cart-drawer__count');
        if (liveCount) liveCount.textContent = n > 0 ? String(n) : '';
      }
    } catch (e) {}
  }

  /** Replace reco strip DOM from freshly rendered section HTML */
  function _refreshRecoFromHTML(sectionId, sectionHTML) {
    try {
      var doc = new DOMParser().parseFromString(sectionHTML, 'text/html');
      var newReco = doc.getElementById('cart-drawer-recommendations');
      var oldReco = document.getElementById('cart-drawer-recommendations');
      if (oldReco && newReco) {
        oldReco.replaceWith(newReco);
      } else if (oldReco && !newReco) {
        oldReco.remove();
      } else if (!oldReco && newReco) {
        var items = document.querySelector('.cart-drawer__items');
        if (items) items.appendChild(newReco);
      }
    } catch (e) {}
  }

  /** Collapse a horizontal row card (height → 0) then tidy the strip */
  function _removeCard(card) {
    var h = card.offsetHeight;
    card.style.maxHeight = h + 'px';
    card.style.overflow = 'hidden';
    requestAnimationFrame(function () {
      card.style.transition = 'opacity 0.2s ease, max-height 0.3s ease 0.05s, padding-top 0.3s ease 0.05s, padding-bottom 0.3s ease 0.05s';
      card.style.opacity = '0';
      card.style.maxHeight = '0';
      card.style.paddingTop = '0';
      card.style.paddingBottom = '0';
    });
    setTimeout(function () {
      card.remove();
      var scroll = document.querySelector('.cart-reco-scroll');
      if (scroll && !scroll.querySelector('.cart-reco-card')) {
        var wrapper = document.getElementById('cart-drawer-recommendations');
        if (wrapper) {
          wrapper.style.transition = 'opacity 0.2s ease';
          wrapper.style.opacity = '0';
          setTimeout(function () { wrapper.remove(); }, 220);
        }
      }
    }, 380);
  }

  /** Optimistically increment all badge elements by 1 before server responds */
  function _optimisticBadgeIncrement() {
    try {
      document.querySelectorAll('cart-icon').forEach(function (icon) {
        var refs = icon.refs;
        var bc = refs ? refs.cartBubbleCount : icon.querySelector('[ref="cartBubbleCount"]');
        var bb = refs ? refs.cartBubble : icon.querySelector('[ref="cartBubble"]');
        if (!bc || !bb) return;
        var n = (parseInt(bc.textContent, 10) || 0) + 1;
        bc.textContent = n < 100 ? String(n) : '99+';
        bc.classList.remove('hidden');
        bb.classList.remove('visually-hidden');
        bb.setAttribute('data-count', String(n));
        icon.classList.add('header-actions__cart-icon--has-cart');
      });
      var fb = document.querySelector('.DISABLED-cart-count-badge');
      if (fb) fb.textContent = String((parseInt(fb.textContent, 10) || 0) + 1);
      var mb = document.querySelector('.cmm-cart-count');
      if (mb) { mb.textContent = String((parseInt(mb.textContent, 10) || 0) + 1); mb.style.display = 'flex'; }
    } catch (e) {}
  }

  /* ── Circular "+" add button ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.cart-reco-btn');
    if (!btn) return;
    var variantId = btn.dataset.variantId;
    if (!variantId || btn.disabled || btn.classList.contains('cart-reco-btn--loading')) return;

    var sectionId = _recoSectionId();
    if (!sectionId) return;

    var card = btn.closest('.cart-reco-card');

    // Instant feedback: optimistic badge + loading state
    btn.disabled = true;
    btn.classList.add('cart-reco-btn--loading');
    _optimisticBadgeIncrement();

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: Number(variantId), quantity: 1, sections: sectionId })
    })
    .then(function (r) {
      if (!r.ok) return r.json().then(function (d) { throw new Error(d.description || 'error'); });
      return r.json();
    })
    .then(function (data) {
      // Show success check, begin card exit
      btn.classList.remove('cart-reco-btn--loading');
      btn.classList.add('cart-reco-btn--added');
      if (card) _removeCard(card);

      var html = data.sections && data.sections[sectionId];
      if (html) {
        // Authoritative sync — corrects any optimistic values
        _updateCartItemsFromHTML(html);
        _updateBadgeFromHTML(html);
        _updateSummaryFromHTML(sectionId, html);
        _refreshRecoFromHTML(sectionId, html);
      }
    })
    .catch(function (err) {
      btn.disabled = false;
      btn.classList.remove('cart-reco-btn--loading');
      // Revert optimistic badge via fresh cart state
      fetch('/cart.js').then(function (r) { return r.json(); }).then(function (c) {
        var n = c.item_count;
        document.querySelectorAll('cart-icon').forEach(function (icon) {
          var refs = icon.refs;
          var bc = refs ? refs.cartBubbleCount : icon.querySelector('[ref="cartBubbleCount"]');
          var bb = refs ? refs.cartBubble : icon.querySelector('[ref="cartBubble"]');
          if (!bc || !bb) return;
          bc.textContent = (n > 0 && n < 100) ? String(n) : '';
          bc.classList.toggle('hidden', n === 0);
          bb.classList.toggle('visually-hidden', n === 0);
          bb.setAttribute('data-count', String(n));
          icon.classList.toggle('header-actions__cart-icon--has-cart', n > 0);
        });
      }).catch(function () {});
      console.warn('[cart-reco] add failed:', err);
    });
  });

  // Sync reco strip when items are removed via __cartMasterRemove
  document.addEventListener('cart:refresh', function (e) {
    try {
      var data = e.detail && e.detail.cart;
      if (!data || !data.sections) return;
      var sid = _recoSectionId();
      if (!sid || !data.sections[sid]) return;
      _refreshRecoFromHTML(sid, data.sections[sid]);
    } catch (e) {}
  });
})();
</script>

