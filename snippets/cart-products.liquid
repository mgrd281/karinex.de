{% liquid
  assign block_settings = block.settings
%}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'volume-pricing-info.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div
  {{ block.shopify_attributes }}
  class="cart-items__wrapper"
  {% if settings.product_title_case == 'uppercase' %}
    style="--product-title-case: uppercase;"
  {% endif %}
>
  {% if cart.empty? %}
    <div class="cart-empty-state">
      <div class="cart-empty-header">
        <div class="cart-empty-icon icon-shimmer">
          {% render 'icon', icon: 'cart-empty', size: 'auto' %}
        </div>
      </div>
      
      <div class="cart-empty-body">
        <h3 class="cart-empty-title">Dein Warenkorb ist leer</h3>
        <p class="cart-empty-desc">Entdecke unsere Bestseller und finde etwas für dich.</p>
        {%- if shop.customer_accounts_enabled and customer == null -%}
          <p class="cart-empty-login">
            {{ 'actions.log_in_html' | t: link: routes.account_login_url }}
          </p>
        {%- endif -%}
      </div>
      <a
        class="cart-empty-btn"
        href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
      >
        {{ 'actions.continue_shopping' | t }}
      </a>

      <!-- Dynamic Extras Container -->
      <div id="cart-drawer-empty-extras" class="cart-drawer-dynamic-extras"></div>
    </div>
    <style>
      .cart-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        text-align: center;
        padding: 40px 24px 32px;
        min-height: calc(100vh - 70px);
        animation: cartEmptyFadeIn 0.25s ease-out both;
        overflow-y: auto;
        overflow-x: hidden;
      }
      .cart-drawer-dynamic-extras {
        width: 100%;
        margin-top: 28px;
        display: none; /* Hidden until loaded via JS */
      }
      .cart-drawer-dynamic-extras.is-loaded {
        display: block;
      }
      .cart-empty-body {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        flex: 1;
        justify-content: center;
      }
      @keyframes cartEmptyFadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .cart-empty-icon {
        color: #1D4739;
        opacity: 0.22;
        margin-bottom: 8px;
      }
      .cart-empty-title {
        font-size: 15px;
        font-weight: 600;
        color: #111;
        margin: 0;
        letter-spacing: 0.02em;
        line-height: 1.3;
      }
      .cart-empty-desc {
        font-size: 13px;
        color: #888;
        margin: 0 0 8px;
        max-width: 230px;
        line-height: 1.6;
      }
      .cart-empty-login {
        font-size: 12px;
        color: #888;
        margin: 0;
      }
      .cart-empty-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: auto;
        max-width: 280px;
        margin: 12px auto 0;
        padding: 0 18px;
        height: 46px;
        background: #1D4739 !important;
        color: #ffffff !important;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border-radius: 10px;
        text-decoration: none !important;
        position: relative;
        overflow: hidden;
        transition: background 0.25s ease, box-shadow 0.25s ease;
        box-shadow: 0 0 0 0 rgba(29,71,57,0);
      }
      .cart-empty-btn:hover {
        background: #163830 !important;
        color: #ffffff !important;
        box-shadow: 0 4px 18px rgba(29,71,57,0.32) !important;
      }
      .cart-empty-btn:active {
        background: #0f2922 !important;
        box-shadow: none !important;
      }

      /* ============================
         CART EXTRAS (RV & UPSELL)
         ============================ */
      .cart-upsell-wrapper {
        width: 100%;
        background: transparent;
        padding: 24px 0 8px 0;
        margin-bottom: 8px;
        box-sizing: border-box;
      }

      .cart-upsell-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
        padding: 0 16px;
      }

      @media screen and (min-width: 750px) {
        .cart-upsell-header {
          padding: 0 22px;
        }
      }

      .cart-upsell-icon {
        color: #1a7a4a; /* Brand Green */
      }
      .cart-upsell-title {
        font-size: 13px;
        font-weight: 700;
        margin: 0;
        color: #111;
        text-transform: uppercase;
        letter-spacing: 1.2px;
      }

      .cart-upsell-items {
        display: flex;
        gap: 12px;
        overflow-x: auto !important;
        overflow-y: hidden;
        padding-bottom: 15px;
        padding-left: 16px;
        padding-right: 16px;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }

      @media screen and (min-width: 750px) {
        .cart-upsell-items {
          padding-left: 22px;
          padding-right: 22px;
        }
      }

      .cart-upsell-items::-webkit-scrollbar {
        display: none;
      }

      .cart-upsell-item {
        flex: 0 0 230px;
        background: #ffffff;
        border: 1px solid #f0f0f0;
        border-radius: 14px;
        padding: 12px;
        display: flex;
        gap: 12px;
        align-items: center;
        scroll-snap-align: start;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
      }
      .cart-upsell-item:hover {
        border-color: #1a7a4a;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transform: translateY(-2px);
      }

      .cart-upsell-image-link {
        flex-shrink: 0;
        width: 64px;
        display: block;
      }
      .cart-upsell-image {
        width: 64px;
        height: 64px;
        border-radius: 10px;
        object-fit: cover;
        display: block;
        background: #fcfcfc;
      }
      .cart-upsell-info {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-width: 0;
      }
      .cart-upsell-vendor {
        font-size: 9px;
        font-weight: 800;
        color: #1a7a4a;
        letter-spacing: 0.8px;
        margin-bottom: 2px;
        text-transform: uppercase;
      }
      .cart-upsell-title-link {
        font-size: 13px;
        color: #111;
        text-decoration: none;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        margin-bottom: 4px;
      }
      .cart-upsell-title-link:hover {
        color: #1a7a4a;
      }
      .upsell-price {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 8px;
        line-height: 1;
      }
      .upsell-sale-price {
        color: #cc2222;
        font-weight: 700;
        font-size: 13px;
      }
      .upsell-compare-price {
        color: #999;
        text-decoration: line-through;
        font-size: 11px;
      }
      .upsell-regular-price {
        color: #111;
        font-weight: 700;
        font-size: 13px;
      }

      .cart-upsell-add-btn {
        background: #000;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0 12px;
        height: 36px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        cursor: pointer;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.1s ease;
      }
      .cart-upsell-add-btn:hover {
        background: #1a7a4a;
      }
      .cart-upsell-add-btn:active {
        transform: scale(0.97);
      }
      .cart-upsell-add-btn[disabled] {
        background: #eee;
        color: #bbb;
        cursor: not-allowed;
      }
    </style>
  {%- else -%}
    {%- comment -%} --- CART TIMER (always visible for all products) - Static HTML --- {%- endcomment -%}
    <cart-timer data-product-ids='{{ cart.items | map: "product_id" | uniq | json | escape }}'>
      <div class="cart-session-timer cart-section cart-section--1" id="cartSessionTimer" style="margin-left: 0; margin-right: 0; width: 100%; display: block;">
        <div class="timer-content">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="timer-icon">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="timer-text">
            Warenkorb reserviert für <span class="time-display">15:00</span>
          </span>
        </div>
      </div>
    </cart-timer>
    <style>
      /* ==== COMPACT TIMER BAR ==== */
      .cart-session-timer {
        background: #f4f7f5 !important;
        border: none !important;
        border-radius: 6px !important;
        padding: 8px 14px !important;
        margin: 0 0 10px 0 !important;
        color: #1f3b33;
        font-size: 12px;
        font-weight: 500;
        font-family: var(--font-body-family);
        box-sizing: border-box;
        width: 100%;
      }
      .timer-content {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }
      .timer-icon {
        color: #0f3b2e !important;
        flex-shrink: 0;
      }
      .time-display {
        font-weight: 700 !important;
        font-variant-numeric: tabular-nums;
        color: #1f3b33 !important;
      }
    </style>

    {%- comment -%} --- ZALANDO STYLE SHIPPING INFO --- {%- endcomment -%}
    {%- comment -%} --- ZALANDO STYLE SHIPPING INFO --- {%- endcomment -%}
    <div class="cart-shipping-info cart-section cart-section--2">
      {%- if cart.requires_shipping -%}
        <div class="shipping-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
        </div>
        <div class="shipping-text">
                      <div class="shipping-provider">Versand mit DHL</div>
                      <div class="shipping-date">
                        {%- liquid
                          comment
                            --- SMART SHIPPING DATE CALCULATION ---
                            - Before 15:00 (3 PM) = Ships same day (if working day)
                            - After 15:00 = Ships next working day
                            - Saturday after 15:00 = Ships Monday
                            - Considers German holidays
                          endcomment
                          
                          assign now_ts = 'now' | date: '%s'
                          assign current_hour = 'now' | date: '%H' | plus: 0
                          assign current_dow = 'now' | date: '%w' | plus: 0
                          assign current_year = 'now' | date: '%Y'
                          assign today_iso = 'now' | date: '%Y-%m-%d'
                          
                          comment
                            German holidays for 2025 and 2026
                          endcomment
                          if current_year == '2025'
                            assign holidays = '2025-01-01,2025-04-18,2025-04-21,2025-05-01,2025-05-29,2025-06-09,2025-10-03,2025-10-31,2025-12-25,2025-12-26'
                          elsif current_year == '2026'
                            assign holidays = '2026-01-01,2026-04-03,2026-04-06,2026-05-01,2026-05-14,2026-05-25,2026-10-03,2026-10-31,2026-12-25,2026-12-26'
                          elsif current_year == '2027'
                            assign holidays = '2027-01-01,2027-03-26,2027-03-29,2027-05-01,2027-05-06,2027-05-17,2027-10-03,2027-10-31,2027-12-25,2027-12-26'
                          else
                            assign holidays = current_year | append: '-01-01,' | append: current_year | append: '-05-01,' | append: current_year | append: '-10-03,' | append: current_year | append: '-12-25,' | append: current_year | append: '-12-26'
                          endif
                          assign holiday_list = holidays | split: ','
                          
                          comment
                            Check if today is a holiday
                          endcomment
                          assign today_is_holiday = false
                          if holiday_list contains today_iso
                            assign today_is_holiday = true
                          endif
                          
                          comment
                            Determine if we can ship today:
                            - Must be before 15:00
                            - Must not be Sunday (0)
                            - Must not be a holiday
                          endcomment
                          assign can_ship_today = false
                          if current_hour < 15 and current_dow != 0 and today_is_holiday == false
                            assign can_ship_today = true
                          endif
                          
                          comment
                            Calculate shipping start date
                          endcomment
                          if can_ship_today
                            assign start_ts = now_ts
                            assign ship_message = 'Heute'
                          else
                            comment
                              Find next working day
                            endcomment
                            assign start_ts = ''
                            for i in (1..14)
                              assign add_seconds = i | times: 86400
                              assign candidate_ts = now_ts | plus: add_seconds
                              assign dow = candidate_ts | date: '%w'
                              assign iso = candidate_ts | date: '%Y-%m-%d'
                              assign is_holiday = false
                              if holiday_list contains iso
                                assign is_holiday = true
                              endif
                              
                              comment
                                Skip Sunday (0) and Holidays
                              endcomment
                              if dow != '0' and is_holiday == false
                                assign start_ts = candidate_ts
                                break
                              endif
                            endfor
                            
                            if start_ts == ''
                              assign start_ts = now_ts | plus: 86400
                            endif
                            assign ship_message = ''
                          endif

                          comment
                            CALCULATE DELIVERY DATES
                            Delivery starts 1 day after shipping, ends 3 days after shipping
                            So if shipping today, delivery is tomorrow to day+3
                          endcomment
                          assign delivery_start_ts = start_ts | plus: 86400
                          assign delivery_end_ts = start_ts | plus: 259200

                          assign delivery_start_day_eng = delivery_start_ts | date: "%a"
                          assign delivery_end_day_eng = delivery_end_ts | date: "%a"
                          
                          case delivery_start_day_eng
                            when 'Mon'
                              assign delivery_start_day_de = 'Mo.'
                            when 'Tue'
                              assign delivery_start_day_de = 'Di.'
                            when 'Wed'
                              assign delivery_start_day_de = 'Mi.'
                            when 'Thu'
                              assign delivery_start_day_de = 'Do.'
                            when 'Fri'
                              assign delivery_start_day_de = 'Fr.'
                            when 'Sat'
                              assign delivery_start_day_de = 'Sa.'
                            when 'Sun'
                              assign delivery_start_day_de = 'So.'
                          endcase

                          case delivery_end_day_eng
                            when 'Mon'
                              assign delivery_end_day_de = 'Mo.'
                            when 'Tue'
                              assign delivery_end_day_de = 'Di.'
                            when 'Wed'
                              assign delivery_end_day_de = 'Mi.'
                            when 'Thu'
                              assign delivery_end_day_de = 'Do.'
                            when 'Fri'
                              assign delivery_end_day_de = 'Fr.'
                            when 'Sat'
                              assign delivery_end_day_de = 'Sa.'
                            when 'Sun'
                              assign delivery_end_day_de = 'So.'
                          endcase
                          
                          assign ship_day_eng = start_ts | date: "%a"
                          case ship_day_eng
                            when 'Mon'
                              assign ship_day_de = 'Mo.'
                            when 'Tue'
                              assign ship_day_de = 'Di.'
                            when 'Wed'
                              assign ship_day_de = 'Mi.'
                            when 'Thu'
                              assign ship_day_de = 'Do.'
                            when 'Fri'
                              assign ship_day_de = 'Fr.'
                            when 'Sat'
                              assign ship_day_de = 'Sa.'
                            when 'Sun'
                              assign ship_day_de = 'So.'
                          endcase
                        -%}
                        {%- if can_ship_today -%}
                          <span style="color: #000; font-weight: 600;">Versand heute</span> - Bei dir: <strong>{{ delivery_start_day_de }}, {{ delivery_start_ts | date: "%d.%m." }} - {{ delivery_end_day_de }}, {{ delivery_end_ts | date: "%d.%m." }}</strong>
                        {%- else -%}
                          <span style="color: #000; font-weight: 600;">Versand {{ ship_day_de }}, {{ start_ts | date: "%d.%m." }}</span> - Bei dir: <strong>{{ delivery_start_day_de }}, {{ delivery_start_ts | date: "%d.%m." }} - {{ delivery_end_day_de }}, {{ delivery_end_ts | date: "%d.%m." }}</strong>
                        {%- endif -%}
                      </div>
        </div>
      {%- else -%}
        <div class="shipping-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </div>
        <div class="shipping-text">
          <strong>Sofort lieferbar per E-Mail</strong>
        </div>
      {%- endif -%}
    </div>
    <style>
      /* ============================
         SHIPPING INFO — COMPACT
         ============================ */
      .cart-shipping-info {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin: 10px 20px;
        color: #4a4a4a;
        font-size: 12px;
        line-height: 1.5;
      }
      .shipping-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
      }
      .shipping-icon svg {
        width: 16px;
        height: 16px;
        stroke: #0f3b2e;
      }
      .shipping-text {
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .shipping-text strong {
        font-weight: 600;
      }
      .shipping-provider {
        font-size: 11px;
        color: #6a6a6a;
        font-weight: 500;
      }
      .shipping-date {
        font-size: 12px;
        color: #444;
        line-height: 1.5;
      }
      .shipping-date strong {
        font-weight: 600;
      }

      /* ── Cart Drawer Overrides ── */
      .cart-drawer .cart-shipping-info {
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 12px;
        margin-bottom: 0;
      }
      .cart-drawer .cart-items__price {
        padding-right: 0;
      }

      /* ── Force cart items to fit in drawer ── */
      .cart-drawer .cart-items {
        container-type: normal !important;
      }

      /* ── Recently viewed container for non-empty cart ── */
      .cart-drawer-rv-container {
        display: none;
      }
      .cart-drawer-rv-container.is-loaded {
        display: block;
      }

      /* ============================
         PRODUCT ROW — COMPACT PREMIUM
         ============================ */
      .cart-drawer .cart-items__table-row {
        position: relative !important;
        display: grid !important;
        grid-template-columns: 64px 1fr auto !important;
        gap: 10px !important;
        padding: 14px 16px !important;
        border-bottom: 1px solid #f0f0f0 !important;
        align-items: start !important;
        transition: background 0.25s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.3s ease, max-height 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
        max-height: 200px;
        overflow: hidden;
      }
      .cart-drawer .cart-items__table-row.removing {
        opacity: 0;
        max-height: 0 !important;
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        border-bottom-color: transparent !important;
      }
      .cart-drawer .cart-items__table-row:hover {
        background: #fafafa;
      }

      /* Product image */
      .cart-drawer .cart-items__media-container {
        display: block;
        width: 64px;
        height: 64px;
        overflow: hidden;
        border-radius: 8px;
        flex-shrink: 0;
        background: #f6f6f6;
        transition: transform 0.2s ease;
      }
      .cart-drawer .cart-items__media-container:hover {
        transform: scale(1.02);
      }
      .cart-drawer .cart-items__media-image {
        width: 64px !important;
        height: 64px !important;
        object-fit: cover !important;
        border-radius: 8px !important;
      }

      /* Product title — max 2 lines */
      .cart-drawer .cart-items__title {
        font-size: 14px !important;
        font-weight: 500 !important;
        line-height: 1.4 !important;
        color: #1a1a1a !important;
        text-decoration: none !important;
        display: -webkit-box !important;
        -webkit-line-clamp: 2 !important;
        -webkit-box-orient: vertical !important;
        overflow: hidden !important;
        padding-right: 0;
        transition: color 0.2s ease;
      }
      .cart-drawer .cart-items__title:hover {
        color: #0f3b2e !important;
      }
      .cart-drawer .cart-items__details {
        min-width: 0;
      }

      /* Variant / options sub text */
      .cart-drawer .cart-items__variants {
        font-size: 12px !important;
        color: #999 !important;
        margin-top: 2px;
      }

      /* ============================
         PRICE HIERARCHY
         ============================ */
      .cart-drawer .cart-items__details > div {
        margin-top: 4px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 5px;
      }
      .cart-drawer .cart-items__details > div > span:not(.compare-at-price):not(.visually-hidden) {
        font-size: 15px !important;
        font-weight: 700 !important;
        color: #111 !important;
      }
      .cart-drawer .cart-items__details .compare-at-price {
        font-size: 12px !important;
        color: #777 !important;
        text-decoration: line-through !important;
      }

      /* ============================
         QUANTITY SELECTOR — COMPACT
         ============================ */
      .cart-drawer .cart-items__quantity-controls {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 4px;
        margin-top: 4px;
      }
      .cart-drawer quantity-selector,
      .cart-drawer .quantity-selector {
        height: 32px !important;
        border-radius: 8px !important;
        border: 1px solid #e8e8e8 !important;
        display: flex !important;
        align-items: center !important;
        overflow: hidden !important;
        background: #fff !important;
      }
      .cart-drawer quantity-selector button,
      .cart-drawer .quantity-selector button {
        width: 28px !important;
        height: 30px !important;
        font-size: 16px !important;
        background: transparent !important;
        border: none !important;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease;
        color: #444;
      }
      .cart-drawer quantity-selector button:hover,
      .cart-drawer .quantity-selector button:hover {
        background: #f3f3f3 !important;
      }
      .cart-drawer quantity-selector input,
      .cart-drawer .quantity-selector input {
        font-weight: 500 !important;
        text-align: center !important;
        border: none !important;
        background: transparent !important;
        width: 28px !important;
        font-size: 13px !important;
        color: #1a1a1a !important;
      }

      /* X remove button — inline next to price */
      .cart-drawer .cart-items__remove {
        position: static !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 26px !important;
        height: 26px !important;
        min-width: 26px !important;
        background: transparent !important;
        border: none !important;
        border-radius: 50% !important;
        color: #bbb !important;
        cursor: pointer;
        padding: 0 !important;
        box-shadow: none !important;
        pointer-events: auto !important;
        transition: background 0.2s ease, color 0.2s ease !important;
        -webkit-tap-highlight-color: transparent;
        flex-shrink: 0 !important;
        margin-left: 2px;
      }
      .cart-drawer .cart-items__remove:hover,
      .cart-drawer .cart-items__remove:active {
        background: #f0f0f0 !important;
        color: #666 !important;
      }
      .cart-drawer .cart-items__remove svg {
        width: 12px !important;
        height: 12px !important;
        stroke-width: 2 !important;
      }

      /* Line item total price — flex row with X button */
      .cart-drawer .cart-items__price {
        display: flex !important;
        align-items: center !important;
        justify-content: flex-end !important;
        gap: 8px !important;
        font-size: 14px;
        font-weight: 700;
        color: #111;
        padding-right: 0 !important;
        text-align: right;
        white-space: nowrap;
      }

      /* ============================
         WISHLIST — HEART OVERLAY ON IMAGE
         ============================ */

      /* Title row: title + heart side by side */
      .cart-title-row {
        display: flex !important;
        align-items: flex-start !important;
        gap: 6px !important;
      }

      .cart-wishlist-container {
        flex-shrink: 0 !important;
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .cart-wishlist-btn {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 22px !important;
        height: 22px !important;
        border-radius: 50% !important;
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        margin: 0 !important;
        cursor: pointer;
        transition: transform 0.15s ease !important;
      }
      .cart-wishlist-btn:hover {
        transform: scale(1.2) !important;
      }
      .cart-wishlist-btn:hover svg {
        stroke: #e53935 !important;
      }
      .cart-wishlist-btn svg {
        width: 14px !important;
        height: 14px !important;
        stroke: #ccc !important;
        fill: none !important;
        transition: stroke 0.2s ease, fill 0.2s ease !important;
      }

      /* Active (in wishlist) state */
      .cart-wishlist-container.in-wishlist .cart-wishlist-btn svg {
        stroke: #e53935 !important;
        fill: #e53935 !important;
      }

      /* ============================
         DUAL SWIPE — DELETE + WISHLIST
         ============================ */
      @media (max-width: 749px) {
        .swipe-row {
          overflow: visible !important;
          will-change: auto;
          -webkit-user-select: none;
          user-select: none;
          -webkit-tap-highlight-color: transparent;
        }

        /* GPU-accelerated content cells */
        .swipe-row > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row > button.cart-items__remove {
          will-change: transform;
          transform: translate3d(0,0,0);
          -webkit-backface-visibility: hidden;
          backface-visibility: hidden;
        }

        /* --- Shared layer base --- */
        .swipe-delete-layer,
        .swipe-wish-layer {
          position: absolute !important;
          top: 0 !important;
          bottom: 0 !important;
          width: 120px !important;
          display: flex !important;
          align-items: center !important;
          justify-content: center !important;
          z-index: 5 !important;
          border-radius: 0 !important;
          padding: 0 !important;
          border: none !important;
          grid-area: unset !important;
          will-change: transform;
          -webkit-backface-visibility: hidden;
          backface-visibility: hidden;
          overflow: hidden !important;
        }

        /* --- DELETE layer (right side, revealed on LEFT swipe) --- */
        .swipe-delete-layer {
          right: 0 !important;
          left: auto !important;
          background: linear-gradient(135deg, #FF3B30 0%, #E0321E 100%) !important;
          transform: translate3d(100%,0,0) !important;
        }

        /* --- WISHLIST layer (left side, revealed on RIGHT swipe) --- */
        .swipe-wish-layer {
          left: 0 !important;
          right: auto !important;
          background: linear-gradient(135deg, #EEF3F0 0%, #E4ECE7 100%) !important;
          transform: translate3d(-100%,0,0) !important;
        }

        /* --- Inner content (both layers) --- */
        .swipe-delete-inner,
        .swipe-wish-inner {
          display: flex !important;
          flex-direction: column !important;
          align-items: center !important;
          gap: 6px !important;
          font-size: 11px !important;
          font-weight: 600 !important;
          letter-spacing: 0.4px !important;
          user-select: none !important;
          opacity: 0;
          transform: scale(0.65);
          transition: opacity 0.2s ease, transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .swipe-delete-inner {
          color: #fff !important;
        }
        .swipe-wish-inner {
          color: #3D5A4E !important;
          font-weight: 400 !important;
          font-size: 10.5px !important;
          letter-spacing: 0.6px !important;
          text-transform: uppercase !important;
        }
        .swipe-wish-icon-circle {
          width: 38px;
          height: 38px;
          border-radius: 50%;
          background: rgba(15, 59, 46, 0.06);
          display: flex;
          align-items: center;
          justify-content: center;
          transition: background 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .swipe-wish-layer.wish-triggered .swipe-wish-icon-circle {
          background: rgba(15, 59, 46, 0.10);
          transform: scale(1.08);
        }
        .swipe-wish-inner svg {
          stroke: #5A8068 !important;
          fill: none;
          filter: drop-shadow(0 1px 3px rgba(15, 59, 46, 0.10));
          transition: fill 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                      stroke 0.35s ease,
                      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                      filter 0.3s ease;
        }

        .swipe-delete-layer.revealed .swipe-delete-inner,
        .swipe-wish-layer.revealed .swipe-wish-inner {
          opacity: 1;
          transform: scale(1);
        }

        /* Heart pop animation on trigger */
        .swipe-wish-layer.wish-triggered .swipe-wish-inner svg {
          fill: #5A8068 !important;
          stroke: #5A8068 !important;
          transform: scale(1.3);
          filter: drop-shadow(0 2px 8px rgba(90, 128, 104, 0.30));
        }

        /* --- Swiping (no transitions for instant tracking) --- */
        .swipe-row.swiping > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row.swiping > button.cart-items__remove,
        .swipe-row.swiping > .swipe-delete-layer,
        .swipe-row.swiping > .swipe-wish-layer {
          transition: none !important;
        }

        /* --- Snapping spring --- */
        .swipe-row.snapping > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row.snapping > button.cart-items__remove {
          transition: transform 0.45s cubic-bezier(0.32, 1.28, 0.54, 1) !important;
        }
        .swipe-row.snapping > .swipe-delete-layer,
        .swipe-row.snapping > .swipe-wish-layer {
          transition: transform 0.4s cubic-bezier(0.32, 1.28, 0.54, 1) !important;
        }

        /* --- Locked open: LEFT swipe (delete) --- */
        .swipe-row.swiped-left > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row.swiped-left > button.cart-items__remove {
          transform: translate3d(-120px,0,0) !important;
        }
        .swipe-row.swiped-left .swipe-delete-layer {
          transform: translate3d(0,0,0) !important;
        }

        /* --- Locked open: RIGHT swipe (wishlist) --- */
        .swipe-row.swiped-right > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row.swiped-right > button.cart-items__remove {
          transform: translate3d(120px,0,0) !important;
        }
        .swipe-row.swiped-right .swipe-wish-layer {
          transform: translate3d(0,0,0) !important;
        }

        /* --- Collapse-out animation --- */
        .swipe-row.swipe-removing {
          transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0.08s,
                      opacity 0.3s ease,
                      margin 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0.08s,
                      padding 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0.08s !important;
          max-height: 0 !important;
          opacity: 0 !important;
          margin-bottom: 0 !important;
          padding-bottom: 0 !important;
          pointer-events: none !important;
          overflow: hidden !important;
        }

        /* --- Full swipe slide-out (delete) --- */
        .swipe-row.swipe-full-remove > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row.swipe-full-remove > button.cart-items__remove {
          transform: translate3d(-120%,0,0) !important;
          transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }
        .swipe-row.swipe-full-remove .swipe-delete-layer {
          width: 100% !important;
          transform: translate3d(0,0,0) !important;
          transition: width 0.3s ease, transform 0.3s ease !important;
        }

        /* --- Full swipe slide-out (wishlist) --- */
        .swipe-row.swipe-full-wish > td:not(.swipe-delete-layer):not(.swipe-wish-layer),
        .swipe-row.swipe-full-wish > button.cart-items__remove {
          transform: translate3d(120%,0,0) !important;
          transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }
        .swipe-row.swipe-full-wish .swipe-wish-layer {
          width: 100% !important;
          transform: translate3d(0,0,0) !important;
          transition: width 0.3s ease, transform 0.3s ease !important;
        }

        /* --- Drag elevation --- */
        .swipe-row.swiping {
          box-shadow: 0 4px 24px rgba(0,0,0,0.10) !important;
          z-index: 2 !important;
          border-radius: 8px !important;
        }
      }

      /* Hide swipe layers on desktop */
      @media (min-width: 750px) {
        .swipe-delete-layer,
        .swipe-wish-layer {
          display: none !important;
        }
      }

    </style>

    <span
      class="visually-hidden"
      ref="cartItemCount"
      aria-hidden="true"
    >
      {{- cart.item_count -}}
    </span>
    <form
      action="{{ routes.cart_url }}"
      class="cart-form cart-section cart-section--3"
      id="cart-form"
      method="post"
    >
      <div
        class="cart-items spacing-style{% if block_settings.dividers %} cart-items--dividers{% endif %}"
        style="{%  render 'spacing-style', settings: block_settings %} --cart-items-gap:{{ block_settings.gap | append: "px" }};"
      >
        <table
          class="cart-items__table"
          role="table"
        >
          <caption
            class="visually-hidden"
            role="caption"
          >
            {{ 'content.cart_total' | t }}
            <span>
              {{ cart.total_price | money_without_currency }} EUR
            </span>
          </caption>

          <thead
            class="visually-hidden"
            role="rowgroup"
          >
            <tr
              role="row"
              class="cart-items__table-row"
            >
              <th
                id="productImage"
                scope="col"
                role="columnheader"
              >
                {{ 'content.product_image' | t }}
              </th>
              <th
                id="productInformation"
                scope="col"
                role="columnheader"
              >
                {{ 'content.product_information' | t }}
              </th>
              <th
                id="quantity"
                scope="col"
                role="columnheader"
              >
                {{ 'content.quantity' | t }}
              </th>
              <th
                id="productTotal"
                scope="col"
                role="columnheader"
              >
                {{ 'content.product_total' | t }}
              </th>
            </tr>
          </thead>

          <tbody role="rowgroup">
            {% for item in cart.items %}
              <tr
                role="row"
                class="cart-items__table-row swipe-row{% if item.parent_relationship.parent != null %} cart-items__nested-line{% endif %}"
                ref="cartItemRows[]"
                data-parent-key="{{ item.parent_relationship.parent.key }}"
                data-key="{{ item.key }}"
                data-line-index="{{ item.index | plus: 1 }}"
                style="position: relative !important;"
              >
                <td
                  class="cart-items__media"
                  role="cell"
                  headers="productImage"
                >
                  {% if item.image -%}
                    {% liquid
                      assign ratio = 1
                      assign border_opacity = settings.cart_thumbnail_border_opacity | divided_by: 100.0
                      assign border_override = '--border-width: [cart_thumbnail_border_width]px; --border-style: [cart_thumbnail_border_style]; --border-color: rgb(var(--color-border-rgb) / [cart_thumbnail_border_opacity]); --border-radius: [cart_thumbnail_border_radius]px;' | replace: '[cart_thumbnail_border_width]', settings.cart_thumbnail_border_width | replace: '[cart_thumbnail_border_style]', settings.cart_thumbnail_border | replace: '[cart_thumbnail_border_opacity]', border_opacity | replace: '[cart_thumbnail_border_radius]', settings.cart_thumbnail_border_radius

                      if settings.cart_thumbnail_border_radius > 0
                        assign border_override = border_override | append: ' overflow: hidden;'
                      endif
                      if block_settings.image_ratio == 'portrait'
                        assign ratio = 0.8
                      elsif block_settings.image_ratio == 'adapt'
                        assign ratio = item.image.aspect_ratio
                      endif
                    %}
                    <a
                      href="{{ item.url }}"
                      class="cart-items__media-container"
                      style="--ratio:{{ ratio }};"
                    >
                      {%- liquid
                        echo item.image | image_url: width: 250 | image_tag: class: 'cart-items__media-image border-style', style: border_override, alt: item.image.alt | default: item.product.title
                      -%}
                    </a>

                  {%- endif %}
                </td>
                <td
                  class="cart-items__details cart-primary-typography"
                  role="cell"
                  headers="productInformation"
                >
                  <div class="cart-title-row">
                    <p style="flex:1;margin:0;">
                      <a
                        href="{{ item.url }}"
                        class="cart-items__title"
                        {% if item.parent_relationship.parent != null %}
                          aria-label="{{ 'accessibility.nested_product' | t: product_title: item.product.title, parent_title: item.parent_relationship.parent.title | escape }}"
                        {% endif %}
                      >
                        {{- item.product.title -}}
                      </a>
                    </p>
                    <div class="cart-wishlist-container" data-handle="{{ item.product.handle }}">
                      <button
                        type="button"
                        class="cart-wishlist-btn"
                        aria-label="Auf den Wunschzettel"
                        data-handle="{{ item.product.handle }}"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                      </button>
                      <div class="cart-wishlist-active" style="display:none;">
                        <svg viewBox="0 0 24 24" fill="#e53935" stroke="none">
                          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                  {% if item.product.vendor and block_settings.vendor %}
                    <p>
                      {{ item.product.vendor }}
                    </p>
                  {% endif %}

                  {%- if item.item_components.size != 0 -%}
                    <ul class="cart-items__bundle list-unstyled">
                      {%- for component in item.item_components -%}
                        <li>
                          {{- component.title -}}
                          {%- if component.quantity > 1 -%}
                            <span> × {{ component.quantity }}</span>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- if item.product.has_only_default_variant == false
                    or item.properties.size != 0
                    or item.selling_plan_allocation != null
                  -%}
                    <dl class="cart-items__variants">
                      {%- if item.product.has_only_default_variant == false and item.item_components.size == 0 -%}
                        {%- for option in item.options_with_values -%}
                          <div class="cart-items__variant">
                            <dt class="visually-hidden">{{ option.name }}:</dt>
                            <dd>
                              {{- option.value -}}
                              {%- if forloop.last != true %},&nbsp;{% endif -%}
                            </dd>
                          </div>
                        {%- endfor -%}
                      {%- endif -%}

                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          <div class="cart-items__properties">
                            <dt>{{ property.first }}:</dt>
                            <dd>
                              {%- if property.last contains '/uploads/' -%}
                                <a href="{{ property.last }}">{{ property.last | split: '/' | last }}</a>
                              {%- else -%}
                                {{ property.last }}
                              {%- endif -%}
                            </dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </dl>

                    {% if item.selling_plan_allocation %}
                      <p>{{ item.selling_plan_allocation.selling_plan.name }}</p>
                    {% endif %}
                  {%- endif -%}



                  {% if item.line_level_discount_allocations.size > 0 %}
                    <ul
                      class="list-unstyled"
                      role="list"
                    >
                      {%- for discount in item.line_level_discount_allocations -%}
                        <li>{{ discount.discount_application.title | escape }}</li>
                      {%- endfor -%}
                    </ul>
                  {% endif %}

                  <div>
                    {% if item.original_price != item.final_price %}
                      <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
                      <span>{{ item.final_price | money_without_currency }} EUR</span>
                      <span class="visually-hidden">{{ 'content.price_regular' | t }}</span>
                      <s class="compare-at-price">
                        {% if item.variant.compare_at_price > item.original_price %}
                          {{ item.variant.compare_at_price | money_without_currency }} EUR
                        {% else %}
                          {{ item.original_price | money_without_currency }} EUR
                        {% endif %}
                      </s>
                    {% else %}
                      {% if item.variant.compare_at_price > item.original_price %}
                        <span class="visually-hidden">{{ 'content.price_sale' | t }}</span>
                      {% else %}
                        <span class="visually-hidden">{{ 'content.price' | t }}</span>
                      {% endif %}

                      <span>{{ item.original_price | money_without_currency }} EUR</span>

                      {% if item.variant.compare_at_price > item.original_price %}
                        <span class="visually-hidden">{{ 'content.price_regular' | t }}</span>
                        <s class="compare-at-price">{{ item.variant.compare_at_price | money_without_currency }} EUR</s>
                      {% endif %}
                    {% endif %}
                  </div>

                  {%- comment -%} Heart icon is now placed in the image cell — see media td below {%- endcomment -%}

                  {% if item.line_level_discount_allocations.size > 0 %}
                    <ul
                      class="list-unstyled"
                      role="list"
                    >
                      {%- for discount in item.line_level_discount_allocations -%}
                        <li>{{ discount.discount_application.title | escape }}</li>
                      {%- endfor -%}
                    </ul>
                  {% endif %}

                </td>
                <td
                  class="cart-items__quantity"
                  role="cell"
                  headers="quantity"
                >
                  {% # Here I want to pass some arguments to the quantity block so it knows which value should the input be set to. Though quantity block could be a snippet instead %}
                  {% assign can_update_quantity = item.instructions.can_update_quantity
                    | default: true, allow_false: true
                  %}
                  <div class="cart-items__quantity-controls">
                    {% render 'volume-pricing-info',
                      variant: item.variant,
                      unique_id: item.index,
                      quantity: item.quantity
                    %}

                    {% render 'quantity-selector',
                      product: item.product,
                      variant: item.variant,
                      in_cart_quantity: item.quantity,
                      line_index: item.index,
                      class: 'cart-primary-typography',
                      can_update_quantity: can_update_quantity
                    %}
                  </div>
                </td>
                <td
                  class="cart-items__error hidden"
                  role="cell"
                  ref="cartItemErrorContainer-{{ item.index | plus: 1 }}"
                  headers="quantity"
                >
                  <div
                    class="cart-item__error"
                    role="alert"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    <small
                      class="cart-item__error-text cart-primary-typography"
                      ref="cartItemError-{{ item.index | plus: 1 }}"
                    ></small>
                  </div>
                </td>
                <td
                  class="cart-items__price cart-secondary-typography"
                  role="cell"
                  headers="productTotal"
                >
                  {%- liquid
                    if settings.currency_code_enabled_cart_items
                      assign price = item.final_line_price | money_without_currency | append: ' EUR'
                      assign unit_price = item.unit_price | money_without_currency | append: ' EUR'
                    else
                      assign price = item.final_line_price | money_without_currency | append: ' EUR'
                      assign unit_price = item.unit_price | money_without_currency | append: ' EUR'
                    endif
                  -%}
                  <text-component value="{{ price | strip_html }}">{{ price }}</text-component>
                  {%- if item.unit_price_measurement -%}
                    <div class="cart-items__price-unit cart-secondary-typography">
                      {% render 'unit-price', price: unit_price, measurement: item.unit_price_measurement %}
                    </div>
                  {%- endif -%}
                  <button
                    class="button button--tertiary cart-items__remove"
                    type="button"
                    aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                    on:click="/onLineItemRemove/{{ item.index | plus: 1 }}"
                    {% assign can_remove = item.instructions.can_remove | default: true, allow_false: true %}
                    {% if can_remove == false %}
                      hidden
                    {% endif %}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    <span class="visually-hidden">{{ 'accessibility.remove' | t }}</span>
                  </button>
                </td>
                {%- comment -%} Swipe action layers {%- endcomment -%}
                <td class="swipe-wish-layer" aria-hidden="true">
                  <div class="swipe-wish-inner">
