<!-- ═══════════════════════════════════════════════════════
     DRAWER CLOSE GUARD v3 — bulletproof inline protection
     Patches closeDialog() on the custom element instance,
     monitors dialog open state via MutationObserver,
     and blocks premature events at capture phase.
     ═══════════════════════════════════════════════════════ -->
<script>
(function() {
  /* ── Track user-initiated close gestures ── */
  var userClose = false;
  function markUserClose() {
    userClose = true;
    setTimeout(function() { userClose = false; }, 1500);
  }
  document.addEventListener('pointerdown', function(e) {
    if (e.target.closest('.cart-drawer__close-button, [on\\:click*="close"]')) markUserClose();
    if (e.target.tagName === 'DIALOG' && e.target.closest('cart-drawer-component')) markUserClose();
  }, true);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') markUserClose();
  }, true);

  /* ── Helpers ── */
  function cartHasItems() {
    return document.querySelectorAll(
      '.cart-drawer .cart-items__table-row:not(.removing):not(.swipe-removing)'
    ).length > 0;
  }

  /* ═══ LAYER 1: Capture-phase event blockers ═══ */
  document.addEventListener('cart:empty', function(e) {
    if (cartHasItems()) { e.stopImmediatePropagation(); e.stopPropagation(); }
  }, true);

  document.addEventListener('cart:update', function(e) {
    var d = e.detail;
    var cnt = (d && d.itemCount != null) ? d.itemCount : (d && d.data && d.data.itemCount);
    if (cnt === 0 && cartHasItems()) { e.stopImmediatePropagation(); e.stopPropagation(); }
  }, true);

  /* ═══ LAYER 2: Patch closeDialog() on <cart-drawer-component> instance ═══
     closeDialog is an arrow-function class field on each instance.
     When theme code calls this.closeDialog(), it resolves via the
     instance property — so overriding it here is picked up immediately. */
  function patchDrawer() {
    var drawer = document.querySelector('cart-drawer-component');
    if (!drawer || drawer.__closeGuard) return !!drawer;

    var origClose = drawer.closeDialog;
    if (typeof origClose !== 'function') return false;

    drawer.closeDialog = async function() {
      if (userClose || !cartHasItems()) {
        return origClose();
      }
      /* Cart still has items → block auto-close */
    };
    drawer.__closeGuard = true;

    /* Also patch dialog.close() as a safety net */
    var dialog = drawer.querySelector('dialog');
    if (dialog && !dialog.__closeGuard) {
      var origDialogClose = HTMLDialogElement.prototype.close;
      dialog.close = function(rv) {
        if (userClose || !cartHasItems()) return origDialogClose.call(this, rv);
      };
      dialog.__closeGuard = true;
    }
    return true;
  }

  /* ═══ LAYER 3: MutationObserver — re-open dialog if it loses open attribute
     while cart has items (catches morph replacements, edge cases) ═══ */
  function watchDialog() {
    var dialog = document.querySelector('cart-drawer-component dialog');
    if (!dialog) return false;

    new MutationObserver(function(muts) {
      for (var i = 0; i < muts.length; i++) {
        if (muts[i].attributeName === 'open' && !dialog.open && cartHasItems() && !userClose) {
          queueMicrotask(function() {
            if (!dialog.open && cartHasItems() && !userClose) {
              try { dialog.showModal(); } catch(e) {}
            }
          });
          break;
        }
      }
    }).observe(dialog, { attributes: true, attributeFilter: ['open'] });
    return true;
  }

  /* ── Initialize with retries (elements may not exist yet) ── */
  function init() {
    var patched = patchDrawer();
    var watched = watchDialog();
    return patched && watched;
  }

  if (!init()) {
    var t = 0;
    var iv = setInterval(function() {
      if (init() || ++t > 40) clearInterval(iv);
    }, 200);
  }
})();
</script>

<!-- ═══════════════════════════════════════════════════════
     MASTER CART REMOVE — unified removal with full re-render
     Handles: X-button, swipe-delete, swipe-wishlist, wishlist-btn
     Fetches with sections param → updates summary, totals,
     checkout, payment, badge. Closes drawer when empty.
     ═══════════════════════════════════════════════════════ -->
<script>
(function() {
  /* ── Helpers ── */
  function getSectionId() {
    var c = document.querySelector('.cart-drawer cart-items-component');
    return c && c.dataset ? c.dataset.sectionId : null;
  }

  function updateBadge(count) {
    /* (Social proof badge should not be updated with item count) */
    /* Mobile menu badge */
    var mmBadge = document.querySelector('.cmm-cart-count');
    if (mmBadge) {
      mmBadge.textContent = count > 0 ? String(count) : '0';
      mmBadge.style.display = count > 0 ? 'flex' : 'none';
    }
  }

  /**
   * Directly update the <cart-icon> badge without dispatching cart:update.
   * This avoids triggering component-cart-items.js re-morph which would
   * undo our visual row removal animation.
   */
  function updateCartIconBadge(count) {
    var icons = document.querySelectorAll('cart-icon');
    icons.forEach(function(icon) {
      /* Try refs first (set by Component.connectedCallback) */
      var refs = icon.refs;
      var bubbleCount = refs ? refs.cartBubbleCount : icon.querySelector('[ref="cartBubbleCount"]');
      var bubble      = refs ? refs.cartBubble      : icon.querySelector('[ref="cartBubble"]');
      if (!bubbleCount || !bubble) return;

      /* Update text */
      bubbleCount.textContent = (count > 0 && count < 100) ? String(count) : '';
      /* Update visibility */
      bubbleCount.classList.toggle('hidden', count === 0);
      bubble.classList.toggle('visually-hidden', count === 0);
      bubble.setAttribute('data-count', String(count));
      /* Update parent class */
      icon.classList.toggle('header-actions__cart-icon--has-cart', count > 0);
    });
    /* Persist for back-button restoration */
    try {
      sessionStorage.setItem('cart-count', JSON.stringify({
        value: String(count),
        timestamp: Date.now()
      }));
    } catch(e) {}
  }

  function updateDrawerHeadingCount(count) {
    var el = document.querySelector('.cart-drawer__count');
    if (el) el.textContent = count > 0 ? String(count) : '';
  }

  function closeDrawer() {
    var drawer = document.querySelector('cart-drawer-component');
    if (!drawer) return;
    if (typeof drawer.closeDialog === 'function') {
      drawer.closeDialog();
    } else {
      var dlg = drawer.querySelector('dialog');
      if (dlg && dlg.open) try { dlg.close(); } catch(e) {}
    }
  }

  /**
   * Replace the summary footer with fresh server-rendered HTML.
   * Also updates checkout button total and heading count.
   */
  function updateSummaryFromHTML(sectionId, sectionHTML, itemCount) {
    var doc = new DOMParser().parseFromString(sectionHTML, 'text/html');
    var newSection = doc.getElementById('shopify-section-' + sectionId);
    if (!newSection) return;

    /* Summary (totals + checkout + payment buttons) */
    var newSummary = newSection.querySelector('.cart-drawer__summary');
    var oldSummary = document.querySelector('.cart-drawer__summary');
    if (newSummary && oldSummary) {
      oldSummary.innerHTML = newSummary.innerHTML;
    }

    /* Heading count */
    updateDrawerHeadingCount(itemCount);
  }

  /**
   * Render the full empty-cart state (replaces entire cart-items-component body).
   */
  function renderEmptyState(sectionId, sectionHTML) {
    var doc = new DOMParser().parseFromString(sectionHTML, 'text/html');
    var newSection = doc.getElementById('shopify-section-' + sectionId);
    if (!newSection) return;
    var existingComp = document.querySelector('#shopify-section-' + sectionId + ' cart-items-component');
    var newComp = newSection.querySelector('cart-items-component');
    if (existingComp && newComp) {
      existingComp.innerHTML = newComp.innerHTML;
    }
    /* Also update the dialog class for empty styling */
    var dlg = document.querySelector('.cart-drawer__dialog');
    if (dlg) dlg.classList.add('cart-drawer--empty');
  }

  /* ═══════════════════════════════════════════════════════
     __cartMasterRemove(key, row, opts)
     Single entry point for ALL cart item removals.
     - key: the cart line-item key
     - row: the DOM <tr> element
     - opts.animDelay: ms to wait for row animation (default 450)
     - opts.skipAnim: if row is already animated
     Returns a Promise.
     ═══════════════════════════════════════════════════════ */
  window.__cartMasterRemove = function(key, row, opts) {
    opts = opts || {};
    var sectionId = getSectionId();
    if (!key || !sectionId) return Promise.reject('Missing key or sectionId');
    var animDelay = opts.animDelay || 450;

    return fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: key,
        quantity: 0,
        sections: sectionId,
        sections_url: window.location.pathname
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var sectionHTML = data.sections ? data.sections[sectionId] : null;

      updateBadge(data.item_count);
      updateCartIconBadge(data.item_count);

      if (data.item_count === 0) {
        /* ── Cart is now empty ── */
        setTimeout(function() {
          if (sectionHTML) renderEmptyState(sectionId, sectionHTML);
          document.dispatchEvent(new CustomEvent('cart:empty', { bubbles: true, composed: true }));
          setTimeout(closeDrawer, 80);
        }, animDelay);
      } else {
        /* ── Cart still has items — update summary immediately ── */
        if (sectionHTML) updateSummaryFromHTML(sectionId, sectionHTML, data.item_count);
        /* Remove the row after its collapse animation */
        if (row) setTimeout(function() { row.remove(); }, animDelay);
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true, detail: { cart: data } }));
      }

      return data;
    });
  };

  /* ═══ INTERCEPT X-BUTTON CLICKS ═══
     Capture phase — runs BEFORE the theme component's on:click routing.
     We handle the removal ourselves with sections re-rendering. */
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.cart-drawer .cart-items__remove');
    if (!btn) return;

    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();

    var row = btn.closest('tr.cart-items__table-row');
    if (!row || !row.dataset.key) return;

    /* Animate collapse (matches theme's native .removing animation) */
    row.style.setProperty('--row-height', row.clientHeight + 'px');
    row.classList.add('removing');

    window.__cartMasterRemove(row.dataset.key, row, { animDelay: 500 })
      .catch(function() {
        row.classList.remove('removing');
        row.style.removeProperty('--row-height');
      });
  }, true); /* capture phase */
})();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {

    // 1. Initial Check: Updates UI based on localStorage
    const updateWishlistUI = () => {
      try {
        let wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
        wishlist = wishlist.map(i => typeof i === 'string' ? i.trim() : i).filter(Boolean);

        const containers = document.querySelectorAll('.cart-wishlist-container');
        containers.forEach(container => {
          const handle = container.dataset.handle;
          if (!handle) return;

          if (wishlist.includes(handle)) {
             container.classList.add('in-wishlist');
          } else {
             container.classList.remove('in-wishlist');
          }
        });
      } catch (e) {
        console.error('DEBUG: Error in updateWishlistUI:', e);
      }
    };

    updateWishlistUI();
    // Re-check if wishlist updates elsewhere (e.g. storage event maybe?)
    window.addEventListener('wishlist-updated', updateWishlistUI);


    // Toast Logic
    const showToast = (message) => {
      const toast = document.getElementById('wishlist-toast');
      if (!toast) return;
      
      if (message) {
        const span = toast.querySelector('span');
        if (span) span.textContent = message;
      }
      
      toast.classList.add('show');
      toast.setAttribute('aria-hidden', 'false');
      
      setTimeout(() => {
        toast.classList.remove('show');
        toast.setAttribute('aria-hidden', 'true');
      }, 4000);
    };

    // Use delegation for dynamic cart updates
    document.body.addEventListener('click', (e) => {
      const btn = e.target.closest('.cart-wishlist-btn');
      if (!btn) return;
      e.preventDefault();
      const handle = btn.dataset.handle;
      if (!handle) return;

      // Toggle active state visually
      const container = btn.closest('.cart-wishlist-container');
      if (container) {
        container.classList.add('in-wishlist');
        btn.style.display = 'none';
        const activeDiv = container.querySelector('.cart-wishlist-active');
        if (activeDiv) activeDiv.style.display = 'flex';
      }

        // 1. Add to Wishlist
        let wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
        wishlist = wishlist.map(i => typeof i === 'string' ? i.trim() : i).filter(Boolean);
        
        if (!wishlist.includes(handle)) {
          wishlist.push(handle);
          localStorage.setItem('wishlist', JSON.stringify(wishlist));
          window.dispatchEvent(new Event('wishlist-updated')); 
          showToast('Der Artikel wurde erfolgreich zum Wunschzettel hinzugefügt.');
        } else {
          showToast('Der Artikel ist bereits auf deinem Wunschzettel.');
        }

        // 2. Remove from Cart via masterRemove
        const row = btn.closest('tr');
        if (row && row.dataset.key) {
           btn.style.opacity = '0.5';
           btn.style.pointerEvents = 'none';
           row.style.transition = 'opacity 0.5s, transform 0.5s';
           row.style.opacity = '0';
           row.style.transform = 'translateX(20px)';
           row.classList.add('removing');

           window.__cartMasterRemove(row.dataset.key, row, { animDelay: 500 })
             .catch(function(err) {
               console.error('Error removing item:', err);
               row.style.opacity = '';
               row.style.transform = '';
             });
        }
    });

    // FAILSAFE: Find and hide phantom duplicate buttons
    const hidePhantomButtons = () => {
       const allButtons = document.querySelectorAll('button, a, div[role="button"]');
       allButtons.forEach(el => {
         if (el.textContent.trim() === 'Auf den Wunschzettel' && !el.classList.contains('cart-wishlist-btn')) {
           el.style.display = 'none';
           el.style.visibility = 'hidden';
         }
       });
    };
    // Run repeatedly in case of dynamic rendering
    setTimeout(hidePhantomButtons, 500);
    setTimeout(hidePhantomButtons, 1500);
    setTimeout(hidePhantomButtons, 3000);

    /* X-button removal is now handled by the capture-phase interceptor
       in the MASTER CART REMOVE script above. */
  });
</script>

<!-- Dual Swipe JS — Delete (left) + Wishlist (right) — 60fps GPU -->
<script>
(function() {
  if (window.matchMedia('(min-width: 750px)').matches) return;

  const THRESHOLD = 60;
  const MAX = 120;
  const FULL_VEL = 1.6;
  const RUBBER = 0.28;

  let row = null;
  let sx = 0, sy = 0, cx = 0;
  let lastX = 0, lastT = 0, vel = 0;
  let swiping = false, scrolling = false, decided = false;
  let dir = 0; // -1 = left (delete), +1 = right (wish), 0 = undecided
  let raf = null;
  let undoTimer = null, pendingDelete = null;
  let wishSnackTimer = null;

  const haptic = () => { if (navigator.vibrate) navigator.vibrate(8); };

  const targets = r => r.querySelectorAll(':scope > td:not(.swipe-delete-layer):not(.swipe-wish-layer), :scope > button.cart-items__remove');

  function paint(r, x) {
    const t3d = 'translate3d(' + x + 'px,0,0)';
    targets(r).forEach(el => { el.style.transform = t3d; });

    const delLayer = r.querySelector('.swipe-delete-layer');
    const wishLayer = r.querySelector('.swipe-wish-layer');

    if (x < 0 && delLayer) {
      const reveal = Math.min(Math.abs(x), MAX);
      delLayer.style.transform = 'translate3d(' + (MAX - reveal) + 'px,0,0)';
      delLayer.classList.toggle('revealed', Math.abs(x) > 28);
      // Hide the other
      if (wishLayer) wishLayer.style.transform = 'translate3d(-100%,0,0)';
    } else if (x > 0 && wishLayer) {
      const reveal = Math.min(x, MAX);
      wishLayer.style.transform = 'translate3d(' + (reveal - MAX) + 'px,0,0)';
      wishLayer.classList.toggle('revealed', x > 28);
      if (delLayer) delLayer.style.transform = 'translate3d(100%,0,0)';
    } else {
      if (delLayer) { delLayer.style.transform = 'translate3d(100%,0,0)'; delLayer.classList.remove('revealed'); }
      if (wishLayer) { wishLayer.style.transform = 'translate3d(-100%,0,0)'; wishLayer.classList.remove('revealed'); }
    }
  }

  function frame(r, x) {
    if (raf) cancelAnimationFrame(raf);
    raf = requestAnimationFrame(() => { paint(r, x); raf = null; });
  }

  function closeRow(r) {
    if (!r) return;
    r.classList.remove('swiping', 'swiped-left', 'swiped-right');
    r.classList.add('snapping');
    paint(r, 0);
    setTimeout(() => r.classList.remove('snapping'), 480);
  }

  function openLeft(r) {
    r.classList.remove('swiping');
    r.classList.add('snapping', 'swiped-left');
    paint(r, -MAX);
    haptic();
    setTimeout(() => r.classList.remove('snapping'), 480);
  }

  function openRight(r) {
    r.classList.remove('swiping');
    r.classList.add('snapping', 'swiped-right');
    paint(r, MAX);
    haptic();
    setTimeout(() => r.classList.remove('snapping'), 480);
  }

  // ── DELETE ──
  function fullDelete(r) {
    haptic();
    r.classList.remove('swiping', 'swiped-left');
    r.classList.add('swipe-full-remove');
    r.querySelector('.swipe-delete-layer')?.classList.add('revealed');
    setTimeout(() => removeItem(r), 280);
  }

  function removeItem(r) {
    const key = r.dataset.key;
    if (!key) return;
    const h = r.offsetHeight + parseInt(getComputedStyle(r).marginBottom || 0);
    r.style.maxHeight = h + 'px';
    r.offsetHeight;
    r.classList.add('swipe-removing');
    haptic();

    const sb = document.getElementById('swipe-undo-snackbar');
    if (sb) {
      sb.classList.add('show');
      pendingDelete = { key, row: r };
      clearTimeout(undoTimer);
      undoTimer = setTimeout(confirmDelete, 4500);
    } else {
      doRemove(key, r);
    }
  }

  function confirmDelete() {
    document.getElementById('swipe-undo-snackbar')?.classList.remove('show');
    if (pendingDelete) { doRemove(pendingDelete.key, pendingDelete.row); pendingDelete = null; }
  }

  function doRemove(key, r) {
    window.__cartMasterRemove(key, r, { animDelay: 450 })
      .catch(function() {
        r.classList.remove('swipe-removing', 'swipe-full-remove');
        r.style.maxHeight = '';
        closeRow(r);
      });
  }

  // ── WISHLIST ──
  function fullWish(r) {
    haptic();
    r.classList.remove('swiping', 'swiped-right');
    r.classList.add('swipe-full-wish');
    const wl = r.querySelector('.swipe-wish-layer');
    if (wl) { wl.classList.add('revealed', 'wish-triggered'); }
    setTimeout(() => doWishlist(r), 350);
  }

  function doWishlist(r) {
    const handle = r.querySelector('[data-handle]')?.dataset.handle;
    if (!handle) return;

    // Add to localStorage wishlist
    let wl = [];
    try { wl = JSON.parse(localStorage.getItem('wishlist') || '[]'); } catch(e) {}
    wl = wl.map(i => typeof i === 'string' ? i.trim() : i).filter(Boolean);
    if (!wl.includes(handle)) {
      wl.push(handle);
      localStorage.setItem('wishlist', JSON.stringify(wl));
      window.dispatchEvent(new Event('wishlist-updated'));
    }

    // Heart pop animation
    const wishLayer = r.querySelector('.swipe-wish-layer');
    if (wishLayer) wishLayer.classList.add('wish-triggered');

    // Show wishlist feedback snackbar
    const wsb = document.getElementById('swipe-wish-snackbar');
    if (wsb) {
      wsb.classList.add('show');
      clearTimeout(wishSnackTimer);
      wishSnackTimer = setTimeout(() => wsb.classList.remove('show'), 3000);
    }

    // Remove from cart via masterRemove
    const key = r.dataset.key;
    if (key) {
      const h = r.offsetHeight + parseInt(getComputedStyle(r).marginBottom || 0);
      r.style.maxHeight = h + 'px';
      r.offsetHeight;
      r.classList.add('swipe-removing');

      window.__cartMasterRemove(key, r, { animDelay: 450 })
        .catch(function() {
          r.classList.remove('swipe-removing', 'swipe-full-wish');
          r.style.maxHeight = '';
          closeRow(r);
        });
    }
  }

  // ── Undo button ──
  const undoBtn = document.getElementById('swipe-undo-btn');
  if (undoBtn) {
    undoBtn.addEventListener('click', () => {
      clearTimeout(undoTimer);
      document.getElementById('swipe-undo-snackbar')?.classList.remove('show');
      if (pendingDelete?.row) {
        const r = pendingDelete.row;
        r.classList.remove('swipe-removing', 'swipe-full-remove');
        r.style.maxHeight = '';
        closeRow(r);
        pendingDelete = null;
      }
    });
  }

  // ── TOUCH START ──
  document.addEventListener('touchstart', function(e) {
    const r = e.target.closest('.swipe-row');
    if (!r || e.target.closest('.quantity-selector, input, select, .swipe-delete-layer, .swipe-wish-layer')) return;

    // Close other open rows
    document.querySelectorAll('.swipe-row.swiped-left, .swipe-row.swiped-right').forEach(o => {
      if (o !== r) closeRow(o);
    });

    const t = e.touches[0];
    sx = t.clientX; sy = t.clientY;
    cx = 0; vel = 0; dir = 0;
    lastX = t.clientX; lastT = Date.now();
    swiping = false; scrolling = false; decided = false;
    row = r;
  }, { passive: true });

  // ── TOUCH MOVE (60fps) ──
  document.addEventListener('touchmove', function(e) {
    if (!row) return;
    const t = e.touches[0];
    const dx = t.clientX - sx;
    const dy = t.clientY - sy;

    if (!decided) {
      if (Math.abs(dy) > 6 && Math.abs(dy) > Math.abs(dx) * 1.2) {
        scrolling = true; decided = true; row = null; return;
      }
      if (Math.abs(dx) > 6) {
        swiping = true; decided = true;
        dir = dx < 0 ? -1 : 1;
        row.classList.add('swiping');
        row.classList.remove('snapping', 'swiped-left', 'swiped-right');
        sx = t.clientX; // zero-jump reset
      } else { return; }
    }

    if (scrolling) return;
    e.preventDefault();

    // Velocity
    const now = Date.now();
    const dt = now - lastT;
    if (dt > 0) vel = (lastX - t.clientX) / dt; // positive = left
    lastX = t.clientX; lastT = now;

    let raw = t.clientX - sx;

    // Lock direction after first decision
    if (dir === -1 && raw > 0) raw = 0;
    if (dir === 1 && raw < 0) raw = 0;

    // Rubber-band past max
    const abs = Math.abs(raw);
    let offset;
    if (abs > MAX) {
      offset = (raw > 0 ? 1 : -1) * (MAX + (abs - MAX) * RUBBER);
    } else {
      offset = raw;
    }

    cx = offset;
    frame(row, offset);
  }, { passive: false });

  // ── TOUCH END ──
  document.addEventListener('touchend', function() {
    if (raf) { cancelAnimationFrame(raf); raf = null; }
    if (!row || !swiping) { row = null; return; }

    const r = row;
    row = null;
    r.classList.remove('swiping');

    const abs = Math.abs(cx);
    const absVel = Math.abs(vel);

    if (dir === -1) {
      // LEFT swipe → delete
      if (vel > FULL_VEL || abs > MAX * 1.15) { fullDelete(r); return; }
      if (abs >= THRESHOLD || vel > 0.5) { openLeft(r); }
      else { closeRow(r); }
    } else if (dir === 1) {
      // RIGHT swipe → wishlist
      if (-vel > FULL_VEL || abs > MAX * 1.15) { fullWish(r); return; }
      if (abs >= THRESHOLD || absVel > 0.5) { openRight(r); }
      else { closeRow(r); }
    } else {
      closeRow(r);
    }
  }, { passive: true });

  // ── Tap action layers ──
  document.addEventListener('click', function(e) {
    const del = e.target.closest('.swipe-delete-layer');
    if (del) { const r = del.closest('.swipe-row'); if (r) removeItem(r); return; }

    const wish = e.target.closest('.swipe-wish-layer');
    if (wish) { const r = wish.closest('.swipe-row'); if (r) doWishlist(r); return; }
  });

  // Close on scroll
  let st;
  document.addEventListener('scroll', function() {
    clearTimeout(st);
    st = setTimeout(() => {
      document.querySelectorAll('.swipe-row.swiped-left, .swipe-row.swiped-right').forEach(closeRow);
    }, 150);
  }, { passive: true });

  // Close on outside tap
  document.addEventListener('touchstart', function(e) {
    if (!e.target.closest('.swipe-row.swiped-left, .swipe-row.swiped-right, .swipe-snackbar')) {
      document.querySelectorAll('.swipe-row.swiped-left, .swipe-row.swiped-right').forEach(closeRow);
    }
  }, { passive: true });

})();
</script>

{% stylesheet %}
  .cart-items {
