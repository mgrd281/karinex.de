  .cart-items__properties dt,
  .cart-items__properties dd {
    display: inline;
  }

  /* ─────────────────────────────────────────────────────────────
     Wird oft zusammen gekauft — horizontal row cards
     ───────────────────────────────────────────────────────────── */
  .cart-reco-wrapper {
    padding: 8px 0 6px;
  }

  .cart-reco-header {
    margin: 0 var(--padding-sm) 8px;
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.52);
  }

  /* Vertical list of horizontal rows */
  .cart-reco-scroll {
    display: flex;
    flex-direction: column;
    padding: 0 var(--padding-sm) 6px;
  }

  @keyframes fadeInUpCartReco {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cart-reco-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.06);
    max-height: 200px;
    overflow: visible;
    opacity: 0;
    animation: fadeInUpCartReco 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .cart-reco-card:last-child {
    border-bottom: none;
  }

  .cart-reco-img-link {
    flex: 0 0 62px;
    width: 62px;
    height: 62px;
    border-radius: 9px;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    display: block;
  }

  .cart-reco-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cart-reco-card:hover .cart-reco-img {
    transform: scale(1.04);
  }

  .cart-reco-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cart-reco-name {
    font-size: 12.5px;
    font-weight: 500;
    line-height: 1.3;
    color: rgb(var(--color-foreground-rgb));
    text-decoration: none;
    transition: opacity 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cart-reco-name:hover {
    opacity: 0.62;
  }

  .cart-reco-meta {
    display: flex;
    align-items: baseline;
    gap: 5px;
    flex-wrap: wrap;
  }

  .cart-reco-now {
    font-size: 13px;
    font-weight: 700;
    color: rgb(var(--color-foreground-rgb));
  }

  .cart-reco-now--sale {
    color: #b5291c;
  }

  .cart-reco-was {
    font-size: 11px;
    font-weight: 400;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    text-decoration: line-through;
    text-decoration-color: rgb(var(--color-foreground-rgb) / 0.35);
  }

  /* Circular "+" add button */
  .cart-reco-btn {
    flex: 0 0 auto;
    position: relative;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    background: transparent;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.12s ease;
  }

  .cart-reco-btn__plus,
  .cart-reco-btn__check {
    position: absolute;
    transition: opacity 0.18s ease, transform 0.22s ease;
  }

  .cart-reco-btn__check {
    opacity: 0;
    transform: scale(0.5);
  }

  .cart-reco-btn:hover:not(:disabled) {
    background: rgb(var(--color-foreground-rgb));
    border-color: rgb(var(--color-foreground-rgb));
    color: rgb(var(--color-background-rgb));
    transform: scale(1.08);
    box-shadow: 0 0 0 3px rgb(var(--color-foreground-rgb) / 0.08);
  }

  .cart-reco-btn:active:not(:disabled) {
    transform: scale(0.88);
  }

  .cart-reco-btn:disabled {
    opacity: 0.28;
    cursor: default;
  }

  /* Loading state */
  .cart-reco-btn--loading {
    pointer-events: none;
    border-color: rgb(var(--color-foreground-rgb) / 0.12) !important;
    color: transparent !important;
  }

  .cart-reco-btn--loading .cart-reco-btn__plus,
  .cart-reco-btn--loading .cart-reco-btn__check {
    opacity: 0;
  }

  .cart-reco-btn--loading::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1.5px solid rgb(var(--color-foreground-rgb) / 0.14);
    border-top-color: rgb(var(--color-foreground-rgb) / 0.6);
    border-radius: 50%;
    animation: _cart-reco-spin 0.6s linear infinite;
  }

  @keyframes _cart-reco-spin {
    to { transform: rotate(360deg); }
  }

  /* Added / success state */
  .cart-reco-btn--added {
    background: #1D4739 !important;
    border-color: #1D4739 !important;
    color: #fff !important;
    pointer-events: none;
  }

  .cart-reco-btn--added .cart-reco-btn__plus {
    opacity: 0;
    transform: scale(0.5) rotate(45deg);
  }

  .cart-reco-btn--added .cart-reco-btn__check {
    opacity: 1;
    transform: scale(1);
  }
{% endstylesheet %}
