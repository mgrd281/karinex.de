{%- comment -%}
  Karinex Locale Switcher — modal popup (ABOUT YOU-style).

  Renders:
    1. Trigger button in the header showing `🇩🇪 DE | EUR`
    2. A centered 320 px modal with:
       - Globe icon + "Sprache und Land" header
       - Language pill toggle (Deutsch / English / Polski / Svenska)
       - "Aktueller Shop" label + chevron
       - Scrollable country list with flag, name, currency, ✓ on selected
    3. Backdrop, ESC, outside-click close
    4. Mobile: full-width with dark overlay

  Uses Shopify's native {% form 'localization' %} so language + country
  submits go through the standard Shopify locale routing. No app needed.
{%- endcomment -%}

<style>
  /* ── Trigger button (header) ─────────────────────────────────── */
  .klsw-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: none;
    padding: 6px 8px;
    cursor: pointer;
    font-family: inherit;
    color: #222;
    line-height: 1;
    -webkit-tap-highlight-color: transparent;
  }
  .klsw-trigger:hover { background: rgba(0,0,0,0.04); border-radius: 6px; }
  .klsw-trigger:focus-visible { outline: 2px solid #1D4739; outline-offset: 2px; }
  .klsw-trigger__flag { font-size: 14px; line-height: 1; }
  .klsw-trigger__code {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.5px;
    color: #222;
  }
  .klsw-trigger__chev {
    width: 10px; height: 10px;
    color: #666;
    transition: transform .2s ease;
  }
  .klsw-trigger[aria-expanded="true"] .klsw-trigger__chev { transform: rotate(180deg); }

  /* ── Backdrop ────────────────────────────────────────────────── */
  .klsw-backdrop {
    position: fixed; inset: 0;
    background: rgba(15, 25, 20, 0.45);
    z-index: 10000;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .klsw-backdrop.is-open { opacity: 1; pointer-events: auto; }

  /* ── Modal ───────────────────────────────────────────────────── */
  .klsw-modal {
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(.96);
    width: 320px;
    max-width: calc(100vw - 24px);
    background: #FFFFFF;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    z-index: 10001;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease, transform .3s cubic-bezier(.34,1.56,.64,1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: min(85vh, 600px);
    font-family: inherit;
  }
  .klsw-modal.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, -50%) scale(1);
  }

  /* ── Modal header ────────────────────────────────────────────── */
  .klsw-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 18px 14px;
    border-bottom: 1px solid #EFEFEF;
  }
  .klsw-head__globe {
    width: 20px; height: 20px;
    color: #1D4739;
    flex-shrink: 0;
  }
  .klsw-head__title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: #1d1d1f;
    flex: 1;
    letter-spacing: -0.005em;
  }
  .klsw-close {
    width: 28px; height: 28px;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: #555;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s ease, color .15s ease;
    flex-shrink: 0;
  }
  .klsw-close:hover { background: #F5F5F5; color: #111; }
  .klsw-close:focus-visible { outline: 2px solid #1D4739; outline-offset: 1px; }

  /* ── Sections ────────────────────────────────────────────────── */
  .klsw-section {
    padding: 14px 18px 4px;
  }
  .klsw-label {
    display: block;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b6b6b;
    margin: 0 0 10px;
  }
  .klsw-label--row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px;
  }
  .klsw-label__chev {
    width: 12px; height: 12px;
    color: #aaa;
  }

  /* ── Language pills ──────────────────────────────────────────── */
  .klsw-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 6px;
  }
  .klsw-pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border: 1.5px solid #E5E5E5;
    border-radius: 999px;
    background: #FFFFFF;
    color: #1d1d1f;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color .15s ease, background .15s ease, color .15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .klsw-pill:hover { border-color: #BFBFBF; background: #FAFAFA; }
  .klsw-pill.is-active {
    border-color: #1d1d1f;
    background: #FFFFFF;
    color: #1d1d1f;
    font-weight: 600;
  }
  .klsw-pill:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px rgba(29,71,57,0.4);
  }

  /* ── Country list ────────────────────────────────────────────── */
  .klsw-countries {
    max-height: 280px;
    overflow-y: auto;
    padding: 4px 8px 12px;
    scrollbar-width: thin;
    scrollbar-color: #ccc transparent;
  }
  .klsw-countries::-webkit-scrollbar { width: 5px; }
  .klsw-countries::-webkit-scrollbar-thumb { background: #ccc; border-radius: 5px; }
  .klsw-country {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 10px 10px;
    border: none;
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: #1d1d1f;
    transition: background .12s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .klsw-country:hover { background: #F5F5F5; }
  .klsw-country:focus-visible {
    outline: none;
    background: #F5F5F5;
    box-shadow: inset 2px 0 0 #1D4739;
  }
  .klsw-country__flag {
    font-size: 18px;
    line-height: 1;
    width: 22px;
    text-align: center;
    flex-shrink: 0;
  }
  .klsw-country__name {
    flex: 1;
    font-size: 13.5px;
    font-weight: 500;
    color: #1d1d1f;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .klsw-country__curr {
    font-size: 11.5px;
    font-weight: 500;
    color: #888;
    letter-spacing: 0.4px;
    flex-shrink: 0;
  }
  .klsw-country__check {
    width: 14px; height: 14px;
    color: #1D4739;
    flex-shrink: 0;
    opacity: 0;
  }
  .klsw-country.is-active { background: #F5F5F5; }
  .klsw-country.is-active .klsw-country__check { opacity: 1; }
  .klsw-country.is-active .klsw-country__name { font-weight: 600; }

  /* ── Mobile ──────────────────────────────────────────────────── */
  @media (max-width: 520px) {
    .klsw-modal {
      top: auto; left: 0;
      bottom: 0;
      width: 100vw;
      max-width: 100vw;
      max-height: 88vh;
      border-radius: 16px 16px 0 0;
      transform: translate(0, 100%);
    }
    .klsw-modal.is-open { transform: translate(0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .klsw-modal, .klsw-backdrop, .klsw-pill, .klsw-country { transition: none; }
  }
</style>

<div class="klsw">
  {%- liquid
    # Trigger flag emoji from current country ISO (computed via JS data attribute)
    assign cur_iso = localization.country.iso_code
    assign cur_curr = localization.country.currency.iso_code
  -%}
  <button
    type="button"
    class="klsw-trigger"
    id="klswTrigger"
    aria-haspopup="dialog"
    aria-controls="klswModal"
    aria-expanded="false"
    aria-label="{{ 'accessibility.localization_region_and_language' | t: default: 'Sprache und Land' }}"
  >
    <span class="klsw-trigger__flag" data-klsw-iso="{{ cur_iso }}" aria-hidden="true">🌐</span>
    <span class="klsw-trigger__code">{{ cur_iso }} | {{ cur_curr }}</span>
    <svg class="klsw-trigger__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </button>

  <div class="klsw-backdrop" id="klswBackdrop" aria-hidden="true"></div>

  <aside
    class="klsw-modal"
    id="klswModal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="klswTitle"
    aria-hidden="true"
  >
    <header class="klsw-head">
      <svg class="klsw-head__globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      <h3 class="klsw-head__title" id="klswTitle">Sprache und Land</h3>
      <button type="button" class="klsw-close" id="klswClose" aria-label="Schließen">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </header>

    {%- form 'localization', id: 'klsw-form', class: 'klsw-form' -%}
      <input type="hidden" name="locale_code"  value="{{ localization.language.iso_code }}">
      <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">

      {%- if localization.available_languages.size > 1 -%}
        <section class="klsw-section">
          <span class="klsw-label">Sprache</span>
          <div class="klsw-pills" role="group" aria-label="Sprache wählen">
            {%- for lang in localization.available_languages -%}
              <button
                type="submit"
                name="locale_code"
                value="{{ lang.iso_code }}"
                class="klsw-pill{% if lang.iso_code == localization.language.iso_code %} is-active{% endif %}"
                {% if lang.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}
              >
                {{ lang.endonym_name | capitalize }}
              </button>
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}

      {%- if localization.available_countries.size > 1 -%}
        <section class="klsw-section">
          <span class="klsw-label klsw-label--row">
            Aktueller Shop
            <svg class="klsw-label__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </section>
        <div class="klsw-countries" id="klswCountries">
          {%- for country in localization.available_countries -%}
            <button
              type="submit"
              name="country_code"
              value="{{ country.iso_code }}"
              class="klsw-country{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}"
              {% if country.iso_code == localization.country.iso_code %}aria-current="true"{% endif %}
            >
              <span class="klsw-country__flag" data-klsw-iso="{{ country.iso_code }}" aria-hidden="true">🌐</span>
              <span class="klsw-country__name">{{ country.name }}</span>
              <span class="klsw-country__curr">{{ country.currency.iso_code }}</span>
              <svg class="klsw-country__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endform -%}
  </aside>
</div>

<script>
  (function () {
    var trigger  = document.getElementById('klswTrigger');
    var modal    = document.getElementById('klswModal');
    var backdrop = document.getElementById('klswBackdrop');
    var closeBtn = document.getElementById('klswClose');
    if (!trigger || !modal) return;

    // Flag emoji from ISO (regional indicator symbols)
    function flagEmoji(iso) {
      if (!iso || iso.length !== 2) return '🌐';
      iso = iso.toUpperCase();
      var a = iso.charCodeAt(0), b = iso.charCodeAt(1);
      if (a < 65 || a > 90 || b < 65 || b > 90) return '🌐';
      return String.fromCodePoint(127397 + a) + String.fromCodePoint(127397 + b);
    }
    document.querySelectorAll('[data-klsw-iso]').forEach(function (el) {
      el.textContent = flagEmoji(el.getAttribute('data-klsw-iso'));
    });

    function openModal() {
      modal.classList.add('is-open');
      backdrop.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Scroll the active country into view
      var active = modal.querySelector('.klsw-country.is-active');
      if (active) {
        setTimeout(function () { active.scrollIntoView({ block: 'center' }); }, 50);
      }
    }
    function closeModal() {
      modal.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      modal.classList.contains('is-open') ? closeModal() : openModal();
    });
    closeBtn && closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });
  })();
</script>
