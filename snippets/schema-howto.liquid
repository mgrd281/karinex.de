{% comment %}
  ═══════════════════════════════════════════════════════
  SCHEMA: HOWTO
  Version: 1.0 | Created: 20.01.2026
  Purpose: Installation/setup guides with step-by-step rich snippets
  Usage: Include in product pages for digital products
  ═══════════════════════════════════════════════════════
{% endcomment %}

{% comment %} Example usage - add to product pages {% endcomment %}
{% if product.type contains 'Windows' or product.type contains 'Office' or product.type contains 'Software' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Wie installiere ich {{ product.title }}",
  "url": "{{ canonical_url }}",
  "description": "Schritt-für-Schritt-Anleitung zur Installation von {{ product.title }}",
  "image": {
    "@type": "ImageObject",
    "url": "https:{{ product.featured_image | image_url: width: 800 }}"
  },
  "totalTime": "{% if product.type contains 'Windows' %}PT20M{% elsif product.type contains 'Office' %}PT15M{% else %}PT10M{% endif %}",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "{{ cart.currency.iso_code }}",
    "value": "0"
  },
  "tool": [
    {
      "@type": "HowToTool",
      "name": "Computer mit Internetverbindung"
    }
  ],
  "supply": [
    {
      "@type": "HowToSupply",
      "name": "Produktschlüssel"
    }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Download",
      "text": "Laden Sie die Installationsdatei von der offiziellen Microsoft-Website herunter."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Installation starten",
      "text": "Führen Sie die heruntergeladene Datei aus und folgen Sie dem Setup-Assistenten."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Produktschlüssel eingeben",
      "text": "Geben Sie den von Karinex erhaltenen Produktschlüssel ein, wenn Sie dazu aufgefordert werden."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Installation abschließen",
      "text": "Befolgen Sie die verbleibenden Anweisungen und starten Sie Ihren Computer neu, wenn erforderlich."
    }
  ]
}
</script>
{% endif %}
