{% comment %}
  BreadcrumbList JSON-LD Schema — v1.1
  Renders alongside existing HTML breadcrumbs on product/collection/page/article templates.
  Usage: {% render 'schema-breadcrumb' %}
{% endcomment %}

{%- if request.page_type == 'product' -%}
  {%- assign best_col = nil -%}
  {%- for col in product.collections -%}
    {%- assign h = col.handle -%}
    {%- unless h == 'all' or h == 'alle' or h == 'frontpage' -%}
      {%- assign best_col = col -%}
      {%- break -%}
    {%- endunless -%}
  {%- endfor -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "{{ shop.url }}"
    }
    {%- if best_col -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ best_col.title | json }},
      "item": "{{ shop.url }}{{ best_col.url }}"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
    {%- else -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
    {%- endif -%}
  ]
}
</script>

{%- elsif request.page_type == 'collection' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Kategorien",
      "item": "{{ shop.url }}/collections"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
  ]
}
</script>

{%- elsif request.page_type == 'article' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": "{{ shop.url }}{{ article.url }}"
    }
  ]
}
</script>

{%- elsif request.page_type == 'page' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": "{{ shop.url }}{{ page.url }}"
    }
  ]
}
</script>

{%- endif -%}
