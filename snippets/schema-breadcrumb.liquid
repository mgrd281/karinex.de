{% comment %}
  BreadcrumbList JSON-LD Schema — v1.2
  Renders alongside existing HTML breadcrumbs on collection/page/article templates.

  NOTE: Product breadcrumbs are intentionally NOT emitted here. They are
  produced by snippets/product-rich-schema.liquid inside its @graph, so
  emitting them again here would put two BreadcrumbList blocks on every
  product page. Keep product breadcrumbs in product-rich-schema only.

  Usage: {% render 'schema-breadcrumb' %}
{% endcomment %}

{%- if request.page_type == 'collection' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "{% if request.locale.iso_code == 'en' %}Home{% elsif request.locale.iso_code == 'pl' %}Strona główna{% else %}Startseite{% endif %}",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Kategorien",
      "item": "{{ shop.url }}/collections"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ collection.title | json }},
      "item": "{{ shop.url }}{{ collection.url }}"
    }
  ]
}
</script>

{%- elsif request.page_type == 'article' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "{% if request.locale.iso_code == 'en' %}Home{% elsif request.locale.iso_code == 'pl' %}Strona główna{% else %}Startseite{% endif %}",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ blog.title | json }},
      "item": "{{ shop.url }}{{ blog.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": "{{ shop.url }}{{ article.url }}"
    }
  ]
}
</script>

{%- elsif request.page_type == 'page' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "{% if request.locale.iso_code == 'en' %}Home{% elsif request.locale.iso_code == 'pl' %}Strona główna{% else %}Startseite{% endif %}",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ page.title | json }},
      "item": "{{ shop.url }}{{ page.url }}"
    }
  ]
}
</script>

{%- endif -%}
