{% comment %}
  ═══════════════════════════════════════════════════════
  SCHEMA: WEBPAGE
  Version: 1.0 | Created: 20.01.2026
  Purpose: Define page type and breadcrumb context
  ═══════════════════════════════════════════════════════
{% endcomment %}

{% liquid
  assign page_type_schema = 'WebPage'
  assign _date_published = 'now' | date: '%Y-%m-%d'
  assign _date_modified = 'now' | date: '%Y-%m-%d'
  
  if request.page_type == 'product'
    assign page_type_schema = 'ItemPage'
    assign _date_published = product.published_at | date: '%Y-%m-%d'
    assign _date_modified = product.updated_at | default: product.published_at | date: '%Y-%m-%d'
  elsif request.page_type == 'collection'
    assign page_type_schema = 'CollectionPage'
    assign _date_published = collection.published_at | date: '%Y-%m-%d'
    assign _date_modified = collection.updated_at | default: collection.published_at | date: '%Y-%m-%d'
  elsif request.page_type == 'article'
    assign page_type_schema = 'WebPage'
    assign _date_published = article.published_at | date: '%Y-%m-%d'
    assign _date_modified = article.updated_at | default: article.published_at | date: '%Y-%m-%d'
  elsif request.page_type == 'page'
    assign _date_published = page.published_at | date: '%Y-%m-%d'
    assign _date_modified = page.updated_at | default: page.published_at | date: '%Y-%m-%d'
  elsif request.page_type == 'index'
    assign page_type_schema = 'WebPage'
  endif
  
  assign page_url = canonical_url | default: request.origin
  assign page_name = page_title | default: shop.name
  assign page_desc = page_description | default: shop.description
%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ page_type_schema }}",
  "@id": "{{ page_url }}#webpage",
  "url": "{{ page_url }}",
  "name": "{{ page_name | escape }}",
  "description": "{{ page_desc | escape }}",
  "isPartOf": {
    "@id": "{{ shop.url }}/#website"
  },
  "inLanguage": "{{ request.locale.iso_code | replace: 'de', 'de-DE' | replace: 'en', 'en-US' | replace: 'pl', 'pl-PL' }}",
  "datePublished": "{{ _date_published }}",
  "dateModified": "{{ _date_modified }}"
  {%- if request.page_type == 'collection' and collection.products_count > 0 -%}
  ,"mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- for p in collection.products limit: 10 -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "url": "{{ shop.url }}{{ p.url }}"
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  {%- endif -%}
  {% if page_image %}
  ,
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": "https:{{ page_image | image_url: width: 800, format: 'webp' }}",
    "width": 800,
    "height": 630
  }
  {% endif %}
}
</script>
