{%- doc -%}
  Durchmesser (Diameter) filter for collection pages.
  Works entirely client-side via JavaScript — no Search & Discovery app needed.
  Reads data-durchmesser attributes from product grid items and hides/shows them.
  Shown on Uhren collections.

  @param {string} filter_style - 'horizontal' or 'vertical'
  @param {string} sectionId - The section ID
{%- enddoc -%}

{%- capture durchmesser_list -%}
  {%- for product in collection.products limit: 1000 -%}
    {%- capture raw_dm -%}{%- render 'product-durchmesser-value', product: product -%}{%- endcapture -%}
    {%- assign p_dm = raw_dm | strip -%}
    {%- if p_dm != '' -%}|{{ p_dm }}|,{%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- assign dm_entries = durchmesser_list | split: ',' -%}
{%- assign unique_dms = dm_entries | uniq | sort -%}

{%- comment -%} Remove blank entries and count {%- endcomment -%}
{%- assign clean_dms = '' -%}
{%- assign dm_count = 0 -%}
{%- for d in unique_dms -%}
  {%- assign d_stripped = d | strip -%}
  {%- if d_stripped != '' -%}
    {%- assign d_value = d_stripped | remove: '|' -%}
    {%- if d_value != '' -%}
      {%- assign d_product_count = 0 -%}
      {%- for entry in dm_entries -%}
        {%- assign entry_stripped = entry | strip -%}
        {%- if entry_stripped == d_stripped -%}
          {%- assign d_product_count = d_product_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign dm_count = dm_count | plus: 1 -%}
      {%- assign dm_with_count = d_value | append: ':' | append: d_product_count -%}
      {%- if clean_dms == '' -%}
        {%- assign clean_dms = dm_with_count -%}
      {%- else -%}
        {%- assign clean_dms = clean_dms | append: '|||' | append: dm_with_count -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- assign final_dms = clean_dms | split: '|||' -%}

{%- if dm_count > 1 -%}
<accordion-custom
  class="facets__item durchmesser-filter-accordion"
  {% if filter_style == 'horizontal' %}
    data-disable-animation-on-desktop="true"
    data-close-with-escape="true"
  {% endif %}
  {% if filter_style == 'vertical' %}
  {% endif %}
>
  <details
    id="Facet-Details-{{ sectionId }}-durchmesser-{{ filter_style }}"
    class="facets__panel"
    {% if filter_style == 'horizontal' %}
      data-auto-close-details="desktop"
    {% endif %}
  >
    <summary class="facets__summary">
      <span class="facets__label" style="font-weight: 700; font-size: 14px;">Durchmesser</span>
      <div class="facets__status-wrapper">
        <span class="durchmesser-filter-count" style="display: none;"></span>
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </div>
    </summary>
    <floating-panel-component
      {% unless filter_style == 'vertical' %}data-close-on-resize{% endunless %}
      class="facets__inputs facets__panel-content details-content{% if filter_style == 'horizontal' %} color-{{ settings.popover_color_scheme }}{% endif %}"
    >
      <div class="facets__inputs-wrapper">
        <ul class="facets__inputs-list list-unstyled">
          {%- for dm in final_dms -%}
            {%- assign dm_parts = dm | split: ':' -%}
            {%- assign dm_stripped = dm_parts[0] | strip -%}
            {%- assign dm_product_count = dm_parts[1] | strip -%}
            {%- if dm_stripped != '' -%}
              {%- assign dm_id = 'durchmesser-filter-' | append: forloop.index | append: '-' | append: filter_style -%}
              <li class="facets__inputs-list-item" data-skip-node-update="true">
                <div class="checkbox durchmesser-filter-item">
                  <input
                    type="checkbox"
                    id="{{ dm_id }}"
                    class="checkbox__input js-durchmesser-checkbox"
                    data-durchmesser-value="{{ dm_stripped | escape }}"
                    value="{{ dm_stripped | escape }}"
                  >
                  <label class="checkbox__label" for="{{ dm_id }}" role="checkbox">
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                    <span class="checkbox__label-text">{{ dm_stripped }} <span style="color: #767676;">({{ dm_product_count }})</span></span>
                  </label>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </floating-panel-component>
  </details>
</accordion-custom>
{%- endif -%}
