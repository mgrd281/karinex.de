{% comment %}
  Article Schema for Blog Posts - Elite SEO
  Helps Google understand blog content and display rich snippets
{% endcomment %}

{% if request.page_type == 'article' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ article.title | escape }}",
  "image": {% if article.image %}"{{ article.image | image_url: width: 800, format: 'webp' }}"{% else %}"{{ settings.logo | image_url: width: 800, format: 'webp' }}"{% endif %},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
  "author": {
    "@type": "Person",
    "name": "{% if article.author %}{{ article.author }}{% else %}{{ shop.name }}{% endif %}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ shop.name }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{% if settings.logo %}{{ settings.logo | image_url: width: 600 }}{% else %}{{ shop.brand.logo | image_url: width: 600 }}{% endif %}"
    }
  },
  "description": "{{ article.excerpt_or_content | strip_html | truncate: 200 | escape }}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ shop.url }}{{ article.url }}"
  }
}
</script>
{% endif %}
