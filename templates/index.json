    "custom_liquid_bGzNwc": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<div style=\"max-width: 1200px; margin: 3rem auto; padding: 2rem; background: #f9f9f9; border-radius: 12px;\">\n  \n  <h2 style=\"font-size: 2rem; text-align: center; color: #1D4739; margin-bottom: 1.5rem;\">\n    Karinex - Ihr Online-Shop für Software, Spielzeug und Luxusuhren\n  </h2>\n  \n  <p style=\"font-size: 1.1rem; line-height: 1.8; text-align: center; margin-bottom: 2rem;\">\n    Seit 2020 ist Karinex Ihr vertrauenswürdiger Online-Shop für Original Microsoft Software, \n    LEGO Spielzeug, Luxusuhren und PlayStation Games. Wir bieten Ihnen Top-Produkte zu \n    günstigen Preisen mit sofortigem Download bzw. schnellem Versand und deutschem Kundensupport.\n  </p>\n\n  <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin: 2rem 0;\">\n    \n    <div style=\"text-align: center; padding: 1.5rem; background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);\">\n      <div style=\"font-size: 3rem; margin-bottom: 1rem;\">💻</div>\n      <h3 style=\"font-size: 1.3rem; color: #1D4739; margin-bottom: 1rem;\">Microsoft Software</h3>\n      <p style=\"color: #666; line-height: 1.6;\">\n        Original-Lizenzen für Office 2024, Windows 11 und Server-Software mit sofortigem Download.\n      </p>\n    </div>\n    \n    <div style=\"text-align: center; padding: 1.5rem; background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);\">\n      <div style=\"font-size: 3rem; margin-bottom: 1rem;\">🧱</div>\n      <h3 style=\"font-size: 1.3rem; color: #1D4739; margin-bottom: 1rem;\">LEGO & Spielzeug</h3>\n      <p style=\"color: #666; line-height: 1.6;\">\n        Hochwertige LEGO Sets von Technic bis Star Wars zu günstigen Preisen.\n      </p>\n    </div>\n    \n    <div style=\"text-align: center; padding: 1.5rem; background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);\">\n      <div style=\"font-size: 3rem; margin-bottom: 1rem;\">⌚</div>\n      <h3 style=\"font-size: 1.3rem; color: #1D4739; margin-bottom: 1rem;\">Luxusuhren</h3>\n      <p style=\"color: #666; line-height: 1.6;\">\n        Premium-Uhren von BOSS, Michael Kors und TAG Heuer mit Garantie.\n      </p>\n    </div>\n    \n    <div style=\"text-align: center; padding: 1.5rem; background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);\">\n      <div style=\"font-size: 3rem; margin-bottom: 1rem;\">🎮</div>\n      <h3 style=\"font-size: 1.3rem; color: #1D4739; margin-bottom: 1rem;\">Gaming</h3>\n      <p style=\"color: #666; line-height: 1.6;\">\n        PlayStation 5 Spiele und Controller für das ultimative Spielerlebnis.\n      </p>\n    </div>\n    \n  </div>\n\n  <h3 style=\"font-size: 1.5rem; text-align: center; margin: 2rem 0 1rem; color: #1D4739;\">\n    Warum Karinex?\n  </h3>\n  \n  <div style=\"max-width: 800px; margin: 0 auto; background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);\">\n    <ul style=\"list-style: none; padding: 0; font-size: 1.05rem; line-height: 2.5;\">\n      <li>✓ <strong>100% Original-Produkte</strong> - Garantiert echt</li>\n      <li>✓ <strong>Sofortiger Download / Schneller Versand</strong> - Keine Wartezeit</li>\n      <li>✓ <strong>Deutscher Kundensupport</strong> - Wir helfen gerne</li>\n      <li>✓ <strong>30 Tage Geld-zurück-Garantie</strong> - Risikofrei kaufen</li>\n      <li>✓ <strong>Günstige Preise</strong> - Bis zu 70% sparen</li>\n    </ul>\n  </div>\n\n</div>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
