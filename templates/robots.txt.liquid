{%- comment -%}
  CAUTION: To customize robots.txt, Shopify requires a file named robots.txt.liquid in the templates directory.
  This file addresses the Google Search Console warning about 'Crawl-delay' being ignored.
{%- endcomment -%}

{%- for group in robots.rules -%}
  {{ group.user_agent }}

  {%- for rule in group.rules -%}
    {%- unless group.user_agent contains 'Googlebot' and rule.directive == 'Crawl-delay' -%}
      {{ rule.directive }}: {{ rule.value }}
    {%- endunless -%}
  {%- endfor -%}

  {# Search result pages should not be crawled/indexed #}
  Disallow: /search
  Disallow: /search?*
  {# OAuth login redirects — always noindex, waste of crawl budget #}
  Disallow: /customer_authentication/
  Disallow: /authentication/oauth
  Disallow: /authentication/oauth?*
  {# Vendor filter pages #}
  Disallow: /collections/vendors
  Disallow: /collections/vendors?*
  {# SV-prefixed orphan pages — Shopify Markets exposes these German-content
     pages under /sv/ but they have no SV-side internal navigation. URL
     Redirects don't apply for /sv/ paths, so block at crawler level. #}
  Disallow: /sv/pages/windows-11-lizenz-kaufen
  Disallow: /sv/pages/windows-11-aktivierung
  Disallow: /sv/pages/windows-10-pro-kaufen-32-64-bit-downloads-installationsanleitung
  Disallow: /sv/pages/windows-10-vs-windows-11
  Disallow: /sv/pages/office-2021-vs-2024
  Disallow: /sv/pages/office-2024-professional-plus-windows
  Disallow: /sv/pages/office-2024-standard-mac-download
  Disallow: /sv/pages/geschenkkarten
  Disallow: /sv/pages/partner-dashboard
  Disallow: /sv/pages/partnerprogramm-1
  Disallow: /sv/pages/rechtliche-hinweise-1
  Disallow: /sv/pages/widerrufsformular
  Disallow: /sv/pages/xwiderrufsrecht
  Disallow: /sv/collections/digital-goods-vat-tax
  Disallow: /sv/blogs/guides

  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}

  {%- if group.user_agent contains '*' -%}
    Sitemap: {{ shop.url }}/blogs/news.google-news.xml
  {%- endif -%}
{%- endfor -%}
