{%- comment -%}
  CAUTION: To customize robots.txt, Shopify requires a file named robots.txt.liquid in the templates directory.
  This file addresses the Google Search Console warning about 'Crawl-delay' being ignored.
{%- endcomment -%}

{%- for group in robots.rules -%}
  {{ group.user_agent }}

  {%- for rule in group.rules -%}
    {%- unless group.user_agent contains 'Googlebot' and rule.directive == 'Crawl-delay' -%}
      {{ rule.directive }}: {{ rule.value }}
    {%- endunless -%}
  {%- endfor -%}

  {# Search result pages should not be crawled/indexed #}
  Disallow: /search
  Disallow: /search?*
  {# OAuth login redirects — always noindex, waste of crawl budget #}
  Disallow: /customer_authentication/
  Disallow: /authentication/oauth
  Disallow: /authentication/oauth?*
  {# Customer account area — always 302s to the accounts flow, never indexable #}
  Disallow: /account
  {# Vendor filter pages #}
  Disallow: /collections/vendors
  Disallow: /collections/vendors?*
  {# Product-recommendation tracking params (pr_*) create duplicate URLs of real
     products. Google crawls them but never indexes them ("Crawled - currently not
     indexed", ~1500 URLs) — pure crawl-budget waste. Block crawling; the clean
     product URLs (no params) stay fully crawlable & indexable. #}
  Disallow: /*pr_prod_strat=
  Disallow: /*pr_rec_pid=
  Disallow: /*pr_rec_id=
  Disallow: /*pr_ref_pid=
  Disallow: /*pr_seq=

  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}

  {%- if group.user_agent contains '*' -%}
    Sitemap: {{ shop.url }}/blogs/news.google-news.xml
  {%- endif -%}
{%- endfor -%}
