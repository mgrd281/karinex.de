{%- if recommendations.performed? -%}
  {%- if recommendations.products_count > 0 -%}
    <div class="cart-upsell-wrapper">

      <div class="cart-upsell-header">
         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="cart-upsell-icon" style="color: #333;"><path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3Z"/></svg>
         <h3 class="cart-upsell-title">DAS PASST DAZU</h3>
      </div>
      <div class="cart-upsell-items">
        {%- for product in recommendations.products limit: 4 -%}
          {% render 'cart-extra-product-card', product: product %}
        {%- endfor -%}
      </div>
    </div>

  {%-endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Cart Upsell",
  "settings": []
}
{% endschema %}
