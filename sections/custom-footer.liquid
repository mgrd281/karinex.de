    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Cookie Settings Logic
            const openCookieSettings = (e) => {
                e.preventDefault();
                
                const tryOpen = () => {
                    // 1. Shopify Customer Privacy API
                    if (window.Shopify && window.Shopify.customerPrivacy && typeof window.Shopify.customerPrivacy.showPreferences === 'function') {
                        window.Shopify.customerPrivacy.showPreferences();
                        return true;
                    } 
                    // 2. Cookiebot
                    else if (window.Cookiebot && typeof window.Cookiebot.renew === 'function') {
                        window.Cookiebot.renew();
                        return true;
                    }
                    // 3. Consentmo / GDPR App
                    else if (window.Gdpr && typeof window.Gdpr.openPreferences === 'function') {
                        window.Gdpr.openPreferences();
                        return true;
                    }
                    return false;
                };

                if (!tryOpen()) {
                    // Attempt to load Shopify Privacy Features explicitly
                    if (window.Shopify && window.Shopify.loadFeatures) {
                        window.Shopify.loadFeatures(
                            [
                                {
                                    name: 'consent-tracking-api',
                                    version: '0.1',
                                },
                            ],
                            function (error) {
                                if (error) {
                                    console.error('Error loading Privacy API:', error);
                                    window.location.href = '/policies/privacy-policy';
                                } else {
                                    setTimeout(() => {
                                         if(window.Shopify.customerPrivacy && typeof window.Shopify.customerPrivacy.showPreferences === 'function') {
                                             window.Shopify.customerPrivacy.showPreferences();
                                         } else {
                                             // If still not available (e.g. wrong region), go to fallback page
                                             window.location.href = '/policies/privacy-policy';
                                         }
                                    }, 500);
                                }
                            }
                        );
                    } else {
                        // Fallback if loadFeatures is not available
                        setTimeout(() => {
                            if (!tryOpen()) {
                                 window.location.href = '/policies/privacy-policy';
                            }
                        }, 500);
                    }
                }
            };

            const cookieLinks = document.querySelectorAll('.js-cookie-settings');
            cookieLinks.forEach(link => {
                link.addEventListener('click', openCookieSettings);
            });
            // Mobile Collapsible Sections
            const sectionHeaders = document.querySelectorAll('.section-header');
            
            sectionHeaders.forEach(header => {
                // Skip the first section (logo) from being collapsible
                if (header.closest('.footer-section').querySelector('.karinex-logo-wrapper')) {
                    return;
                }
                
                header.addEventListener('click', function() {
                    const section = this.closest('.footer-section');
                    section.classList.toggle('active');
                });
            });

            // FAQ Accordion Functionality - KORRIGIERT
            // FAQ ACCORDION FUNCTIONALITY REMOVED - NOW HANDLED GLOBALLY BY theme.liquid
            // This prevents the "double toggle" issue.

            // Enhanced touch interactions for mobile
            document.querySelectorAll('.footer-section a').forEach(link => {
                link.addEventListener('touchstart', function() {
                    this.style.transform = 'scale(0.98)';
                });
                
                link.addEventListener('touchend', function() {
                    this.style.transform = '';
                });
            });
        });
    </script>


