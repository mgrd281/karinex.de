{% schema %}
{
  "name": "Modern Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kontakt"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Wir freuen uns auf Ihre Nachricht und helfen gerne weiter."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Nachricht senden"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#fcfcfc"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show Phone Field",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "topic",
      "name": "Topic",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lieferung"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Lieferzeiten · Lieferdetails · Lieferstatus"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Lieferung)" },
            { "value": "return", "label": "Return Box (Rücksendung)" },
            { "value": "case", "label": "Case (Reklamation)" },
            { "value": "bag", "label": "Bag (Stornierung)" },
            { "value": "chat", "label": "Chat (Produkteigenschaften)" },
            { "value": "euro", "label": "Euro (Zahlung)" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "truck"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modern Contact Form",
      "blocks": [
        { "type": "topic", "settings": { "title": "Lieferung", "subtitle": "Lieferzeiten · Lieferdetails · Lieferstatus", "icon": "truck" } },
        { "type": "topic", "settings": { "title": "Rücksendung", "subtitle": "Rücksendefrist · Etikett · QR-Code", "icon": "return" } },
        { "type": "topic", "settings": { "title": "Reklamation", "subtitle": "Gewährleistung · Artikel defekt · Garantie", "icon": "case" } },
        { "type": "topic", "settings": { "title": "Zahlung", "subtitle": "Zahlungsinformation · Zahlungserinnerung", "icon": "euro" } }
      ]
    }
  ]
}
{% endschema %}

<div class="modern-contact-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="contact-container">
    <div class="contact-header">
      <h1 class="contact-title">{{ section.settings.heading }} – Support & Service Karinex</h1>
      {% if section.settings.subheading != blank %}
        <p class="contact-subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <!-- Topic Selection Section -->
    <div class="topics-wrapper">
       <h3 class="topics-heading">Bitte wähle das Thema</h3>
       <div class="topics-list">
         {% for block in section.blocks %}
           <button class="topic-item" type="button" onclick="selectTopic(this, '{{ block.settings.title | escape }}')">
             <div class="topic-icon">
               {% case block.settings.icon %}
                 {% when 'truck' %}
                   <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
                 {% when 'return' %}
                   <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" /></svg>
                 {% when 'case' %}
                   <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                 {% when 'bag' %}
                   <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                 {% when 'chat' %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
                 {% when 'euro' %}
                   <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 7.756a4.5 4.5 0 100 8.488M7.5 10.5h5.25m-5.25 3h5.25M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                 {% else %}
                   <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
               {% endcase %}
             </div>
             <div class="topic-content">
               <div class="topic-title">{{ block.settings.title }}</div>
               <div class="topic-subtitle">{{ block.settings.subtitle }}</div>
             </div>
             <div class="topic-arrow">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
             </div>
           </button>
         {% endfor %}
       </div>
    </div>

    <div class="contact-card">
      {% form 'contact', id: 'ModernContactForm' %}
        
        {%- if form.posted_successfully? -%}
          <div class="form-message success" tabindex="-1" autofocus>
            <div class="icon-check">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <div class="text">
              <strong>Vielen Dank!</strong>
              <p>Ihre Nachricht wurde erfolgreich gesendet. Wir melden uns in Kürze.</p>
            </div>
          </div>
        {%- elsif form.errors -%}
          <div class="form-message error" tabindex="-1" autofocus>
            <div class="icon-error">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
            </div>
             <div class="text">
              <strong>Ein Fehler ist aufgetreten</strong>
              <p>Bitte überprüfen Sie Ihre Eingaben und versuchen Sie es erneut.</p>
            </div>
          </div>
        {%- endif -%}
        
        <!-- Hidden Subject Field populated by Topic Selection -->
        <input type="hidden" name="contact[subject]" id="ContactForm-subject" value="Allgemeine Anfrage">

        <div class="form-grid">
          <!-- Name -->
          <div class="form-field">
            <label for="ContactForm-name">Name <span aria-hidden="true">*</span></label>
            <div class="input-wrapper">
               <input 
                 type="text" 
                 id="ContactForm-name" 
                 name="contact[name]" 
                 value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" 
                 placeholder="Ihr Name"
                 required
               >
               <div class="field-icon">
                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
               </div>
            </div>
          </div>

          <!-- Email -->
          <div class="form-field">
            <label for="ContactForm-email">E-Mail Adresse <span aria-hidden="true">*</span></label>
            <div class="input-wrapper">
              <input 
                type="email" 
                id="ContactForm-email" 
                name="contact[email]" 
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" 
                placeholder="name@beispiel.de"
                required
              >
               <div class="field-icon">
                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
               </div>
            </div>
          </div>

          <!-- Phone (Optional) -->
          {% if section.settings.show_phone %}
          <div class="form-field full">
            <label for="ContactForm-phone">Telefonnummer <span class="opt">(Optional)</span></label>
            <div class="input-wrapper">
              <input 
                type="tel" 
                id="ContactForm-phone" 
                name="contact[phone]" 
                value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" 
                placeholder="+49 123 456789"
              >
              <div class="field-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              </div>
            </div>
          </div>
          {% endif %}

          <!-- File Upload -->
          <div class="form-field full">
            <label>Dateien anhängen (Bilder oder Videos)</label>
            <div class="file-upload-wrapper" id="file-drop-area">
               <input type="file" id="ContactForm-file" name="contact[attachment]" accept="image/*,video/*" multiple style="display:none;">
               <div class="file-upload-ui" onclick="document.getElementById('ContactForm-file').click();">
                  <div class="icon-upload">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                    </svg>
                  </div>
                  <span class="upload-text">Hier klicken oder Dateien ablegen</span>
                  <span class="upload-hint">Unbegrenzte Anzahl (Bilder & Videos)</span>
               </div>
               <div id="file-list-display" class="file-list-container"></div>
            </div>
          </div>
          
          <!-- Comment -->
          <div class="form-field full">
            <label for="ContactForm-body">Nachricht <span aria-hidden="true">*</span></label>
            <div class="input-wrapper textarea-wrapper">
              <textarea 
                rows="5" 
                id="ContactForm-body" 
                name="contact[body]" 
                placeholder="Wie können wir Ihnen helfen?" 
                required
              >{{ form.body }}</textarea>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="modern-submit-btn">
            <span class="btn-text">{{ section.settings.button_label }}</span>
            <span class="btn-loader" style="display:none;"><svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg> Senden...</span>
          </button>
        </div>

      {% endform %}
    </div>
  </div>
</div>

<script>
  // Simple loader logic
  document.getElementById('ModernContactForm').addEventListener('submit', function(e) {
      const btn = this.querySelector('.modern-submit-btn');
      const text = btn.querySelector('.btn-text');
      const loader = btn.querySelector('.btn-loader');
      
      // Prevent double submit visual if already submitting
      if(btn.disabled) return;
      
      // We let the form submit naturally, just update UI
      btn.style.opacity = '0.8';
      text.style.display = 'none';
      loader.style.display = 'flex';
  });

  // File Upload Logic (Multiple Files)
  const fileInput = document.getElementById('ContactForm-file');
  const dropArea = document.getElementById('file-drop-area');
  const listContainer = document.getElementById('file-list-display');
  const dt = new DataTransfer();

  if(fileInput && listContainer) {
      fileInput.addEventListener('change', function(e) {
          for(let i = 0; i < this.files.length; i++){
              dt.items.add(this.files[i]);
          }
          this.files = dt.files; // Update input with accumulated files
          updateFileList();
      });
  }

  function updateFileList() {
     if(!listContainer) return;
     listContainer.innerHTML = '';
     if (dt.files.length > 0) {
        dropArea.classList.add('has-file');
        for(let i = 0; i < dt.files.length; i++) {
           const file = dt.files[i];
           const item = document.createElement('div');
           item.className = 'file-list-item';
           item.innerHTML = `
             <div class="file-info">
               <svg class="file-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
               <span class="file-name">${file.name}</span>
             </div>
             <button type="button" class="remove-file" onclick="removeFile(${i})">&times;</button>
           `;
           listContainer.appendChild(item);
        }
     } else {
        dropArea.classList.remove('has-file');
     }
  }

  function removeFile(index) {
     dt.items.remove(index);
     fileInput.files = dt.files;
     updateFileList();
  }

  // Topic Selection Logic
  function selectTopic(btn, topicTitle) {
      // Highlight selected
      document.querySelectorAll('.topic-item').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      
      // Update hidden subject
      const subjectInput = document.getElementById('ContactForm-subject');
      if(subjectInput) subjectInput.value = topicTitle;
      
      // Scroll to form
      const formCard = document.querySelector('.contact-card');
      if(formCard) {
          formCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
  }
</script>

<style>
/* Scoped Variables */
.modern-contact-section {
  padding: 80px 20px;
  min-height: 80vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  --primary-color: #111;
  --accent-color: #3b82f6; /* Focus color */
  --text-main: #1f2937;
  --text-light: #6b7280;
  --input-bg: #fff;
  --input-border: #e5e7eb;
  --radius: 12px;
}

.contact-container {
  width: 100%;
  max-width: 600px;
}

.contact-header {
  text-align: center;
  margin-bottom: 40px;
}
.contact-title {
  font-size: 36px;
  font-weight: 700;
  color: var(--primary-color);
  margin: 0 0 12px 0;
  letter-spacing: -0.5px;
}
.contact-subtitle {
  font-size: 16px;
  color: var(--text-light);
  margin: 0;
  line-height: 1.5;
}

/* Card */
.contact-card {
  background: #ffffff;
  border-radius: var(--radius);
  box-shadow: 0 20px 40px -10px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.03);
  padding: 40px;
}

/* Form Grid */
.form-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24px;
}
.form-field {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
@media (min-width: 640px) {
  /* Name & Email side-by-side on desktop */
  .form-field:not(.full) {
    width: calc(50% - 12px);
  }
}
.form-field.full { width: 100%; }

/* Inputs */
.form-field label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-main);
  margin-left: 2px;
}
.form-field label span.opt {
  font-weight: 400;
  color: var(--text-light);
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}
.input-wrapper input, .input-wrapper textarea {
  width: 100%;
  padding: 14px 16px 14px 44px; /* Space for icon */
  font-size: 15px;
  color: var(--text-main);
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: 8px;
  transition: all 0.2s ease;
  font-family: inherit;
  appearance: none;
}
.input-wrapper.textarea-wrapper input, 
.input-wrapper.textarea-wrapper textarea {
  padding-left: 16px; /* No icon for textarea usually */
}

.input-wrapper input:focus, .input-wrapper textarea:focus {
  outline: none;
  border-color: var(--accent-color);
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
}
.input-wrapper input::placeholder, .input-wrapper textarea::placeholder {
  color: #9ca3af;
}

/* Icons */
.field-icon {
  position: absolute;
  left: 14px;
  width: 20px;
  height: 20px;
  color: var(--text-light);
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.input-wrapper input:focus + .field-icon {
  color: var(--accent-color);
}

/* File Upload */
.file-upload-wrapper {
  margin-top: 4px;
}
.file-upload-ui {
  border: 2px dashed var(--input-border);
  border-radius: 8px;
  padding: 24px;
  text-align: center;
  cursor: pointer;
  background: #fafafa;
  transition: all 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.file-upload-ui:hover {
  border-color: var(--accent-color);
  background: #f0f9ff;
}
.file-upload-wrapper.has-file .file-upload-ui {
  border-style: solid;
  border-color: var(--accent-color);
  background: #f0fdf4;
}
.icon-upload {
  width: 32px; height: 32px;
  color: var(--text-light);
  margin-bottom: 4px;
}
.file-upload-ui:hover .icon-upload { color: var(--accent-color); }
.upload-text {
  font-size: 14px; font-weight: 600; color: var(--text-main);
}
.upload-hint {
  font-size: 12px; color: var(--text-light);
}

.file-list-container {
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.file-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border: 1px solid var(--input-border);
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 14px;
  animation: fadeIn 0.3s ease;
}
.file-info {
  display: flex;
  align-items: center;
  gap: 8px;
  overflow: hidden;
}
.file-icon {
  width: 16px; height: 16px; color: var(--text-light); flex-shrink: 0;
}
.file-name {
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;
}
.remove-file {
  background: none; border: none; font-size: 18px; color: #999; cursor: pointer; padding: 0 4px; line-height: 1;
}
