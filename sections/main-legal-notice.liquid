              </svg>
            </span>
            <span class="reference-content">
              <span class="reference-title">Impressum</span>
              <span class="reference-desc">Anbieterkennzeichnung gemäß § 5 DDG</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>
        </div>
      </section>

    </article>

    <!-- TRUST SECTION -->
    <section class="legal-trust">
      <div class="trust-grid">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Deutsche Gesetzgebung</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Verbraucherschutzkonform</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Regelmäßig aktualisiert</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="20 6 9 17 4 12"/>
