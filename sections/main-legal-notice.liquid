              <span class="reference-desc">Ihr Widerrufsrecht im Detail</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>

          <a href="{{ _root }}policies/privacy-policy" class="legal-reference-box">
            <span class="reference-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </span>
            <span class="reference-content">
              <span class="reference-title">Datenschutzerklärung</span>
              <span class="reference-desc">Verarbeitung personenbezogener Daten</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>

          <a href="{{ _root }}policies/legal-notice" class="legal-reference-box">
            <span class="reference-icon">
