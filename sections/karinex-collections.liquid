{%- doc -%}
  Karinex Collections — practical e-commerce grid.

  Compact, conversion-oriented layout: 3–4 columns desktop with
  small square cards, image + title + product count + thin "Ansehen"
  link. Brand greens used sparingly. Matches mainstream software
  reseller storefronts.
{%- enddoc -%}

{%- liquid
  assign heading = section.settings.heading
  assign sub     = section.settings.subheading
  assign cols    = section.settings.cols | default: '3'
-%}

<section class="kxc-list">
  {%- if heading != blank or sub != blank -%}
    <header class="kxc-list__head">
      {%- if heading != blank -%}<h1>{{ heading }}</h1>{%- endif -%}
      {%- if sub     != blank -%}<p>{{ sub }}</p>{%- endif -%}
    </header>
  {%- endif -%}

  <div class="kxc-list__grid" data-cols="{{ cols }}">
    {%- for c in collections -%}
      {%- if c.products_count == 0 and section.settings.hide_empty -%}{%- continue -%}{%- endif -%}
      <a class="kxc-card" href="{{ c.url }}">
        <div class="kxc-card__img">
          {%- if c.image -%}
            <img src="{{ c.image | image_url: width: 480 }}"
                 srcset="{{ c.image | image_url: width: 320 }} 320w,
                         {{ c.image | image_url: width: 480 }} 480w,
                         {{ c.image | image_url: width: 640 }} 640w"
                 sizes="(max-width: 640px) 45vw, 280px"
                 alt="{{ c.title | escape }}"
                 width="480" height="480"
                 loading="lazy">
          {%- elsif c.products.first.featured_image -%}
            <img src="{{ c.products.first.featured_image | image_url: width: 480 }}"
                 alt="{{ c.title | escape }}"
                 width="480" height="480"
                 loading="lazy">
          {%- endif -%}
        </div>
        <div class="kxc-card__body">
          <h2 class="kxc-card__title">{{ c.title }}</h2>
          <p class="kxc-card__count">
            {{ c.products_count }}&nbsp;{% if c.products_count == 1 %}Produkt{% else %}Produkte{% endif %}
          </p>
          <span class="kxc-card__link">
            Ansehen
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .kxc-list {
    --c-brand: #1F3A2B;
    --c-ink:   #1A1A1A;
    --c-ink-2: #6B6B6B;
    --c-line:  #E8E6E0;
    --c-bg:    #FAFAF8;

    max-width: 1280px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    font-family: inherit;
    color: var(--c-ink);
  }
  .kxc-list *,
  .kxc-list *::before,
  .kxc-list *::after { box-sizing: border-box; }

  /* ── Header ── */
  .kxc-list__head {
    text-align: left;
    margin: 0 0 28px;
  }
  .kxc-list__head h1 {
    margin: 0;
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--c-ink);
  }
  .kxc-list__head p {
    margin: 8px 0 0;
    font-size: 14px;
    color: var(--c-ink-2);
    line-height: 1.5;
  }

  /* ── Grid ── */
  .kxc-list__grid {
    display: grid;
    gap: 20px;
  }
  .kxc-list__grid[data-cols="2"] { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .kxc-list__grid[data-cols="3"] { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .kxc-list__grid[data-cols="4"] { grid-template-columns: repeat(4, minmax(0, 1fr)); }

  /* ── Card ── */
  .kxc-card {
    display: block;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }
  .kxc-card:hover,
  .kxc-card:focus-visible {
    border-color: var(--c-brand);
    box-shadow: 0 4px 14px rgba(31,58,43,0.08);
    transform: translateY(-2px);
    outline: none;
  }

  .kxc-card__img {
    aspect-ratio: 1 / 1;
    background: var(--c-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .kxc-card__img img {
    width: 92%;
    height: 92%;
    object-fit: contain;
    transition: transform 360ms ease;
  }
  .kxc-card:hover .kxc-card__img img { transform: scale(1.04); }

  .kxc-card__body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .kxc-card__title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--c-ink);
  }
  .kxc-card__count {
    margin: 0;
    font-size: 12.5px;
    color: var(--c-ink-2);
  }
  .kxc-card__link {
    margin-top: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-brand);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    letter-spacing: 0.2px;
    transition: gap 200ms ease;
  }
  .kxc-card:hover .kxc-card__link { gap: 8px; }

  /* ── Responsive ── */
  @media (max-width: 1023px) {
    .kxc-list__grid[data-cols="4"] { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .kxc-list__grid[data-cols="3"] { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 767px) {
    .kxc-list { padding: 24px 16px 56px; }
    .kxc-list__grid,
    .kxc-list__grid[data-cols="4"],
    .kxc-list__grid[data-cols="3"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .kxc-list__head h1 { font-size: 22px; }
    .kxc-card__body { padding: 12px 12px 14px; }
    .kxc-card__title { font-size: 14px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kxc-card,
    .kxc-card__img img,
    .kxc-card__link { transition: none; }
    .kxc-card:hover { transform: none; }
    .kxc-card:hover .kxc-card__img img { transform: none; }
  }
</style>

{% schema %}
{
  "name": "Karinex Collections",
  "settings": [
    { "type": "text",     "id": "heading",    "label": "Überschrift",   "default": "Alle Kategorien" },
    { "type": "text",     "id": "subheading", "label": "Kurzer Untertitel" },
    { "type": "select",   "id": "cols",       "label": "Spalten (Desktop)", "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    { "type": "checkbox", "id": "hide_empty", "label": "Leere Kollektionen ausblenden", "default": true }
  ],
  "presets": [{ "name": "Karinex Collections" }]
}
{% endschema %}
