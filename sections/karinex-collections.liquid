{%- doc -%}
  Karinex Premium Collection-List Page

  Renders all collections in the shop as a clean editorial grid with
  serif headlines, brand colours, and a hover-reveal CTA — matching
  the product page v2 visual language.
{%- enddoc -%}

{%- liquid
  assign cols    = section.settings.cols | default: 3
  assign heading = section.settings.heading | default: 'Alle Kollektionen'
  assign sub     = section.settings.subheading | default: 'Microsoft Office, Windows, Server, Tools — schnell und legal.'
-%}

<section class="kxc">

  <header class="kxc__hero">
    <p class="kxc__eyebrow">Sortiment</p>
    <h1 class="kxc__title">{{ heading }}</h1>
    {%- if sub != blank -%}
      <p class="kxc__sub">{{ sub }}</p>
    {%- endif -%}
  </header>

  <div class="kxc__grid" style="--kxc-cols: {{ cols }};">
    {%- for c in collections -%}
      {%- if c.products_count == 0 and section.settings.hide_empty -%}{%- continue -%}{%- endif -%}
      <a class="kxc-card" href="{{ c.url }}" aria-label="{{ c.title | escape }}">
        <div class="kxc-card__media">
          {%- if c.image -%}
            <img src="{{ c.image | image_url: width: 720 }}"
                 srcset="{{ c.image | image_url: width: 480 }} 480w,
                         {{ c.image | image_url: width: 720 }} 720w,
                         {{ c.image | image_url: width: 1024 }} 1024w"
                 sizes="(max-width: 767px) 50vw, (max-width: 1023px) 33vw, 25vw"
                 alt="{{ c.title | escape }}"
                 width="720" height="540"
                 loading="lazy">
          {%- elsif c.products.first.featured_image -%}
            <img src="{{ c.products.first.featured_image | image_url: width: 720 }}"
                 alt="{{ c.title | escape }}"
                 width="720" height="540"
                 loading="lazy">
          {%- else -%}
            <span class="kxc-card__placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" width="48" height="48">
                <path d="M12 3l9 5-9 5-9-5 9-5Z"/><path d="M3 13l9 5 9-5M3 17.5l9 5 9-5"/>
              </svg>
            </span>
          {%- endif -%}
          <span class="kxc-card__veil" aria-hidden="true"></span>
        </div>

        <div class="kxc-card__body">
          <h2 class="kxc-card__title">{{ c.title }}</h2>
          <p class="kxc-card__meta">
            <span>{{ c.products_count }}&nbsp;{% if c.products_count == 1 %}Produkt{% else %}Produkte{% endif %}</span>
            <span class="kxc-card__cta" aria-hidden="true">
              Entdecken
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </p>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .kxc {
    --kx-c-primary:   #1F3A2B;
    --kx-c-primary-h: #2A4D3A;
    --kx-c-bronze:    #B8956A;
    --kx-c-bg:        #F8F7F4;
    --kx-c-surface:   #FFFFFF;
    --kx-c-ink-1:     #1A1A1A;
    --kx-c-ink-2:     #666666;
    --kx-c-line:      #E5E3DE;

    --kx-f-serif:     'Cormorant Garamond', 'Playfair Display', Georgia, serif;
    --kx-f-body:      'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;

    background: var(--kx-c-bg);
    font-family: var(--kx-f-body);
    color: var(--kx-c-ink-1);
    padding: 56px 24px 96px;
    max-width: 1440px;
    margin: 0 auto;
  }
  .kxc *,
  .kxc *::before,
  .kxc *::after { box-sizing: border-box; }

  /* ─── Hero header ─── */
  .kxc__hero {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
  }
  .kxc__eyebrow {
    margin: 0 0 14px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--kx-c-bronze);
  }
  .kxc__title {
    margin: 0;
    font-family: var(--kx-f-serif);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--kx-c-ink-1);
  }
  .kxc__sub {
    margin: 16px auto 0;
    max-width: 540px;
    font-size: 16px;
    color: var(--kx-c-ink-2);
    line-height: 1.55;
  }

  /* ─── Grid ─── */
  .kxc__grid {
    display: grid;
    grid-template-columns: repeat(var(--kxc-cols, 3), minmax(0, 1fr));
    gap: 28px;
  }

  /* ─── Card ─── */
  .kxc-card {
    display: block;
    background: var(--kx-c-surface);
    border: 1px solid var(--kx-c-line);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 280ms ease,
                border-color 280ms ease;
  }
  .kxc-card:hover,
  .kxc-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(15, 25, 20, 0.10);
    border-color: var(--kx-c-primary);
    outline: none;
  }

  .kxc-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--kx-c-bg);
    overflow: hidden;
  }
  .kxc-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .kxc-card:hover .kxc-card__media img { transform: scale(1.04); }

  .kxc-card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(31, 58, 43, 0.18);
  }

  .kxc-card__veil {
    position: absolute;
    inset: auto 0 0 0;
    height: 50%;
    background: linear-gradient(to top, rgba(15,25,20,0.16), transparent);
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 280ms ease;
  }
  .kxc-card:hover .kxc-card__veil { opacity: 1; }

  .kxc-card__body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .kxc-card__title {
    margin: 0;
    font-family: var(--kx-f-serif);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--kx-c-ink-1);
  }
  .kxc-card__meta {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: 13px;
    color: var(--kx-c-ink-2);
  }
  .kxc-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--kx-c-primary);
    font-weight: 600;
    letter-spacing: 0.3px;
    transition: gap 200ms ease;
  }
  .kxc-card:hover .kxc-card__cta { gap: 8px; }
  .kxc-card__cta svg { transition: transform 200ms ease; }

  /* ─── Responsive ─── */
  @media (max-width: 1023px) {
    .kxc { padding: 40px 20px 72px; }
    .kxc__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; }
    .kxc__title { font-size: 38px; }
    .kxc__hero { margin-bottom: 40px; }
  }
  @media (max-width: 559px) {
    .kxc { padding: 32px 16px 56px; }
    .kxc__grid { gap: 16px; }
    .kxc__title { font-size: 32px; }
    .kxc-card__body { padding: 14px 16px 16px; }
    .kxc-card__title { font-size: 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kxc-card,
    .kxc-card__media img,
    .kxc-card__cta { transition: none; }
    .kxc-card:hover { transform: none; }
    .kxc-card:hover .kxc-card__media img { transform: none; }
  }
</style>

{% schema %}
{
  "name": "Karinex Collections",
  "settings": [
    { "type": "text",     "id": "heading",    "label": "Überschrift",   "default": "Alle Kollektionen" },
    { "type": "text",     "id": "subheading", "label": "Unter-Text",    "default": "Microsoft Office, Windows, Server, Tools — schnell und legal." },
    { "type": "range",    "id": "cols",       "label": "Spalten (Desktop)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "checkbox", "id": "hide_empty", "label": "Leere Kollektionen ausblenden", "default": true }
  ],
  "presets": [{ "name": "Karinex Collections" }]
}
{% endschema %}
