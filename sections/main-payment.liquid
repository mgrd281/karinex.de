{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
{%- comment -%} Updated: 2026-02-12 – Unified with Über KARINEX {%- endcomment -%}
<link rel="stylesheet" href="{{ 'main-about.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'main-payment.css' | asset_url }}">

<div class="about-page">

  <!-- ================================================
       1) HERO – Same as Über KARINEX
       ================================================ -->
  <section class="about-hero">
    <div class="about-hero-content">
      <h1 class="about-hero-title">Zahlungsarten</h1>
      <p class="about-hero-subtitle">Sichere und flexible Zahlungsmöglichkeiten für Ihren Einkauf bei KARINEX.</p>
      <div class="about-hero-divider"></div>
    </div>
  </section>

  <div class="about-container">

    <!-- ================================================
         2) TRUST BADGES
         ================================================ -->
    <section class="about-section">
      <div class="pay-trust-row">
        <span class="pay-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
          SSL-verschlüsselt
        </span>
        <span class="pay-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Sichere Zahlung
        </span>
        <span class="pay-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
          DSGVO-konform
        </span>
      </div>
    </section>

    <!-- ================================================
         3) ZAHLUNGSMETHODEN – Value Cards (same grid)
         ================================================ -->
    <section class="about-section about-values">
      <h2 class="about-section-title">Unsere Zahlungsmethoden</h2>
      <div class="about-values-grid">

        <div class="about-value-card pay-card--highlight">
          <div class="pay-badge">Empfohlen</div>
          <div class="about-value-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
            </svg>
          </div>
          <h3 class="about-value-title">Express Checkout</h3>
          <p class="about-value-text">Besonders schnell und bequem – ohne manuelle Eingabe Ihrer Zahlungsdaten.</p>
          <div class="pay-tags">
            <span class="pay-tag">Shop Pay</span>
            <span class="pay-tag">Apple Pay</span>
            <span class="pay-tag">Google Pay</span>
          </div>
        </div>

        <div class="about-value-card">
          <div class="about-value-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
            </svg>
          </div>
          <h3 class="about-value-title">Kreditkarten</h3>
          <p class="about-value-text">Alle gängigen Kreditkarten – sicher und verschlüsselt über unseren Zahlungsdienstleister.</p>
          <div class="pay-tags">
            <span class="pay-tag">Visa</span>
            <span class="pay-tag">Mastercard</span>
            <span class="pay-tag">American Express</span>
          </div>
        </div>

        <div class="about-value-card">
          <div class="about-value-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="about-value-title">Klarna</h3>
          <p class="about-value-text">Flexible Zahlungsoptionen – sofort, später oder in bequemen Raten.</p>
          <div class="pay-klarna">
            <div class="pay-klarna__item"><strong>Sofort bezahlen</strong> – Direkte Zahlung per Online-Banking</div>
            <div class="pay-klarna__item"><strong>Später bezahlen</strong> – Zahlung innerhalb von 30 Tagen</div>
            <div class="pay-klarna__item"><strong>Ratenkauf</strong> – Bequeme monatliche Raten</div>
            <div class="pay-klarna__item"><strong>Rechnung (B2B)</strong> – Für Geschäftskunden</div>
          </div>
        </div>

        <div class="about-value-card">
          <div class="about-value-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
            </svg>
          </div>
          <h3 class="about-value-title">PayPal</h3>
          <p class="about-value-text">Schnell und sicher mit Ihrem PayPal-Konto bezahlen. Sie werden während des Bestellvorgangs zu PayPal weitergeleitet.</p>
        </div>

      </div>
    </section>

    <!-- ================================================
         4) BANKÜBERWEISUNG
         ================================================ -->
    <section class="about-section">
      <h2 class="about-section-title">Banküberweisung (Vorkasse)</h2>
      <div class="about-mission-content">
        <p>Überweisen Sie den Rechnungsbetrag direkt auf unser Geschäftskonto. Die Bestellung wird nach Zahlungseingang bearbeitet und versendet.</p>
      </div>

      <div class="pay-bank">
        <div class="pay-bank__row">
          <span class="pay-bank__label">Empfänger</span>
          <span class="pay-bank__value">Karina Khrystych</span>
        </div>
        <div class="pay-bank__row">
          <span class="pay-bank__label">IBAN</span>
          <span class="pay-bank__value pay-bank__value--mono">DE22 1001 1001 2087 5043 11</span>
        </div>
        <div class="pay-bank__row">
          <span class="pay-bank__label">BIC</span>
          <span class="pay-bank__value pay-bank__value--mono">NTSBDEB1XXX</span>
        </div>
        <div class="pay-bank__row">
          <span class="pay-bank__label">Bank</span>
          <span class="pay-bank__value">N26 Bank</span>
        </div>
        <div class="pay-bank__row">
          <span class="pay-bank__label">Verwendungszweck</span>
          <span class="pay-bank__value">Ihre Bestellnummer</span>
        </div>
      </div>

      <p class="pay-note">Hinweis: Privatkunden empfehlen wir die Nutzung einer anderen Zahlungsart für eine schnellere Abwicklung.</p>
    </section>

    <!-- ================================================
         5) SICHERHEIT – Trust section (same as Über uns)
         ================================================ -->
    <section class="about-section about-trust">
      <h2 class="about-section-title">Ihre Sicherheit</h2>
      <div class="about-trust-content">
        <p class="about-trust-intro">Beim Bezahlen bei KARINEX sind Sie bestens geschützt.</p>
        <div class="about-trust-points">
          <div class="about-trust-point">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>256-Bit SSL-Verschlüsselung</span>
          </div>
          <div class="about-trust-point">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Trusted Shops Käuferschutz</span>
          </div>
          <div class="about-trust-point">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>DSGVO-konforme Verarbeitung</span>
          </div>
          <div class="about-trust-point">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>14-Tage Rückgaberecht</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         6) CTA – Same as Über uns
         ================================================ -->
    <section class="about-cta">
      <h2 class="about-cta-title">Fragen zur Zahlung?</h2>
      <p class="about-cta-text">Unser Support-Team hilft Ihnen gerne weiter.</p>
      <a href="{{ _root }}pages/kontakt" class="about-cta-button">Kontakt aufnehmen</a>
    </section>

  </div>
</div>

{% schema %}
{
  "name": "Zahlungsarten",
  "tag": "section",
  "class": "section-payment",
  "settings": []
}
{% endschema %}
