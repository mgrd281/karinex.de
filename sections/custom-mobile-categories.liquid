{% schema %}
{
  "name": "Mobile Category Grid",
  "class": "section-mobile-category-grid",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable Section",
      "default": true
    },
    {
      "type": "select",
      "id": "visibility",
      "label": "Visibility",
      "options": [
        { "value": "mobile", "label": "Mobile Only (≤ 768px)" },
        { "value": "mobile_tablet", "label": "Mobile & Tablet (≤ 1024px)" },
        { "value": "always", "label": "Always Visible" }
      ],
      "default": "mobile"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Kostenloser Versand* & Rückversand"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show Heading",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout & Design"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed (Page Width)" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_side",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Side Padding (Mobile)",
      "default": 10
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (Mobile)",
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Grid Gap",
      "default": 6
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Card Content"
    },
    {
      "type": "checkbox",
      "id": "show_card_title",
      "label": "Show Category Title",
      "default": true
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Title Font Size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Deals Card"
    },
    {
      "type": "checkbox",
      "id": "enable_deal_card",
      "label": "Show Deals Card",
      "default": true
    },
    {
      "type": "text",
      "id": "deal_label",
      "label": "Deals Label",
      "default": "Deals"
    },
    {
      "type": "color",
      "id": "deal_bg_color",
      "label": "Deals Background",
      "default": "#ff5000"
    },
    {
      "type": "color",
      "id": "deal_text_color",
      "label": "Deals Text/Icon Color",
      "default": "#ffffff"
    },
    {
      "type": "url",
      "id": "deal_link",
      "label": "Deals Link"
    },
    {
      "type": "select",
      "id": "deal_position",
      "label": "Deals Card Position",
      "options": [
        { "value": "first", "label": "First Item" },
        { "value": "last", "label": "Last Item" }
      ],
      "default": "first"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides collection image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides collection title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link",
          "info": "Overrides collection link"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon / Text Center",
          "info": "Replaces image (e.g. Emoji 👕 or Text %)"
        },
        {
          "type": "checkbox",
          "id": "show_badge",
          "label": "Show % Badge",
          "default": false
        },
        {
          "type": "color",
          "id": "badge_bg",
          "label": "Badge Background",
          "default": "#ff5000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mobile Category Grid",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}

{%- if section.settings.enable_section and request.page_type == 'index' -%}
  <style>
    /* Section Visibility */
    #shopify-section-{{ section.id }} .mcg-wrapper {
      display: none;
    }
    
    {%- if section.settings.visibility == 'mobile' -%}
      @media (max-width: 768px) {
        #shopify-section-{{ section.id }} .mcg-wrapper { display: block; }
      }
    {%- elsif section.settings.visibility == 'mobile_tablet' -%}
      @media (max-width: 1024px) {
        #shopify-section-{{ section.id }} .mcg-wrapper { display: block; }
      }
    {%- else -%}
      #shopify-section-{{ section.id }} .mcg-wrapper { display: block; }
    {%- endif -%}

    /* Reset & Base Styles */
    #shopify-section-{{ section.id }} .mcg-wrapper {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_side }}px;
      padding-right: {{ section.settings.padding_side }}px;
      background-color: transparent;
      font-family: var(--font-body-family, sans-serif);
      box-sizing: border-box;
    }

    #shopify-section-{{ section.id }} .mcg-container {
      margin: 0 auto;
      {% if section.settings.section_width == 'boxed' %}
        max-width: var(--page-width, 1400px);
      {% else %}
        max-width: 100%;
      {% endif %}
    }

    /* Header */
    #shopify-section-{{ section.id }} .mcg-header {
      text-align: center;
      margin-bottom: 12px;
      font-size: 11px;
      font-weight: 600;
      color: #333;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }
    #shopify-section-{{ section.id }} .mcg-header svg {
      width: 14px;
      height: 14px;
    }

    /* Grid Layout */
    #shopify-section-{{ section.id }} .mcg-grid {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.grid_gap }}px;
    }

    /* Card Styles */
    #shopify-section-{{ section.id }} .mcg-card {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      color: inherit;
    }

    #shopify-section-{{ section.id }} .mcg-image-container {
      width: 100%;
      aspect-ratio: 1 / 1;
      background-color: #f8f8f8;
      border-radius: {{ section.settings.card_radius }}px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: {% if section.settings.show_card_title %}6px{% else %}0{% endif %};
      position: relative;
    }

    #shopify-section-{{ section.id }} .mcg-image-container img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      mix-blend-mode: multiply;
      display: block;
    }
    
    #shopify-section-{{ section.id }} .mcg-title {
      font-size: {{ section.settings.title_size }}px;
      font-weight: 700;
      text-align: center;
      line-height: 1.2;
      color: #000;
      letter-spacing: 0.2px;
      width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Deals Card */
    #shopify-section-{{ section.id }} .mcg-card.is-deal .mcg-image-container {
      background-color: {{ section.settings.deal_bg_color }};
    }
    #shopify-section-{{ section.id }} .mcg-card.is-deal .mcg-title {
      color: #ffffff; /* White text for contrast on orange background */
    }
    #shopify-section-{{ section.id }} .deal-icon {
      font-size: 3em;
      font-weight: 900;
      color: {{ section.settings.deal_text_color }};
      line-height: 1;
    }

    /* Custom Icons */
    #shopify-section-{{ section.id }} .category-icon-text {
      font-size: 2.5em;
      line-height: 1;
    }

    /* Badge */
    #shopify-section-{{ section.id }} .mcg-badge {
      position: absolute;
      top: 0;
      left: 0;
      color: #fff;
      font-size: 11px;
      font-weight: 800;
      padding: 0;
      border-bottom-right-radius: 8px;
      border-top-left-radius: {{ section.settings.card_radius }}px;
      line-height: 1;
      width: 26px;
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
    }
  </style>

  <div class="mcg-wrapper">
    <div class="mcg-container">
      
      {%- if section.settings.show_heading and section.settings.heading != blank -%}
        <div class="mcg-header">
           <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
           <span>{{ section.settings.heading }}</span>
        </div>
      {%- endif -%}

      <div class="mcg-grid">
        
        {%- capture deal_card_html -%}
          {%- if section.settings.enable_deal_card -%}
            <a href="{{ section.settings.deal_link | default: '#' }}" class="mcg-card is-deal">
              <div class="mcg-image-container">
                <span class="deal-icon">%</span>
              </div>
              {%- if section.settings.show_card_title -%}
                <div class="mcg-title">{{ section.settings.deal_label }}</div>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endcapture -%}

        {%- if section.settings.deal_position == 'first' -%}
          {{ deal_card_html }}
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- assign col = block.settings.collection -%}
          {%- assign img = block.settings.image | default: col.image | default: col.products.first.featured_image -%}
          {%- assign title = block.settings.title | default: col.title | default: block.settings.collection.title | default: "Category" -%}
          {%- assign link = block.settings.link | default: col.url | default: '#' -%}

          <a href="{{ link }}" class="mcg-card" {{ block.shopify_attributes }}>
            <div class="mcg-image-container">
               {%- if block.settings.show_badge -%}
                 <div class="mcg-badge" style="background-color: {{ block.settings.badge_bg }};">%</div>
               {%- endif -%}

               {%- if block.settings.icon != blank -%}
                 <span class="category-icon-text">{{ block.settings.icon }}</span>
               {%- elsif img != blank -%}
                <img src="{{ img | image_url: width: 300 }}" loading="lazy" width="150" height="150" alt="{{ title | escape }}">
               {%- else -%}
                 {{ 'collection-1' | placeholder_svg_tag }}
               {%- endif -%}
            </div>
            {%- if section.settings.show_card_title -%}
              <div class="mcg-title">{{ title }}</div>
            {%- endif -%}
          </a>
        {%- endfor -%}

        {%- if section.settings.deal_position == 'last' -%}
          {{ deal_card_html }}
        {%- endif -%}

      </div>
    </div>
  </div>
{%- endif -%}
