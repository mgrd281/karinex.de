<script>
/* Auto-redirect broken 404 URLs (legacy locale prefixes, typos) */
(function() {
  var p = location.pathname;
  var q = location.search;
  var target = null;

  /* /encollections/... → /collections/... */
  if (p.indexOf('/encollections/') === 0) {
    target = '/collections/' + p.substring('/encollections/'.length) + q;
  }
  /* /plcollections/... → /collections/... */
  else if (p.indexOf('/plcollections/') === 0) {
    target = '/collections/' + p.substring('/plcollections/'.length) + q;
  }
  /* Specific product redirects (deleted/renamed products) */
  else if (p === '/products/windows-11-pro' || p === '/en/products/windows-11-pro' || p === '/pl/products/windows-11-pro') {
    target = '/products/windows-11-pro-key-kaufen-download' + q;
  }
  /* /collections/herren-uhren → /collections/uhren */
  else if (p === '/collections/herren-uhren') {
    target = '/collections/uhren' + q;
  }
  /* /en/... → strip locale prefix */
  else if (p.indexOf('/en/') === 0) {
    target = p.substring(3) + q;
  }
  /* /pl/... → strip locale prefix */
  else if (p.indexOf('/pl/') === 0) {
    target = p.substring(3) + q;
  }

  if (target && target !== p + q) {
    location.replace(target);
  }
})();
</script>

