          'windows-10-professional': '/collections/windows-10',
          'windows-10-home': '/collections/windows-10',
          'windows-10-enterprise': '/collections/windows-10',
          
          // Windows Server
          'windows-server': '/collections/software',
          'windows-server-2022': '/collections/software',
          'windows-server-2019': '/collections/software',
          'server-2022': '/collections/software',
          'server-2019': '/collections/software',
          
          // Project & Visio
          'project': '/collections/software',
          'project-2021': '/collections/software',
          'project-2019': '/collections/software',
          'visio': '/collections/software',
          'visio-2021': '/collections/software',
          'visio-2019': '/collections/software',
          
          // Antivirus & Security
          'antivirus': '/collections/software',
          'kaspersky': '/collections/software',
          'norton': '/collections/software',
          'mcafee': '/collections/software',
          'avira': '/collections/software',
          'bitdefender': '/collections/software',
          
          // Other Software
          'adobe': '/collections/software',
          'photoshop': '/collections/software',
          'acrobat': '/collections/software',
          'autocad': '/collections/software',
          
          // Collections
          'bestseller': '/collections/unsere-bestseller',
          'sale': '/collections/sale',
          'neuheiten': '/collections/all',
          'angebote': '/collections/sale',
