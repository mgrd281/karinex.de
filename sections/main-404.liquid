          'all-products': '/collections/all',
          'microsoft': '/collections/microsoft',
          
          // Pages
          'kontakt': '/pages/kontakt',
          'contact': '/pages/kontakt',
          'impressum': '/policies/legal-notice',
          'imprint': '/policies/legal-notice',
          'datenschutz': '/policies/privacy-policy',
          'privacy': '/policies/privacy-policy',
          'agb': '/policies/terms-of-service',
          'terms': '/policies/terms-of-service',
          'faq': '/pages/faq',
          'hilfe': '/pages/faq',
          'help': '/pages/faq',
          'ueber-uns': '/pages/ueber-uns',
          'about': '/pages/ueber-uns',
          'widerrufsbelehrung': '/pages/widerrufsrecht',
          'widerruf': '/pages/widerrufsrecht',
          
          // Cart & Account
          'warenkorb': '/cart',
          'cart': '/cart',
          'basket': '/cart',
          'konto': '/account',
          'account': '/account',
          'login': '/account/login',
          'anmelden': '/account/login',
          'registrieren': '/account/register',
          'register': '/account/register',
          'bestellungen': '/account/orders',
          'orders': '/account/orders',
          'wishlist': '/pages/wishlist',
          'wunschliste': '/pages/wishlist',
          'merkliste': '/pages/wishlist',
        };
        
        // ═══════════════════════════════════════════════════════
        // FUZZY MATCHING - Find similar words
        // ═══════════════════════════════════════════════════════
        
        function levenshtein(a, b) {
          if (a.length === 0) return b.length;
          if (b.length === 0) return a.length;
          const matrix = [];
          for (let i = 0; i <= b.length; i++) matrix[i] = [i];
          for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
          for (let i = 1; i <= b.length; i++) {
            for (let j = 1; j <= a.length; j++) {
              if (b.charAt(i - 1) === a.charAt(j - 1)) {
                matrix[i][j] = matrix[i - 1][j - 1];
              } else {
                matrix[i][j] = Math.min(
                  matrix[i - 1][j - 1] + 1,
                  matrix[i][j - 1] + 1,
                  matrix[i - 1][j] + 1
                );
              }
            }
          }
          return matrix[b.length][a.length];
        }
        
        function findBestMatch(input, dictionary) {
          let bestMatch = null;
          let bestScore = Infinity;
          const threshold = 3; // Max 3 character differences
          
          for (const key of Object.keys(dictionary)) {
            const distance = levenshtein(input, key);
            if (distance < bestScore && distance <= threshold) {
              bestScore = distance;
              bestMatch = key;
            }
          }
          return bestMatch;
        }
        
        // ═══════════════════════════════════════════════════════
        // SMART REDIRECT LOGIC
        // ═══════════════════════════════════════════════════════
        
        let redirectUrl = null;
        
        // 0. FIRST: Try to find model number and search for it
        const modelNumber = extractModelNumber(path);
        if (modelNumber) {
          const modelProduct = await searchByModelNumber(modelNumber);
          if (modelProduct && modelProduct.url) {
            // Track in Analytics
            if (typeof gtag === 'function') {
              gtag('event', 'model_redirect', {
                'model': modelNumber,
                'product': modelProduct.title
              });
            }
            // Instant redirect to the product
            window.location.replace(modelProduct.url);
            return;
          }
        }
        
        // 1. Check exact match in dictionary
        if (productDictionary[pathClean]) {
          redirectUrl = productDictionary[pathClean];
        }
        
        // 2. Check if path contains product/collection prefix
        if (!redirectUrl) {
          const productMatch = pathClean.match(/^products\/(.+)/);
          const collectionMatch = pathClean.match(/^collections\/(.+)/);
          const pagesMatch = pathClean.match(/^pages\/(.+)/);
          
          if (productMatch && productDictionary[productMatch[1]]) {
            redirectUrl = productDictionary[productMatch[1]];
          } else if (collectionMatch && productDictionary[collectionMatch[1]]) {
            redirectUrl = productDictionary[collectionMatch[1]];
          } else if (pagesMatch && productDictionary[pagesMatch[1]]) {
            redirectUrl = productDictionary[pagesMatch[1]];
          }
        }
        
        // 3. Try fuzzy matching
        if (!redirectUrl) {
          const searchTerms = [pathClean];
          // Also try without prefixes
          if (pathClean.startsWith('products/')) searchTerms.push(pathClean.replace('products/', ''));
          if (pathClean.startsWith('collections/')) searchTerms.push(pathClean.replace('collections/', ''));
          if (pathClean.startsWith('pages/')) searchTerms.push(pathClean.replace('pages/', ''));
          
          for (const term of searchTerms) {
            const fuzzyMatch = findBestMatch(term, productDictionary);
            if (fuzzyMatch) {
              redirectUrl = productDictionary[fuzzyMatch];
              break;
            }
          }
        }
        
        // 4. Fallback patterns (regex-based)
        if (!redirectUrl) {
          const redirectRules = [
            // Product patterns - keep users on an indexable shopping page
            { pattern: /\/products\/(.+)/, redirect: () => '/collections/all' },
            
            // Collection patterns
            { pattern: /\/collections\/(.+)/, redirect: () => '/collections/all' },
            
            // Common typos & old URLs
            { pattern: /\/(produkte?|artikel|shop)\/(.+)/, redirect: () => '/collections/all' },
            { pattern: /\/(kategorie|category)\/(.+)/, redirect: () => '/collections/all' },
            
            // Windows products (any format)
            { pattern: /win(dows)?[-_\s]?11/i, redirect: () => '/collections/software' },
            { pattern: /win(dows)?[-_\s]?10/i, redirect: () => '/collections/windows-10' },
            
            // Office products (any format)
            { pattern: /office[-_\s]?2024/i, redirect: () => '/collections/microsoft-office-2024' },
            { pattern: /office[-_\s]?2021/i, redirect: () => '/collections/office-2021' },
            { pattern: /office[-_\s]?2019/i, redirect: () => '/collections/office-2019' },
            { pattern: /office[-_\s]?365|microsoft[-_\s]?365|m365/i, redirect: () => '/collections/microsoft-365' },
          ];
          
          for (const rule of redirectRules) {
            const match = path.match(rule.pattern);
            if (match) {
              redirectUrl = rule.redirect(match);
              break;
            }
          }
        }
        
        // ═══════════════════════════════════════════════════════
        // 5. LIVE API SEARCH (Last resort - find real products)
        // ═══════════════════════════════════════════════════════
        
        if (!redirectUrl) {
          const searchQuery = extractSearchTerms(pathClean);
          
          if (searchQuery && searchQuery.length >= 2) {
            showNotice('Suche nach passenden Produkten...', null, true);
            
            const products = await searchProducts(searchQuery);
            
            if (products && products.length > 0) {
              // Found real products! Show them as suggestions
              const notice = document.getElementById('smart-redirect-notice');
              if (notice) {
                notice.innerHTML = `
                  <p style="margin:0 0 10px;font-weight:600;">🎯 Meinten Sie vielleicht:</p>
                  <div style="display:flex;flex-direction:column;gap:8px;">
                    ${products.map(p => `
                      <a href="${p.url}" style="color:#fff;text-decoration:none;background:rgba(255,255,255,0.15);padding:8px 15px;border-radius:6px;display:flex;align-items:center;gap:10px;">
                        ${p.image ? `<img src="${p.image}" alt="${p.title.replace(/"/g,'&quot;')}" width="40" height="40" style="width:40px;height:40px;object-fit:cover;border-radius:4px;">` : ''}
                        <span>${p.title}</span>
                      </a>
                    `).join('')}
                  </div>
                `;
              }
              
              // Auto-redirect to first product after 3 seconds
              redirectUrl = products[0].url;
              setTimeout(() => {
                window.location.href = redirectUrl;
              }, 3000);
            } else {
              // No products found, remove loading notice
              const notice = document.getElementById('smart-redirect-notice');
              if (notice) notice.remove();
            }
          }
        }
        
        // ═══════════════════════════════════════════════════════
        // EXECUTE REDIRECT (for dictionary/fuzzy matches)
        // ═══════════════════════════════════════════════════════
        
        if (redirectUrl && redirectUrl !== path && !redirectUrl.startsWith('/products/')) {
          // Instant redirect - no message
          window.location.replace(redirectUrl);
          return; // Stop execution
        }
        
        // ═══════════════════════════════════════════════════════
        // ANALYTICS TRACKING
        // ═══════════════════════════════════════════════════════
        
        const errorData = {
          page_path: window.location.pathname,
          page_referrer: document.referrer || 'direct',
          page_title: '404 - Seite nicht gefunden',
          timestamp: new Date().toISOString(),
          auto_redirect: redirectUrl || null,
          method: redirectUrl ? (products ? 'api_search' : 'dictionary_or_fuzzy') : 'none'
        };
        
        // Google Analytics 4 (gtag)
        if (typeof gtag === 'function') {
          gtag('event', 'page_not_found', {
            'page_location': window.location.href,
            'page_path': errorData.page_path,
            'page_referrer': errorData.page_referrer,
            'auto_redirect': errorData.auto_redirect,
            'redirect_method': errorData.method
          });
        }
        
        // Google Analytics Universal (ga)
        if (typeof ga === 'function') {
          ga('send', 'event', '404 Error', errorData.page_path, errorData.page_referrer);
        }
        
        // Console log for debugging
        console.warn('404 Error:', errorData);
        
        // Store in localStorage for admin review
        try {
          const errors404 = JSON.parse(localStorage.getItem('karinex_404_errors') || '[]');
          errors404.push(errorData);
          // Keep only last 50 errors
          if (errors404.length > 50) errors404.shift();
          localStorage.setItem('karinex_404_errors', JSON.stringify(errors404));
        } catch(e) {}
      })();
    </script>
    
