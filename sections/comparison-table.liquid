{% comment %}
  Comparison Table Section - Exact LizenzHub Style
{% endcomment %}

<section class="comparison-section">
  <div class="comparison-wrapper">
    <table class="comparison-table">
      <!-- Header Row -->
      <thead>
        <tr>
          <th class="ct-label"></th>
          <th class="ct-main"><div class="ct-badge">Karinex</div></th>
          <th class="ct-alt">Marken auf <span class="text-red">Ebay</span></th>
          <th class="ct-alt">Andere <span class="text-green">Websites</span></th>
        </tr>
      </thead>
      <tbody>
        <!-- Preis -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M15 9.5a2.5 2.5 0 00-2.5-2.5H10a2.5 2.5 0 000 5h4a2.5 2.5 0 010 5h-4.5A2.5 2.5 0 017 14.5M12 5v2m0 10v2"/></svg>
            Preis
          </td>
          <td class="ct-main"><span class="check">✓</span> Preiswert und transparent – keine versteckten Gebühren</td>
          <td class="ct-alt"><span class="cross">✗</span> Billig, aber nächsten Monat musst du es wieder kaufen</td>
          <td class="ct-alt"><span class="check">✓</span> Es sollte funktionieren</td>
        </tr>
        <!-- Authentizität -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            Authentizität
          </td>
          <td class="ct-main"><span class="check">✓</span> 100% originale Lizenzen, garantiert</td>
          <td class="ct-alt"><span class="cross">✗</span> Unsicher – Viele fragwürdige Produkte</td>
          <td class="ct-alt"><span class="cross">✗</span> Unklare Authentizität, keine Garantien</td>
        </tr>
        <!-- Lieferung -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m6 5h.01"/></svg>
            Lieferung
          </td>
          <td class="ct-main"><span class="check">✓</span> Sofortige digitale Lieferung direkt nach dem Kauf</td>
          <td class="ct-alt"><span class="cross">✗</span> Kann Stunden oder Tage dauern, um die Lizenz zu erhalten.</td>
          <td class="ct-alt"><span class="check">✓</span> Lieferzeiten variieren, oft unzuverlässig.</td>
        </tr>
        <!-- Kundensupport -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            Kundensupport
          </td>
          <td class="ct-main"><span class="check">✓</span> Wir sind süchtig nach 5-Sterne-Bewertungen</td>
          <td class="ct-alt"><span class="cross">✗</span> Kein konsistenter Support – hängt vom Verkäufer ab.</td>
          <td class="ct-alt"><span class="cross">✗</span> Spricht kein Deutsch und hat lange Wartezeiten</td>
        </tr>
        <!-- Garantie -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Garantie
          </td>
          <td class="ct-main"><span class="check">✓</span> Volle 30-Tage-Geld-zurück-Garantie</td>
          <td class="ct-alt"><span class="cross">✗</span> Eine Rückerstattung ist praktisch nicht möglich.</td>
          <td class="ct-alt"><span class="cross">✗</span> Selten Rückerstattungen oder Garantien</td>
        </tr>
        <!-- Sicherheit -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Sicherheit
          </td>
          <td class="ct-main"><span class="check">✓</span> Plattform für sichere, verschlüsselte Zahlungen</td>
          <td class="ct-alt"><span class="cross">✗</span> Hohe Gefahr durch nicht-verifizierte Verkäufer</td>
          <td class="ct-alt"><span class="cross">✗</span> Unklare Zahlungsmethoden</td>
        </tr>
        <!-- Benutzerfreundlichkeit -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
            Benutzerfreundlichkeit
          </td>
          <td class="ct-main"><span class="check">✓</span> Einfacher und unkomplizierter Lizenzaktivierungs-prozess</td>
          <td class="ct-alt"><span class="cross">✗</span> Oft unklare Anweisungen</td>
          <td class="ct-alt"><span class="check">✓</span> Sie werden wahrscheinlich Erfolg haben</td>
        </tr>
        <!-- Reputation -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 010-5H6M18 9h1.5a2.5 2.5 0 000-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0012 0V2z"/></svg>
            Reputation
          </td>
          <td class="ct-main"><span class="check">✓</span> Wir sind süchtig nach 5-Sterne-Bewertungen</td>
          <td class="ct-alt"><span class="cross">✗</span> In der Regel Verkäufer ohne Reputation</td>
          <td class="ct-alt"><span class="check">✓</span> Variiert, manche sind ok</td>
        </tr>
        <!-- Rechnungsstellung -->
        <tr>
          <td class="ct-label">
            <svg class="ct-icon" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
            Rechnungsstellung
          </td>
          <td class="ct-main"><span class="check">✓</span> Rechnung mit MwSt.? Bei uns garantiert!</td>
          <td class="ct-alt"><span class="cross">✗</span> Viel Glück damit</td>
          <td class="ct-alt"><span class="cross">✗</span> Rechnungen meist nicht verfügbar.</td>
        </tr>
      </tbody>
      <!-- Footer -->
      <tfoot>
        <tr>
          <td class="ct-label"></td>
          <td class="ct-main ct-footer">
            <div class="ct-rating">
              <svg width="108" height="20" viewBox="0 0 108 20">
                <rect x="0" y="0" width="20" height="20" fill="#00b67a"/>
                <rect x="22" y="0" width="20" height="20" fill="#00b67a"/>
                <rect x="44" y="0" width="20" height="20" fill="#00b67a"/>
                <rect x="66" y="0" width="20" height="20" fill="#00b67a"/>
                <rect x="88" y="0" width="20" height="20" fill="#00b67a"/>
                <path d="M10 3l2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5L2.8 8.2l5-.7z" fill="#fff"/>
                <path d="M32 3l2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.6-3.5 5-.7z" fill="#fff"/>
                <path d="M54 3l2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.6-3.5 5-.7z" fill="#fff"/>
                <path d="M76 3l2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.6-3.5 5-.7z" fill="#fff"/>
                <path d="M98 3l2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.6-3.5 5-.7z" fill="#fff"/>
              </svg>
              <span class="ct-score">{{ section.settings.rating | default: '4.90' }}</span>
            </div>
            <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="ct-cta">{{ section.settings.cta_text | default: 'Zum Shop' }}<span>›</span></a>
          </td>
          <td class="ct-alt"></td>
          <td class="ct-alt"></td>
        </tr>
      </tfoot>
    </table>
  </div>
</section>

<style>
.comparison-section {
  padding: 60px 20px;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ed 100%);
}
.comparison-wrapper {
  max-width: 1100px;
  margin: 0 auto;
}
.comparison-table {
  width: 100%;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  border-collapse: collapse;
  overflow: hidden;
}
.comparison-table th,
.comparison-table td {
  padding: 16px 20px;
  text-align: left;
  vertical-align: middle;
  font-size: 0.9rem;
  line-height: 1.5;
  border-bottom: 1px solid #eef1f5;
}
.comparison-table thead th {
  background: #f8fafc;
  font-weight: 500;
  color: #64748b;
  font-size: 0.95rem;
}
.comparison-table thead th.ct-main {
  background: #3b82f6;
  border-radius: 8px 8px 0 0;
}
.ct-badge {
  color: #fff;
  font-weight: 700;
  font-size: 1.1rem;
  text-align: center;
}
.ct-label {
  background: #f8fafc;
  font-weight: 600;
  color: #334155;
  white-space: nowrap;
  width: 180px;
}
.ct-icon {
  width: 20px;
  height: 20px;
  vertical-align: middle;
  margin-right: 10px;
}
.ct-main {
  background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
  color: #1e40af;
  border-left: 3px solid #3b82f6;
}
.ct-alt {
  color: #475569;
  border-left: 1px solid #eef1f5;
}
.text-red { color: #dc2626; font-weight: 600; }
.text-green { color: #16a34a; font-weight: 600; }
.check {
  color: #16a34a;
  font-weight: 700;
  margin-right: 6px;
}
.cross {
  color: #dc2626;
  font-weight: 700;
  margin-right: 6px;
}
.ct-footer {
  text-align: center;
  padding: 24px 20px;
}
.ct-rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 16px;
}
.ct-score {
  font-weight: 700;
  font-size: 1rem;
  color: #1e293b;
}
.ct-cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #ef4444;
  color: #fff;
  padding: 12px 32px;
  border-radius: 6px;
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  transition: background 0.2s, transform 0.2s;
}
.ct-cta:hover {
  background: #dc2626;
  transform: translateY(-1px);
}
.ct-cta span {
  font-size: 1.1rem;
}
.comparison-table tfoot td {
  border-bottom: none;
}

/* Mobile */
@media (max-width: 900px) {
  .comparison-section { padding: 30px 12px; }
  .comparison-table { display: block; overflow-x: auto; }
  .comparison-table th,
  .comparison-table td { padding: 12px 14px; font-size: 0.85rem; min-width: 140px; }
  .ct-label { min-width: 120px; }
}
</style>

{% schema %}
{
  "name": "Vergleichstabelle",
  "tag": "section",
  "class": "section-comparison-table",
  "settings": [
    {"type":"text","id":"rating","label":"Bewertung","default":"4.90"},
    {"type":"text","id":"cta_text","label":"Button Text","default":"Zum Shop"},
    {"type":"url","id":"cta_link","label":"Button Link"}
  ],
  "presets":[{"name":"Vergleichstabelle","category":"Marketing"}]
}
{% endschema %}
