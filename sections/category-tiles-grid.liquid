{%- comment -%}
  Category Tiles Grid — aboutyou.de mobile homepage style.
  3-column grid of square tiles. Each tile = product image inside a soft
  card with a red "%" badge ribbon on the top-left, label below.
  First tile can be a solid-color "Deals" panel.
{%- endcomment -%}

{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}

<section class="ctg-section" aria-label="{{ section.settings.heading | default: 'Kategorien' | escape }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="ctg-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="ctg-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign tile_url = '#'
        assign target_collection = collections[block.settings.collection]
        if target_collection != blank
          assign tile_url = target_collection.url
        elsif block.settings.custom_url != blank
          assign tile_url = block.settings.custom_url
        endif

        assign tile_image = block.settings.image
        if tile_image == blank and target_collection != blank
          if target_collection.image != blank
            assign tile_image = target_collection.image
          elsif target_collection.products.first.featured_image != blank
            assign tile_image = target_collection.products.first.featured_image
          endif
        endif
      -%}

      <a class="ctg-tile{% if block.settings.solid_panel %} ctg-tile--solid{% endif %}"
         href="{{ tile_url }}"
         {{ block.shopify_attributes }}>
        <div class="ctg-tile__card">
          {%- if block.settings.show_badge -%}
            <span class="ctg-tile__badge" aria-hidden="true">%</span>
          {%- endif -%}

          {%- if block.settings.solid_panel -%}
            <span class="ctg-tile__big-percent" aria-hidden="true">%</span>
          {%- elsif tile_image != blank -%}
            <img
              class="ctg-tile__img"
              src="{{ tile_image | image_url: width: 360 }}"
              alt="{{ block.settings.label | escape }}"
              loading="lazy"
              width="180" height="180">
          {%- else -%}
            <span class="ctg-tile__placeholder" aria-hidden="true">{{ block.settings.label | slice: 0, 1 }}</span>
          {%- endif -%}
        </div>
        <span class="ctg-tile__label{% if block.settings.highlight_label %} ctg-tile__label--hot{% endif %}">
          {{- block.settings.label -}}
        </span>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .ctg-section {
    padding: 20px 16px 28px;
    background: #ffffff;
  }
  .ctg-heading {
    margin: 0 0 16px;
    font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #0d2e22;
  }

  .ctg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .ctg-tile {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  .ctg-tile__card {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f4f4f4;
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .25s cubic-bezier(.22,.61,.36,1), box-shadow .25s ease;
  }

  /* Solid-panel variant (the 'Deals' panel — brand green) */
  .ctg-tile--solid .ctg-tile__card {
    background: #1D4739;
  }
  .ctg-tile__big-percent {
    color: #c9a84c;  /* champagne gold % inside green panel */
    font-family: 'Outfit', system-ui, -apple-system, sans-serif;
    font-size: clamp(56px, 16vw, 88px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  /* Product image */
  .ctg-tile__img {
    width: 78%;
    height: 78%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  .ctg-tile__placeholder {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 48px;
    font-weight: 500;
    color: #cfcfcf;
  }

  /* Brand-green "%" badge ribbon — top-left corner */
  .ctg-tile__badge {
    position: absolute;
    top: 0;
    left: 0;
    width: 38px;
    height: 38px;
    background: #1D4739;
    color: #c9a84c;  /* champagne gold % on green */
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 800;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px 0 14px 0;
    z-index: 2;
    /* Soft cloud-like bottom-right edge */
    clip-path: path('M 0 0 H 38 V 28 Q 32 30 26 34 Q 20 38 12 38 H 0 Z');
  }

  /* Label below tile */
  .ctg-tile__label {
    display: block;
    margin-top: 10px;
    text-align: center;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #1a1a1a;
  }
  .ctg-tile__label--hot {
    color: #c9a84c;  /* champagne gold for SALE / Deals labels */
  }

  /* Touch / hover feedback */
  @media (hover: hover) {
    .ctg-tile:hover .ctg-tile__card {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,0,0,.08);
    }
  }
  .ctg-tile:active .ctg-tile__card {
    transform: scale(.97);
  }

  /* Tablet and up: keep 3 columns but give tiles more width */
  @media (min-width: 600px) {
    .ctg-section { padding: 28px 24px 36px; }
    .ctg-grid { gap: 16px; }
    .ctg-tile__label { font-size: 15px; margin-top: 12px; }
  }

  /* ============================================================
     DESKTOP ≥ 990px — EDITORIAL LUXURY REDESIGN
     Asymmetric 4-col bento grid. First tile (Deals) is featured,
     spans 2x2 cells. Cards have depth, gradient surfaces, hover
     lift. Mobile / tablet untouched.
     ============================================================ */
  @media (min-width: 990px) {
    .ctg-section {
      padding: 96px clamp(32px, 6vw, 80px) 120px;
      max-width: 1240px;
      margin: 0 auto;
      background: #ffffff;
      position: relative;
    }

    /* Eyebrow label above the heading */
    .ctg-section::before {
      content: 'EXPLORE';
      display: block;
      font-family: 'Outfit', system-ui, -apple-system, sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.42em;
      color: rgba(13, 46, 34, 0.45);
      text-align: center;
      margin-bottom: 14px;
    }

    .ctg-heading {
      font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
      font-size: clamp(38px, 3.4vw, 52px);
      font-weight: 400;
      letter-spacing: -0.01em;
      line-height: 1.05;
      color: #0d2e22;
      text-align: center;
      margin: 0 auto 56px;
      max-width: 720px;
    }

    /* 4-col bento grid with first tile spanning 2x2 = featured */
    .ctg-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(180px, 1fr);
      gap: 18px;
    }
    .ctg-tile:first-child {
      grid-column: span 2;
      grid-row: span 2;
    }

    /* CARD — refined surface, depth, hover lift */
    .ctg-tile {
      align-items: stretch;  /* override mobile center align */
    }
    .ctg-tile__card {
      width: 100%;
      height: 100%;
      aspect-ratio: auto;       /* let bento rows define height */
      border-radius: 20px;
      background:
        linear-gradient(165deg,
          rgba(255,255,255,0.6) 0%,
          rgba(244,244,242,1) 100%);
      border: 1px solid rgba(13, 46, 34, 0.06);
      box-shadow:
        0 1px 2px rgba(13, 46, 34, 0.03),
        0 12px 32px -8px rgba(13, 46, 34, 0.07);
      overflow: hidden;
      transition:
        transform 0.45s cubic-bezier(.22,.61,.36,1),
        box-shadow 0.45s cubic-bezier(.22,.61,.36,1),
        border-color 0.45s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    /* Subtle inner highlight on top edge */
    .ctg-tile__card::after {
      content: '';
      position: absolute;
      top: 0; left: 8%; right: 8%;
      height: 1px;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(255,255,255,0.95) 50%,
        transparent 100%);
      pointer-events: none;
    }

    .ctg-tile:hover .ctg-tile__card {
      transform: translateY(-4px);
      box-shadow:
        0 1px 2px rgba(13, 46, 34, 0.04),
        0 24px 48px -12px rgba(13, 46, 34, 0.14);
      border-color: rgba(13, 46, 34, 0.10);
    }

    /* FEATURED tile (Deals) — cinematic dark green with gold pull */
    .ctg-tile--solid .ctg-tile__card {
      background:
        radial-gradient(120% 80% at 30% 0%,
          rgba(45, 107, 84, 0.55) 0%,
          transparent 60%),
        linear-gradient(155deg, #1D4739 0%, #0d2e22 100%);
      border-color: rgba(255,255,255,0.05);
      box-shadow:
        0 1px 2px rgba(13, 46, 34, 0.10),
        0 24px 48px -12px rgba(13, 46, 34, 0.30);
    }
    .ctg-tile--solid .ctg-tile__card::after {
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(201, 168, 76, 0.4) 50%,
        transparent 100%);
    }
    .ctg-tile--solid .ctg-tile__big-percent {
      font-size: clamp(120px, 12vw, 200px);
      font-weight: 200;
      letter-spacing: -0.06em;
      color: #c9a84c;
      opacity: 0.95;
      line-height: 1;
      transform: translateY(-8px);
    }
    .ctg-tile--solid:hover .ctg-tile__big-percent {
      transform: translateY(-12px) scale(1.02);
      transition: transform 0.6s cubic-bezier(.22,.61,.36,1);
    }

    /* PRODUCT IMAGE in standard tiles — bigger, with subtle scale on hover */
    .ctg-tile__img {
      width: 72%;
      height: 72%;
      object-fit: contain;
      transition: transform 0.5s cubic-bezier(.22,.61,.36,1);
    }
    .ctg-tile:hover .ctg-tile__img {
      transform: scale(1.04);
    }

    /* Placeholder letter — refined fallback */
    .ctg-tile__placeholder {
      font-family: 'Newsreader', Georgia, serif;
      font-size: 96px;
      font-weight: 300;
      color: rgba(13, 46, 34, 0.10);
      letter-spacing: -0.04em;
    }
    .ctg-tile:first-child .ctg-tile__placeholder {
      font-size: 160px;
    }

    /* BADGE — restrained, smaller, more elegant */
    .ctg-tile__badge {
      top: 14px;
      left: 14px;
      width: 36px;
      height: 36px;
      font-size: 14px;
      font-weight: 700;
      background: #1D4739;
      color: #c9a84c;
      border-radius: 999px;     /* perfect circle, not ribbon */
      clip-path: none;          /* drop the cloud edge */
      box-shadow: 0 4px 12px rgba(13, 46, 34, 0.22);
    }
    /* Featured tile: no badge — the big % is its statement */
    .ctg-tile--solid .ctg-tile__badge { display: none; }

    /* LABEL — editorial caption */
    .ctg-tile__label {
      font-family: 'Newsreader', Georgia, serif;
      font-size: 15px;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: #0d2e22;
      margin-top: 18px;
      text-align: left;          /* editorial left-align on desktop */
      padding: 0 2px;
    }
    .ctg-tile__label--hot {
      color: #c9a84c;
      font-weight: 600;
    }
  }

  /* Wide desktop ≥ 1440: more cinematic spacing */
  @media (min-width: 1440px) {
    .ctg-section { max-width: 1320px; padding: 120px 48px 140px; }
    .ctg-grid { grid-auto-rows: minmax(200px, 1fr); gap: 22px; }
    .ctg-tile__label { font-size: 16px; margin-top: 20px; }
  }
</style>

{% schema %}
{
  "name": "Category tiles grid",
  "tag": "section",
  "class": "section-category-tiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)",
      "default": "Kategorien"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Kategorie"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (link target)"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom URL (used if no collection)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)",
          "info": "If empty, the collection's image or the first product image is used."
        },
        {
          "type": "checkbox",
          "id": "show_badge",
          "label": "Show red % badge",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "solid_panel",
          "label": "Solid red 'Deals' panel (instead of image)",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "highlight_label",
          "label": "Highlight label in red",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Category tiles grid",
      "blocks": [
        { "type": "tile", "settings": { "label": "Deals", "solid_panel": true, "highlight_label": true, "show_badge": false } },
        { "type": "tile", "settings": { "label": "Microsoft Office" } },
        { "type": "tile", "settings": { "label": "Windows" } },
        { "type": "tile", "settings": { "label": "Office für Mac" } },
        { "type": "tile", "settings": { "label": "Microsoft 365" } },
        { "type": "tile", "settings": { "label": "Windows Server" } },
        { "type": "tile", "settings": { "label": "Microsoft Tools" } },
        { "type": "tile", "settings": { "label": "SALE", "highlight_label": true } },
        { "type": "tile", "settings": { "label": "Top 100" } }
      ]
    }
  ]
}
{% endschema %}
