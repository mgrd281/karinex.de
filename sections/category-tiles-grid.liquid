{%- comment -%}
  Category Tiles Grid — aboutyou.de mobile homepage style.
  3-column grid of square tiles. Each tile = product image inside a soft
  card with a red "%" badge ribbon on the top-left, label below.
  First tile can be a solid-color "Deals" panel.
{%- endcomment -%}

{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}

<section class="ctg-section ctg-section--show-{{ section.settings.heading_visibility | default: 'both' }}" aria-label="{{ section.settings.heading | default: 'Kategorien' | escape }}">
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="ctg-head">
      {%- if section.settings.heading != blank -%}
        <h2 class="ctg-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ctg-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ctg-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign tile_url = '#'
        assign target_collection = collections[block.settings.collection]
        if target_collection != blank
          assign tile_url = target_collection.url
        elsif block.settings.custom_url != blank
          assign tile_url = block.settings.custom_url
        endif

        assign tile_image = block.settings.image
        if tile_image == blank and target_collection != blank
          if target_collection.image != blank
            assign tile_image = target_collection.image
          elsif target_collection.products.first.featured_image != blank
            assign tile_image = target_collection.products.first.featured_image
          endif
        endif
      -%}

      <a class="ctg-tile{% if block.settings.solid_panel %} ctg-tile--solid{% endif %}"
         href="{{ tile_url }}"
         {{ block.shopify_attributes }}>
        <div class="ctg-tile__card">
          {%- if block.settings.show_badge -%}
            <span class="ctg-tile__badge" aria-hidden="true">%</span>
          {%- endif -%}

          {%- if block.settings.solid_panel -%}
            <span class="ctg-tile__big-percent" aria-hidden="true">%</span>
          {%- elsif tile_image != blank -%}
            <img
              class="ctg-tile__img"
              src="{{ tile_image | image_url: width: 360 }}"
              alt="{{ block.settings.label | escape }}"
              loading="lazy"
              width="180" height="180">
          {%- else -%}
            <span class="ctg-tile__placeholder" aria-hidden="true">{{ block.settings.label | slice: 0, 1 }}</span>
          {%- endif -%}
        </div>
        <span class="ctg-tile__label{% if block.settings.highlight_label %} ctg-tile__label--hot{% endif %}">
          {{- block.settings.label -}}
        </span>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .ctg-section {
    padding: 20px 16px 28px;
    background: #ffffff;
  }
  .ctg-heading {
    margin: 0 0 16px;
    font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #0d2e22;
  }
  /* Subheading default: hidden on mobile (will be revealed by
     heading_visibility setting + desktop breakpoint below). */
  .ctg-subheading {
    display: none;
  }

  /* ----- HEADING VISIBILITY CONTROL (Theme Editor setting) -----
     Section gets a class .ctg-section--show-{both|mobile|desktop|hidden}
     that drives whether .ctg-head is visible on each breakpoint.
     #shopify-section-{{ section.id }} + !important to override any
     theme-side rules and Shopify's section wrappers. */
  #shopify-section-{{ section.id }} .ctg-section--show-hidden .ctg-head { display: none !important; }
  /* Default 'both' = show on all viewports. No override needed. */
  /* Mobile-only: hide head on desktop */
  /* Desktop-only: hide head on mobile (handled below in media query) */
  #shopify-section-{{ section.id }} .ctg-section--show-desktop .ctg-head { display: none !important; }

  .ctg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .ctg-tile {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  .ctg-tile__card {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #f4f4f4;
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .25s cubic-bezier(.22,.61,.36,1), box-shadow .25s ease;
  }

  /* Solid-panel variant (the 'Deals' panel — brand green) */
  .ctg-tile--solid .ctg-tile__card {
    background: #1D4739;
  }
  .ctg-tile__big-percent {
    color: #c9a84c;  /* champagne gold % inside green panel */
    font-family: 'Outfit', system-ui, -apple-system, sans-serif;
    font-size: clamp(56px, 16vw, 88px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  /* Product image */
  .ctg-tile__img {
    width: 78%;
    height: 78%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  .ctg-tile__placeholder {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 48px;
    font-weight: 500;
    color: #cfcfcf;
  }

  /* Brand-green "%" badge ribbon — top-left corner */
  .ctg-tile__badge {
    position: absolute;
    top: 0;
    left: 0;
    width: 38px;
    height: 38px;
    background: #1D4739;
    color: #c9a84c;  /* champagne gold % on green */
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 800;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px 0 14px 0;
    z-index: 2;
    /* Soft cloud-like bottom-right edge */
    clip-path: path('M 0 0 H 38 V 28 Q 32 30 26 34 Q 20 38 12 38 H 0 Z');
  }

  /* Label below tile */
  .ctg-tile__label {
    display: block;
    margin-top: 10px;
    text-align: center;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #1a1a1a;
  }
  .ctg-tile__label--hot {
    color: #c9a84c;  /* champagne gold for SALE / Deals labels */
  }

  /* Touch / hover feedback */
  @media (hover: hover) {
    .ctg-tile:hover .ctg-tile__card {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,0,0,.08);
    }
  }
  .ctg-tile:active .ctg-tile__card {
    transform: scale(.97);
  }

  /* Tablet and up: keep 3 columns but give tiles more width */
  @media (min-width: 600px) {
    .ctg-section { padding: 28px 24px 36px; }
    .ctg-grid { gap: 16px; }
    .ctg-tile__label { font-size: 15px; margin-top: 12px; }
  }

  /* Desktop: 3x3 grid kept compact — narrower container so tiles
     stay ~190px and don't dominate the page. */
  @media (min-width: 990px) {
    .ctg-section {
      padding: 60px 24px 80px;
      max-width: 760px;          /* tighter than 1000 — tiles ~190px */
      margin: 0 auto;
    }
    .ctg-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    /* Heading wrapper mirrors BF Slider's .bf-head spacing */
    .ctg-head {
      text-align: left;
      margin-bottom: 28px;
    }
    /* Match BF Slider's .bf-h2 exactly */
    .ctg-heading {
      font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
      font-size: 28px;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: 0.02em;
      margin: 0;
      color: #0d2e22;
      text-align: left;
    }
    /* Match BF Slider's .bf-subtitle exactly */
    .ctg-subheading {
      display: block;
      font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
      margin: 4px 0 0;
      font-size: 14px;
      font-weight: 400;
      line-height: 1.4;
      letter-spacing: 0.01em;
      color: rgba(13, 46, 34, 0.55);
    }

    /* Desktop overrides for visibility setting */
    /* Mobile-only: hide head on desktop */
    #shopify-section-{{ section.id }} .ctg-section--show-mobile .ctg-head { display: none !important; }
    /* Desktop-only: show head on desktop (overrides the global hide rule) */
    #shopify-section-{{ section.id }} .ctg-section--show-desktop .ctg-head { display: block !important; }
    /* Hidden everywhere */
    #shopify-section-{{ section.id }} .ctg-section--show-hidden .ctg-head { display: none !important; }
    /* When heading is hidden on desktop, drop the top padding so no
       empty space remains above the grid. */
    #shopify-section-{{ section.id }} .ctg-section--show-mobile,
    #shopify-section-{{ section.id }} .ctg-section--show-hidden {
      padding-top: 0 !important;
    }
    /* Both & desktop view: show (default, no override needed) */
    .ctg-tile__card {
      border-radius: 16px;
    }
    .ctg-tile__img {
      width: 70%;
      height: 70%;
    }
    .ctg-tile__placeholder {
      font-size: 56px;
      font-weight: 400;
      color: #d8d8d8;
    }
    .ctg-tile__big-percent {
      font-size: 72px;
    }
    .ctg-tile__badge {
      width: 40px;
      height: 40px;
      font-size: 16px;
      border-radius: 16px 0 16px 0;
    }
    .ctg-tile__label {
      font-size: 14px;
      font-weight: 600;
      margin-top: 12px;
    }
  }

  /* Wide desktop: cap the section to keep tiles tight even on 4K screens */
  @media (min-width: 1440px) {
    .ctg-section { max-width: 820px; padding: 72px 24px 96px; }
    /* Same heading-hidden top-padding reduction at this breakpoint */
    #shopify-section-{{ section.id }} .ctg-section--show-mobile,
    #shopify-section-{{ section.id }} .ctg-section--show-hidden {
      padding-top: 0 !important;
    }
  }
</style>

{% schema %}
{
  "name": "Category tiles grid",
  "tag": "section",
  "class": "section-category-tiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)",
      "default": "Kategorien"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (optional)",
      "default": "Alle Bereiche im Überblick"
    },
    {
      "type": "select",
      "id": "heading_visibility",
      "label": "Show heading on",
      "info": "Choose where the heading + subheading should appear.",
      "options": [
        { "value": "both",    "label": "Both — mobile + desktop" },
        { "value": "mobile",  "label": "Mobile only" },
        { "value": "desktop", "label": "Desktop only" },
        { "value": "hidden",  "label": "Hidden everywhere" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Kategorie"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (link target)"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom URL (used if no collection)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)",
          "info": "If empty, the collection's image or the first product image is used."
        },
        {
          "type": "checkbox",
          "id": "show_badge",
          "label": "Show red % badge",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "solid_panel",
          "label": "Solid red 'Deals' panel (instead of image)",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "highlight_label",
          "label": "Highlight label in red",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Category tiles grid",
      "blocks": [
        { "type": "tile", "settings": { "label": "Deals", "solid_panel": true, "highlight_label": true, "show_badge": false } },
        { "type": "tile", "settings": { "label": "Microsoft Office" } },
        { "type": "tile", "settings": { "label": "Windows" } },
        { "type": "tile", "settings": { "label": "Office für Mac" } },
        { "type": "tile", "settings": { "label": "Microsoft 365" } },
        { "type": "tile", "settings": { "label": "Windows Server" } },
        { "type": "tile", "settings": { "label": "Microsoft Tools" } },
        { "type": "tile", "settings": { "label": "SALE", "highlight_label": true } },
        { "type": "tile", "settings": { "label": "Top 100" } }
      ]
    }
  ]
}
{% endschema %}
