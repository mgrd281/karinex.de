{%- comment -%}
  Use-Case Landing Page — reusable section for SEO landing pages like
    /pages/software-fur-studenten
    /pages/software-fur-unternehmen
    /pages/software-fur-mac
    /pages/upgrade-windows-11

  Each instance of this section is fully configured from the Theme
  Editor (heading, intro, list of featured collection handles,
  optional list of curated product handles, FAQ blocks).

  The output is a single page that combines:
    1. Hero heading + intro
    2. Featured product carousel (top picks for this use-case)
    3. 3-4 deep category links
    4. Optional rich-text content blocks
    5. Mini FAQ (helps with rich-results in Google)

  Layout is deliberately link-heavy: every product, every collection
  and every FAQ entry doubles as an internal link the search engines
  can crawl.
{%- endcomment -%}

{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless

  assign hero_h = section.settings.heading | default: page.title
  assign hero_kicker = section.settings.kicker
  assign hero_intro = section.settings.intro

  assign curated_handles = section.settings.curated_product_handles | strip | split: ','
  assign featured_handles = section.settings.featured_collection_handles | strip | split: ','
-%}

<section class="kx-use">

  <header class="kx-use__hero">
    {%- if hero_kicker != blank -%}
      <p class="kx-use__kicker">{{ hero_kicker }}</p>
    {%- endif -%}
    <h1 class="kx-use__h1">{{ hero_h }}</h1>
    {%- if hero_intro != blank -%}
      <div class="kx-use__intro rte">{{ hero_intro }}</div>
    {%- endif -%}
  </header>

  {%- comment -%} ── Curated picks (single comma-separated handle list) ── {%- endcomment -%}
  {%- if curated_handles.size > 0 -%}
    <section class="kx-use__picks">
      <h2 class="kx-use__h2">
        {{ section.settings.picks_heading | default: 'Empfohlen für dich' }}
      </h2>
      <ul class="kx-use__pick-grid" role="list">
        {%- for handle in curated_handles -%}
          {%- assign h = handle | strip -%}
          {%- assign p = all_products[h] -%}
          {%- if p and p.title != blank -%}
            {%- assign _full = p.title -%}
            {%- assign _short = _full | split: ' – ' | first | split: ' | ' | first | truncatewords: 6, '…' -%}
            <li class="kx-use__pick">
              <a href="{{ p.url }}" class="kx-use__pick-link" title="{{ _full | escape }}">
                {%- if p.featured_image -%}
                  <img class="kx-use__pick-img"
                       src="{{ p.featured_image | image_url: width: 240 }}"
                       alt="{{ p.title | escape }}"
                       loading="lazy"
                       width="120" height="120">
                {%- endif -%}
                <span class="kx-use__pick-body">
                  <span class="kx-use__pick-name">{{ _short }}</span>
                  {%- if p.compare_at_price > p.price -%}
                    <span class="kx-use__pick-price">
                      <s class="kx-use__pick-old">{{ p.compare_at_price | money }}</s>
                      <strong class="kx-use__pick-new">{{ p.price | money }}</strong>
                    </span>
                  {%- else -%}
                    <strong class="kx-use__pick-price">{{ p.price | money }}</strong>
                  {%- endif -%}
                </span>
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </section>
  {%- endif -%}

  {%- comment -%} ── Featured collections ── {%- endcomment -%}
  {%- if featured_handles.size > 0 -%}
    <section class="kx-use__cats">
      <h2 class="kx-use__h2">
        {{ section.settings.cats_heading | default: 'Passende Kategorien' }}
      </h2>
      <div class="kx-use__cat-grid">
        {%- for handle in featured_handles -%}
          {%- assign h = handle | strip -%}
          {%- assign c = collections[h] -%}
          {%- if c and c.products_count > 0 -%}
            <a class="kx-use__cat" href="{{ c.url }}">
              <span class="kx-use__cat-title">{{ c.title }}</span>
              <span class="kx-use__cat-meta">{{ c.products_count }} Produkte</span>
              <span class="kx-use__cat-arrow" aria-hidden="true">→</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── Rich-text / FAQ blocks ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <section class="kx-use__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'richtext' -%}
            <article class="kx-use__rich rte" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="kx-use__h2">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {{ block.settings.body }}
            </article>
          {%- when 'faq' -%}
            <details class="kx-use__faq" {{ block.shopify_attributes }}>
              <summary class="kx-use__faq-q">{{ block.settings.question }}</summary>
              <div class="kx-use__faq-a rte">{{ block.settings.answer }}</div>
            </details>
        {%- endcase -%}
      {%- endfor -%}
    </section>
  {%- endif -%}

</section>

<style>
  .kx-use {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 56px) clamp(16px, 4vw, 40px);
    color: #1a1a1a;
  }
  .kx-use__hero { margin-bottom: 36px; }
  .kx-use__kicker {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c9a84c;
    margin: 0 0 8px;
  }
  .kx-use__h1 {
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 700;
    color: #1B3A2E;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .kx-use__intro {
    font-size: 16px;
    color: #444;
    line-height: 1.6;
    max-width: 70ch;
  }
  .kx-use__h2 {
    font-size: 22px;
    font-weight: 700;
    color: #1B3A2E;
    margin: 0 0 16px;
  }
  .kx-use__picks { margin-bottom: 40px; }
  .kx-use__pick-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
  }
  .kx-use__pick-link {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px;
    background: #faf7f0;
    border: 1px solid #ece6d6;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
    height: 100%;
  }
  .kx-use__pick-link:hover,
  .kx-use__pick-link:focus-visible {
    border-color: #c9a84c;
    background: #fff;
    transform: translateY(-2px);
  }
  .kx-use__pick-img {
    width: 100%;
    height: 130px;
    object-fit: contain;
    background: #fff;
    border-radius: 8px;
  }
  .kx-use__pick-body { display: flex; flex-direction: column; gap: 4px; }
  .kx-use__pick-name {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
    color: #1a1a1a;
  }
  .kx-use__pick-price { font-size: 14px; font-weight: 700; color: #E30613; }
  .kx-use__pick-old { font-weight: 400; color: #999; margin-right: 6px; font-size: 12px; }
  .kx-use__pick-new { color: #E30613; }

  .kx-use__cats { margin-bottom: 40px; }
  .kx-use__cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }
  .kx-use__cat {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    background: #ffffff;
    border: 1px solid #d8d0bb;
    border-radius: 10px;
    color: #1B3A2E;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 180ms ease, border-color 180ms ease, transform 180ms ease;
  }
  .kx-use__cat:hover,
  .kx-use__cat:focus-visible {
    background: #1B3A2E;
    border-color: #1B3A2E;
    color: #fff;
    transform: translateY(-1px);
  }
  .kx-use__cat-title { flex: 1 1 auto; font-size: 14px; }
  .kx-use__cat-meta { font-size: 12px; opacity: 0.7; font-weight: 500; }
  .kx-use__cat-arrow { font-size: 16px; font-weight: 600; opacity: 0.6; transition: opacity 180ms ease, transform 200ms ease; }
  .kx-use__cat:hover .kx-use__cat-arrow,
  .kx-use__cat:focus-visible .kx-use__cat-arrow { opacity: 1; transform: translateX(3px); }

  .kx-use__content { margin-top: 32px; }
  .kx-use__rich {
    margin-bottom: 28px;
    max-width: 75ch;
  }
  .kx-use__rich :where(p, li) { line-height: 1.65; }
  .kx-use__rich a { color: #1B3A2E; }
  .kx-use__faq {
    margin: 0 0 10px;
    border: 1px solid #ece6d6;
    border-radius: 8px;
    background: #faf7f0;
    padding: 0 16px;
  }
  .kx-use__faq[open] { background: #fff; border-color: #c9a84c; }
  .kx-use__faq-q {
    cursor: pointer;
    font-weight: 600;
    padding: 14px 0;
    color: #1B3A2E;
    list-style: none;
  }
  .kx-use__faq-q::-webkit-details-marker { display: none; }
  .kx-use__faq-q::before {
    content: '+';
    display: inline-block;
    width: 1.2em;
    color: #c9a84c;
    font-weight: 700;
  }
  .kx-use__faq[open] .kx-use__faq-q::before { content: '−'; }
  .kx-use__faq-a {
    padding: 0 0 14px 1.2em;
    line-height: 1.6;
    color: #333;
  }
  .kx-use__faq-a a { color: #1B3A2E; }
</style>

{% schema %}
{
  "name": "Use-Case Landing",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "kicker", "label": "Kicker (eyebrow)", "default": "Use-Case" },
    { "type": "text", "id": "heading", "label": "H1 (leave blank to use page title)" },
    { "type": "richtext", "id": "intro", "label": "Intro paragraph", "default": "<p>Beschreibe hier kurz, für wen diese Seite gedacht ist und welche Software sie braucht.</p>" },

    { "type": "header", "content": "Empfohlene Produkte" },
    { "type": "text", "id": "picks_heading", "label": "Section heading", "default": "Empfohlen für dich" },
    { "type": "textarea", "id": "curated_product_handles", "label": "Product handles (comma-separated)", "info": "z. B. office-2024-professional-plus-key,windows-11-pro,microsoft-365-personal" },

    { "type": "header", "content": "Passende Kategorien" },
    { "type": "text", "id": "cats_heading", "label": "Section heading", "default": "Passende Kategorien" },
    { "type": "textarea", "id": "featured_collection_handles", "label": "Collection handles (comma-separated)", "info": "z. B. microsoft-office,windows,microsoft-365-abonnement,microsoft-tools" }
  ],
  "blocks": [
    {
      "type": "richtext",
      "name": "Text block",
      "settings": [
        { "type": "text", "id": "heading", "label": "H2 heading" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Hier kannst du SEO-Text einfügen — beschreibe das Use-Case, vergleiche Versionen, verlinke andere relevante Produkte oder Blog-Artikel.</p>" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ entry",
      "settings": [
        { "type": "text", "id": "question", "label": "Frage", "default": "Welche Software brauche ich?" },
        { "type": "richtext", "id": "answer", "label": "Antwort", "default": "<p>Antwort mit eingebetteten Links zu relevanten Produkten und Kategorien.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Use-Case Landing" }
  ]
}
{% endschema %}
