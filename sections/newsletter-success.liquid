{% schema %}
{
  "name": "Newsletter Success",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Anmeldung erfolgreich!"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Success Message",
      "default": "<p>Vielen Dank für deine Anmeldung. Dein 10 € Willkommens-Gutschein ist bereits auf dem Weg in dein E-Mail-Postfach.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Weiter einkaufen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#2e7d32"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Success"
    }
  ]
}
{% endschema %}

<div class="newsletter-success-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="newsletter-success-container">
    
    <div class="success-icon-wrapper">
      <div class="success-icon-circle">
        <svg class="success-icon-check" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div class="success-icon-pulse"></div>
    </div>

    <h1 class="success-heading" style="color: {{ section.settings.text_color }};">
      {{ section.settings.heading }}
    </h1>

    <div class="success-message" style="color: {{ section.settings.text_color }};">
      {{ section.settings.text }}
    </div>

    <a href="{{ section.settings.button_link }}" class="success-button">
      {{ section.settings.button_label }}
    </a>

  </div>
</div>

<style>
  .newsletter-success-section {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .newsletter-success-container {
    max-width: 600px;
    width: 100%;
    text-align: center;
    /* Optional: Glassmorphism / Card effect if background is not white */
    /* background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 60px 40px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05); */
  }

  /* Animated Icon */
  .success-icon-wrapper {
    position: relative;
    width: 80px;
    height: 80px;
    margin: 0 auto 32px;
  }

  .success-icon-circle {
    position: relative;
    width: 100%;
    height: 100%;
    background: {{ section.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 10px 20px rgba(46, 125, 50, 0.2);
    animation: scaleIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .success-icon-check {
    width: 40px;
    height: 40px;
    color: white;
    stroke-dasharray: 24;
    stroke-dashoffset: 24;
    animation: drawCheck 0.4s 0.3s ease forwards;
  }

  .success-icon-pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: {{ section.settings.accent_color }};
    opacity: 0.2;
    z-index: 1;
    animation: pulse 2s infinite;
  }

  /* Typography */
  .success-heading {
    font-size: 36px;
    font-weight: 700;
    margin: 0 0 16px;
    letter-spacing: -0.5px;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s ease forwards;
  }

  .success-message {
    font-size: 18px;
    line-height: 1.6;
    margin: 0 auto 40px;
    max-width: 480px;
    opacity: 0.8;
    opacity: 0;
    animation: fadeUp 0.6s 0.3s ease forwards;
  }
  
  .success-message p {
    margin: 0;
  }

  /* Button */
  .success-button {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: white;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 40px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(46, 125, 50, 0.2);
    opacity: 0;
    animation: fadeUp 0.6s 0.4s ease forwards;
  }

  .success-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(46, 125, 50, 0.3);
    background: #1b5e20; /* Darker shade */
    color: white;
  }

  /* Animations */
  @keyframes scaleIn {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.2; }
    70% { transform: scale(1.5); opacity: 0; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  @keyframes fadeUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .newsletter-success-section {
      padding: 40px 20px;
    }
    
    .success-heading {
      font-size: 28px;
    }
    
    .success-message {
      font-size: 16px;
    }
    
    .success-button {
      width: 100%;
      text-align: center;
    }
  }
</style>
