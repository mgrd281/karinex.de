{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
<link rel="stylesheet" href="{{ 'main-legal-notice.css' | asset_url }}">

<style>
  /* Form-only additions on top of legal-notice palette */
  .kb-form-grid { display: grid; gap: 16px; }
  @media (min-width: 640px) { .kb-form-grid { grid-template-columns: 1fr 1fr; } }
  .kb-field { display: flex; flex-direction: column; gap: 6px; }
  .kb-field--full { grid-column: 1 / -1; }
  .kb-field label { font-size: 14px; font-weight: 600; color: var(--legal-text); letter-spacing: 0.1px; }
  .kb-field input, .kb-field select, .kb-field textarea {
    font: inherit; font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--legal-border);
    border-radius: var(--legal-radius);
    background: #fff; color: var(--legal-text);
    transition: border-color var(--legal-transition);
  }
  .kb-field input:focus, .kb-field select:focus, .kb-field textarea:focus {
    outline: none; border-color: var(--legal-accent);
  }
  .kb-field textarea { resize: vertical; min-height: 96px; }
  .kb-checkbox { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: var(--legal-text-muted); line-height: 1.5; }
  .kb-checkbox input { width: 18px; height: 18px; margin-top: 2px; flex-shrink: 0; accent-color: var(--legal-accent); }
  .kb-checkbox a { color: var(--legal-accent); text-decoration: underline; }
  .kb-submit {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%;
    background: var(--legal-text); color: #fff;
    font-size: 15px; font-weight: 700; letter-spacing: 0.3px;
    padding: 16px 24px; border: none; border-radius: var(--legal-radius);
    cursor: pointer; min-height: 52px;
    transition: background var(--legal-transition), transform var(--legal-transition);
  }
  .kb-submit:hover { background: var(--legal-accent); transform: translateY(-1px); }
  .kb-form-meta { font-size: 13px; color: var(--legal-text-light); text-align: center; margin-top: 4px; }
  .kb-form-error { color: #b91c1c; font-size: 14px; font-weight: 600; min-height: 20px; text-align: center; }
  .kb-form-success { display: none; color: var(--legal-accent); font-weight: 700; text-align: center; padding: 14px; background: #e8f5e9; border-radius: var(--legal-radius); }
  .kb-hidden { display: none; }
  /* Steps grid */
  .kb-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 8px; }
  .kb-step { padding: 20px; background: var(--legal-bg-soft); border-radius: var(--legal-radius); border: 1px solid var(--legal-border); }
  .kb-step-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--legal-accent); color: #fff;
    font-weight: 700; font-size: 16px; margin-bottom: 12px;
  }
  .kb-step-title { font-size: 16px; font-weight: 700; color: var(--legal-text); margin: 0 0 6px; }
  .kb-step-text { font-size: 14px; color: var(--legal-text-muted); margin: 0; line-height: 1.55; }
</style>

<div class="legal-page">

  <!-- HERO SECTION -->
  <section class="legal-hero">
    <div class="legal-hero-content">
      <h1 class="legal-hero-title">Kostenlose Microsoft-Beratung</h1>
      <p class="legal-hero-subtitle">Persönliche Beratung zu Microsoft-Lizenzen, Office-Versionen, Windows-Aktivierung und Installation. Wir rufen Sie kostenlos zurück.</p>
      <div class="legal-hero-divider"></div>
    </div>
  </section>

  <div class="legal-container">

    <article class="legal-content">

      <!-- 1. Wofür wir beraten -->
      <section class="legal-section" id="themen">
        <h2 class="legal-section-title">Wofür wir beraten</h2>
        <p>Unser Team kennt das Microsoft-Ökosystem im Detail. Ob Lizenzwahl, Aktivierungsfragen oder Installationsschritte – wir nehmen uns Zeit für Ihre konkrete Situation.</p>
        <ul class="legal-list">
          <li><strong>Microsoft Office:</strong> Beratung zu Office 2021, Office 2024 und Microsoft 365 – welche Version passt zu Ihrem Arbeitsalltag?</li>
          <li><strong>Windows:</strong> Hilfe bei Windows 10, Windows 11 und Windows Server – Edition-Wahl, Upgrade-Pfade und Aktivierung.</li>
          <li><strong>Microsoft Tools:</strong> Project, Visio, SQL Server – wann sich welche Lizenz lohnt.</li>
          <li><strong>Lizenz-Aktivierung:</strong> Schritt-für-Schritt-Hilfe bei Produktschlüssel-Eingabe, Aktivierungsfehlern und Migration.</li>
          <li><strong>Outlook & E-Mail:</strong> Einrichtung von Outlook, IMAP/POP3-Konten und Microsoft-Konto-Verknüpfung.</li>
          <li><strong>Nach dem Kauf:</strong> Download-Links, Installation und Erst-Konfiguration auf Ihrem Gerät.</li>
        </ul>
      </section>

      <!-- 2. So funktioniert es -->
      <section class="legal-section" id="ablauf">
        <h2 class="legal-section-title">So funktioniert die Beratung</h2>
        <p>Drei einfache Schritte – keine Wartezeit in einer Hotline, kein Verkaufsdruck:</p>
        <div class="kb-steps">
          <div class="kb-step">
            <div class="kb-step-num">1</div>
            <h3 class="kb-step-title">Formular ausfüllen</h3>
            <p class="kb-step-text">Telefonnummer eingeben und Thema auswählen. Optional: Wunschzeit für den Rückruf.</p>
          </div>
          <div class="kb-step">
            <div class="kb-step-num">2</div>
            <h3 class="kb-step-title">Wir rufen zurück</h3>
            <p class="kb-step-text">Werktags innerhalb von 30 Minuten. Direkt von einem Microsoft-Spezialisten – kein Callcenter.</p>
          </div>
          <div class="kb-step">
            <div class="kb-step-num">3</div>
            <h3 class="kb-step-title">Lösung erhalten</h3>
            <p class="kb-step-text">Konkrete Empfehlung oder Schritt-für-Schritt-Hilfe – kostenlos und unverbindlich.</p>
          </div>
        </div>
      </section>

      <!-- 3. Rückruf-Formular -->
      <section class="legal-section" id="rueckruf">
        <h2 class="legal-section-title">Rückruf anfordern</h2>
        <p>Tragen Sie Ihre Telefonnummer ein – alle weiteren Felder sind optional und helfen uns, gezielter zu beraten.</p>

        <form id="kbCallbackForm" class="kb-form-grid" method="post" autocomplete="on" novalidate>
          <div class="kb-field">
            <label for="kb-name">Vorname (optional)</label>
            <input id="kb-name" type="text" name="name" placeholder="z. B. Maria" autocomplete="given-name">
          </div>
          <div class="kb-field">
            <label for="kb-phone">Telefonnummer *</label>
            <input id="kb-phone" type="tel" name="phone" placeholder="+49 170 1234567" required inputmode="tel" autocomplete="tel" pattern="[+0-9 ][0-9 ]{6,}" title="Bitte gültige Telefonnummer eingeben.">
          </div>
          <div class="kb-field">
            <label for="kb-orderNumber">Bestellnummer (optional)</label>
            <input id="kb-orderNumber" type="text" name="orderNumber" placeholder="Falls vorhanden" autocomplete="off">
          </div>
          <div class="kb-field">
            <label for="kb-topic">Thema</label>
            <select id="kb-topic" name="topic">
              <option value="">Bitte auswählen</option>
              <option>Microsoft Office (2021 / 2024 / 365)</option>
              <option>Windows (10 / 11 / Server)</option>
              <option>Microsoft Tools (Project / Visio / SQL)</option>
              <option>Lizenz-Aktivierung & Installation</option>
              <option>Sonstiges</option>
            </select>
          </div>
          <div class="kb-field">
            <label for="kb-preferredTime">Wunschzeit (optional)</label>
            <select id="kb-preferredTime" name="preferredTime">
              <option value="">Bitte auswählen</option>
              <option>Sofort</option>
              <option>Heute</option>
              <option>Morgen</option>
              <option>Zeitfenster wählen</option>
            </select>
          </div>
          <div class="kb-field kb-hidden" id="kbCustomTimeWrap">
            <label for="kb-customTime">Eigenes Wunschzeitfenster</label>
            <input id="kb-customTime" type="text" name="customTime" placeholder="z. B. Mo–Fr 10–14 Uhr">
          </div>
          <div class="kb-field kb-field--full">
            <label for="kb-message">Kurzbeschreibung (optional)</label>
            <textarea id="kb-message" name="message" placeholder="Worum geht es bei Ihrer Anfrage?"></textarea>
          </div>
          <input type="text" name="_honeypot" class="kb-hidden" aria-hidden="true" tabindex="-1">
          <div class="kb-field--full">
            <label class="kb-checkbox">
              <input type="checkbox" name="whatsapp">
              Kontakt auch per WhatsApp möglich
            </label>
          </div>
          <div class="kb-field--full">
            <label class="kb-checkbox">
              <input type="checkbox" name="consent" required>
              Ich stimme zu, dass KARINEX mich telefonisch kontaktiert. Weitere Infos in der <a href="{{ _root }}policies/privacy-policy" target="_blank" rel="noopener">Datenschutzerklärung</a>.
            </label>
          </div>
          <div class="kb-field--full">
            <button type="submit" class="kb-submit">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Kostenlosen Rückruf anfordern
            </button>
          </div>
          <p class="kb-form-error kb-field--full" id="kbFormError" role="alert" aria-live="polite"></p>
          <p class="kb-form-success kb-field--full" id="kbFormSuccess" role="status" aria-live="polite">Vielen Dank! Wir rufen Sie in Kürze zurück.</p>
          <p class="kb-form-meta kb-field--full">Antwortzeit werktags i.d.R. innerhalb von 30 Minuten · Servicezeiten: Mo–Fr 10:00–18:00 Uhr</p>
        </form>
      </section>

      <!-- 4. Quick-Links zu unserem Microsoft-Sortiment -->
      <section class="legal-section" id="sortiment">
        <h2 class="legal-section-title">Unser Microsoft-Sortiment</h2>
        <p>Falls Sie sich vorab einen Überblick verschaffen möchten – hier sind unsere meistgefragten Bereiche:</p>

        <div class="legal-references">
          <a href="{{ _root }}collections/microsoft-office" class="legal-reference-box">
            <span class="reference-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18M9 21V9"/>
              </svg>
            </span>
            <span class="reference-content">
              <span class="reference-title">Microsoft Office</span>
              <span class="reference-desc">Office 2021, 2024 und Microsoft 365</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>

          <a href="{{ _root }}collections/windows" class="legal-reference-box">
            <span class="reference-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5l8-1v8H3V5zm0 9h8v8l-8-1v-7zm9-10l9-1v9h-9V4zm0 10h9v9l-9-1v-8z"/>
              </svg>
            </span>
            <span class="reference-content">
              <span class="reference-title">Windows</span>
              <span class="reference-desc">Windows 10, 11 und Windows Server</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>

          <a href="{{ _root }}collections/microsoft-tools" class="legal-reference-box">
            <span class="reference-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            </span>
            <span class="reference-content">
              <span class="reference-title">Microsoft Tools</span>
              <span class="reference-desc">Project, Visio und Spezial-Lizenzen</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>

          <a href="{{ _root }}pages/faq" class="legal-reference-box">
            <span class="reference-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </span>
            <span class="reference-content">
              <span class="reference-title">FAQ &amp; Anleitungen</span>
              <span class="reference-desc">Antworten auf häufige Fragen</span>
            </span>
            <span class="reference-arrow">→</span>
          </a>
        </div>
      </section>

    </article>

    <!-- TRUST SECTION -->
    <section class="legal-trust">
      <div class="trust-grid">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>100 % kostenlos</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Microsoft-Spezialisten</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Antwort &lt; 30 Min</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Datenschutz garantiert</span>
        </div>
      </div>
    </section>

    <!-- CONTACT BLOCK -->
    <section class="legal-contact">
      <div class="contact-content">
        <h2 class="contact-title">Lieber direkt schreiben oder anrufen?</h2>
        <p class="contact-text">Erreichen Sie uns auf dem Kanal, der Ihnen am liebsten ist.</p>
        <div class="contact-actions">
          <a href="tel:+4915563133956" class="contact-btn contact-btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            01556 / 3133956
          </a>
          <a href="mailto:shop@karinex.de" class="contact-btn contact-btn-secondary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            shop@karinex.de
          </a>
        </div>
      </div>
    </section>

  </div>
</div>

<script>
(function () {
  var form = document.getElementById('kbCallbackForm');
  if (!form) return;
  var preferredTime = document.getElementById('kb-preferredTime');
  var customTimeWrap = document.getElementById('kbCustomTimeWrap');
  var customTimeInput = document.getElementById('kb-customTime');
  var formError = document.getElementById('kbFormError');
  var formSuccess = document.getElementById('kbFormSuccess');

  preferredTime.addEventListener('change', function () {
    if (preferredTime.value === 'Zeitfenster wählen') {
      customTimeWrap.classList.remove('kb-hidden');
      customTimeInput.required = true;
    } else {
      customTimeWrap.classList.add('kb-hidden');
      customTimeInput.required = false;
      customTimeInput.value = '';
    }
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    formError.textContent = '';
    formSuccess.style.display = 'none';

    var phoneRaw = form.phone.value.trim();
    var phone = phoneRaw.replace(/\s+/g, '');
    if (!phone.match(/^\+?\d{7,}$/)) {
      formError.textContent = 'Bitte gültige Telefonnummer eingeben.';
      return;
    }
    if (form.consent && !form.consent.checked) {
      formError.textContent = 'Bitte stimmen Sie der Kontaktaufnahme zu.';
      return;
    }
    if (form._honeypot.value) return;

    // TODO: AJAX-Request an Backend/Shopify/Google Sheet
    form.reset();
    customTimeWrap.classList.add('kb-hidden');
    customTimeInput.required = false;
    formSuccess.style.display = 'block';
  });
})();
</script>

