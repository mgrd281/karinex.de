<!-- Minimal, clean, enterprise-style German returns portal (Step 1) for Shopify, as in the screenshot -->
<div style="max-width:400px;margin:48px auto;padding:32px 24px;background:#fff;border-radius:16px;box-shadow:0 2px 16px #0001;text-align:center;font-family:sans-serif;">
  <svg style="width:56px;height:56px;margin-bottom:18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 1 1 0 8h-1"/></svg>
  <p style="font-size:1.08rem;color:#222;margin-bottom:24px;">Du kannst deine Artikel in wenigen einfachen Schritten zurücksenden. Bitte beachte, dass für einige Rückgabeoptionen möglicherweise ein Drucker erforderlich ist.</p>
  <form id="returnsForm" style="display:flex;flex-direction:column;gap:18px;text-align:left;">
    <label for="kx-retour-orderId" style="font-weight:600;font-size:1rem;">Bestellnummer/-ID</label>
    <input type="text" id="kx-retour-orderId" name="orderId" placeholder="" aria-label="Bestellnummer oder Bestell-ID" style="font-size:1rem;padding:14px 12px;border-radius:8px;border:1px solid #e0e0e0;outline:none;">
    <div style="font-size:0.95rem;color:#888;margin-top:-12px;margin-bottom:8px;">e.g. #DE123456</div>
    <label for="kx-retour-plz" style="font-weight:600;font-size:1rem;">PLZ</label>
    <input type="text" id="kx-retour-plz" name="plz" placeholder="" aria-label="Postleitzahl" style="font-size:1rem;padding:14px 12px;border-radius:8px;border:1px solid #e0e0e0;outline:none;">
    <div style="display:flex;justify-content:space-between;font-size:0.97rem;margin:8px 0 0 0;">
      <a href="#" style="color:#222;text-decoration:underline;" aria-label="Rücksendung per E-Mail beginnen">Mit einer E-Mail beginnen</a>
      <a href="#" style="color:#222;text-decoration:underline;" aria-label="Geschenk-Rücksendung starten">Sie haben ein Geschenk erhalten? <span style="font-weight:600;">Hier beginnen</span></a>
    </div>
    <button type="submit" disabled style="margin-top:18px;background:#eee;color:#888;font-size:1.1rem;font-weight:700;padding:16px 0;border:none;border-radius:8px;cursor:not-allowed;min-height:48px;">Rücksendung beginnen</button>
  </form>
  <div style="margin-top:24px;font-size:0.97rem;color:#666;line-height:1.5;">
    Indem Sie fortfahren, bestätigen Sie, dass Sie Gelegenheit hatten, die <a href="#" style="color:#222;text-decoration:underline;" aria-label="Datenschutzerklärung lesen">Datenschutzerklärung</a> zu lesen.
  </div>
</div>
