{%- comment -%}
  Trust logo row — grayscale at 60%, full opacity on hover.
  Logos uploaded as section blocks so the merchant can rearrange/replace
  in the theme editor without touching code.
{%- endcomment -%}

<section class="product-software product-software--trust" aria-labelledby="product-software-trust-title">
  <div class="product-software__trust-wrap">
    <h2 id="product-software-trust-title" class="product-software__trust-title">{{ section.settings.heading }}</h2>
    <ul class="product-software__trust-logos" role="list">
      {%- for block in section.blocks -%}
        <li class="product-software__trust-logo-cell" {{ block.shopify_attributes }}>
          {%- if block.settings.logo != blank -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" rel="noopener" aria-label="{{ block.settings.label | default: 'Partner' | escape }}">
                <img
                  src="{{ block.settings.logo | image_url: width: 240 }}"
                  srcset="{{ block.settings.logo | image_url: width: 120 }} 120w, {{ block.settings.logo | image_url: width: 240 }} 240w"
                  sizes="120px"
                  alt="{{ block.settings.label | default: block.settings.logo.alt | escape }}"
                  loading="lazy"
                  decoding="async"
                  width="120"
                  height="40">
              </a>
            {%- else -%}
              <img
                src="{{ block.settings.logo | image_url: width: 240 }}"
                srcset="{{ block.settings.logo | image_url: width: 120 }} 120w, {{ block.settings.logo | image_url: width: 240 }} 240w"
                sizes="120px"
                alt="{{ block.settings.label | default: block.settings.logo.alt | escape }}"
                loading="lazy"
                decoding="async"
                width="120"
                height="40">
            {%- endif -%}
          {%- else -%}
            <span class="product-software__trust-logo-placeholder">{{ block.settings.label }}</span>
          {%- endif -%}
        </li>
      {%- else -%}
        <li class="product-software__trust-logo-cell"><span class="product-software__trust-logo-placeholder">Microsoft Partner</span></li>
        <li class="product-software__trust-logo-cell"><span class="product-software__trust-logo-placeholder">Trusted Shops</span></li>
        <li class="product-software__trust-logo-cell"><span class="product-software__trust-logo-placeholder">idealo</span></li>
        <li class="product-software__trust-logo-cell"><span class="product-software__trust-logo-placeholder">Klarna</span></li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Software · Trust Logos",
  "tag": "section",
  "class": "section-product-software-trust",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Vertrauen, das wir uns verdient haben"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo (PNG/SVG, einfarbig empfohlen)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (Alt-Text)",
          "default": "Partner"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Software · Trust Logos",
      "category": "Product",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
