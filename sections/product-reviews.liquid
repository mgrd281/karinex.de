<!-- ====================================================
     PRODUCT REVIEWS (Bewertungen) – Karinex card design
     ==================================================== -->
<section class="kx-reviews-section" aria-labelledby="kx-reviews-title">
  <article class="kx-reviews-card">
    <header class="kx-reviews-card__head">
      <h2 id="kx-reviews-title" class="kx-reviews-card__title">{{ 'karinex.reviews.heading' | t }}</h2>
      <span class="kx-reviews-card__rule" aria-hidden="true"></span>
    </header>
    <div class="kx-reviews-card__body">
      <div id="rechnung-profi-reviews-widget" data-product-id="{{ product.id }}">
        {%- comment -%}
          Instant skeleton placeholder. The reviews widget's script replaces
          the innerHTML on load, so this auto-clears once real reviews arrive.
          Keeps the area visually alive (no 3–4s blank gap → better LCP feel).
        {%- endcomment -%}
        <div class="kx-rev-skel" aria-hidden="true">
          <div class="kx-rev-skel__head">
            <div class="kx-rev-skel__big"></div>
            <div class="kx-rev-skel__pill"></div>
          </div>
          {%- for i in (1..3) -%}
            <div class="kx-rev-skel__card">
              <div class="kx-rev-skel__row">
                <div class="kx-rev-skel__avatar"></div>
                <div class="kx-rev-skel__col">
                  <div class="kx-rev-skel__bar kx-rev-skel__bar--name"></div>
                  <div class="kx-rev-skel__bar kx-rev-skel__bar--date"></div>
                </div>
              </div>
              <div class="kx-rev-skel__bar kx-rev-skel__bar--stars"></div>
              <div class="kx-rev-skel__bar kx-rev-skel__bar--text"></div>
              <div class="kx-rev-skel__bar kx-rev-skel__bar--text"></div>
              <div class="kx-rev-skel__bar kx-rev-skel__bar--text-short"></div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </article>
</section>

<style>
  /* ══════════════════════════════════════════════════════
     SKELETON PLACEHOLDER (shown until reviews widget loads)
     ══════════════════════════════════════════════════════ */
  .kx-rev-skel { display: flex; flex-direction: column; gap: 16px; }
  .kx-rev-skel__head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-bottom: 8px;
  }
  .kx-rev-skel__big { width: 38%; max-width: 220px; height: 44px; border-radius: 999px; }
  .kx-rev-skel__pill { width: 28%; max-width: 160px; height: 32px; border-radius: 999px; }
  .kx-rev-skel__card {
    background: #faf7f0; border: 1px solid #ece9df; border-radius: 12px;
    padding: 18px 18px 20px;
  }
  .kx-rev-skel__row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .kx-rev-skel__avatar { width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0; }
  .kx-rev-skel__col { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 0; }
  .kx-rev-skel__bar { height: 11px; border-radius: 6px; }
  .kx-rev-skel__bar--name { width: 32%; }
  .kx-rev-skel__bar--date { width: 22%; height: 9px; }
  .kx-rev-skel__bar--stars { width: 110px; height: 14px; margin: 4px 0 12px; }
  .kx-rev-skel__bar--text { width: 100%; margin-bottom: 7px; }
  .kx-rev-skel__bar--text-short { width: 58%; }
  .kx-rev-skel__bar,
  .kx-rev-skel__avatar,
  .kx-rev-skel__big,
  .kx-rev-skel__pill {
    background: linear-gradient(90deg, #ececec 0%, #f6f6f4 50%, #ececec 100%);
    background-size: 200% 100%;
    animation: kxRevShimmer 1.4s ease-in-out infinite;
  }
  @keyframes kxRevShimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .kx-rev-skel__bar, .kx-rev-skel__avatar,
    .kx-rev-skel__big, .kx-rev-skel__pill { animation: none; }
  }

  /* ══════════════════════════════════════════════════════
     REVIEWS SECTION – Karinex card design
     ══════════════════════════════════════════════════════ */
  .kx-reviews-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 8px 16px 48px;
  }
  .kx-reviews-card {
    background: #ffffff;
    border: 1px solid #ece9df;
    border-radius: 20px;
    padding: 32px 32px 28px;
    box-shadow:
      0 1px 2px rgba(13, 46, 34, 0.04),
      0 12px 32px rgba(13, 46, 34, 0.05);
    position: relative;
  }
  .kx-reviews-card__head {
    margin-bottom: 24px;
  }
  .kx-reviews-card__title {
    font-family: var(--font-heading-family, 'Newsreader', serif);
    font-size: 28px;
    font-weight: 500;
    color: #0d2e22;
    letter-spacing: -0.4px;
    line-height: 1.15;
    margin: 0;
  }
  .kx-reviews-card__rule {
    display: block;
    width: 44px;
    height: 2px;
    margin-top: 14px;
    background: #c9a84c;
    border-radius: 2px;
  }
  .kx-reviews-card__body {
    min-height: 120px;
  }

  /* ── Override widget's default "no reviews" state ── */
  .rp-widget {
    font-family: inherit !important;
  }

  /* ── Mobile: tighter padding ── */
  @media (max-width: 600px) {
    .kx-reviews-section {
      padding: 4px 12px 32px;
    }
    .kx-reviews-card {
      padding: 22px 18px 22px;
      border-radius: 16px;
    }
    .kx-reviews-card__head {
      margin-bottom: 18px;
    }
    .kx-reviews-card__title {
      font-size: 22px;
    }
    .kx-reviews-card__rule {
      width: 36px;
      margin-top: 10px;
    }
  }

  /* ══════════════════════════════════════════════════════
     REVIEW MODAL – Ultra Premium Redesign
     ══════════════════════════════════════════════════════ */

  /* ── Backdrop: frosted glass ── */
  .rp-modal-overlay {
    background: rgba(0, 0, 0, 0.3) !important;
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
    animation: kxOverlayIn 0.25s ease both !important;
  }
  @keyframes kxOverlayIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── Modal container ── */
  .rp-modal {
    background: #fff !important;
    border-radius: 20px !important;
    padding: 28px 32px 24px !important;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.10), 0 1px 4px rgba(0, 0, 0, 0.04) !important;
    border: none !important;
    max-width: 560px !important;
    max-height: 90vh !important;
    overflow-y: auto !important;
    animation: kxModalIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
  }
  @keyframes kxModalIn {
    from { opacity: 0; transform: scale(0.96) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ── Header ── */
  .rp-modal-header {
    margin-bottom: 8px !important;
    padding-bottom: 0 !important;
    border: none !important;
  }
  .rp-modal-title {
    font-size: 20px !important;
    font-weight: 600 !important;
    color: #1a1a1a !important;
    letter-spacing: -0.4px !important;
    line-height: 1.2 !important;
  }
  /* Subtitle injected via JS below the title */
  .rp-modal-subtitle {
    font-size: 13px;
    color: #999;
    font-weight: 400;
    margin: 2px 0 14px;
    line-height: 1.4;
  }

  /* ── Close button ── */
  .rp-close-btn {
    width: 32px !important;
    height: 32px !important;
    border-radius: 50% !important;
    background: transparent !important;
    border: none !important;
    color: #bbb !important;
    font-size: 20px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important;
    cursor: pointer !important;
    transition: color 0.2s ease, background 0.2s ease !important;
    line-height: 1 !important;
  }
  .rp-close-btn:hover {
    color: #666 !important;
    background: #f5f5f5 !important;
  }

  /* ── Star rating: hero element ── */
  .rp-star-input {
    gap: 5px !important;
    padding: 2px 0 2px !important;
  }
  .rp-star-input label {
    font-size: 28px !important;
    color: #e0e0e0 !important;
    transition: color 0.15s ease, transform 0.15s cubic-bezier(0.16, 1, 0.3, 1) !important;
    line-height: 1 !important;
  }
  .rp-star-input label:hover {
    transform: scale(1.15) !important;
  }
  .rp-star-input label:hover,
  .rp-star-input label:hover ~ label,
  .rp-star-input input:checked ~ label {
    color: #c9a84c !important;
  }

  /* ── Form groups: breathing space ── */
  .rp-form-group {
    margin-bottom: 14px !important;
  }

  /* ── Labels ── */
  .rp-label {
    font-size: 13px !important;
    font-weight: 500 !important;
    color: #777 !important;
    margin-bottom: 7px !important;
    letter-spacing: 0.01em !important;
  }

  /* ── Text inputs ── */
  .rp-input,
  .rp-textarea {
    border: 1.5px solid #eaeaea !important;
    border-radius: 12px !important;
    padding: 10px 14px !important;
    font-size: 14px !important;
    color: #1a1a1a !important;
    background: #fff !important;
    outline: none !important;
    box-shadow: none !important;
    transition: border-color 0.25s ease, box-shadow 0.25s ease !important;
    font-family: inherit !important;
    -webkit-appearance: none !important;
  }
  .rp-input:focus,
  .rp-textarea:focus {
    border-color: #1D4739 !important;
    box-shadow: 0 0 0 3px rgba(29, 71, 57, 0.06) !important;
  }
  .rp-input::placeholder,
  .rp-textarea::placeholder {
    color: #c5c5c5 !important;
    font-weight: 400 !important;
  }

  /* ── Textarea: larger, comfortable ── */
  .rp-textarea {
    min-height: 80px !important;
    resize: vertical !important;
    line-height: 1.5 !important;
  }

  /* ── File upload ── */
  .rp-form-group input[type="file"].rp-input,
  .rp-modal input[type="file"] {
    border: 1.5px dashed #ddd !important;
    border-radius: 12px !important;
    padding: 10px 14px !important;
    background: #fafafa !important;
    font-size: 13px !important;
    color: #999 !important;
    cursor: pointer !important;
    transition: border-color 0.2s ease, background 0.2s ease !important;
  }
  .rp-form-group input[type="file"].rp-input:hover,
  .rp-modal input[type="file"]:hover {
    border-color: #1D4739 !important;
    background: #f7faf9 !important;
  }
  .rp-form-group small {
    font-size: 11px !important;
    color: #c5c5c5 !important;
    display: none !important;
  }

  /* ── Submit CTA ── */
  .rp-submit-btn {
    height: 44px !important;
    background: #1D4739 !important;
    color: #fff !important;
    border: none !important;
    border-radius: 12px !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    cursor: pointer !important;
    letter-spacing: 0.01em !important;
    margin-top: 8px !important;
    padding: 0 !important;
    transition: background 0.25s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease !important;
    font-family: inherit !important;
  }
  .rp-submit-btn:hover:not(:disabled) {
    background: #16362b !important;
    transform: translateY(-1px) scale(1.01) !important;
    box-shadow: 0 8px 24px rgba(29, 71, 57, 0.16) !important;
  }
  .rp-submit-btn:active:not(:disabled) {
    transform: scale(0.98) !important;
    box-shadow: none !important;
  }
  .rp-submit-btn:disabled {
    opacity: 0.6 !important;
    background: #1D4739 !important;
  }

  /* ── Write Review trigger button (in widget header) ── */
  .rp-write-btn {
    background: #1D4739 !important;
    border-radius: 999px !important;
    padding: 11px 26px !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease !important;
  }
  .rp-write-btn:hover {
    opacity: 1 !important;
    background: #16362b !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 4px 14px rgba(29, 71, 57, 0.15) !important;
  }

  /* ── Success state after submit ── */
  .rp-modal [style*="color: #16a34a"] {
    color: #1D4739 !important;
  }
</style>

<script>
(function() {
  /* Remove file restrictions from modal when it opens */
  var enhanced = false;
  function enhanceModal() {
    if (enhanced) return;
    var fileInputs = document.querySelectorAll('.rp-modal input[type="file"]');
    if (fileInputs.length) {
      fileInputs.forEach(function(fi) {
        fi.removeAttribute('accept');
        fi.removeAttribute('max');
        fi.removeAttribute('maxlength');
      });
      enhanced = true;
    }
  }
  /* Check periodically when modal might be open */
  document.addEventListener('click', function() {
    setTimeout(enhanceModal, 300);
  });
})();
</script>

<script>
/* Strip the pill-style "Verifizierter Kauf" badge to an elegant inline
   label, regardless of the class names the reviews widget uses. We
   locate it by its visible text and clear the pill background, padding
   and radius on the styled ancestor. */
(function () {
  var WIDGET = document.getElementById('rechnung-profi-reviews-widget');
  if (!WIDGET) return;

  var LABELS = [
    {{ 'karinex.reviews_widget.verified_purchase' | t | json }},
    'Verifizierter Kauf',
    'Verifizierter Käufer',
    'Verified Purchase',
    'Verified purchase',
    'Zakup zweryfikowany',
    'Verifierat köp'
  ];

  function strip(el) {
    if (!el || el.dataset.kxCleaned) return;
    el.dataset.kxCleaned = '1';
    el.style.setProperty('background', 'transparent', 'important');
    el.style.setProperty('background-color', 'transparent', 'important');
    el.style.setProperty('border', '0', 'important');
    el.style.setProperty('border-radius', '0', 'important');
    el.style.setProperty('box-shadow', 'none', 'important');
    el.style.setProperty('padding', '0', 'important');
    el.style.setProperty('color', '#1D4739', 'important');
    el.style.setProperty('font-weight', '600', 'important');
    el.style.setProperty('font-size', '13px', 'important');
    el.style.setProperty('display', 'inline-flex', 'important');
    el.style.setProperty('align-items', 'center', 'important');
    el.style.setProperty('gap', '5px', 'important');
  }

  function clean() {
    var all = WIDGET.querySelectorAll('*');
    for (var i = 0; i < all.length; i++) {
      var el = all[i];
      if (el.dataset.kxCleaned) continue;
      var txt = (el.textContent || '').replace(/\s+/g, ' ').trim();
      if (!txt) continue;
      var hit = false;
      for (var j = 0; j < LABELS.length; j++) {
        var lbl = LABELS[j];
        if (!lbl) continue;
        if (txt === lbl) { hit = true; break; }
        if (txt.length - lbl.length < 6 && txt.indexOf(lbl) !== -1) { hit = true; break; }
      }
      if (!hit) continue;
      var styled = el;
      var depth = 0;
      while (styled && styled !== WIDGET && depth < 6) {
        var cs = window.getComputedStyle(styled);
        var bg = cs.backgroundColor || '';
        var hasBg = bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent';
        var rad = parseFloat(cs.borderRadius) || 0;
        if (hasBg || rad > 4) { strip(styled); break; }
        styled = styled.parentElement;
        depth++;
      }
      strip(el);
    }
  }

  clean();
  try {
    new MutationObserver(function () { clean(); })
      .observe(WIDGET, { childList: true, subtree: true });
  } catch (e) {}
})();
</script>

{% schema %}
{
  "name": "Bewertungen",
  "settings": []
}
{% endschema %}
