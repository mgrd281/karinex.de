      <p class="kr-section-sub">Je höher dein Level, desto exklusiver deine Vorteile.</p>
    </div>
    <div class="kr-container">
      <div class="kr-tiers__grid">

        <div class="kr-tiers__card{% if customer and kx_tier == 'bronze' %} kr-tiers__card--active{% endif %}">
          {%- if customer and kx_tier == 'bronze' -%}<span class="kr-tiers__badge kr-tiers__badge--status">Dein Status</span>{%- endif -%}
