          </ul>
        </div>

        <div class="kr-tiers__card kr-tiers__card--gold{% if customer and kx_tier == 'gold' %} kr-tiers__card--active{% endif %}">
          <span class="kr-tiers__badge kr-tiers__badge--gold">{%- if customer and kx_tier == 'gold' -%}Dein Status{%- else -%}Exklusiv{%- endif -%}</span>
          <div class="kr-tiers__icon kr-tiers__icon--gold">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3>Gold</h3>
          <p class="kr-tiers__req">Ab 20.000 Punkte</p>
          <ul class="kr-tiers__perks">
            <li>10% Cashback in Punkten</li>
            <li>VIP-Support (Priorität)</li>
            <li>Exklusive Produkte</li>
            <li>Immer kostenloser Versand</li>
            <li>3x Geburtstagspunkte</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  {%- comment -%} ═══ 7. REFERRAL ═══ {%- endcomment -%}
  <section class="kr-referral" id="kr-referral">
    <div class="kr-container">
      <div class="kr-referral__box">
        <div class="kr-referral__content">
          <span class="kr-section-label">Empfehlen & profitieren</span>
          <h2>Freunde einladen, gemeinsam profitieren</h2>
          <p>Teile deinen persönlichen Link. Dein Freund erhält <strong>10% Rabatt</strong> auf die erste Bestellung — du bekommst <strong>500 Punkte</strong> (= €5).</p>
          {%- if customer -%}
            <div class="kr-referral__link-row">
              <input type="text" id="kr-ref-link" value="https://www.karinex.de/?ref={{ customer.id }}" readonly class="kr-referral__input">
              <button type="button" class="kr-btn kr-btn--gold kr-btn--sm" onclick="navigator.clipboard.writeText(document.getElementById('kr-ref-link').value);this.textContent='Kopiert ✓';setTimeout(()=>{this.textContent='Link kopieren'},2000)">Link kopieren</button>
            </div>
            <div class="kr-referral__share">
