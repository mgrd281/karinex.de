          {%- else -%}
            <a href="/account/login" class="kx-ly-btn kx-ly-btn--redeem kx-ly-btn--ghost-sm">Einloggen</a>
          {%- endif -%}
        </div>
        <div class="kx-ly-redeem__card" data-redeem-pts="2000" data-redeem-euro="25">
