  .kx-ly-aff-stats__card{background:#fff;border:1.5px solid #e8e8e8;border-radius:14px;padding:22px 18px;text-align:center;box-shadow:0 2px 10px rgba(0,0,0,.04);transition:transform .2s,box-shadow .2s}
