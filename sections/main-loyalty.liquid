    <div class="kr-dash__card">
      <div class="kr-dash__header">
        <h2 class="kr-dash__greeting">Hallo, {{ customer.first_name | default: customer.email | split: '@' | first }}.</h2>
        <span class="kr-dash__tier kr-dash__tier--{{ kx_tier }}">{{ kx_tier_label }}-Mitglied</span>
      </div>
      <div class="kr-dash__stats">
        <div class="kr-dash__stat">
          <span class="kr-dash__stat-num">{{ kx_pts }}</span>
          <span class="kr-dash__stat-label">Punkte</span>
        </div>
        <div class="kr-dash__stat">
          <span class="kr-dash__stat-num">{{ kx_tier_label }}</span>
          <span class="kr-dash__stat-label">Status</span>
        </div>
        <div class="kr-dash__stat">
          <span class="kr-dash__stat-num">{{ kx_cashback }}%</span>
          <span class="kr-dash__stat-label">Cashback</span>
        </div>
      </div>
      <div class="kr-dash__progress">
        <div class="kr-dash__bar">
          <div class="kr-dash__fill" style="width: {{ kx_progress }}%"></div>
        </div>
        {%- if kx_next_tier != '' -%}
          <p class="kr-dash__progress-text">Noch <strong>{{ kx_pts_to_next }}</strong> Punkte bis {{ kx_next_tier }}</p>
        {%- else -%}
