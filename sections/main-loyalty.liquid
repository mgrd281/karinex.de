{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless

  if customer
    assign kx_pts = customer.metafields.karinex.loyalty_points.value | default: 0 | plus: 0
    assign kx_tier_raw = customer.metafields.karinex.loyalty_tier.value | default: 'bronze'

    if kx_pts >= 20000
      assign kx_tier = 'gold'
      assign kx_tier_label = 'Gold'
      assign kx_cashback = 10
      assign kx_progress = 100
      assign kx_next_tier = ''
      assign kx_pts_to_next = 0
    elsif kx_pts >= 8000
      assign kx_tier = 'silber'
      assign kx_tier_label = 'Silber'
      assign kx_cashback = 7
      assign kx_pts_in = kx_pts | minus: 8000
      assign kx_progress = kx_pts_in | times: 100 | divided_by: 12000
      assign kx_next_tier = 'Gold'
      assign kx_pts_to_next = 20000 | minus: kx_pts
    else
      assign kx_tier = 'bronze'
      assign kx_tier_label = 'Bronze'
      assign kx_cashback = 5
      assign kx_progress = kx_pts | times: 100 | divided_by: 8000
      assign kx_next_tier = 'Silber'
      assign kx_pts_to_next = 8000 | minus: kx_pts
    endif
  endif
-%}
{% comment %} ═══════════════════════════════════════════════════════
  KARINEX LOYALTY & REFERRAL PROGRAM – Enterprise Grade
  Like: About You, Douglas, Zalando
═══════════════════════════════════════════════════════ {% endcomment %}

<link rel="stylesheet" href="{{ 'main-loyalty.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'main-loyalty.css' | asset_url }}"></noscript>

<div class="kx-loyalty" id="kx-loyalty">

