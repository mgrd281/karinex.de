  .kx-ly-aff-page-row__url{flex:1;color:#666;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace;font-size:.8rem}
  .kx-ly-aff-page-row__count{font-weight:700;color:#c9a84c;min-width:50px;text-align:right}
  .kx-ly-aff-page-row__bar{flex:0 0 100px;height:6px;background:#f0f0f0;border-radius:3px;overflow:hidden}
  .kx-ly-aff-page-row__fill{height:100%;background:linear-gradient(90deg,#c9a84c,#e6c770);border-radius:3px}
  /* ── Referral Table ── */
