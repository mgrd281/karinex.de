{%- comment -%} ═══ COUNTER ANIMATION + REDEEM + AFFILIATE DASHBOARD ═══ {%- endcomment -%}
<script>
(function(){
  /* ─── Counter Animation ─── */
  var counted = false;
  function animateCounters(){
    if(counted) return;
    var els = document.querySelectorAll('[data-count]');
    if(!els.length) return;
    var rect = els[0].getBoundingClientRect();
    if(rect.top > window.innerHeight) return;
    counted = true;
    els.forEach(function(el){
      var target = parseInt(el.dataset.count, 10);
      var duration = 2000;
      var startTime = null;
      function step(ts){
        if(!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        var current = Math.floor(eased * target);
        el.textContent = current.toLocaleString('de-DE');
        if(progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    });
  }
  window.addEventListener('scroll', animateCounters, {passive: true});
  animateCounters();

  /* ─── Redeem Logic ─── */
  var GAS_URL = 'https://script.google.com/macros/s/AKfycbz0KQ6sRNj7ZPV8ivb53EPM3kK9Ms5RcUDzaiXkz_Vq8W8DZXaFwBM7oo84U2IY37Wd/exec';
  var redeemBtns = document.querySelectorAll('[data-redeem]');
  var overlay = document.getElementById('kr-redeem-overlay');
  var codeEl = document.getElementById('kr-redeem-code');
  var infoEl = document.getElementById('kr-redeem-info');
  var copyBtn = document.getElementById('kr-redeem-copy');
  var closeBtn = document.getElementById('kr-redeem-close');
  var balanceEl = document.getElementById('kr-redeem-balance');

  redeemBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      if(btn.disabled) return;
      var pts = parseInt(btn.dataset.redeem);
      var card = btn.closest('.kr-redeem__card');
      var euro = card ? card.dataset.redeemEuro : '';
      btn.disabled = true;
      btn.textContent = 'Wird erstellt…';
      btn.classList.add('kr-btn--loading');

      var email = '{{ customer.email | default: "" }}';
      if(!email){ btn.textContent = 'Bitte einloggen'; return; }

      var url = GAS_URL + '?action=redeem_points&email=' + encodeURIComponent(email) + '&points=' + pts;
      fetch(url)
        .then(function(r){ return r.json(); })
        .then(function(d){
          btn.classList.remove('kr-btn--loading');
          if(d.ok){
            codeEl.textContent = d.code;
            infoEl.textContent = '€' + d.discount_euro + ' Rabatt — Restguthaben: ' + d.points_remaining.toLocaleString('de-DE') + ' Punkte';
            overlay.style.display = 'flex';
            if(balanceEl) balanceEl.textContent = d.points_remaining.toLocaleString('de-DE');
            redeemBtns.forEach(function(b){
              var reqPts = parseInt(b.dataset.redeem);
              if(d.points_remaining < reqPts){
                b.disabled = true;
                b.textContent = 'Noch ' + (reqPts - d.points_remaining).toLocaleString('de-DE') + ' Punkte';
                b.classList.add('kr-btn--disabled');
              } else {
                b.disabled = false;
                b.textContent = 'Jetzt einlösen';
                b.classList.remove('kr-btn--disabled');
              }
            });
          } else {
            var msg = d.error === 'insufficient_points' ? 'Nicht genug Punkte' :
                      d.error === 'too_fast' ? 'Bitte kurz warten…' : 'Fehler: ' + d.error;
            btn.textContent = msg;
            setTimeout(function(){ btn.textContent = 'Jetzt einlösen'; btn.disabled = false; }, 3000);
          }
        })
        .catch(function(){
          btn.classList.remove('kr-btn--loading');
          btn.textContent = 'Fehler — erneut versuchen';
          btn.disabled = false;
        });
    });
  });

  if(copyBtn) copyBtn.addEventListener('click', function(){
    navigator.clipboard.writeText(codeEl.textContent);
    copyBtn.textContent = 'Kopiert ✓';
    setTimeout(function(){ copyBtn.textContent = 'Code kopieren'; }, 2000);
  });
  if(closeBtn) closeBtn.addEventListener('click', function(){ overlay.style.display = 'none'; });
  if(overlay) overlay.addEventListener('click', function(e){ if(e.target === overlay) overlay.style.display = 'none'; });

  /* ═══ AFFILIATE DASHBOARD ═══ */
  var affSection = document.getElementById('kr-aff-stats');
  if(affSection){
    var CID = '{{ customer.id | default: "" }}';
    var AFF_EMAIL = '{{ customer.email | default: "" }}';
    var affLoadEl = document.getElementById('kr-aff-loading');
    var affChartData = [];
    var affChartDays = 30;

    var affCopy = document.getElementById('kr-aff-dash-copy');
    var affInput = document.getElementById('kr-aff-dash-link');
    if(affCopy && affInput){
      affCopy.addEventListener('click', function(){
        navigator.clipboard.writeText(affInput.value).then(function(){
          affCopy.textContent = 'Kopiert ✓';
          setTimeout(function(){ affCopy.textContent = 'Kopieren'; }, 2200);
        });
      });
    }

    fetch(GAS_URL + '?action=affiliate_dashboard&customer_id=' + CID + '&email=' + encodeURIComponent(AFF_EMAIL))
      .then(function(r){ return r.json(); })
      .then(function(d){
        if(affLoadEl) affLoadEl.style.display = 'none';
        if(!d.ok) return;
        affTxt('kr-aff-clicks', affFmt(d.clicks ? d.clicks.total : 0));
        affTxt('kr-aff-clicks-today', 'heute: ' + affFmt(d.clicks ? d.clicks.today : 0) + '  ·  7T: ' + affFmt(d.clicks ? d.clicks.days7 : 0));
        affTxt('kr-aff-referrals', affFmt(d.total_referrals || 0));
        affTxt('kr-aff-conversion', 'Conversion: ' + (d.conversion_rate || 0) + '%');
        affTxt('kr-aff-purchases', affFmt(d.total_purchases || 0));
        affTxt('kr-aff-earnings', affFmt(d.total_earned || 0));
        affTxt('kr-aff-pending', 'ausstehend: ' + affFmt(d.pending_points || 0));
        affChartData = d.clicks ? d.clicks.daily || [] : [];
        affRenderChart(30);
        affRenderPages(d.clicks ? d.clicks.top_pages || [] : []);
        affRenderTable(d.referrals || []);
      })
      .catch(function(){
        if(affLoadEl) affLoadEl.innerHTML = '<span style="color:#ff3b30">Fehler beim Laden</span>';
      });

    function affRenderChart(days){
      var emptyEl = document.getElementById('kr-aff-chart-empty');
      var canvas = document.getElementById('kr-aff-canvas');
      if(!affChartData.length || !canvas){ if(emptyEl) emptyEl.style.display='flex'; return; }
      if(emptyEl) emptyEl.style.display='none';
      canvas.style.display='block';
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio||1;
      var rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width*dpr; canvas.height = 180*dpr;
      canvas.style.width = rect.width+'px'; canvas.style.height = '180px';
      ctx.scale(dpr,dpr);
      var W=rect.width, H=180, pad={top:16,right:8,bottom:26,left:36};
      var cW=W-pad.left-pad.right, cH=H-pad.top-pad.bottom;
      var data = affChartData.slice(-days);
      if(!data.length) return;
      var max = Math.max.apply(null, data.map(function(d){return d.clicks||0}));
      if(max===0) max=1;
      var barW = Math.max(2,(cW/data.length)-2);
      ctx.clearRect(0,0,W,H);
      ctx.strokeStyle='#f0f0f0'; ctx.lineWidth=1;
      for(var g=0;g<=4;g++){var gy=pad.top+(cH/4)*g; ctx.beginPath(); ctx.moveTo(pad.left,gy); ctx.lineTo(W-pad.right,gy); ctx.stroke();}
      for(var j=0;j<data.length;j++){
        var bH=(data[j].clicks/max)*cH;
        var bx=pad.left+(cW/data.length)*j+1;
        var by=pad.top+cH-bH;
        var grad=ctx.createLinearGradient(0,by,0,by+bH);
        grad.addColorStop(0,'#D4AF37'); grad.addColorStop(1,'#E8D48B');
        ctx.fillStyle=grad;
        ctx.beginPath(); ctx.roundRect(bx,by,barW,bH,[3,3,0,0]); ctx.fill();
        if(j%Math.ceil(data.length/6)===0||j===data.length-1){
          ctx.fillStyle='#aaa'; ctx.font='10px system-ui'; ctx.textAlign='center';
          ctx.fillText(data[j].date?data[j].date.slice(5):'',bx+barW/2,H-6);
        }
      }
      ctx.fillStyle='#aaa'; ctx.font='10px system-ui'; ctx.textAlign='right';
      for(var k=0;k<=4;k++){ ctx.fillText(Math.round(max-(max/4)*k),pad.left-5,pad.top+(cH/4)*k+4); }
    }

    document.querySelectorAll('.kr-aff-chip[data-aff-days]').forEach(function(el){
      el.addEventListener('click', function(){
        document.querySelectorAll('.kr-aff-chip[data-aff-days]').forEach(function(c){c.classList.remove('kr-aff-chip--active');});
        el.classList.add('kr-aff-chip--active');
        affRenderChart(parseInt(el.dataset.affDays,10));
      });
    });

    function affRenderPages(pages){
      var panel = document.getElementById('kr-aff-pages-panel');
      var container = document.getElementById('kr-aff-pages');
      if(!pages.length || !panel || !container) return;
      panel.style.display = 'block';
      var maxC = pages[0].clicks || 1;
      var html = '';
      for(var i=0; i<pages.length && i<8; i++){
        var pct = Math.round((pages[i].clicks/maxC)*100);
        var label = pages[i].page || '/';
        if(label.indexOf('/products/') === 0) label = label.replace('/products/','📦 ');
        html += '<div class="kr-aff-page-row">'
          + '<span class="kr-aff-page-row__url">' + affEsc(label) + '</span>'
          + '<div class="kr-aff-page-row__bar"><div class="kr-aff-page-row__fill" style="width:'+pct+'%"></div></div>'
          + '<span class="kr-aff-page-row__count">' + pages[i].clicks + '</span>'
          + '</div>';
      }
      container.innerHTML = html;
    }

    function affRenderTable(refs){
      var emptyEl = document.getElementById('kr-aff-table-empty');
      var tbl = document.getElementById('kr-aff-table');
      var tbody = document.getElementById('kr-aff-tbody');
      if(!refs.length){ if(emptyEl) emptyEl.style.display='block'; return; }
      if(emptyEl) emptyEl.style.display='none';
      if(tbl) tbl.style.display='table';
      var html='';
      for(var i=0;i<refs.length;i++){
        var r=refs[i];
        var sc=r.purchased?'purchased':'pending';
        var st=r.purchased?'✓ Gekauft':'⏳ Ausstehend';
        var dt=r.date?r.date.slice(0,10):'–';
        html+='<tr><td>'+affEsc(r.email_masked||'–')+'</td><td><code style="background:var(--kr-gray-50);padding:2px 7px;border-radius:4px;font-size:.78rem">'+affEsc(r.code||'–')+'</code></td><td>'+dt+'</td><td><span class="kr-aff-status kr-aff-status--'+sc+'">'+st+'</span></td><td><strong>'+(r.points_earned||0)+'</strong></td></tr>';
      }
      if(tbody) tbody.innerHTML=html;
    }

    function affTxt(id,val){var el=document.getElementById(id);if(el)el.textContent=val;}
    function affFmt(n){return n>=1000?(n/1000).toFixed(1).replace(/\.0$/,'')+'k':String(n);}
    function affEsc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML;}
  }
})();
</script>

