          {%- if customer -%}
            <button type="button" class="kx-ly-btn kx-ly-btn--redeem{% if kx_pts < 200 %} kx-ly-btn--disabled{% endif %}" data-redeem="200" {% if kx_pts < 200 %}disabled{% endif %}>
              {%- if kx_pts >= 200 -%}Jetzt einlösen{%- else -%}Noch {{ 200 | minus: kx_pts }} Punkte{%- endif -%}
            </button>
          {%- else -%}
            <a href="/account/login" class="kx-ly-btn kx-ly-btn--redeem kx-ly-btn--ghost-sm">Einloggen</a>
