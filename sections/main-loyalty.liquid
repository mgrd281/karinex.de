{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless

  if customer
    assign kx_pts = customer.metafields.karinex.loyalty_points.value | default: 0 | plus: 0
    assign kx_tier_raw = customer.metafields.karinex.loyalty_tier.value | default: 'bronze'

    if kx_pts >= 20000
      assign kx_tier = 'gold'
      assign kx_tier_label = 'Gold'
      assign kx_cashback = 10
      assign kx_progress = 100
      assign kx_next_tier = ''
      assign kx_pts_to_next = 0
    elsif kx_pts >= 8000
      assign kx_tier = 'silber'
      assign kx_tier_label = 'Silber'
      assign kx_cashback = 7
      assign kx_pts_in = kx_pts | minus: 8000
      assign kx_progress = kx_pts_in | times: 100 | divided_by: 12000
      assign kx_next_tier = 'Gold'
      assign kx_pts_to_next = 20000 | minus: kx_pts
    else
      assign kx_tier = 'bronze'
      assign kx_tier_label = 'Bronze'
      assign kx_cashback = 5
      assign kx_progress = kx_pts | times: 100 | divided_by: 8000
      assign kx_next_tier = 'Silber'
      assign kx_pts_to_next = 8000 | minus: kx_pts
    endif
  endif
-%}
{% comment %} ═══════════════════════════════════════════════════════
  KARINEX REWARDS — Premium Luxury Design
  Apple · Stripe · Nike inspired
═══════════════════════════════════════════════════════ {% endcomment %}

<link rel="stylesheet" href="{{ 'kr-rewards.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'kr-rewards.css' | asset_url }}"></noscript>

<div class="kr" id="kr-rewards">

  {%- comment -%} ═══ 1. HERO ═══ {%- endcomment -%}
  <section class="kr-hero">
    <div class="kr-hero__glow"></div>
    <div class="kr-hero__noise"></div>
    <div class="kr-hero__inner">
      <div class="kr-hero__badge">
        <span class="kr-hero__badge-dot"></span>
        Rewards Programm
      </div>
      <h1 class="kr-hero__title">Sammle. Spare. Profitiere.</h1>
      <p class="kr-hero__sub">Bei jedem Einkauf Punkte verdienen, exklusive Rabatte einlösen und von VIP-Vorteilen profitieren.</p>
      <div class="kr-hero__ctas">
        {%- if customer -%}
          <a href="#kr-redeem" class="kr-btn kr-btn--gold kr-btn--lg">Punkte einlösen</a>
          <a href="#kr-affiliate" class="kr-btn kr-btn--ghost">Partner-Dashboard</a>
        {%- else -%}
          <a href="/account/register" class="kr-btn kr-btn--gold kr-btn--lg">Kostenlos beitreten</a>
          <a href="/account/login" class="kr-btn kr-btn--ghost">Einloggen</a>
        {%- endif -%}
      </div>
      <div class="kr-hero__metrics">
        <div class="kr-hero__metric">
          <span class="kr-hero__metric-num" data-count="12850">0</span>
          <span class="kr-hero__metric-label">Mitglieder</span>
        </div>
        <div class="kr-hero__metric">
          <span class="kr-hero__metric-num" data-count="285000">0</span>
          <span class="kr-hero__metric-label">Punkte eingelöst</span>
        </div>
        <div class="kr-hero__metric">
          <span class="kr-hero__metric-num" data-count="48500">0</span>
          <span class="kr-hero__metric-label">€ gespart</span>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ═══ 2. USER DASHBOARD (logged-in) ═══ {%- endcomment -%}
  {%- if customer -%}
