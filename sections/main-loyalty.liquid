{%- comment -%} ── Affiliate Dashboard (integrated) styles ── {%- endcomment -%}
<style>
  /* ── Affiliate Link Box ── */
  .kx-ly-aff-link{background:#fff;border:1.5px solid #e8e8e8;border-radius:14px;padding:24px;margin-bottom:28px;box-shadow:0 2px 12px rgba(0,0,0,.04)}
