            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3>Bronze</h3>
          <p class="kr-tiers__req">Ab 0 Punkte</p>
          <ul class="kr-tiers__perks">
            <li>5% Cashback in Punkten</li>
            <li>Geburtstagsbonus</li>
            <li>Newsletter-Angebote</li>
          </ul>
        </div>

        <div class="kr-tiers__card{% if customer and kx_tier == 'silber' %} kr-tiers__card--active{% endif %}">
          {%- if customer and kx_tier == 'silber' -%}<span class="kr-tiers__badge kr-tiers__badge--status">Dein Status</span>{%- endif -%}
          <div class="kr-tiers__icon kr-tiers__icon--silver">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3>Silber</h3>
          <p class="kr-tiers__req">Ab 8.000 Punkte</p>
