  .kx-ly-aff-table td{padding:13px 14px;border-bottom:1px solid #f5f5f5}
  .kx-ly-aff-table tr:last-child td{border-bottom:none}
  .kx-ly-aff-table tr:hover td{background:#fafafa}
  .kx-ly-aff-status{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:.76rem;font-weight:600}
  .kx-ly-aff-status--purchased{background:rgba(34,197,94,.1);color:#16a34a}
  .kx-ly-aff-status--pending{background:rgba(201,168,76,.12);color:#b8943f}
