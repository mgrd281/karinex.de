  .kx-ly-aff-stats__icon--referrals{background:rgba(26,26,26,.08);color:#1a1a1a}
  .kx-ly-aff-stats__icon--purchases{background:rgba(34,197,94,.1);color:#22c55e}
  .kx-ly-aff-stats__icon--earnings{background:rgba(201,168,76,.12);color:#c9a84c}
  .kx-ly-aff-stats__val{font-size:1.8rem;font-weight:800;line-height:1.1;margin-bottom:3px;color:#1a1a1a}
  .kx-ly-aff-stats__label{font-size:.82rem;color:#888;font-weight:500}
  .kx-ly-aff-stats__sub{font-size:.72rem;color:#aaa;margin-top:5px}
