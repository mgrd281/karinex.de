    <div class="kr-container kr-section-center">
      <span class="kr-section-label">Punkte verdienen</span>
      <h2 class="kr-section-title">Viele Wege, ein Ziel</h2>
      <p class="kr-section-sub">Je aktiver du bist, desto größer dein Vorteil.</p>
    </div>
    <div class="kr-container">
      <div class="kr-earn__grid">

        <div class="kr-earn__card kr-earn__card--featured">
          <span class="kr-earn__tag">Automatisch</span>
          <div class="kr-earn__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          </div>
          <div class="kr-earn__pts">5%</div>
          <h3>Cashback auf jeden Einkauf</h3>
          <p>5% des Bestellwerts zurück als Punkte — bei jeder Bestellung.</p>
        </div>

        <div class="kr-earn__card">
          <div class="kr-earn__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="kr-earn__pts">500</div>
          <h3>Freunde werben</h3>
          <p>Dein Freund bekommt 10% Rabatt, du 500 Punkte.</p>
        </div>

        <div class="kr-earn__card">
          <div class="kr-earn__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
          </div>
          <div class="kr-earn__pts">100</div>
          <h3>Newsletter</h3>
          <p>Sofort 100 Punkte bei Newsletter-Anmeldung.</p>
        </div>

        <div class="kr-earn__card">
          <div class="kr-earn__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <div class="kr-earn__pts">75</div>
          <h3>Produkt bewerten</h3>
          <p>Schreibe eine ehrliche Bewertung und erhalte 75 Punkte.</p>
        </div>

        <div class="kr-earn__card">
          <div class="kr-earn__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="kr-earn__pts">200</div>
          <h3>Geburtstagsbonus</h3>
          <p>200 Punkte geschenkt an deinem Geburtstag.</p>
        </div>

        <div class="kr-earn__card">
          <div class="kr-earn__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <div class="kr-earn__pts">50</div>
          <h3>Social Media</h3>
          <p>Folge uns auf Instagram oder TikTok — je 50 Punkte.</p>
        </div>

      </div>
    </div>
  </section>

  {%- comment -%} ═══ 5. REDEEM REWARDS ═══ {%- endcomment -%}
  <section class="kr-redeem" id="kr-redeem">
    <div class="kr-container kr-section-center">
      <span class="kr-section-label">Einlösen</span>
      <h2 class="kr-section-title">Punkte in Rabatte umwandeln</h2>
      <p class="kr-section-sub">Wähle deinen gewünschten Betrag und erhalte sofort einen Gutscheincode.</p>

      {%- if customer -%}
        <div class="kr-redeem__balance">
          <span class="kr-redeem__balance-label">Dein Guthaben</span>
          <span class="kr-redeem__balance-pts" id="kr-redeem-balance">{{ kx_pts }}</span>
        </div>
      {%- endif -%}
    </div>
    <div class="kr-container">
      <div class="kr-redeem__grid">

        <div class="kr-redeem__card" data-redeem-pts="200" data-redeem-euro="2">
          <div class="kr-redeem__value">€2</div>
          <div class="kr-redeem__pts">200 Punkte</div>
          <div class="kr-redeem__bar"><div class="kr-redeem__fill" style="width:{% if customer %}{% if kx_pts >= 200 %}100{% else %}{{ kx_pts | times: 100 | divided_by: 200 }}{% endif %}{% else %}20{% endif %}%"></div></div>
          {%- if customer -%}
            <button type="button" class="kr-btn kr-btn--dark kr-btn--sm{% if kx_pts < 200 %} kr-btn--disabled{% endif %}" data-redeem="200" {% if kx_pts < 200 %}disabled{% endif %}>
              {%- if kx_pts >= 200 -%}Jetzt einlösen{%- else -%}Noch {{ 200 | minus: kx_pts }} Punkte{%- endif -%}
            </button>
          {%- else -%}
            <a href="/account/login" class="kr-btn kr-btn--outline kr-btn--sm">Einloggen</a>
          {%- endif -%}
        </div>

        <div class="kr-redeem__card" data-redeem-pts="500" data-redeem-euro="5">
          <div class="kr-redeem__value">€5</div>
          <div class="kr-redeem__pts">500 Punkte</div>
          <div class="kr-redeem__bar"><div class="kr-redeem__fill" style="width:{% if customer %}{% if kx_pts >= 500 %}100{% else %}{{ kx_pts | times: 100 | divided_by: 500 }}{% endif %}{% else %}50{% endif %}%"></div></div>
          {%- if customer -%}
            <button type="button" class="kr-btn kr-btn--dark kr-btn--sm{% if kx_pts < 500 %} kr-btn--disabled{% endif %}" data-redeem="500" {% if kx_pts < 500 %}disabled{% endif %}>
              {%- if kx_pts >= 500 -%}Jetzt einlösen{%- else -%}Noch {{ 500 | minus: kx_pts }} Punkte{%- endif -%}
            </button>
          {%- else -%}
            <a href="/account/login" class="kr-btn kr-btn--outline kr-btn--sm">Einloggen</a>
          {%- endif -%}
        </div>

        <div class="kr-redeem__card kr-redeem__card--popular" data-redeem-pts="1000" data-redeem-euro="10">
          <span class="kr-redeem__badge">Beliebt</span>
          <div class="kr-redeem__value">€10</div>
          <div class="kr-redeem__pts">1.000 Punkte</div>
          <div class="kr-redeem__bar"><div class="kr-redeem__fill" style="width:{% if customer %}{% if kx_pts >= 1000 %}100{% else %}{{ kx_pts | times: 100 | divided_by: 1000 }}{% endif %}{% else %}70{% endif %}%"></div></div>
          {%- if customer -%}
            <button type="button" class="kr-btn kr-btn--dark kr-btn--sm{% if kx_pts < 1000 %} kr-btn--disabled{% endif %}" data-redeem="1000" {% if kx_pts < 1000 %}disabled{% endif %}>
              {%- if kx_pts >= 1000 -%}Jetzt einlösen{%- else -%}Noch {{ 1000 | minus: kx_pts }} Punkte{%- endif -%}
            </button>
          {%- else -%}
            <a href="/account/login" class="kr-btn kr-btn--outline kr-btn--sm">Einloggen</a>
          {%- endif -%}
        </div>

        <div class="kr-redeem__card" data-redeem-pts="2000" data-redeem-euro="25">
          <div class="kr-redeem__value">€25</div>
          <div class="kr-redeem__pts">2.000 Punkte</div>
          <div class="kr-redeem__bar"><div class="kr-redeem__fill" style="width:{% if customer %}{% if kx_pts >= 2000 %}100{% else %}{{ kx_pts | times: 100 | divided_by: 2000 }}{% endif %}{% else %}100{% endif %}%"></div></div>
          {%- if customer -%}
            <button type="button" class="kr-btn kr-btn--dark kr-btn--sm{% if kx_pts < 2000 %} kr-btn--disabled{% endif %}" data-redeem="2000" {% if kx_pts < 2000 %}disabled{% endif %}>
              {%- if kx_pts >= 2000 -%}Jetzt einlösen{%- else -%}Noch {{ 2000 | minus: kx_pts }} Punkte{%- endif -%}
            </button>
          {%- else -%}
            <a href="/account/login" class="kr-btn kr-btn--outline kr-btn--sm">Einloggen</a>
          {%- endif -%}
        </div>

      </div>

      {%- comment -%} Redeem modal overlay {%- endcomment -%}
      <div class="kr-redeem__overlay" id="kr-redeem-overlay" style="display:none">
        <div class="kr-redeem__modal">
          <div class="kr-redeem__modal-icon">✓</div>
          <h3 class="kr-redeem__modal-title">Gutschein erfolgreich erstellt</h3>
          <p class="kr-redeem__modal-sub">Dein persönlicher Rabattcode:</p>
          <div class="kr-redeem__modal-code" id="kr-redeem-code"></div>
          <p class="kr-redeem__modal-info" id="kr-redeem-info"></p>
          <div class="kr-redeem__modal-actions">
            <button type="button" class="kr-btn kr-btn--gold" id="kr-redeem-copy">Code kopieren</button>
            <button type="button" class="kr-btn kr-btn--outline" id="kr-redeem-close">Schließen</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ═══ 6. VIP TIERS ═══ {%- endcomment -%}
