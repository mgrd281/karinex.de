{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
{% schema %}
{
  "name": "Order Tracking",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestellstatus verfolgen"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Gib deine Bestellnummer und E-Mail-Adresse ein, um den Status deiner Bestellung zu sehen."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Bestellung anzeigen"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F9FAFB"
    }
  ],
  "presets": [
    {
      "name": "Order Tracking"
    }
  ]
}
{% endschema %}

<div class="order-tracking-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="tracking-container">
    <div class="tracking-header">
      <h1 class="tracking-title">{{ section.settings.heading }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="tracking-subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="tracking-card">
      <form id="OrderTrackingForm" class="tracking-form">
        
        <!-- Input Fields -->
        <div class="form-grid">
          
          <!-- Order Number -->
          <div class="form-field">
            <label for="order-number">Bestellnummer <span aria-hidden="true">*</span></label>
            <div class="input-wrapper">
              <input 
                type="text" 
                id="order-number" 
                name="order_number" 
                placeholder="z.B. #1001"
                required
                autocomplete="off"
              >
              <div class="field-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Email Address -->
          <div class="form-field">
            <label for="order-email">E-Mail-Adresse <span aria-hidden="true">*</span></label>
            <div class="input-wrapper">
              <input 
                type="email" 
                id="order-email" 
                name="email" 
                placeholder="name@beispiel.de"
                required
                autocomplete="email"
              >
              <div class="field-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
            </div>
          </div>

        </div>

        <!-- Submit Button -->
        <div class="form-actions">
          <button type="submit" class="tracking-submit-btn">
            <span class="btn-text">{{ section.settings.button_label }}</span>
            <span class="btn-loader" style="display:none;">
              <svg class="spinner" viewBox="0 0 50 50">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
              </svg>
              Wird geladen...
            </span>
          </button>
        </div>

      </form>

      <!-- Results Container (Hidden by default) -->
      <div id="tracking-results" class="tracking-results" style="display:none;">
        <!-- Results will be injected here by JavaScript -->
      </div>

      <!-- Error Message Container (Hidden by default) -->
      <div id="tracking-error" class="tracking-message error" style="display:none;">
        <div class="message-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
        <div class="message-content">
          <strong>Bestellung nicht gefunden</strong>
          <p>Bitte überprüfe deine Angaben und versuche es erneut.</p>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  const form = document.getElementById('OrderTrackingForm');
  const resultsContainer = document.getElementById('tracking-results');
  const errorContainer = document.getElementById('tracking-error');

  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    const btn = this.querySelector('.tracking-submit-btn');
    const btnText = btn.querySelector('.btn-text');
    const btnLoader = btn.querySelector('.btn-loader');
    let orderNumber = document.getElementById('order-number').value.trim();
    const email = document.getElementById('order-email').value.trim();

    // Hide previous results/errors
    resultsContainer.style.display = 'none';
    errorContainer.style.display = 'none';

    // Show loading state
    btn.disabled = true;
    btn.style.opacity = '0.8';
    btnText.style.display = 'none';
    btnLoader.style.display = 'flex';

    // Clean order number (remove # if present)
    orderNumber = orderNumber.replace(/^#/, '');

    // Show helpful message since Shopify doesn't provide a direct guest order lookup
    setTimeout(function() {
      // Reset button
      btn.disabled = false;
      btn.style.opacity = '1';
      btnText.style.display = 'inline';
      btnLoader.style.display = 'none';

      // Show info message
      showInfoMessage(orderNumber, email);
    }, 800);
  });

  function showInfoMessage(orderNumber, email) {
    resultsContainer.innerHTML = `
      <div class="order-info-header">
        <div class="info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
          </svg>
        </div>
        <h3>So findest du deine Bestellung</h3>
      </div>

      <div class="order-info-content">
        <p class="info-main-text">
          Um den Status deiner Bestellung <strong>#${escapeHtml(orderNumber)}</strong> zu sehen, 
          überprüfe bitte die E-Mail-Bestätigung, die an <strong>${escapeHtml(email)}</strong> gesendet wurde.
        </p>

        <div class="info-steps">
          <div class="info-step">
            <div class="step-number">1</div>
            <div class="step-content">
              <strong>Öffne deine E-Mail</strong>
              <p>Suche nach der Bestellbestätigung von {{ shop.name }}</p>
            </div>
          </div>

          <div class="info-step">
            <div class="step-number">2</div>
            <div class="step-content">
              <strong>Klicke auf "Bestellung ansehen"</strong>
              <p>Du findest dort den aktuellen Status und alle Details</p>
            </div>
          </div>

          <div class="info-step">
            <div class="step-number">3</div>
            <div class="step-content">
              <strong>Tracking-Informationen</strong>
              <p>Sobald deine Bestellung versandt wurde, findest du dort auch die Tracking-Nummer</p>
            </div>
          </div>
        </div>

        <div class="info-help">
          <p><strong>E-Mail nicht gefunden?</strong></p>
          <p>Überprüfe deinen Spam-Ordner oder <a href="{{ _root }}pages/contact">kontaktiere uns</a> für Hilfe.</p>
        </div>
      </div>
    `;

    resultsContainer.style.display = 'block';
    resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function showError() {
    errorContainer.style.display = 'flex';
    errorContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
})();
</script>

<style>
/* Scoped Variables */
.order-tracking-section {
  padding: 80px 20px;
  min-height: 80vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  --primary-color: #111;
  --accent-color: #3b82f6;
  --success-color: #2e7d32;
  --error-color: #d32f2f;
  --text-main: #1f2937;
  --text-light: #6b7280;
  --input-bg: #fff;
  --input-border: #e5e7eb;
  --radius: 12px;
}

.tracking-container {
  width: 100%;
  max-width: 600px;
}

/* Header */
.tracking-header {
  text-align: center;
  margin-bottom: 40px;
}

.tracking-title {
  font-size: 36px;
  font-weight: 700;
  color: var(--primary-color);
  margin: 0 0 12px 0;
  letter-spacing: -0.5px;
}

.tracking-subtitle {
  font-size: 16px;
  color: var(--text-light);
  margin: 0;
  line-height: 1.5;
}

/* Card */
.tracking-card {
  background: #ffffff;
  border-radius: var(--radius);
  box-shadow: 0 20px 40px -10px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.03);
  padding: 40px;
}

/* Form Grid */
.form-grid {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.form-field {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* Labels */
.form-field label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-main);
  margin-left: 2px;
}

.form-field label span {
  color: var(--error-color);
}

/* Input Wrapper */
.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-wrapper input {
  width: 100%;
  padding: 14px 16px 14px 44px;
  font-size: 15px;
  color: var(--text-main);
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: 8px;
  transition: all 0.2s ease;
  font-family: inherit;
}

.input-wrapper input:focus {
  outline: none;
  border-color: var(--accent-color);
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
}

.input-wrapper input::placeholder {
  color: #9ca3af;
}

/* Field Icons */
.field-icon {
  position: absolute;
  left: 14px;
  width: 20px;
  height: 20px;
  color: var(--text-light);
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-wrapper input:focus + .field-icon {
  color: var(--accent-color);
}

/* Submit Button */
.form-actions {
  margin-top: 32px;
}

.tracking-submit-btn {
  width: 100%;
  background: var(--primary-color);
  color: #ffffff;
  border: none;
  font-size: 16px;
  font-weight: 600;
  padding: 16px;
  border-radius: 8px;
  cursor: pointer;
  transition: transform 0.15s ease, opacity 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
}

.tracking-submit-btn:hover {
  background: #000;
  transform: translateY(-1px);
  box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
}

.tracking-submit-btn:active {
  transform: translateY(0);
}

.tracking-submit-btn:disabled {
  cursor: not-allowed;
}

/* Loader */
.btn-loader {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  animation: rotate 2s linear infinite;
  width: 18px;
  height: 18px;
  margin-right: 8px;
}

.spinner .path {
  stroke: #fff;
  stroke-linecap: round;
  animation: dash 1.5s ease-in-out infinite;
}

@keyframes rotate {
  100% { transform: rotate(360deg); }
}

@keyframes dash {
  0% { stroke-dasharray: 1, 150; stroke-dashoffset: 0; }
  50% { stroke-dasharray: 90, 150; stroke-dashoffset: -35; }
  100% { stroke-dasharray: 90, 150; stroke-dashoffset: -124; }
}

/* Results Container */
.tracking-results {
  margin-top: 32px;
  padding-top: 32px;
  border-top: 1px solid var(--input-border);
  animation: fadeIn 0.4s ease;
}

.order-success-header {
  text-align: center;
  margin-bottom: 24px;
}

.success-icon {
  width: 60px;
  height: 60px;
  background: var(--success-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
  box-shadow: 0 8px 16px rgba(46,125,50,0.2);
}

.success-icon svg {
  width: 30px;
  height: 30px;
  color: white;
}

.order-success-header h3 {
  font-size: 24px;
  font-weight: 700;
  color: var(--primary-color);
  margin: 0;
}

/* Order Details */
.order-details {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.order-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f3f4f6;
}

.order-detail:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-light);
}

.detail-value {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-main);
  text-align: right;
}

/* Order Status Badge */
.order-status {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 100px;
  font-size: 13px;
  font-weight: 600;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-processing {
  background: #dbeafe;
  color: #1e40af;
}

.status-shipped {
  background: #d1fae5;
  color: #065f46;
}

.status-delivered {
  background: #d1fae5;
  color: #065f46;
}

.status-cancelled {
  background: #fee2e2;
  color: #991b1b;
}

/* Tracking Link */
.tracking-link {
  color: var(--accent-color);
  text-decoration: none;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  transition: color 0.2s;
}

.tracking-link:hover {
  color: #2563eb;
  text-decoration: underline;
}

/* Error Message */
.tracking-message {
  margin-top: 24px;
  padding: 16px;
  border-radius: 8px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  animation: fadeIn 0.3s ease;
}

.tracking-message.error {
  background-color: #fef2f2;
  border: 1px solid #fecaca;
  color: #991b1b;
}

.message-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.message-content {
  font-size: 14px;
  line-height: 1.4;
}

.message-content strong {
  display: block;
  margin-bottom: 4px;
  font-weight: 600;
}

.message-content p {
  margin: 0;
}

/* Animations */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Info Message Styles */
.order-info-header {
  text-align: center;
  margin-bottom: 24px;
}

.info-icon {
  width: 60px;
  height: 60px;
  background: #3b82f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
  box-shadow: 0 8px 16px rgba(59,130,246,0.2);
}

.info-icon svg {
  width: 30px;
  height: 30px;
  color: white;
}

.order-info-header h3 {
  font-size: 24px;
  font-weight: 700;
  color: var(--primary-color);
  margin: 0;
}

.order-info-content {
  text-align: left;
}

.info-main-text {
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-main);
  margin: 0 0 24px 0;
}

.info-steps {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 24px;
}

.info-step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  padding: 16px;
  background: #f9fafb;
  border-radius: 8px;
  border-left: 3px solid var(--accent-color);
}

.step-number {
  width: 32px;
  height: 32px;
  background: var(--accent-color);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 16px;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-content strong {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 4px;
}

.step-content p {
  font-size: 14px;
  color: var(--text-light);
  margin: 0;
  line-height: 1.5;
}

.info-help {
  padding: 16px;
  background: #fef3c7;
  border-radius: 8px;
  border-left: 3px solid #f59e0b;
}

.info-help p {
  font-size: 14px;
  margin: 0 0 8px 0;
  line-height: 1.5;
}

.info-help p:last-child {
  margin-bottom: 0;
}

.info-help a {
  color: var(--accent-color);
  text-decoration: none;
  font-weight: 600;
}

.info-help a:hover {
  text-decoration: underline;
}

/* Responsive */
@media (max-width: 640px) {
  .order-tracking-section {
    padding: 40px 16px;
  }

  .tracking-card {
    padding: 24px;
  }

  .tracking-title {
    font-size: 28px;
  }

  .tracking-submit-btn {
    font-size: 15px;
  }

  .order-detail {
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }

  .detail-value {
    text-align: left;
  }

  .info-step {
    flex-direction: column;
    gap: 12px;
  }

  .step-number {
    align-self: flex-start;
  }
}
</style>
