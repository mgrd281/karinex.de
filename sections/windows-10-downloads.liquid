<!-- JAVASCRIPT -->
<script>
  // Selector function - radio behavior
  function kxSelectOption(element) {
    const options = document.querySelectorAll('.kx-option');
    const actionBtn = document.getElementById('kxSelectorAction');
    
    // Remove selected from all
    options.forEach(opt => opt.classList.remove('selected'));
    
    // Add selected to clicked
    element.classList.add('selected');
    
    // Show action button
    if (actionBtn) {
      actionBtn.classList.add('visible');
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    // Thank You Overlay - auto fade out after 3 seconds
    const thankYouOverlay = document.getElementById("kx-thank-you-overlay");
    
    if (thankYouOverlay) {
      setTimeout(() => {
        thankYouOverlay.classList.add("hidden");
        setTimeout(() => {
          thankYouOverlay.style.display = "none";
        }, 1000);
      }, 3000);
    }

    // Video Modal
    const videoModal = document.getElementById("videoModal");
    const openBtn = document.getElementById("openVideoModalBtn");
    const closeBtn = document.getElementById("closeModalBtn");
    const modalVideoContainer = videoModal.querySelector(".kx-modal-content .kx-video-container");

    const videoUrl = "https://www.youtube.com/embed/4gEbLlNwhZQ?autoplay=1&rel=0";

    const openModal = (e) => {
      if (e) e.preventDefault();
      modalVideoContainer.innerHTML = '<iframe src="' + videoUrl + '" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>';
      videoModal.style.display = "flex";
    };

    const closeModal = () => {
      videoModal.style.display = "none";
      modalVideoContainer.innerHTML = "";
    };

    if (openBtn) openBtn.addEventListener("click", openModal);
    if (closeBtn) closeBtn.addEventListener("click", closeModal);

    videoModal.addEventListener("click", function (event) {
      if (event.target === videoModal) closeModal();
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") closeModal();
    });
  });
</script>

