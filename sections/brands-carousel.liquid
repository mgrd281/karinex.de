{%- liquid
  assign gap = section.settings.gap | default: 16
  assign columns = section.settings.columns | default: 4
-%}

<section
  id="brands-carousel-{{ section.id }}"
  class="brands-carousel-section"
  data-image-fit="{{ section.settings.image_fit | default: 'height_fill' }}"
  style="--brands-gap: {{ gap }}px; --brands-columns: {{ columns }};"
>
  <div class="brands-carousel__container">
    <div class="brands-carousel__intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="brands-carousel__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="brands-carousel__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a class="brands-carousel__button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

    <div class="brands-carousel__slider-wrap">
      <div class="brands-carousel__slider">
        <div class="brands-carousel__track">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- liquid
                assign brand_image = block.settings.image
                assign brand_title = block.settings.title
                assign brand_link = block.settings.link
              -%}

              <a
                class="brand-tile"
                href="{{ brand_link | default: '#' }}"
                {% if brand_link != blank %}rel="noopener"{% endif %}
                {{ block.shopify_attributes }}
              >
                <div class="brand-tile__media">
                  {%- if brand_image != blank -%}
                    <img
                      class="brand-tile__img-bg"
                      src="{{ brand_image | image_url: width: 900, format: 'webp' }}"
                      srcset="{{ brand_image | image_url: width: 450, format: 'webp' }} 450w, {{ brand_image | image_url: width: 700, format: 'webp' }} 700w, {{ brand_image | image_url: width: 900, format: 'webp' }} 900w"
                      sizes="(max-width: 749px) 70vw, (max-width: 989px) 40vw, 22vw"
                      alt="{{ brand_title | escape }}"
                      loading="lazy"
                      decoding="async"
                    >
                    <img
                      class="brand-tile__img"
                      src="{{ brand_image | image_url: width: 900, format: 'webp' }}"
                      srcset="{{ brand_image | image_url: width: 450, format: 'webp' }} 450w, {{ brand_image | image_url: width: 700, format: 'webp' }} 700w, {{ brand_image | image_url: width: 900, format: 'webp' }} 900w"
                      sizes="(max-width: 749px) 70vw, (max-width: 989px) 40vw, 22vw"
                      alt="{{ brand_title | escape }}"
                      loading="lazy"
                      decoding="async"
                    >
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'brand-tile__placeholder' }}
                  {%- endif -%}
                  <div class="brand-tile__overlay"></div>
                </div>

                {%- if brand_title != blank -%}
                  <div class="brand-tile__title">{{ brand_title }}</div>
                {%- endif -%}

                <span class="brand-tile__arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 18l6-6-6-6"/>
                  </svg>
                </span>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <a class="brand-tile" href="#" aria-label="Marke entdecken">
                <div class="brand-tile__media">
                  {{ 'collection-1' | placeholder_svg_tag: 'brand-tile__placeholder' }}
                  <div class="brand-tile__overlay"></div>
                </div>
                <div class="brand-tile__title">MARKE</div>
                <span class="brand-tile__arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 18l6-6-6-6"/>
                  </svg>
                </span>
              </a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.show_arrows -%}
        <button class="brands-carousel__arrow brands-carousel__arrow--prev" type="button" aria-label="Zurück" disabled>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="brands-carousel__arrow brands-carousel__arrow--next" type="button" aria-label="Weiter">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .brands-carousel-section {
    --brands-bg: #ffffff;
    --brands-border: rgba(0, 0, 0, 0.06);
    --brands-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
    background: #ffffff;
    padding: 32px 0;
  }

  .brands-carousel__container {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 24px;
    align-items: stretch;
  }

  .brands-carousel__container {
    padding-left: 16px;
    padding-right: 16px;
  }

  .brands-carousel__intro {
    background: #ffffff;
    border: 0;
    border-radius: 0;
    padding: 0;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 260px;
  }

  .brands-carousel__heading {
    margin: 0 0 10px;
    font-size: 1.8rem;
    line-height: 1.1;
    font-weight: 400;
    color: #2a2a2a;
    letter-spacing: 0;
  }

  .brands-carousel__text {
    color: #6a6a6a;
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 18px;
    max-width: 36ch;
  }

  .brands-carousel__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 42px;
    padding: 0 18px;
    border: 1px solid #2a2a2a;
    border-radius: 0;
    text-decoration: none;
    color: #2a2a2a;
    font-weight: 600;
    font-size: 0.9rem;
    width: fit-content;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .brands-carousel__button:hover {
    background: #2a2a2a;
    color: #ffffff;
    box-shadow: none;
    transform: none;
  }

  .brands-carousel__slider-wrap {
    position: relative;
    display: flex;
    align-items: stretch;
    border-radius: 0;
    background: transparent;
    border: 0;
    box-shadow: none;
    padding: 0;
  }

  .brands-carousel__slider {
    overflow: hidden;
    width: 100%;
  }

  .brands-carousel__track {
    display: flex;
    gap: var(--brands-gap);
    transition: transform 0.4s ease;
    will-change: transform;
  }

  .brand-tile {
    position: relative;
    flex: 0 0 calc((100% - (var(--brands-columns) - 1) * var(--brands-gap)) / var(--brands-columns));
    min-width: 210px;
    border-radius: 0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: #f6f6f6;
    border: 0;
    box-shadow: none;
    transform: translateY(0);
    transition: none;
  }

  .brand-tile__media {
    position: relative;
    aspect-ratio: 3 / 4;
    background: #f2f2f2;
  }

  .brand-tile__img-bg,
  .brand-tile__img,
  .brand-tile__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.35s ease;
  }

  .brand-tile__img-bg {
    display: none;
    position: absolute;
    inset: 0;
    filter: blur(16px);
    transform: scale(1.1);
    opacity: 0.55;
  }

  .brand-tile__img {
    position: relative;
    z-index: 1;
  }

  .brands-carousel-section[data-image-fit="contain"] .brand-tile__img {
    object-fit: contain;
  }

  .brands-carousel-section[data-image-fit="contain"] .brand-tile__media {
    background: #ffffff;
  }

  .brands-carousel-section[data-image-fit="contain_blur"] .brand-tile__img {
    object-fit: contain;
  }

  .brands-carousel-section[data-image-fit="contain_blur"] .brand-tile__img-bg {
    display: block;
  }

  .brands-carousel-section[data-image-fit="height_fill"] .brand-tile__img {
    object-fit: cover;
  }

  .brands-carousel-section[data-image-fit="height_fill"] .brand-tile__img-bg {
    display: block;
  }

  .brand-tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.0) 55%, rgba(0,0,0,0.35) 100%);
    pointer-events: none;
  }

  .brand-tile__title {
    position: absolute;
    left: 12px;
    right: 52px;
    bottom: 12px;
    top: auto;
    transform: none;
    padding: 10px 10px;
    border-radius: 0;
    background: rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #ffffff;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.35);
    text-align: left;
    line-height: 1.1;
  }

  .brand-tile__arrow {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    background: rgba(255, 255, 255, 0.9);
    color: #1f1f1f;
    box-shadow: none;
    border: 1px solid rgba(0, 0, 0, 0.12);
  }

  .brand-tile:hover {
    transform: none;
    box-shadow: none;
    border-color: transparent;
  }

  .brands-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(17, 17, 17, 0.10);
    border-radius: 50%;
    cursor: pointer;
    z-index: 4;
    box-shadow: 0 18px 40px rgba(0,0,0,0.14);
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  .brands-carousel__arrow:hover:not(:disabled) {
    transform: translateY(-50%) scale(1.04);
    background: rgba(255, 255, 255, 0.92);
  }

  .brands-carousel__arrow:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .brands-carousel__arrow--prev { left: -16px; }
  .brands-carousel__arrow--next { right: -16px; }

  @media screen and (max-width: 989px) {
    .brands-carousel__container {
      grid-template-columns: 300px 1fr;
    }

    .brand-tile {
      min-width: 190px;
    }
  }

  @media screen and (max-width: 749px) {
    .brands-carousel__container {
      grid-template-columns: 1fr;
    }

    .brands-carousel-section {
      padding: 28px 0;
    }

    .brands-carousel__intro {
      min-height: auto;
      padding: 22px 18px;
    }

    .brands-carousel__heading {
      font-size: 1.55rem;
    }

    .brands-carousel__text {
      font-size: 0.95rem;
      max-width: 42ch;
    }

    .brands-carousel__track {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 6px;
    }

    .brands-carousel__track::-webkit-scrollbar {
      display: none;
    }

    .brand-tile {
      flex: 0 0 70%;
      scroll-snap-align: start;
    }

    .brands-carousel__arrow {
      display: none;
    }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('#brands-carousel-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('.brands-carousel__track');
    const prevBtn = section.querySelector('.brands-carousel__arrow--prev');
    const nextBtn = section.querySelector('.brands-carousel__arrow--next');

    if (!track || !prevBtn || !nextBtn) return;

    const cards = track.querySelectorAll('.brand-tile');
    if (cards.length === 0) return;

    let currentIndex = 0;
    const visibleCards = {{ section.settings.columns | default: 4 }};
    const totalCards = cards.length;
    const maxIndex = Math.max(0, totalCards - visibleCards);

    function updateArrows() {
      prevBtn.disabled = currentIndex <= 0;
      nextBtn.disabled = currentIndex >= maxIndex;
    }

    function scrollToIndex(index) {
      currentIndex = Math.max(0, Math.min(index, maxIndex));
      const card = cards[currentIndex];
      if (card) {
        const gap = {{ section.settings.gap | default: 16 }};
        const offset = currentIndex * (card.offsetWidth + gap);
        track.style.transform = `translateX(-${offset}px)`;
      }
      updateArrows();
    }

    prevBtn.addEventListener('click', () => scrollToIndex(currentIndex - 1));
    nextBtn.addEventListener('click', () => scrollToIndex(currentIndex + 1));

    updateArrows();

    let startX = 0;
    let isDragging = false;

    track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      const endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      if (Math.abs(diff) > 50) {
        if (diff > 0) scrollToIndex(currentIndex + 1);
        else scrollToIndex(currentIndex - 1);
      }
      isDragging = false;
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Brands Carousel",
  "tag": "section",
  "class": "brands-carousel-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Die schönsten Marken"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Marken, die deinen Look komplett machen – lass dich bei Brandfind inspirieren.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "ALLE MARKEN"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Bild-Anpassung (ohne Kartengröße zu ändern)",
      "default": "height_fill",
      "options": [
        {
          "value": "cover",
          "label": "Vollflächig (Cover)"
        },
        {
          "value": "contain",
          "label": "Komplett sichtbar (Contain)"
        },
        {
          "value": "contain_blur",
          "label": "Komplett sichtbar + Hintergrund weich (Pro)"
        },
        {
          "value": "height_fill",
          "label": "Höhe füllen + Hintergrund weich (Pro)"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Kacheln pro Ansicht (Desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Abstand",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Pfeile anzeigen",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marke",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "PANDORA"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Brands Carousel",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
