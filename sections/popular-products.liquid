{%- liquid
  assign products_to_show = section.settings.products_to_show | default: 4
  assign source = section.settings.source | default: 'collection'
  assign heading = section.settings.heading | default: 'Aktuell sehr beliebt'
  assign manual_products = section.settings.products
  assign source_collection = section.settings.collection

  # Decide which product list will actually be rendered, so the
  # heading is only shown when there is something below it.
  assign render_products = manual_products
  if source == 'manual'
    assign render_products = manual_products
  elsif source == 'recommendations'
    if recommendations.performed? and recommendations.products_count > 0
      assign render_products = recommendations.products
    else
      assign render_products = source_collection.products
    endif
  else
    assign render_products = source_collection.products
  endif
  assign has_products = false
  if render_products != blank and render_products.size > 0
    assign has_products = true
  endif
-%}

{%- if has_products -%}
<div class="popular-products" data-section-id="{{ section.id }}">
  {%- if heading != blank -%}
    <h3 class="popular-products__heading">{{ heading }}</h3>
  {%- endif -%}

  <div class="popular-products__list">
    {%- for product in render_products limit: products_to_show -%}
      {% render 'popular-product-card', product: product %}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{%- stylesheet -%}
.popular-products {
  margin-top: 24px;
  padding: 16px 0;
}
.popular-products__heading {
  font-size: 16px;
  font-weight: 600;
  margin: 0 0 16px;
  color: #111;
}
.popular-products__list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.pp-card {
  display: grid;
  grid-template-columns: 80px 1fr auto;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
  border-bottom: 1px solid #eee;
}
.pp-card:last-child { border-bottom: 0; }
.pp-card__img-wrap {
  display: block;
  width: 80px;
  height: 80px;
  border-radius: 8px;
  background: #f5f5f5;
  overflow: hidden;
  flex-shrink: 0;
}
.pp-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.pp-card__body {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
}
.pp-card__title {
  font-size: 14px;
  font-weight: 500;
  color: #111;
  text-decoration: none;
  line-height: 1.3;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.pp-card__title:hover { text-decoration: underline; }
.pp-card__rating {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #666;
}
.pp-card__stars {
  color: #111;
  letter-spacing: 1px;
  font-size: 12px;
}
.pp-card__rating-count {
  font-style: italic;
}
.pp-card__price-row {
  display: flex;
  align-items: baseline;
  gap: 6px;
  font-size: 14px;
}
.pp-card__price {
  font-weight: 600;
  color: #111;
}
.pp-card__price--sale {
  color: #e10600;
}
.pp-card__compare {
  color: #999;
  font-size: 13px;
}
.pp-card__form { margin: 0; }
.pp-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border: 0;
  border-radius: 6px;
  background: #2563eb;
  color: #fff;
  cursor: pointer;
  transition: background 0.15s ease;
  flex-shrink: 0;
}
.pp-card__btn:hover { background: #1d4ed8; }
.pp-card__btn:disabled {
  background: #ccc;
  cursor: not-allowed;
}
.pp-card__btn-x { font-size: 22px; line-height: 1; }
@media (max-width: 480px) {
  .pp-card { grid-template-columns: 64px 1fr auto; gap: 10px; }
  .pp-card__img-wrap { width: 64px; height: 64px; }
  .pp-card__btn { width: 40px; height: 40px; }
}
{%- endstylesheet -%}

{% schema %}
{
  "name": "Popular Products",
  "tag": "section",
  "class": "section-popular-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Aktuell sehr beliebt"
    },
    {
      "type": "select",
      "id": "source",
      "label": "Produktquelle",
      "options": [
        { "value": "collection", "label": "Aus Kollektion" },
        { "value": "manual", "label": "Manuell ausgewählt" },
        { "value": "recommendations", "label": "Shopify Empfehlungen (Fallback: Kollektion)" }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion (für 'Aus Kollektion' und Fallback)"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Manuelle Produktauswahl",
      "limit": 8
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl anzuzeigender Produkte",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Popular Products",
      "category": "Cart"
    }
  ],
  "enabled_on": {
    "templates": ["cart", "page"]
  }
}
{% endschema %}
