{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
{% comment %} ═══════════════════════════════════════════════════════
  KARINEX REFERRAL LANDING PAGE
  URL: /pages/einladung?ref=XXXX
  Flow: Open link → Enter email → Get 10% discount code
═══════════════════════════════════════════════════════ {% endcomment %}

<style>
  .kx-ref { font-family: var(--font-body, -apple-system, BlinkMacSystemFont, sans-serif); color: #1a1a1a; }

  /* ─── HERO ─── */
  .kx-ref-hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #1a1a1a; color: #fff; position: relative; overflow: hidden; padding: 40px 20px; }
  .kx-ref-hero__bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 40%, rgba(201,168,76,.12) 0%, transparent 60%), radial-gradient(ellipse at 70% 80%, rgba(201,168,76,.08) 0%, transparent 50%); }
  .kx-ref-hero__inner { position: relative; text-align: center; max-width: 560px; width: 100%; }
  .kx-ref-hero__badge { display: inline-block; padding: 8px 20px; border-radius: 100px; background: rgba(201,168,76,.15); color: #c9a84c; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 28px; border: 1px solid rgba(201,168,76,.3); }
  .kx-ref-hero__gift { font-size: clamp(4rem, 10vw, 7rem); line-height: 1; margin: 0 0 16px; }
  .kx-ref-hero__title { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; letter-spacing: -.02em; line-height: 1.15; margin: 0 0 12px; }
  .kx-ref-hero__title span { color: #c9a84c; }
  .kx-ref-hero__sub { font-size: 1.05rem; opacity: .7; max-width: 420px; margin: 0 auto 36px; line-height: 1.6; }

  /* ─── FORM ─── */
  .kx-ref-form { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 20px; padding: 32px 28px; backdrop-filter: blur(10px); }
  .kx-ref-form__label { display: block; font-size: .8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,.5); margin-bottom: 10px; text-align: left; }
  .kx-ref-form__row { display: flex; gap: 10px; margin-bottom: 16px; }
  .kx-ref-form__input { flex: 1; padding: 16px 20px; border: 1px solid rgba(255,255,255,.15); border-radius: 12px; background: rgba(255,255,255,.05); color: #fff; font-size: 1rem; outline: none; transition: border-color .2s; }
  .kx-ref-form__input:focus { border-color: #c9a84c; }
  .kx-ref-form__input::placeholder { color: rgba(255,255,255,.3); }
  .kx-ref-form__btn { padding: 16px 28px; border: none; border-radius: 12px; background: #c9a84c; color: #1a1a1a; font-size: .95rem; font-weight: 700; cursor: pointer; transition: all .25s; white-space: nowrap; }
  .kx-ref-form__btn:hover { background: #b8953f; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(201,168,76,.3); }
  .kx-ref-form__btn:disabled { opacity: .5; cursor: not-allowed; transform: none; box-shadow: none; }
  .kx-ref-form__hint { font-size: .75rem; color: rgba(255,255,255,.35); margin: 0; }
  .kx-ref-form__error { color: #ff6b6b; font-size: .85rem; margin: 8px 0 0; display: none; }

  /* ─── SUCCESS ─── */
  .kx-ref-success { display: none; text-align: center; }
  .kx-ref-success.active { display: block; }
  .kx-ref-form.hidden { display: none; }
  .kx-ref-success__check { width: 64px; height: 64px; margin: 0 auto 20px; background: rgba(201,168,76,.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .kx-ref-success__check svg { width: 32px; height: 32px; color: #c9a84c; }
  .kx-ref-success__title { font-size: 1.3rem; font-weight: 800; margin: 0 0 8px; }
  .kx-ref-success__sub { font-size: .9rem; opacity: .6; margin: 0 0 24px; }
  .kx-ref-success__code-box { background: rgba(201,168,76,.1); border: 2px dashed #c9a84c; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
  .kx-ref-success__code-label { font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,.4); margin: 0 0 8px; }
  .kx-ref-success__code { font-size: 2rem; font-weight: 800; color: #c9a84c; letter-spacing: 4px; margin: 0; user-select: all; cursor: pointer; }
  .kx-ref-success__copy { display: inline-flex; align-items: center; gap: 6px; padding: 12px 24px; border: 1px solid rgba(255,255,255,.15); border-radius: 100px; background: transparent; color: #fff; font-size: .85rem; font-weight: 600; cursor: pointer; transition: all .2s; margin-bottom: 20px; }
  .kx-ref-success__copy:hover { border-color: #c9a84c; color: #c9a84c; }
  .kx-ref-success__shop { display: inline-flex; padding: 16px 40px; border-radius: 100px; background: #c9a84c; color: #1a1a1a; font-size: 1rem; font-weight: 700; text-decoration: none; transition: all .25s; }
  .kx-ref-success__shop:hover { background: #b8953f; transform: translateY(-1px); }

  /* ─── TRUST ─── */
  .kx-ref-trust { display: flex; gap: 24px; justify-content: center; margin-top: 40px; flex-wrap: wrap; }
  .kx-ref-trust__item { display: flex; align-items: center; gap: 8px; font-size: .8rem; opacity: .4; }
  .kx-ref-trust__item svg { width: 16px; height: 16px; }

  /* ─── MOBILE ─── */
  @media (max-width: 600px) {
    .kx-ref-form__row { flex-direction: column; }
    .kx-ref-form { padding: 24px 20px; }
    .kx-ref-hero { padding: 30px 16px; }
    .kx-ref-trust { gap: 16px; }
  }
</style>

<div class="kx-ref">
  <section class="kx-ref-hero">
    <div class="kx-ref-hero__bg"></div>
    <div class="kx-ref-hero__inner">

      <span class="kx-ref-hero__badge">Einladung von einem Freund</span>
      <div class="kx-ref-hero__gift">🎁</div>
      <h1 class="kx-ref-hero__title">Du hast <span>10% Rabatt</span> geschenkt bekommen</h1>
      <p class="kx-ref-hero__sub">Ein Freund hat dir diesen exklusiven Rabatt bei karinex.de geschenkt. Gib deine E-Mail ein und erhalte sofort deinen Gutscheincode.</p>

      {%- comment -%} ═══ EMAIL FORM ═══ {%- endcomment -%}
      <div class="kx-ref-form" id="kx-ref-form">
        <label class="kx-ref-form__label">Deine E-Mail-Adresse</label>
        <div class="kx-ref-form__row">
          <input type="email" id="kx-ref-email" class="kx-ref-form__input" placeholder="name@beispiel.de" required autocomplete="email">
          <button type="button" id="kx-ref-submit" class="kx-ref-form__btn">Gutschein erhalten</button>
        </div>
        <p class="kx-ref-form__error" id="kx-ref-error"></p>
        <p class="kx-ref-form__hint">Kein Spam. Deine Daten werden nur für den Gutschein verwendet.</p>
      </div>

      {%- comment -%} ═══ SUCCESS STATE ═══ {%- endcomment -%}
      <div class="kx-ref-success" id="kx-ref-success">
        <div class="kx-ref-success__check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <h2 class="kx-ref-success__title">Dein Gutschein ist da!</h2>
        <p class="kx-ref-success__sub">Gültig für deine erste Bestellung bei karinex.de</p>
        <div class="kx-ref-success__code-box">
          <p class="kx-ref-success__code-label">Dein persönlicher Code</p>
          <p class="kx-ref-success__code" id="kx-ref-code">FREUNDE10</p>
        </div>
        <button type="button" class="kx-ref-success__copy" id="kx-ref-copy">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          Code kopieren
        </button>
        <br>
        <a href="/collections/all" class="kx-ref-success__shop">Jetzt einkaufen mit -10%</a>
      </div>

      {%- comment -%} ═══ TRUST SIGNALS ═══ {%- endcomment -%}
      <div class="kx-ref-trust">
        <div class="kx-ref-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          SSL-verschlüsselt
        </div>
        <div class="kx-ref-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          Trusted Shops
        </div>
        <div class="kx-ref-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Sofort einlösbar
        </div>
      </div>

    </div>
  </section>
</div>

<script>
(function(){
  var form = document.getElementById('kx-ref-form');
  var success = document.getElementById('kx-ref-success');
  var emailInput = document.getElementById('kx-ref-email');
  var submitBtn = document.getElementById('kx-ref-submit');
  var errorEl = document.getElementById('kx-ref-error');
  var copyBtn = document.getElementById('kx-ref-copy');
  var codeEl = document.getElementById('kx-ref-code');

  /* Get referrer from URL */
  var params = new URLSearchParams(window.location.search);
  var refCode = params.get('ref') || 'direct';

  function validateEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  submitBtn.addEventListener('click', function(){
    var email = emailInput.value.trim();
    errorEl.style.display = 'none';

    if (!email) {
      errorEl.textContent = 'Bitte gib deine E-Mail-Adresse ein.';
      errorEl.style.display = 'block';
      emailInput.focus();
      return;
    }
    if (!validateEmail(email)) {
      errorEl.textContent = 'Bitte gib eine gültige E-Mail-Adresse ein.';
      errorEl.style.display = 'block';
      emailInput.focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet...';

    /* Subscribe to Shopify customer list with referral tag */
    fetch('/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        'form_type': 'customer',
        'utf8': '✓',
        'customer[email]': email,
        'customer[tags]': 'referral,ref_' + refCode + ',FREUNDE10',
        'customer[accepts_marketing]': 'true'
      })
    }).then(function(){
      /* Always show success — even if email exists, the code is valid */
      showSuccess();
    }).catch(function(){
      /* Show success anyway — the discount code works regardless */
      showSuccess();
    });
  });

  emailInput.addEventListener('keydown', function(e){
    if (e.key === 'Enter') submitBtn.click();
  });

  function showSuccess(){
    form.classList.add('hidden');
    success.classList.add('active');

    /* Store in localStorage so returning visitors see the code */
    try {
      localStorage.setItem('kx_ref_code', 'FREUNDE10');
      localStorage.setItem('kx_ref_email', emailInput.value.trim());
    } catch(e){}
  }

  /* Copy button */
  copyBtn.addEventListener('click', function(){
    var code = codeEl.textContent;
    navigator.clipboard.writeText(code).then(function(){
      copyBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path d="M20 6L9 17l-5-5"/></svg> Kopiert!';
      setTimeout(function(){
        copyBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Code kopieren';
      }, 2500);
    });
  });

  /* Check if already claimed */
  try {
    if (localStorage.getItem('kx_ref_code')) {
      showSuccess();
    }
  } catch(e){}
})();
</script>

{% schema %}
{
  "name": "Referral Landing",
  "class": "section-referral",
  "tag": "section"
}
{% endschema %}
