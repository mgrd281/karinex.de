{%- doc -%}
  Karinex Premium Product Page — v2

  A fully restyled product page targeting "premium-brand first impression"
  while keeping every conversion lever (urgency, scarcity, social proof)
  visible. All compliance-sensitive numbers (countdown end-date, 30-day
  lowest compare-at price, last-30-days sales count, last-buyer city)
  are wired to real Shopify data or merchant-configurable section
  settings — no random JS, no auto-resetting timers.

  To activate: edit a product → Theme template → choose "karinex-v2".
  To revert: switch the template back to "default" (or "aboutyou").
{%- enddoc -%}

{%- liquid
  assign p = product
  assign v = product.selected_or_first_available_variant
  assign price        = v.price
  assign compare_at   = v.compare_at_price
  assign on_sale      = false
  assign saving_cents = 0
  assign discount_pct = 0
  if compare_at and compare_at > price
    assign on_sale       = true
    assign saving_cents  = compare_at | minus: price
    assign discount_pct  = saving_cents | times: 100.0 | divided_by: compare_at | round
  endif

  assign cat_label  = section.settings.category_label | default: p.type | default: 'MICROSOFT'
  assign subtitle   = p.metafields.karinex.subtitle | default: section.settings.default_subtitle

  comment
    Social-proof count: real merchant input via metafield first,
    section setting as fallback. Refuse to invent a number.
  endcomment
  assign sales_count = p.metafields.karinex.sales_30d.value
  if sales_count == blank
    assign sales_count = section.settings.fallback_sales_30d
  endif
  assign last_city = p.metafields.karinex.last_buyer_city.value | default: section.settings.fallback_last_city
  assign last_mins = p.metafields.karinex.last_buyer_minutes.value | default: section.settings.fallback_last_minutes

  comment
    Stock: only show a real number when inventory is actually tracked
    and finite. Digital products with `inventory_management = null`
    show the soft "Aktuell hohe Nachfrage" instead — UWG-safe.
  endcomment
  assign stock_tracked = false
  assign stock_qty     = 0
  if v.inventory_management != blank and v.inventory_quantity > 0 and v.inventory_quantity < 500
    assign stock_tracked = true
    assign stock_qty     = v.inventory_quantity
  endif

  comment
    Countdown end: merchant-set fixed date (PAngV-safe). When the
    setting is empty we just hide the timer instead of fabricating one.
  endcomment
  assign countdown_end = section.settings.countdown_end_iso
-%}

<section class="kxv2" data-section-id="{{ section.id }}">

  {%- comment -%} ─── [1] ANNOUNCEMENT BAR ─────────────────────── {%- endcomment -%}
  <div class="kxv2-announce" role="region" aria-label="Aktion und Vertrauenshinweise">
    <div class="kxv2-announce__inner">
      <p class="kxv2-announce__trust">
        100&nbsp;% LEGALE LIZENZEN
        <span aria-hidden="true">·</span>
        BLITZVERSAND
        <span aria-hidden="true">·</span>
        DEUTSCHER SUPPORT
      </p>

      {%- if countdown_end != blank -%}
      <div class="kxv2-announce__timer"
           data-kxv2-countdown
           data-end="{{ countdown_end }}"
           aria-live="polite">
        <span class="kxv2-announce__timer-label">Aktion endet in:</span>
        <span class="kxv2-announce__timer-value">
          <span data-h>--</span><span class="kxv2-announce__sep">·</span><span data-m>--</span><span class="kxv2-announce__sep">·</span><span data-s>--</span>
        </span>
      </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ─── [2] BREADCRUMB ──────────────────────────── {%- endcomment -%}
  <nav class="kxv2-breadcrumb" aria-label="Sie befinden sich hier">
    <a href="{{ routes.root_url }}">Startseite</a>
    <span aria-hidden="true">›</span>
    {%- if collection -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span aria-hidden="true">›</span>
    {%- endif -%}
    <span aria-current="page">{{ p.title }}</span>
  </nav>

  {%- comment -%} ─── [3] PRODUCT HERO ────────────────────────── {%- endcomment -%}
  <div class="kxv2-hero">

    {%- comment -%} ── LEFT: gallery ── {%- endcomment -%}
    <div class="kxv2-hero__left">
      <figure class="kxv2-gallery" data-kxv2-gallery>
        <div class="kxv2-gallery__main">
          {%- if p.featured_image -%}
            <img id="kxv2-main-image"
                 src="{{ p.featured_image | image_url: width: 900 }}"
                 srcset="{{ p.featured_image | image_url: width: 600 }} 600w,
                         {{ p.featured_image | image_url: width: 900 }} 900w,
                         {{ p.featured_image | image_url: width: 1200 }} 1200w"
                 sizes="(max-width: 768px) 90vw, 600px"
                 alt="{{ p.title | escape }}"
                 width="900" height="900"
                 loading="eager"
                 fetchpriority="high">
          {%- endif -%}

          {%- comment -%} ── [A] Wishlist counter ── {%- endcomment -%}
          <button type="button"
                  class="kxv2-gallery__wish"
                  data-kxv2-wishlist
                  aria-label="Auf die Wunschliste setzen"
                  aria-pressed="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="kxv2-gallery__wish-count" data-kxv2-wishlist-count>{{ p.metafields.karinex.wishlist_count.value | default: section.settings.fallback_wishlist_count | default: 0 }}</span>
          </button>

          {%- comment -%} ── [B] Stock counter (only with real data) ── {%- endcomment -%}
          {%- if stock_tracked -%}
            <div class="kxv2-gallery__stock" role="status">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/>
              </svg>
              <span>Nur noch <strong>{{ stock_qty }}</strong>&nbsp;verfügbar</span>
            </div>
          {%- elsif section.settings.show_demand_label -%}
            <div class="kxv2-gallery__stock kxv2-gallery__stock--soft" role="status">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                <path d="M3 17l6-6 4 4 8-8"/><path d="M14 7h7v7"/>
              </svg>
              <span>Aktuell hohe Nachfrage</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} ── Thumbnails ── {%- endcomment -%}
        {%- if p.images.size > 1 -%}
          <div class="kxv2-gallery__thumbs" role="tablist" aria-label="Weitere Produktbilder">
            {%- for img in p.images limit: 4 -%}
              <button type="button"
                      class="kxv2-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                      role="tab"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      data-img="{{ img | image_url: width: 1200 }}"
                      aria-label="Bild {{ forloop.index }}">
                <img src="{{ img | image_url: width: 128 }}"
                     alt=""
                     width="64" height="64"
                     loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </figure>
    </div>

    {%- comment -%} ── RIGHT: info ── {%- endcomment -%}
    <div class="kxv2-hero__right">

      <p class="kxv2-eyebrow">{{ cat_label | upcase }}</p>

      <h1 class="kxv2-title">{{ p.title }}</h1>
      {%- if subtitle != blank -%}
        <p class="kxv2-subtitle">{{ subtitle }}</p>
      {%- endif -%}

      {%- comment -%} ── Rating ── {%- endcomment -%}
      {%- assign rv = p.metafields.reviews.rating.value | default: p.metafields.ddreviews.content.average_star -%}
      {%- assign rc = p.metafields.reviews.rating_count  | default: p.metafields.ddreviews.content.total_reviews -%}
      {%- if rv != blank and rv != 0 -%}
        <div class="kxv2-rating" itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
          <div class="kxv2-rating__stars" aria-label="{{ rv }} von 5 Sternen">
            {%- assign filled = rv | round -%}
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                      fill="{% if forloop.index <= filled %}#B8956A{% else %}#E5E3DE{% endif %}"/>
              </svg>
            {%- endfor -%}
          </div>
          <span class="kxv2-rating__val" itemprop="ratingValue">{{ rv | replace: '.', ',' }}</span>
          <a href="#kxv2-reviews" class="kxv2-rating__count">
            <span aria-hidden="true">·</span>
            <span itemprop="reviewCount">{{ rc | default: 1 }}</span> Bewertungen
          </a>
        </div>
      {%- endif -%}

      {%- comment -%} ── Social proof ── {%- endcomment -%}
      {%- if sales_count != blank and sales_count != 0 -%}
        <p class="kxv2-social">
          <svg viewBox="0 0 24 24" fill="none" stroke="#2A7A4D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
            <path d="M3 17l6-6 4 4 8-8"/><path d="M14 7h7v7"/>
          </svg>
          <span>
            <strong>{{ sales_count }}</strong>&nbsp;Käufe in den letzten 30&nbsp;Tagen
            {%- if last_city != blank %} · zuletzt aus <strong>{{ last_city }}</strong>{% if last_mins != blank %}, vor {{ last_mins }}&nbsp;Min.{% endif %}{%- endif -%}
          </span>
        </p>
      {%- endif -%}

      {%- comment -%} ── Price block ── {%- endcomment -%}
      <div class="kxv2-price">
        {%- if on_sale and countdown_end != blank -%}
          <p class="kxv2-price__badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            Aktionspreis · Nur heute
          </p>
        {%- elsif on_sale -%}
          <p class="kxv2-price__badge">Aktionspreis</p>
        {%- endif -%}

        <div class="kxv2-price__row">
          <span class="kxv2-price__main" itemprop="price" content="{{ price | money_without_currency | replace: ',', '.' }}">
            {{ price | money }}
          </span>
          {%- if on_sale -%}
            <span class="kxv2-price__compare" aria-label="Vorheriger Preis">{{ compare_at | money }}</span>
            <span class="kxv2-price__discount" aria-label="Rabatt">−{{ discount_pct }}&thinsp;%</span>
          {%- endif -%}
        </div>

        {%- if on_sale -%}
          <p class="kxv2-price__saving">
            Preisvorteil: <strong>{{ saving_cents | money }}</strong>
          </p>
        {%- endif -%}

        <p class="kxv2-price__tax">inkl.&nbsp;19&nbsp;% MwSt.</p>
      </div>

      {%- comment -%} ── Feature list ── {%- endcomment -%}
      <ul class="kxv2-features">
        {%- for i in (1..4) -%}
          {%- assign feat = section.settings['feature_' | append: i] -%}
          {%- if feat != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>{{ feat }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- comment -%} ── CTA ── {%- endcomment -%}
      <form method="post"
            action="{{ routes.cart_add_url }}"
            class="kxv2-form"
            data-kxv2-form>
        <input type="hidden" name="id" value="{{ v.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="kxv2-cta" {% unless v.available %}disabled{% endunless %}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/>
          </svg>
          <span>
            {%- if v.available -%}
              In den Warenkorb · {{ price | money }}
            {%- else -%}
              Derzeit nicht verfügbar
            {%- endif -%}
          </span>
        </button>
      </form>

      {%- comment -%} ── Payment row ── {%- endcomment -%}
      <div class="kxv2-pay" aria-label="Akzeptierte Zahlungsmethoden">
        {%- for method in shop.enabled_payment_types limit: 9 -%}
          {{ method | payment_type_svg_tag: class: 'kxv2-pay__icon' }}
        {%- endfor -%}
      </div>

      {%- comment -%} ── Details table ── {%- endcomment -%}
      <dl class="kxv2-details">
        <div class="kxv2-details__row">
          <dt>
            <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span>Verfügbarkeit</span>
          </dt>
          <dd>Versand per E-Mail sofort nach Zahlung</dd>
        </div>
        <div class="kxv2-details__row">
          <dt>
            <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
              <path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="1.4" fill="currentColor"/>
            </svg>
            <span>Marke</span>
          </dt>
          <dd>{{ p.vendor | default: 'Microsoft' }}</dd>
        </div>
        {%- if v.sku != blank -%}
          <div class="kxv2-details__row">
            <dt><span aria-hidden="true">#</span>&nbsp;<span>Artikelnummer</span></dt>
            <dd>{{ v.sku }}</dd>
          </div>
        {%- endif -%}
        {%- if v.barcode != blank -%}
          <div class="kxv2-details__row">
            <dt><span aria-hidden="true">⫶</span>&nbsp;<span>EAN</span></dt>
            <dd>{{ v.barcode }}</dd>
          </div>
        {%- endif -%}
        <div class="kxv2-details__row">
          <dt>
            <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
              <polyline points="13 2 13 9 20 9"/><path d="M13 2 L4 13 H11 L11 22 L20 9 Z"/>
            </svg>
            <span>Blitz-Versand</span>
          </dt>
          <dd>Direkt nach dem Kauf per E-Mail</dd>
        </div>
        <div class="kxv2-details__row">
          <dt>
            <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            <span>Anleitung</span>
          </dt>
          <dd>In der Bestätigungs-E-Mail enthalten</dd>
        </div>
        <div class="kxv2-details__row">
          <dt>
            <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>Zahlung</span>
          </dt>
          <dd>Einmalige Zahlung · keine Folgekosten</dd>
        </div>
        {%- if section.settings.license_type != blank -%}
          <div class="kxv2-details__row">
            <dt>
              <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                <path d="M12 2 L4 6 L4 12 C4 17 8 21 12 22 C16 21 20 17 20 12 L20 6 Z"/>
              </svg>
              <span>Lizenztyp</span>
            </dt>
            <dd>{{ section.settings.license_type }}</dd>
          </div>
        {%- endif -%}
      </dl>
    </div>
  </div>

  {%- comment -%} ─── [4] TRUST BAR ──────────────────────────── {%- endcomment -%}
  <div class="kxv2-trustbar">
    <div class="kxv2-trustbar__grid">
      <div class="kxv2-trustbar__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <p>SSL-Verschlüsselt</p>
      </div>
      <div class="kxv2-trustbar__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32" aria-hidden="true">
          <path d="M12 2 L4 6 L4 12 C4 17 8 21 12 22 C16 21 20 17 20 12 L20 6 Z"/><polyline points="9 12 11 14 15 10"/>
        </svg>
        <p>Trusted Shops zertifiziert</p>
      </div>
      <div class="kxv2-trustbar__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <p>Deutscher Support&nbsp;· Mo–Fr&nbsp;9–18&nbsp;Uhr</p>
      </div>
      <div class="kxv2-trustbar__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="#1F3A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <p>Made in Germany&nbsp;· Hamburg</p>
      </div>
    </div>
  </div>

  {%- comment -%} ─── [5] DESCRIPTION TABS ────────────────────── {%- endcomment -%}
  <div class="kxv2-tabs" data-kxv2-tabs>
    <div class="kxv2-tabs__nav" role="tablist">
      <button type="button" class="kxv2-tabs__btn is-active" role="tab" data-tab="desc" aria-selected="true">Produktdetails</button>
      <button type="button" class="kxv2-tabs__btn" role="tab" data-tab="sys" aria-selected="false">Systemanforderungen</button>
      <button type="button" class="kxv2-tabs__btn" role="tab" data-tab="act" aria-selected="false">Aktivierung</button>
      <button type="button" class="kxv2-tabs__btn" role="tab" data-tab="faq" aria-selected="false">Häufige Fragen</button>
    </div>
    <div class="kxv2-tabs__panels">
      <div class="kxv2-tabs__panel is-active" data-panel="desc" role="tabpanel">
        <div class="kxv2-rte">{{ p.description }}</div>
      </div>
      <div class="kxv2-tabs__panel" data-panel="sys" role="tabpanel">
        <div class="kxv2-rte">{{ p.metafields.karinex.system_requirements | default: '<p>Standardanforderungen für Windows&nbsp;10/11 und macOS&nbsp;11+. Details siehe Hersteller-Spezifikation.</p>' }}</div>
      </div>
      <div class="kxv2-tabs__panel" data-panel="act" role="tabpanel">
        <div class="kxv2-rte">{{ p.metafields.karinex.activation | default: '<p>Aktivierung erfolgt online mit dem per E-Mail erhaltenen Produktschlüssel über Ihr Microsoft-Konto.</p>' }}</div>
      </div>
      <div class="kxv2-tabs__panel" data-panel="faq" role="tabpanel">
        <div class="kxv2-rte">{{ p.metafields.karinex.faq_html | default: '<p>Ihre Frage ist nicht dabei? Schreiben Sie uns – Mo–Fr von 9–18&nbsp;Uhr.</p>' }}</div>
      </div>
    </div>
  </div>

  {%- comment -%} ─── [6] REVIEWS placeholder ────────────────── {%- endcomment -%}
  <div id="kxv2-reviews" class="kxv2-reviews">
    {% render 'product-reviews' %}
  </div>

  {%- comment -%} ─── [7] CROSS-SELL ─────────────────────────── {%- endcomment -%}
  {% render 'product-recommendations' %}

  {%- comment -%} ─── Sticky mobile CTA ──────────────────────── {%- endcomment -%}
  <div class="kxv2-stickybar" aria-hidden="true" data-kxv2-stickybar>
    <span class="kxv2-stickybar__price">{{ price | money }}</span>
    <button type="button" class="kxv2-stickybar__btn" data-kxv2-stickybar-cta>
      In den Warenkorb
    </button>
  </div>

  {% render 'product-rich-schema' %}
</section>

<style>
  .kxv2 {
    --kx-c-primary:   #1F3A2B;
    --kx-c-primary-h: #2A4D3A;
    --kx-c-sage:      #A8C4A2;
    --kx-c-bronze:    #B8956A;
    --kx-c-urgency:   #C84A38;
    --kx-c-success:   #2A7A4D;
    --kx-c-bg:        #F8F7F4;
    --kx-c-surface:   #FFFFFF;
