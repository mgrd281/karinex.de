<script>
(function(){
  var root = document.currentScript.closest('.kxv2');
  if (!root) return;

  // ── Countdown ────────────────────────────────────────────────
  var cd = root.querySelector('[data-kxv2-countdown]');
  if (cd) {
    var end = new Date(cd.dataset.end).getTime();
    var h = cd.querySelector('[data-h]');
    var m = cd.querySelector('[data-m]');
    var s = cd.querySelector('[data-s]');
    function pad(n){ return n<10 ? '0'+n : ''+n; }
    function tick(){
      var diff = end - Date.now();
      if (diff <= 0) {
        h.textContent = m.textContent = s.textContent = '00';
        cd.setAttribute('data-expired','true');
        return;
      }
      h.textContent = pad(Math.floor(diff/36e5));
      m.textContent = pad(Math.floor((diff%36e5)/6e4));
      s.textContent = pad(Math.floor((diff%6e4)/1e3));
      requestAnimationFrame(function(){ setTimeout(tick, 1000); });
    }
    tick();
  }

  // ── Gallery thumbnails ─────────────────────────────────────
  var main = root.querySelector('#kxv2-main-image');
  root.querySelectorAll('.kxv2-gallery__thumb').forEach(function(t){
    t.addEventListener('click', function(){
      if (!main) return;
      main.src = t.dataset.img;
      main.removeAttribute('srcset');
      root.querySelectorAll('.kxv2-gallery__thumb').forEach(function(o){
        o.classList.remove('is-active');
        o.setAttribute('aria-selected','false');
      });
      t.classList.add('is-active');
      t.setAttribute('aria-selected','true');
    });
  });

  // ── Wishlist (local-only, no auth) ─────────────────────────
  var wishBtn = root.querySelector('[data-kxv2-wishlist]');
  if (wishBtn) {
    var key = 'kxv2_wish_' + (root.dataset.sectionId || 'g');
    if (localStorage.getItem(key) === '1') {
      wishBtn.setAttribute('aria-pressed','true');
    }
    wishBtn.addEventListener('click', function(){
      var on = wishBtn.getAttribute('aria-pressed') !== 'true';
      wishBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
      try { localStorage.setItem(key, on ? '1' : '0'); } catch(e){}
    });
  }

  // ── Tabs ──────────────────────────────────────────────────
  root.querySelectorAll('[data-kxv2-tabs] .kxv2-tabs__btn').forEach(function(b){
    b.addEventListener('click', function(){
      var tab = b.dataset.tab;
      root.querySelectorAll('.kxv2-tabs__btn').forEach(function(o){
        o.classList.toggle('is-active', o === b);
        o.setAttribute('aria-selected', o === b ? 'true' : 'false');
      });
      root.querySelectorAll('.kxv2-tabs__panel').forEach(function(p){
        p.classList.toggle('is-active', p.dataset.panel === tab);
      });
    });
  });

  // ── Sticky-bar CTA → submit form ─────────────────────────
  var stickyCta = root.querySelector('[data-kxv2-stickybar-cta]');
  var form = root.querySelector('[data-kxv2-form]');
  if (stickyCta && form) {
    stickyCta.addEventListener('click', function(){ form.requestSubmit(); });
  }
})();
</script>

