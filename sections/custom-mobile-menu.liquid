{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
{% schema %}
{
  "name": "Custom Mobile Menu",
  "settings": [
    { "type": "header", "content": "Primäre Navigation" },
    { "type": "url", "id": "link_office", "label": "Microsoft Office" },
    { "type": "url", "id": "link_windows", "label": "Microsoft Windows" },
    { "type": "url", "id": "link_all", "label": "Alle Produkte" },
    { "type": "url", "id": "link_offers", "label": "Angebote" },

    { "type": "header", "content": "Service" },
    { "type": "url", "id": "link_account", "label": "Mein Konto" },
    { "type": "url", "id": "link_orders", "label": "Bestellungen" },
    { "type": "url", "id": "link_wishlist", "label": "Merkliste" },
    { "type": "url", "id": "link_support", "label": "Kundensupport" },
    { "type": "url", "id": "link_shipping", "label": "Versand & Lieferung" },

    { "type": "header", "content": "Editorial Feature Block" },
    { "type": "text", "id": "feature_overline", "label": "Overline", "default": "EMPFEHLUNG" },
    { "type": "text", "id": "feature_headline", "label": "Headline", "default": "Office, neu gedacht." },
    { "type": "textarea", "id": "feature_body", "label": "Body", "default": "Microsoft Office 2024 — die Werkzeuge, die seit Jahrzehnten den Standard definieren." },
    { "type": "text", "id": "feature_link_label", "label": "Link Label", "default": "ENTDECKEN" },
    { "type": "url", "id": "feature_link", "label": "Link" },

    { "type": "header", "content": "Footer" },
    { "type": "text", "id": "footer_tagline", "label": "Tagline", "default": "Software, sorgfältig kuratiert." },
    { "type": "text", "id": "footer_legal", "label": "Legal links (separated by · )", "default": "Impressum · AGB · Datenschutz · Widerruf" },

    { "type": "header", "content": "Suche" },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Suchen" }
  ]
}
{% endschema %}

<div class="kx-menu-backdrop" id="cmm-backdrop" aria-hidden="true"></div>

<aside
  id="custom-mobile-menu"
  class="kx-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Hauptmenü"
  tabindex="-1"
>
  {%- comment -%} ============== HEADER ============== {%- endcomment -%}
  <header class="kx-menu__header">
    <a href="{{ _root }}" class="kx-menu__wordmark" aria-label="KARINEX Startseite">KARINEX</a>
    <button type="button" class="kx-menu__close" id="cmm-close" aria-label="Menü schließen">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>
  </header>

  {%- comment -%} ============== SCROLLABLE BODY ============== {%- endcomment -%}
  <div class="kx-menu__scroll">

    {%- comment -%} ----- Search ----- {%- endcomment -%}
    <form action="{{ routes.search_url }}" method="get" role="search" class="kx-menu__search">
      <svg class="kx-menu__search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <line x1="21" y1="21" x2="16.5" y2="16.5"/>
      </svg>
      <input
        type="search"
        name="q"
        class="kx-menu__search-input"
        placeholder="{{ section.settings.search_placeholder }}"
        aria-label="Im Shop suchen"
      >
    </form>

    {%- comment -%} ----- 01 — KOLLEKTION ----- {%- endcomment -%}
    <div class="kx-menu__overline">01 — KOLLEKTION</div>
    <ul class="kx-menu__list kx-menu__list--display" role="list">
      {%- if section.settings.link_office != blank -%}
        <li class="kx-menu__item">
          <a href="{{ section.settings.link_office }}">
            <span>Microsoft Office</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
          </a>
        </li>
      {%- endif -%}
      {%- if section.settings.link_windows != blank -%}
        <li class="kx-menu__item">
          <a href="{{ section.settings.link_windows }}">
            <span>Microsoft Windows</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
          </a>
        </li>
      {%- endif -%}
      {%- if section.settings.link_all != blank -%}
        <li class="kx-menu__item">
          <a href="{{ section.settings.link_all }}">
            <span>Alle Produkte</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
          </a>
        </li>
      {%- endif -%}
      {%- if section.settings.link_offers != blank -%}
        <li class="kx-menu__item kx-menu__item--accent">
          <a href="{{ section.settings.link_offers }}">
            <span>Angebote</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
          </a>
        </li>
      {%- endif -%}
    </ul>

    {%- comment -%} ----- 02 — SERVICE ----- {%- endcomment -%}
    <div class="kx-menu__overline">02 — SERVICE</div>
    <ul class="kx-menu__list kx-menu__list--utility" role="list">
      {%- if section.settings.link_account != blank -%}
        <li class="kx-menu__item-utility"><a href="{{ section.settings.link_account }}">Mein Konto</a></li>
      {%- else -%}
        <li class="kx-menu__item-utility"><a href="{{ routes.account_url }}">Mein Konto</a></li>
      {%- endif -%}
      {%- if section.settings.link_orders != blank -%}
        <li class="kx-menu__item-utility"><a href="{{ section.settings.link_orders }}">Bestellungen</a></li>
      {%- endif -%}
      {%- if section.settings.link_wishlist != blank -%}
        <li class="kx-menu__item-utility"><a href="{{ section.settings.link_wishlist }}">Merkliste</a></li>
      {%- endif -%}
      {%- if section.settings.link_support != blank -%}
        <li class="kx-menu__item-utility"><a href="{{ section.settings.link_support }}">Kundensupport</a></li>
      {%- endif -%}
      {%- if section.settings.link_shipping != blank -%}
        <li class="kx-menu__item-utility"><a href="{{ section.settings.link_shipping }}">Versand & Lieferung</a></li>
      {%- endif -%}
    </ul>

    {%- comment -%} ----- Editorial Feature Block ----- {%- endcomment -%}
    {%- if section.settings.feature_headline != blank -%}
      <section class="kx-menu__feature">
        {%- if section.settings.feature_overline != blank -%}
          <div class="kx-menu__feature-overline">{{ section.settings.feature_overline }}</div>
        {%- endif -%}
        <h3 class="kx-menu__feature-headline">{{ section.settings.feature_headline }}</h3>
        {%- if section.settings.feature_body != blank -%}
          <p class="kx-menu__feature-body">{{ section.settings.feature_body }}</p>
        {%- endif -%}
        {%- if section.settings.feature_link != blank and section.settings.feature_link_label != blank -%}
          <a href="{{ section.settings.feature_link }}" class="kx-menu__feature-link">
            <span>{{ section.settings.feature_link_label }}</span>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="4" y1="12" x2="20" y2="12"/>
              <polyline points="14 6 20 12 14 18"/>
            </svg>
          </a>
        {%- endif -%}
      </section>
    {%- endif -%}

    {%- comment -%} ----- Footer ----- {%- endcomment -%}
    <footer class="kx-menu__footer">
      <div class="kx-menu__locale">Deutsch <span aria-hidden="true">⌄</span></div>
      {%- if section.settings.footer_tagline != blank -%}
        <p class="kx-menu__tagline">{{ section.settings.footer_tagline }}</p>
      {%- endif -%}
      {%- if section.settings.footer_legal != blank -%}
        <p class="kx-menu__legal">{{ section.settings.footer_legal }}</p>
      {%- endif -%}
    </footer>

  </div>
</aside>

{%- stylesheet -%}
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap');

.kx-menu-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(10, 10, 10, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 200ms ease, visibility 0s linear 200ms;
  z-index: 9998;
}
.kx-menu-backdrop.is-open {
  opacity: 1;
  visibility: visible;
  transition: opacity 200ms ease, visibility 0s linear 0s;
}

.kx-menu {
  position: fixed;
  top: 0;
  left: 0;
  height: 100vh;
  height: 100dvh;
  width: 88vw;
  max-width: 380px;
  background: #F5F2EC;
  color: #0A0A0A;
  font-family: "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  transition: transform 320ms cubic-bezier(0.22, 0.61, 0.36, 1);
  z-index: 9999;
  overflow: hidden;
}
.kx-menu.is-open { transform: translateX(0); }
.kx-menu *, .kx-menu *::before, .kx-menu *::after { box-sizing: border-box; }
.kx-menu a { color: inherit; text-decoration: none; }

/* ---------- Header ---------- */
.kx-menu__header {
  flex-shrink: 0;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  border-bottom: 1px solid #C9C2B0;
}
.kx-menu__wordmark {
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: #0A0A0A;
}
.kx-menu__close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  margin-right: -8px;
  background: transparent;
  border: 0;
  padding: 0;
  cursor: pointer;
  color: #0A0A0A;
  transition: color 150ms ease;
}
.kx-menu__close:hover { color: #1D4739; }

/* ---------- Scroll body ---------- */
.kx-menu__scroll {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}
.kx-menu__scroll::-webkit-scrollbar { width: 0; }

/* ---------- Search ---------- */
.kx-menu__search {
  position: relative;
  display: flex;
  align-items: center;
  margin: 0 24px;
  padding: 20px 0;
  border-bottom: 1px solid #C9C2B0;
  transition: border-color 200ms ease;
}
.kx-menu__search:focus-within { border-bottom-color: #C9B486; }
.kx-menu__search-icon {
  flex-shrink: 0;
  color: #3A3A3A;
  margin-right: 12px;
}
.kx-menu__search-input {
  flex: 1;
  width: 100%;
  border: 0;
  background: transparent;
  outline: none;
  font-family: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  font-style: italic;
  font-size: 18px;
  font-weight: 400;
  color: #0A0A0A;
  padding: 0;
}
.kx-menu__search-input::placeholder {
  color: #6A6A6A;
  font-style: italic;
  opacity: 1;
}

/* ---------- Overline ---------- */
.kx-menu__overline {
  padding: 32px 24px 16px;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #6A6A6A;
}

/* ---------- Display list (primary nav) ---------- */
.kx-menu__list { list-style: none; margin: 0; padding: 0; }
.kx-menu__list--display .kx-menu__item {
  border-bottom: 1px solid #C9C2B0;
}
.kx-menu__list--display .kx-menu__item:first-child {
  border-top: 1px solid #C9C2B0;
}
.kx-menu__list--display .kx-menu__item a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  font-family: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  font-size: 32px;
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: 0;
  color: #0A0A0A;
  transition: padding-left 200ms cubic-bezier(0.22, 0.61, 0.36, 1), color 150ms ease;
}
.kx-menu__list--display .kx-menu__item a svg {
  color: #6A6A6A;
  flex-shrink: 0;
  margin-left: 16px;
  transition: color 150ms ease, transform 200ms ease;
}
.kx-menu__list--display .kx-menu__item a:hover,
.kx-menu__list--display .kx-menu__item a:focus-visible,
.kx-menu__list--display .kx-menu__item a:active {
  padding-left: 28px;
}
.kx-menu__list--display .kx-menu__item a:hover svg,
.kx-menu__list--display .kx-menu__item a:focus-visible svg,
.kx-menu__list--display .kx-menu__item a:active svg {
  color: #C9B486;
  transform: translateX(4px);
}
.kx-menu__item--accent a {
  font-style: italic;
  color: #1D4739 !important;
}

/* ---------- Utility list (secondary nav) ---------- */
.kx-menu__list--utility { padding: 0 24px; }
.kx-menu__item-utility a {
  display: block;
  padding: 16px 0;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  color: #3A3A3A;
  border-bottom: 1px solid #C9C2B0;
  transition: color 150ms ease;
}
.kx-menu__item-utility:last-child a { border-bottom: 0; }
.kx-menu__item-utility a:hover,
.kx-menu__item-utility a:focus-visible {
  color: #1D4739;
}

/* ---------- Editorial Feature Block ---------- */
.kx-menu__feature {
  margin: 48px 0 0;
  background: #1D4739;
  color: #D4CDB8;
  padding: 40px 24px;
}
.kx-menu__feature-overline {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #C9B486;
  margin-bottom: 16px;
}
.kx-menu__feature-headline {
  font-family: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  font-style: italic;
  font-weight: 400;
  font-size: 26px;
  line-height: 1.2;
  color: #F5F2EC;
  margin: 0 0 12px;
}
.kx-menu__feature-body {
  font-family: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  font-size: 16px;
  line-height: 1.5;
  color: #D4CDB8;
  margin: 0 0 24px;
  font-weight: 400;
}
.kx-menu__feature-link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #C9B486;
  border-bottom: 1px solid #C9B486;
  padding-bottom: 4px;
  transition: gap 200ms ease, color 150ms ease;
}
.kx-menu__feature-link:hover { gap: 16px; color: #F5F2EC; border-color: #F5F2EC; }

/* ---------- Footer ---------- */
.kx-menu__footer {
  background: #F5F2EC;
  padding: 32px 24px 48px;
}
.kx-menu__locale {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 12px;
  color: #6A6A6A;
  margin-bottom: 24px;
}
.kx-menu__tagline {
  font-family: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  font-style: italic;
  font-size: 14px;
  color: #6A6A6A;
  margin: 0 0 16px;
}
.kx-menu__legal {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 10px;
  letter-spacing: 0.5px;
  color: #8FA39A;
  margin: 0;
}

@media (min-width: 990px) {
  .kx-menu, .kx-menu-backdrop { display: none; }
}
{%- endstylesheet -%}

<script>
(function () {
  function initKarinexMenu() {
    var menu = document.getElementById('custom-mobile-menu');
    var backdrop = document.getElementById('cmm-backdrop');
    var closeBtn = document.getElementById('cmm-close');
    if (!menu) return;

    var lastFocused = null;

    function openMenu() {
      lastFocused = document.activeElement;
      menu.classList.add('is-open');
      if (backdrop) backdrop.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      var nativeDrawer = document.getElementById('Details-menu-drawer-container');
      if (nativeDrawer) {
        nativeDrawer.removeAttribute('open');
        nativeDrawer.classList.remove('menu-open');
      }
      document.body.classList.remove('overflow-hidden');
      setTimeout(function () { if (closeBtn) closeBtn.focus(); }, 80);
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      if (backdrop) backdrop.classList.remove('is-open');
      document.body.style.overflow = '';
      if (lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', function (e) { e.preventDefault(); closeMenu(); });
    }
    if (backdrop) {
      backdrop.addEventListener('click', closeMenu);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) closeMenu();
    });

    document.body.addEventListener('click', function (e) {
      if (window.innerWidth > 990) return;
      var trigger = e.target.closest('.header__icon--menu, [data-header-drawer], .header__drawer summary, .header__icon--menu span');
      if (!trigger) return;
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      openMenu();
      return false;
    }, true);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initKarinexMenu);
  } else {
    initKarinexMenu();
  }
})();
</script>
