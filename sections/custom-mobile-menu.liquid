{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless

  comment
    Bestseller resolver — pick a single source, no array building.
    Priority:
      1. configured collection
      2. 'unsere-bestseller' collection
      3. fallback handle list (rendered via for-loop in markup)
      4. collections.all
  endcomment

  assign primary_handle = section.settings.bestseller_collection | default: 'bestsellers'
  assign source_collection = collections[primary_handle]
  if source_collection == blank or source_collection.products_count == 0
    assign source_collection = collections['unsere-bestseller']
  endif

  assign use_collection = false
  if source_collection != blank and source_collection.products_count > 0
    assign use_collection = true
  endif

  unless use_collection
    assign h1 = section.settings.fallback_handle_1
    assign h2 = section.settings.fallback_handle_2
    assign h3 = section.settings.fallback_handle_3
    assign h4 = section.settings.fallback_handle_4
    assign h5 = section.settings.fallback_handle_5
    assign h6 = section.settings.fallback_handle_6
    assign handle_csv = h1 | append: ',' | append: h2 | append: ',' | append: h3 | append: ',' | append: h4 | append: ',' | append: h5 | append: ',' | append: h6
    assign handle_array = handle_csv | split: ','
  endunless
-%}

