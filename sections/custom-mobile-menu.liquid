<link rel="preload" href="{{ 'custom-mobile-menu.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'custom-mobile-menu.css' | asset_url }}"></noscript>

<script>
// Validated Universal Mobile Menu Hijack (Works on Homepage & Product Pages)
(function() {
  function initCustomMenu() {
    const menu = document.getElementById('custom-mobile-menu');
    const backdrop = document.getElementById('cmm-backdrop');
    const closeBtn = document.getElementById('cmm-close');
    const tabs = document.querySelectorAll('.cmm-tab-item');
    const grids = document.querySelectorAll('.cmm-grid-container');

    if (!menu) return;

    function openMenu() {
      menu.classList.add('is-open');
      if(backdrop) backdrop.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      
      // Force close default drawer if it exists
      const defaultDrawer = document.getElementById('Details-menu-drawer-container');
      if (defaultDrawer) {
        defaultDrawer.removeAttribute('open');
        defaultDrawer.classList.remove('menu-open');
      }
      document.body.classList.remove('overflow-hidden'); // Remove Shopify's overflow lock
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      if(backdrop) backdrop.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    // Close Actions
    if (closeBtn) closeBtn.onclick = function(e) { e.preventDefault(); closeMenu(); };
    if (backdrop) backdrop.onclick = closeMenu;

    // Universal Event Delegation for Menu Toggle
    // Captures clicks on ANY element matching the selectors, even if dynamically added.
    document.body.addEventListener('click', function(e) {
      if (window.innerWidth > 990) return; // Only mobile

      // Find closest trigger element
      const trigger = e.target.closest('.header__icon--menu, [data-header-drawer], .header__drawer summary, .header__icon--menu span');
      
      if (trigger) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        openMenu();
        return false;
      }
    }, true); // Use capture phase to intercept before other handlers

    // Tabs Logic
    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        grids.forEach(g => g.style.display = 'none');
        const targetId = 'cmm-tab-content-' + this.dataset.tab;
        const targetGrid = document.getElementById(targetId);
        if(targetGrid) targetGrid.style.display = 'grid';
      });
    });

    // Update counts via AJAX (Simplified for performance)
    const updateCounts = () => {
      // Cart count
      fetch('/cart.js').then(r=>r.json()).then(c => {
         const el = document.querySelector('.cmm-cart-count');
         if(el) { el.textContent = c.item_count; el.style.display = c.item_count > 0 ? 'flex' : 'none'; }
      }).catch(e=>{});
    };
    // Defer cart count update slightly to ensure page load
    setTimeout(updateCounts, 2000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCustomMenu);
  } else {
    initCustomMenu();
  }
})();
</script>
