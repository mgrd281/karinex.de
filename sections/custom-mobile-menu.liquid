{%- assign drill_keys = 'office,windows,server,project,visio,m365' | split: ',' -%}

<div class="kx-menu-backdrop" id="cmm-backdrop" aria-hidden="true"></div>

<aside
  id="custom-mobile-menu"
  class="kx-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Hauptmenü"
  tabindex="-1"
>
  {%- comment -%} ============== HEADER (dual-state) ============== {%- endcomment -%}
  <header class="kx-menu__header">
    <div class="kx-menu__header-state kx-menu__header-state--l1" data-state="l1">
      <a href="{{ _root }}" class="kx-menu__wordmark" aria-label="KARINEX Startseite">
        <span class="kx-menu__wordmark-text">KARINEX</span>
        <span class="kx-menu__wordmark-dot" aria-hidden="true"></span>
      </a>
    </div>
    <div class="kx-menu__header-state kx-menu__header-state--l2" data-state="l2" aria-hidden="true">
      <button type="button" class="kx-menu__back" id="cmm-back" aria-label="Zurück">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 6 9 12 15 18"/>
        </svg>
        <span class="kx-menu__back-label" id="cmm-back-label">Zurück</span>
      </button>
    </div>
    <button type="button" class="kx-menu__close" id="cmm-close" aria-label="Menü schließen">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>
  </header>

  {%- comment -%} ============== VIEWPORT — horizontal slide track ============== {%- endcomment -%}
  <div class="kx-menu__viewport">
    <div class="kx-menu__track">

      {%- comment -%} ====== LEVEL 1 ====== {%- endcomment -%}
      <section class="kx-menu__panel kx-menu__panel--l1" data-level="1">

        {%- comment -%} ----- Categories grid (drillable) ----- {%- endcomment -%}
        <div class="kx-menu__stage kx-menu__cat-block" data-stage="2">
          <div class="kx-menu__cat-grid">
            {%- for key in drill_keys -%}
              {%- assign label_key  = key | append: '_label' -%}
              {%- assign mark_key   = key | append: '_mark'  -%}
              {%- assign direct_key = key | append: '_link'  -%}
              {%- assign label  = section.settings[label_key] -%}
              {%- assign mark   = section.settings[mark_key] -%}
              {%- assign direct = section.settings[direct_key] -%}
              {%- assign has_products = false -%}
              {%- for i in (1..8) -%}
                {%- assign ph_key = key | append: '_product_' | append: i -%}
                {%- assign ph = section.settings[ph_key] -%}
                {%- if ph != blank -%}
                  {%- assign p = all_products[ph] -%}
                  {%- if p != blank and p.handle != blank -%}
                    {%- assign has_products = true -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_products -%}
                <button type="button" class="kx-menu__cat-card" data-drill="{{ key }}" data-parent-label="{{ label | escape }}">
                  <span class="kx-menu__cat-name">{{ label }}</span>
                  <span class="kx-menu__cat-mark" aria-hidden="true">{{ mark }}</span>
                </button>
              {%- elsif direct != blank -%}
                <a href="{{ direct }}" class="kx-menu__cat-card" data-haptic>
                  <span class="kx-menu__cat-name">{{ label }}</span>
                  <span class="kx-menu__cat-mark" aria-hidden="true">{{ mark }}</span>
                </a>
              {%- endif -%}
            {%- endfor -%}

            {%- if section.settings.all_link != blank -%}
              <a href="{{ section.settings.all_link }}" class="kx-menu__cat-card" data-haptic>
                <span class="kx-menu__cat-name">{{ section.settings.all_label | default: 'Alle Produkte' }}</span>
                <span class="kx-menu__cat-mark" aria-hidden="true">&amp;</span>
              </a>
            {%- endif -%}

            {%- if section.settings.offers_link != blank -%}
              <a href="{{ section.settings.offers_link }}" class="kx-menu__cat-card kx-menu__cat-card--accent" data-haptic>
                <span class="kx-menu__cat-name kx-menu__cat-name--italic">{{ section.settings.offers_label | default: 'Angebote' }}</span>
                <span class="kx-menu__cat-mark kx-menu__cat-mark--accent" aria-hidden="true">%</span>
              </a>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ----- Service list (no overline) ----- {%- endcomment -%}
        <div class="kx-menu__stage kx-menu__service-block" data-stage="3">
          <ul class="kx-menu__service-list" role="list">
            <li class="kx-menu__service-item">
              <a href="{{ section.settings.link_account | default: routes.account_url }}">
                <span>Mein Konto</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              </a>
            </li>
            <li class="kx-menu__service-item">
              <a href="{{ section.settings.link_orders | default: routes.account_url }}">
                <span>Bestellungen</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              </a>
            </li>
            <li class="kx-menu__service-item">
              <a href="{{ section.settings.link_wishlist | default: '/pages/wishlist' }}">
                <span>Merkliste</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              </a>
            </li>
            <li class="kx-menu__service-item">
              <a href="{{ section.settings.link_support | default: '/pages/kontakt' }}">
                <span>Kundensupport</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              </a>
            </li>
            <li class="kx-menu__service-item">
              <a href="{{ section.settings.link_shipping | default: '/pages/versand' }}">
                <span>Versand &amp; Lieferung</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              </a>
            </li>
          </ul>
        </div>

        {%- comment -%} ----- Locale switcher (language + country) ----- {%- endcomment -%}
        {%- liquid
          case request.locale.iso_code
            when 'en'
              assign _T_region = 'Language & Region'
              assign _T_lang   = 'Language'
              assign _T_land   = 'Country'
            when 'pl'
              assign _T_region = 'Język i region'
              assign _T_lang   = 'Język'
              assign _T_land   = 'Kraj'
            when 'sv'
              assign _T_region = 'Språk & region'
              assign _T_lang   = 'Språk'
              assign _T_land   = 'Land'
            else
              assign _T_region = 'Sprache & Region'
              assign _T_lang   = 'Sprache'
              assign _T_land   = 'Land'
          endcase

          assign _cur_lang_flag = ''
          case localization.language.iso_code
            when 'de' then assign _cur_lang_flag = '🇩🇪'
            when 'en' then assign _cur_lang_flag = '🇬🇧'
            when 'pl' then assign _cur_lang_flag = '🇵🇱'
            when 'sv' then assign _cur_lang_flag = '🇸🇪'
            when 'nl' then assign _cur_lang_flag = '🇳🇱'
            when 'da' then assign _cur_lang_flag = '🇩🇰'
            when 'nb' then assign _cur_lang_flag = '🇳🇴'
            when 'fi' then assign _cur_lang_flag = '🇫🇮'
            when 'fr' then assign _cur_lang_flag = '🇫🇷'
            when 'it' then assign _cur_lang_flag = '🇮🇹'
            when 'es' then assign _cur_lang_flag = '🇪🇸'
            when 'pt-PT' then assign _cur_lang_flag = '🇵🇹'
            when 'pt-BR' then assign _cur_lang_flag = '🇧🇷'
          endcase
        -%}
        <div class="kx-menu__stage kx-menu__locale-block" data-stage="4">
          {%- form 'localization', id: 'KxMobileMenuLocaleForm', class: 'kx-menu__locale-form' -%}
            <input type="hidden" name="return_to" value="{{ request.path }}">

            <label class="kx-menu__locale-row" for="kxMobileLangSelect">
              <span class="kx-menu__locale-row-label">{{ _T_lang }}</span>
              <span class="kx-menu__locale-row-value">
                {%- if _cur_lang_flag != '' -%}<span class="kx-menu__locale-flag" aria-hidden="true">{{ _cur_lang_flag }}</span>{%- endif -%}
                <span class="kx-menu__locale-row-text">{{ localization.language.endonym_name | capitalize }}</span>
              </span>
              <svg class="kx-menu__locale-row-caret" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              <select id="kxMobileLangSelect" name="language_code" aria-label="{{ _T_lang }}" class="kx-menu__locale-hidden-select" data-kx-locale-trigger="language">
                {%- for language in localization.available_languages -%}
                  {%- assign _f = '' -%}
                  {%- case language.iso_code -%}
                    {%- when 'de' -%}{%- assign _f = '🇩🇪' -%}
                    {%- when 'en' -%}{%- assign _f = '🇬🇧' -%}
                    {%- when 'pl' -%}{%- assign _f = '🇵🇱' -%}
                    {%- when 'sv' -%}{%- assign _f = '🇸🇪' -%}
                    {%- when 'nl' -%}{%- assign _f = '🇳🇱' -%}
                    {%- when 'da' -%}{%- assign _f = '🇩🇰' -%}
                    {%- when 'nb' -%}{%- assign _f = '🇳🇴' -%}
                    {%- when 'fi' -%}{%- assign _f = '🇫🇮' -%}
                    {%- when 'fr' -%}{%- assign _f = '🇫🇷' -%}
                    {%- when 'it' -%}{%- assign _f = '🇮🇹' -%}
                    {%- when 'es' -%}{%- assign _f = '🇪🇸' -%}
                    {%- when 'pt-PT' -%}{%- assign _f = '🇵🇹' -%}
                    {%- when 'pt-BR' -%}{%- assign _f = '🇧🇷' -%}
                  {%- endcase -%}
                  <option value="{{ language.iso_code }}" lang="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                    {%- if _f != '' -%}{{ _f }}  {% endif -%}{{ language.endonym_name | capitalize }}
                  </option>
                {%- endfor -%}
              </select>
            </label>

            <label class="kx-menu__locale-row" for="kxMobileCountrySelect">
              <span class="kx-menu__locale-row-label">{{ _T_land }}</span>
              <span class="kx-menu__locale-row-value">
                <span class="kx-menu__locale-row-text">{{ localization.country.name }}</span>
                <span class="kx-menu__locale-currency">{{ localization.country.currency.iso_code }}</span>
              </span>
              <svg class="kx-menu__locale-row-caret" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
              <select id="kxMobileCountrySelect" name="country_code" aria-label="{{ _T_land }}" class="kx-menu__locale-hidden-select" data-kx-locale-trigger="country">
                {%- for country in localization.available_countries -%}
                  <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                    {{ country.name }} · {{ country.currency.iso_code }}
                  </option>
                {%- endfor -%}
              </select>
            </label>
          {%- endform -%}
        </div>

        <script>
        (function () {
          var form = document.getElementById('KxMobileMenuLocaleForm');
          if (!form) return;
          form.addEventListener('change', function (event) {
            var target = event.target;
            if (!target || !target.matches || !target.matches('[data-kx-locale-trigger]')) return;
            try {
              if (typeof form.requestSubmit === 'function') {
                form.requestSubmit();
              } else {
                form.submit();
              }
            } catch (e) {
              form.submit();
            }
          });
        })();
        </script>

        {%- comment -%} ----- Editorial Feature Block ----- {%- endcomment -%}
        {%- if section.settings.feature_headline != blank -%}
          <a href="{{ section.settings.feature_link | default: '/' }}" class="kx-menu__feature kx-menu__stage" data-stage="4">
            {%- if section.settings.feature_overline != blank -%}
              <div class="kx-menu__feature-overline">{{ section.settings.feature_overline }}</div>
            {%- endif -%}
            <h3 class="kx-menu__feature-headline">{{ section.settings.feature_headline }}</h3>
            {%- if section.settings.feature_body != blank -%}
              <p class="kx-menu__feature-body">{{ section.settings.feature_body }}</p>
            {%- endif -%}
            {%- if section.settings.feature_link_label != blank -%}
              <span class="kx-menu__feature-link">
                <span>{{ section.settings.feature_link_label }}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="4" y1="12" x2="20" y2="12"/>
                  <polyline points="14 6 20 12 14 18"/>
                </svg>
              </span>
            {%- endif -%}
          </a>
        {%- endif -%}

        {%- comment -%} ----- Footer (always renders so the drawer bottom looks finished) ----- {%- endcomment -%}
        <footer class="kx-menu__footer kx-menu__stage" data-stage="5">
          <div class="kx-menu__footer-rule" aria-hidden="true"></div>
          <div class="kx-menu__footer-wordmark">KARINEX<span class="kx-menu__footer-dot" aria-hidden="true"></span></div>
          {%- if section.settings.footer_tagline != blank -%}
            <p class="kx-menu__tagline">{{ section.settings.footer_tagline }}</p>
          {%- else -%}
            <p class="kx-menu__tagline">Software, sorgfältig kuratiert.</p>
          {%- endif -%}
          <div class="kx-menu__footer-meta">
            <span class="kx-menu__locale">{{ localization.language.endonym_name | capitalize }}</span>
            <span class="kx-menu__footer-sep" aria-hidden="true">·</span>
            <span class="kx-menu__copyright">© {{ 'now' | date: '%Y' }} Karinex</span>
          </div>
          {%- if section.settings.footer_legal != blank -%}
            <p class="kx-menu__legal">{{ section.settings.footer_legal }}</p>
          {%- else -%}
            <p class="kx-menu__legal">Impressum · AGB · Datenschutz · Widerruf</p>
          {%- endif -%}
        </footer>

      </section>

      {%- comment -%} ====== LEVEL 2 — product name lists per category ====== {%- endcomment -%}
      <section class="kx-menu__panel kx-menu__panel--l2" data-level="2" aria-hidden="true">
        {%- for key in drill_keys -%}
          {%- assign l2_label_key = key | append: '_label' -%}
          {%- assign label = section.settings[l2_label_key] -%}
          {%- assign visible_count = 0 -%}
          {%- capture rows -%}
            {%- for i in (1..8) -%}
              {%- assign l2_ph_key = key | append: '_product_' | append: i -%}
              {%- assign ph = section.settings[l2_ph_key] -%}
              {%- if ph != blank -%}
                {%- assign p = all_products[ph] -%}
                {%- if p != blank and p.handle != blank -%}
                  {%- assign visible_count = visible_count | plus: 1 -%}
                  <a href="{{ p.url }}" class="kx-menu__l2-row" data-haptic>
                    <span class="kx-menu__l2-name">{{ p.title }}</span>
                    <svg class="kx-menu__l2-chev" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
                  </a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endcapture -%}
          {%- if visible_count > 0 -%}
            <nav class="kx-menu__sub" data-sub="{{ key }}" hidden aria-label="{{ label | escape }}">
              <div class="kx-menu__sub-overline">{{ label | upcase }}</div>
              <div class="kx-menu__sub-rule" aria-hidden="true"></div>
              {{ rows }}
            </nav>
          {%- endif -%}
        {%- endfor -%}
      </section>

    </div>
  </div>
</aside>

{%- stylesheet -%}
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap');

.kx-menu-backdrop {
  --kx-bg: #FAFAFA;
  --kx-card: #F2EFE9;
  --kx-forest: #1D4739;
  --kx-gold: #C9B486;
  --kx-black: #0A0A0A;
  --kx-charcoal: #3A3A3A;
  --kx-gray: #6A6A6A;
  --kx-hairline: #E5E0D5;
  --kx-beige: #D4CDB8;
  --kx-muted-green: #8FA39A;
  --kx-spring: cubic-bezier(0.32, 0.72, 0, 1);
  --kx-slide:  cubic-bezier(0.22, 0.61, 0.36, 1);
  position: fixed;
  inset: 0;
  background: rgba(10, 10, 10, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 220ms ease, visibility 0s linear 220ms;
  z-index: 9998;
  /* Swallow all gestures so the visible page strip (right ~12 vw)
     can't drive page scroll under the drawer. Click still fires for
     the close-on-backdrop handler. */
  touch-action: none;
  -webkit-user-select: none;
  user-select: none;
}
.kx-menu-backdrop.is-open {
  opacity: 1;
  visibility: visible;
  transition: opacity 240ms ease, visibility 0s linear 0s;
}

.kx-menu {
  --kx-bg: #FAFAFA;
  --kx-card: #F2EFE9;
  --kx-forest: #1D4739;
  --kx-gold: #C9B486;
  --kx-black: #0A0A0A;
  --kx-charcoal: #3A3A3A;
  --kx-gray: #6A6A6A;
  --kx-hairline: #E5E0D5;
  --kx-beige: #D4CDB8;
  --kx-muted-green: #8FA39A;
  --kx-spring: cubic-bezier(0.32, 0.72, 0, 1);
  --kx-slide:  cubic-bezier(0.22, 0.61, 0.36, 1);
  position: fixed;
  top: 0;
  left: 0;
  height: 100vh;
  height: 100dvh;
  width: 88vw;
  max-width: 380px;
  background: var(--kx-bg);
  color: var(--kx-black);
  font-family: "Outfit", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  box-shadow: 0 0 0 rgba(0, 0, 0, 0);
  transition:
    transform 520ms var(--kx-spring),
    box-shadow 520ms var(--kx-spring);
  z-index: 9999;
  overflow: hidden;
  visibility: hidden;
}
.kx-menu.is-open {
  transform: translateX(0);
  box-shadow: 24px 0 56px -16px rgba(10, 10, 10, 0.18);
  visibility: visible;
}
.kx-menu *, .kx-menu *::before, .kx-menu *::after { box-sizing: border-box; }
.kx-menu a { color: inherit; text-decoration: none; }
.kx-menu button { font: inherit; color: inherit; background: transparent; border: 0; padding: 0; cursor: pointer; }

/* ---------- Header ---------- */
.kx-menu__header {
  flex-shrink: 0;
  position: relative;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  background: var(--kx-bg);
  z-index: 5;
  border: 0 !important;
  border-bottom: 0 !important;
  box-shadow: none !important;
}
/* Kill any hairline the host theme's header may leave at the seam
   between the page header and the drawer body when the drawer is open. */
body:has(.kx-menu.is-open) .header,
body:has(.kx-menu.is-open) .header-section,
body:has(.kx-menu.is-open) .ay-utility-bar,
body:has(.kx-menu.is-open) header.section-header {
  border-bottom: 0 !important;
  box-shadow: none !important;
}
.kx-menu__header-state {
  position: absolute;
  left: 24px;
  right: 64px;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  transition: opacity 220ms ease, transform 280ms var(--kx-slide);
}
.kx-menu__header-state--l1 { opacity: 1; transform: translateX(0); }
.kx-menu__header-state--l2 { opacity: 0; transform: translateX(12px); pointer-events: none; }
.kx-menu.is-l2 .kx-menu__header-state--l1 { opacity: 0; transform: translateX(-12px); pointer-events: none; }
.kx-menu.is-l2 .kx-menu__header-state--l2 { opacity: 1; transform: translateX(0); pointer-events: auto; }

.kx-menu__wordmark {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 14px;
  text-transform: uppercase;
  color: var(--kx-black);
  opacity: 0;
  transform: translateY(4px);
  line-height: 1;
  transition: opacity 480ms ease, letter-spacing 640ms var(--kx-spring), transform 480ms var(--kx-spring);
  transition-delay: 220ms;
}
.kx-menu__wordmark-text { display: inline-block; }
.kx-menu__wordmark-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--kx-gold);
  margin-left: -10px;
  flex-shrink: 0;
  transform: translateY(-1px);
}
.kx-menu.is-open .kx-menu__wordmark { opacity: 1; letter-spacing: 8px; transform: translateY(0); }

.kx-menu__back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: "Newsreader", Georgia, serif;
  font-size: 18px;
  font-weight: 500;
  color: var(--kx-black);
  line-height: 1;
  transition: color 150ms ease;
}
.kx-menu__back svg { color: var(--kx-charcoal); transition: color 150ms ease, transform 200ms ease; }
.kx-menu__back:hover { color: var(--kx-forest); }
.kx-menu__back:hover svg { color: var(--kx-forest); transform: translateX(-3px); }
.kx-menu__back-label { display: inline-block; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.kx-menu__close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  margin-right: -8px;
  color: var(--kx-black);
  opacity: 0;
  transition: color 150ms ease, opacity 320ms ease;
  transition-delay: 280ms;
  position: relative;
  z-index: 2;
  margin-left: auto;
}
.kx-menu.is-open .kx-menu__close { opacity: 1; }
.kx-menu__close:hover { color: var(--kx-forest); }

/* ---------- Viewport / Track (horizontal slide L1↔L2) ---------- */
.kx-menu__viewport {
  flex: 1;
  position: relative;
  overflow: hidden;
}
.kx-menu__track {
  display: flex;
  width: 200%;
  height: 100%;
  transform: translateX(0);
  transition: transform 320ms var(--kx-slide);
}
.kx-menu.is-l2 .kx-menu__track { transform: translateX(-50%); }

.kx-menu__panel {
  width: 50%;
  flex-shrink: 0;
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
  scrollbar-width: none;
  -ms-overflow-style: none;
  /* L1: flex column so the footer can pin to the bottom even when
     the cat-grid + service list don't fill the viewport. */
  display: flex;
  flex-direction: column;
}
.kx-menu__panel::-webkit-scrollbar { width: 0; height: 0; display: none; background: transparent; }
.kx-menu, .kx-menu * { scrollbar-width: none; -ms-overflow-style: none; }
.kx-menu *::-webkit-scrollbar { width: 0; height: 0; display: none; }

/* ---------- Staged reveal (L1 only) ---------- */
.kx-menu__stage {
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 380ms ease, transform 480ms var(--kx-spring);
}
.kx-menu.is-open .kx-menu__stage { opacity: 1; transform: translateY(0); }
.kx-menu.is-open .kx-menu__stage[data-stage="1"] { transition-delay: 320ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="2"] { transition-delay: 380ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="3"] { transition-delay: 440ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="4"] { transition-delay: 500ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="5"] { transition-delay: 560ms; }

/* ---------- Bestseller grid (2x3 = 6 cards) ---------- */
.kx-menu__bestseller-grid {
  margin-top: 24px;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.kx-menu__bs-card {
  display: flex;
  flex-direction: column;
  background: var(--kx-card);
  border-radius: 6px;
  overflow: hidden;
  transition: transform 150ms ease;
}
.kx-menu__bs-card:active { transform: scale(0.98); }
.kx-menu__bs-img-wrap {
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
  background: var(--kx-card);
  border-radius: 6px 6px 0 0;
}
.kx-menu__bs-img {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
}
.kx-menu__bs-name {
  padding: 10px 10px 2px;
  font-family: "Newsreader", Georgia, serif;
  font-size: 13px;
  font-weight: 500;
  line-height: 1.3;
  color: var(--kx-black);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.kx-menu__bs-price {
  padding: 0 10px 10px;
  font-family: "Outfit", Arial, sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: var(--kx-forest);
  letter-spacing: 0.2px;
}

/* ---------- Categories grid (drillable, 2 cols × N rows) ---------- */
.kx-menu__cat-block { margin-top: 40px; }
.kx-menu__cat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 0 24px;
}
.kx-menu__cat-card {
  position: relative;
  height: 92px;
  padding: 14px;
  background: var(--kx-card);
  border-radius: 6px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  text-align: left;
  width: 100%;
  transition: background 220ms ease, color 220ms ease, transform 150ms ease;
}
.kx-menu__cat-card:active { transform: scale(0.985); }
.kx-menu__cat-name {
  font-family: "Newsreader", Georgia, serif;
  font-size: 18px;
  font-weight: 500;
  line-height: 1.18;
  color: var(--kx-black);
  position: relative;
  z-index: 2;
  max-width: 70%;
  transition: color 220ms ease;
}
.kx-menu__cat-name--italic { font-style: italic; }
.kx-menu__cat-mark {
  position: absolute;
  bottom: 4px;
  right: 10px;
  font-family: "Newsreader", Georgia, serif;
  font-style: italic;
  font-weight: 400;
  font-size: 40px;
  line-height: 1;
  color: var(--kx-forest);
  opacity: 0.12;
  z-index: 1;
  user-select: none;
  transition: color 220ms ease, opacity 220ms ease;
}
.kx-menu__cat-mark--accent { color: var(--kx-gold); opacity: 0.9; font-size: 38px; }
.kx-menu__cat-card:hover, .kx-menu__cat-card:focus-visible, .kx-menu__cat-card:active {
  background: var(--kx-forest);
  outline: none;
}
.kx-menu__cat-card:hover .kx-menu__cat-name,
.kx-menu__cat-card:focus-visible .kx-menu__cat-name,
.kx-menu__cat-card:active .kx-menu__cat-name { color: var(--kx-bg); }
.kx-menu__cat-card:hover .kx-menu__cat-mark,
.kx-menu__cat-card:focus-visible .kx-menu__cat-mark,
.kx-menu__cat-card:active .kx-menu__cat-mark { color: var(--kx-gold); opacity: 0.25; }

/* ---------- L2 product list ---------- */
.kx-menu__sub {
  display: flex;
  flex-direction: column;
  padding: 28px 0 32px;
}
.kx-menu__sub[hidden] { display: none; }
.kx-menu__sub-overline {
  font-family: "Outfit", Arial, sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--kx-gold);
  padding: 0 24px;
  margin-bottom: 12px;
}
.kx-menu__sub-rule {
  height: 1px;
  background: var(--kx-hairline);
  margin: 0 24px 8px;
}
.kx-menu__l2-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  width: 100%;
  padding: 18px 24px;
  border-bottom: 1px solid var(--kx-hairline);
  transition: padding 220ms var(--kx-slide), background 220ms ease;
}
.kx-menu__l2-row:last-child { border-bottom: 0; }
.kx-menu__l2-name {
  font-family: "Newsreader", Georgia, serif;
  font-size: 18px;
  font-weight: 500;
  line-height: 1.32;
  color: var(--kx-black);
  flex: 1;
  min-width: 0;
  transition: color 150ms ease, transform 220ms var(--kx-slide);
  display: inline-block;
}
.kx-menu__l2-chev {
  color: var(--kx-gray);
  flex-shrink: 0;
  transition: color 200ms ease, transform 220ms var(--kx-slide);
}
.kx-menu__l2-row:hover .kx-menu__l2-name,
.kx-menu__l2-row:focus-visible .kx-menu__l2-name,
.kx-menu__l2-row:active .kx-menu__l2-name {
  transform: translateX(3px);
  color: var(--kx-forest);
}
.kx-menu__l2-row:hover .kx-menu__l2-chev,
.kx-menu__l2-row:focus-visible .kx-menu__l2-chev,
.kx-menu__l2-row:active .kx-menu__l2-chev {
  color: var(--kx-gold);
  transform: translateX(2px);
}

/* ---------- Service list ---------- */
.kx-menu__service-block { margin-top: 40px; }
.kx-menu__service-list { list-style: none; margin: 0; padding: 0 24px; }
.kx-menu__service-item a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
  font-family: "Outfit", Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  color: var(--kx-charcoal);
  border-bottom: 1px solid var(--kx-hairline);
  transition: color 150ms ease, padding-left 200ms var(--kx-spring);
}
.kx-menu__service-item:last-child a { border-bottom: 0; }
.kx-menu__service-item a svg { color: var(--kx-gray); transition: color 150ms ease, transform 200ms ease; }
.kx-menu__service-item a:hover, .kx-menu__service-item a:focus-visible { color: var(--kx-forest); padding-left: 4px; }
.kx-menu__service-item a:hover svg, .kx-menu__service-item a:focus-visible svg { color: var(--kx-gold); transform: translateX(3px); }

/* ---------- Locale switcher (Sprache & Region) ---------- */
.kx-menu__locale-block { margin: 0; padding: 0 24px; }
.kx-menu__locale-form { display: block; margin: 0; }
.kx-menu__locale-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px 0;
  border-bottom: 1px solid var(--kx-hairline);
  font-family: "Outfit", Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  color: var(--kx-charcoal);
  cursor: pointer;
}
.kx-menu__locale-row:last-child { border-bottom: 0; }
.kx-menu__locale-row-label { flex-shrink: 0; pointer-events: none; }
.kx-menu__locale-row-value {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
  padding-right: 22px; /* space for caret */
  color: var(--kx-gray);
  font-size: 15px;
  font-weight: 400;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  pointer-events: none;
}
.kx-menu__locale-row-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.kx-menu__locale-currency {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--kx-gray);
  padding: 2px 6px;
  border: 1px solid var(--kx-hairline);
  border-radius: 4px;
}
.kx-menu__locale-flag { font-size: 18px; line-height: 1; }
.kx-menu__locale-row-caret {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: var(--kx-gray);
  pointer-events: none;
  transition: color 150ms ease;
}
.kx-menu__locale-row:focus-within .kx-menu__locale-row-caret { color: var(--kx-gold); }
/* Hide the native <select> but keep it focusable so the wrapping <label>
   forwards taps to it — opening the iOS / Android native picker. */
.kx-menu__locale-hidden-select {
  position: absolute;
  left: 0;
  top: 0;
  width: 1px;
  height: 1px;
  opacity: 0;
  border: 0;
  padding: 0;
  margin: 0;
  font-size: 16px; /* prevent iOS zoom */
  overflow: hidden;
  /* Keep it focusable: don't use display:none or visibility:hidden */
}

/* Suppress non-keyboard focus ring on the hamburger summary; iOS Safari
   moves focus there when the in-menu <select> picker opens, which the
   merchant flagged as an unwanted rectangle around the menu icon. Base
   theme uses *:focus-visible { outline ... } so we have to override
   :focus-visible too (and use !important to win specificity). */
.header__icon--menu,
.header__icon--summary,
.header__icon--menu:focus,
.header__icon--summary:focus,
.header__icon--menu:focus-visible,
.header__icon--summary:focus-visible {
  outline: none !important;
  box-shadow: none !important;
}
.kx-menu .kx-menu__locale-row,
.kx-menu .kx-menu__locale-select,
.kx-menu__locale-row * {
  -webkit-tap-highlight-color: transparent;
}

/* ---------- Editorial Feature ---------- */
.kx-menu__feature {
  display: block;
  margin: 40px 0 0;
  background: var(--kx-forest);
  color: var(--kx-beige);
  padding: 48px 24px;
}
.kx-menu__feature-overline {
  font-family: "Outfit", Arial, sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--kx-gold);
  margin-bottom: 16px;
}
.kx-menu__feature-headline {
  font-family: "Newsreader", Georgia, serif;
  font-style: italic;
  font-weight: 400;
  font-size: 28px;
  line-height: 1.18;
  color: var(--kx-bg);
  margin: 0 0 12px;
}
.kx-menu__feature-body {
  font-family: "Newsreader", Georgia, serif;
  font-size: 15px;
  line-height: 1.55;
  color: var(--kx-beige);
  margin: 0;
  font-weight: 400;
}
.kx-menu__feature-link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 24px;
  font-family: "Outfit", Arial, sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--kx-gold);
  border-bottom: 1px solid var(--kx-gold);
  padding-bottom: 4px;
  transition: gap 200ms ease, color 150ms ease, border-color 150ms ease;
}
.kx-menu__feature:hover .kx-menu__feature-link { gap: 16px; color: var(--kx-bg); border-color: var(--kx-bg); }

/* ---------- Footer ---------- */
.kx-menu__footer {
  background: var(--kx-bg);
  padding: 32px 24px calc(36px + env(safe-area-inset-bottom, 0px));
  margin-top: auto; /* pin to the bottom of the L1 panel */
}
.kx-menu__footer-rule {
  height: 1px;
  background: var(--kx-hairline);
  margin: 0 0 24px;
}
.kx-menu__footer-wordmark {
  font-family: "Outfit", Arial, sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 8px;
  text-transform: uppercase;
  color: var(--kx-black);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  line-height: 1;
}
.kx-menu__footer-dot {
  display: inline-block;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--kx-gold);
  margin-left: -6px;
  transform: translateY(-1px);
}
.kx-menu__tagline {
  font-family: "Newsreader", Georgia, serif;
  font-style: italic;
  font-size: 14px;
  color: var(--kx-gray);
  margin: 14px 0 0;
  line-height: 1.4;
}
.kx-menu__footer-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 22px;
  font-family: "Outfit", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--kx-gray);
}
.kx-menu__locale { font-family: inherit; font-size: inherit; color: inherit; letter-spacing: inherit; }
.kx-menu__footer-sep { color: var(--kx-hairline); }
.kx-menu__copyright { color: var(--kx-gray); }
.kx-menu__legal {
  font-family: "Outfit", Arial, sans-serif;
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--kx-muted-green);
  margin: 14px 0 0;
  line-height: 1.6;
}

@media (min-width: 990px) {
  .kx-menu, .kx-menu-backdrop { display: none; }
}

@media (prefers-reduced-motion: reduce) {
  .kx-menu {
    transition: opacity 200ms ease, visibility 0s linear 200ms;
    transform: translateX(0);
    opacity: 0;
  }
  .kx-menu.is-open { opacity: 1; transition: opacity 200ms ease, visibility 0s linear 0s; }
  .kx-menu__wordmark, .kx-menu__close, .kx-menu__stage, .kx-menu__header-state, .kx-menu__track {
    opacity: 1 !important;
    transform: none !important;
    letter-spacing: 8px !important;
    transition: none !important;
  }
  .kx-menu.is-l2 .kx-menu__track { transform: translateX(-50%) !important; }
}
{%- endstylesheet -%}

<script>
(function () {
  function initKarinexMenu() {
    var menu = document.getElementById('custom-mobile-menu');
    var backdrop = document.getElementById('cmm-backdrop');
    var closeBtn = document.getElementById('cmm-close');
    var backBtn = document.getElementById('cmm-back');
    var backLabel = document.getElementById('cmm-back-label');
    if (!menu) return;

    var lastFocused = null;
    var savedScrollY = 0;
    var l2Panel = menu.querySelector('.kx-menu__panel--l2');
    var l1Panel = menu.querySelector('.kx-menu__panel--l1');
    var subPanels = menu.querySelectorAll('.kx-menu__sub');

    function lightHaptic() {
      if (window.navigator && window.navigator.vibrate) {
        try { window.navigator.vibrate(8); } catch (e) {}
      }
    }

    function showSub(key) {
      subPanels.forEach(function (s) {
        if (s.getAttribute('data-sub') === key) {
          s.removeAttribute('hidden');
        } else {
          s.setAttribute('hidden', '');
        }
      });
    }

    function drillDown(key, parentLabel) {
      lightHaptic();
      showSub(key);
      if (backLabel) backLabel.textContent = parentLabel || 'Zurück';
      menu.classList.add('is-l2');
      if (l2Panel) {
        l2Panel.setAttribute('aria-hidden', 'false');
        l2Panel.scrollTop = 0;
      }
      if (l1Panel) l1Panel.setAttribute('aria-hidden', 'true');
      setTimeout(function () { if (backBtn) backBtn.focus(); }, 200);
    }

    function goBack() {
      lightHaptic();
      menu.classList.remove('is-l2');
      if (l2Panel) l2Panel.setAttribute('aria-hidden', 'true');
      if (l1Panel) l1Panel.setAttribute('aria-hidden', 'false');
      setTimeout(function () { if (closeBtn) closeBtn.focus(); }, 200);
    }

    function openMenu() {
      lastFocused = document.activeElement;
      menu.classList.add('is-open');
      if (backdrop) backdrop.classList.add('is-open');
      // iOS-Safari-safe body scroll lock: pin <body> at -scrollY so the
      // page underneath cannot move while the drawer is open.
      savedScrollY = window.scrollY || window.pageYOffset || 0;
      var b = document.body.style;
      b.position = 'fixed';
      b.top      = '-' + savedScrollY + 'px';
      b.left     = '0';
      b.right    = '0';
      b.width    = '100%';
      b.overflow = 'hidden';
      var nativeDrawer = document.getElementById('Details-menu-drawer-container');
      if (nativeDrawer) {
        nativeDrawer.removeAttribute('open');
        nativeDrawer.classList.remove('menu-open');
      }
      document.body.classList.remove('overflow-hidden');
      setTimeout(function () { if (closeBtn) closeBtn.focus(); }, 220);
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      if (backdrop) backdrop.classList.remove('is-open');
      // Release the body lock and restore the exact pre-open scroll
      // position — without this iOS jumps the page to top.
      var b = document.body.style;
      b.position = '';
      b.top      = '';
      b.left     = '';
      b.right    = '';
      b.width    = '';
      b.overflow = '';
      window.scrollTo(0, savedScrollY);
      setTimeout(function () {
        menu.classList.remove('is-l2');
        if (l2Panel) l2Panel.setAttribute('aria-hidden', 'true');
        if (l1Panel) l1Panel.setAttribute('aria-hidden', 'false');
      }, 540);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    if (closeBtn) closeBtn.addEventListener('click', function (e) { e.preventDefault(); closeMenu(); });
    if (backdrop) backdrop.addEventListener('click', closeMenu);
    if (backBtn) backBtn.addEventListener('click', function (e) { e.preventDefault(); goBack(); });

    menu.querySelectorAll('[data-drill]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        drillDown(btn.getAttribute('data-drill'), btn.getAttribute('data-parent-label'));
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        if (menu.classList.contains('is-l2')) goBack();
        else closeMenu();
      }
    });

    /* Hijack the theme's hamburger trigger — toggle (open / close) */
    document.body.addEventListener('click', function (e) {
      if (window.innerWidth > 990) return;
      var trigger = e.target.closest('.header__icon--menu, [data-header-drawer], .header__drawer summary, .header__icon--menu span');
      if (!trigger) return;
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      if (menu.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu();
      }
      return false;
    }, true);

    /* Haptic on category and product taps */
    menu.querySelectorAll('[data-haptic], .kx-menu__bs-card').forEach(function (el) {
      el.addEventListener('click', lightHaptic);
    });

    /* Swipe gestures: L1 swipe-left closes; L2 swipe-right goes back */
    var startX = null, startY = null;
    menu.addEventListener('touchstart', function (e) {
      if (e.touches.length === 1) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      }
    }, { passive: true });
    menu.addEventListener('touchend', function (e) {
      if (startX === null) return;
      var t = e.changedTouches[0] || {};
      var dx = (t.clientX || startX) - startX;
      var ady = Math.abs(startY - (t.clientY || startY));
      if (ady < 40) {
        if (menu.classList.contains('is-l2') && dx > 60) {
          goBack();
        } else if (!menu.classList.contains('is-l2') && dx < -60) {
          closeMenu();
        }
      }
      startX = null;
      startY = null;
    });

    /* Focus trap */
    menu.addEventListener('keydown', function (e) {
      if (e.key !== 'Tab' || !menu.classList.contains('is-open')) return;
      var scope = menu.classList.contains('is-l2') ? l2Panel : l1Panel;
      var headerScope = menu.querySelector(menu.classList.contains('is-l2') ? '.kx-menu__header-state--l2' : '.kx-menu__header-state--l1');
      var nodes = [];
      if (headerScope) nodes = nodes.concat(Array.prototype.slice.call(headerScope.querySelectorAll('a[href], button:not([disabled])')));
      if (closeBtn) nodes.push(closeBtn);
      if (scope) {
        var visible = scope.querySelectorAll('a[href], button:not([disabled])');
        nodes = nodes.concat(Array.prototype.slice.call(visible).filter(function (n) {
          return !n.closest('[hidden]');
        }));
      }
      if (!nodes.length) return;
      var first = nodes[0];
      var last = nodes[nodes.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initKarinexMenu);
  } else {
    initKarinexMenu();
  }
})();
</script>
