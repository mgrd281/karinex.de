{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}

{% schema %}
{
  "name": "Custom Mobile Menu",
  "settings": [
    { "type": "header", "content": "Microsoft Office (Drill-down)" },
    { "type": "text", "id": "office_label", "label": "Label", "default": "Microsoft Office" },
    { "type": "text", "id": "office_sub_1_label", "label": "Sub 1 — Label", "default": "Office 2024" },
    { "type": "url",  "id": "office_sub_1_url",   "label": "Sub 1 — Link" },
    { "type": "text", "id": "office_sub_2_label", "label": "Sub 2 — Label", "default": "Office 2024 Übersicht" },
    { "type": "url",  "id": "office_sub_2_url",   "label": "Sub 2 — Link" },
    { "type": "text", "id": "office_sub_3_label", "label": "Sub 3 — Label", "default": "Microsoft Software" },
    { "type": "url",  "id": "office_sub_3_url",   "label": "Sub 3 — Link" },
    { "type": "text", "id": "office_sub_4_label", "label": "Sub 4 — Label" },
    { "type": "url",  "id": "office_sub_4_url",   "label": "Sub 4 — Link" },
    { "type": "text", "id": "office_sub_5_label", "label": "Sub 5 — Label" },
    { "type": "url",  "id": "office_sub_5_url",   "label": "Sub 5 — Link" },
    { "type": "text", "id": "office_sub_6_label", "label": "Sub 6 — Label" },
    { "type": "url",  "id": "office_sub_6_url",   "label": "Sub 6 — Link" },

    { "type": "header", "content": "Microsoft Windows (Drill-down)" },
    { "type": "text", "id": "windows_label", "label": "Label", "default": "Microsoft Windows" },
    { "type": "text", "id": "windows_sub_1_label", "label": "Sub 1 — Label", "default": "Windows 11" },
    { "type": "url",  "id": "windows_sub_1_url",   "label": "Sub 1 — Link" },
    { "type": "text", "id": "windows_sub_2_label", "label": "Sub 2 — Label", "default": "Windows 10" },
    { "type": "url",  "id": "windows_sub_2_url",   "label": "Sub 2 — Link" },
    { "type": "text", "id": "windows_sub_3_label", "label": "Sub 3 — Label" },
    { "type": "url",  "id": "windows_sub_3_url",   "label": "Sub 3 — Link" },
    { "type": "text", "id": "windows_sub_4_label", "label": "Sub 4 — Label" },
    { "type": "url",  "id": "windows_sub_4_url",   "label": "Sub 4 — Link" },
    { "type": "text", "id": "windows_sub_5_label", "label": "Sub 5 — Label" },
    { "type": "url",  "id": "windows_sub_5_url",   "label": "Sub 5 — Link" },
    { "type": "text", "id": "windows_sub_6_label", "label": "Sub 6 — Label" },
    { "type": "url",  "id": "windows_sub_6_url",   "label": "Sub 6 — Link" },

    { "type": "header", "content": "Direkte Links (kein Drill-down)" },
    { "type": "text", "id": "all_label",   "label": "Alle Produkte — Label",  "default": "Alle Produkte" },
    { "type": "url",  "id": "all_url",     "label": "Alle Produkte — Link" },
    { "type": "text", "id": "offers_label","label": "Angebote — Label",       "default": "Angebote" },
    { "type": "url",  "id": "offers_url",  "label": "Angebote — Link" },

    { "type": "header", "content": "Service" },
    { "type": "url", "id": "link_account",  "label": "Mein Konto" },
    { "type": "url", "id": "link_orders",   "label": "Bestellungen" },
    { "type": "url", "id": "link_wishlist", "label": "Merkliste" },
    { "type": "url", "id": "link_support",  "label": "Kundensupport" },
    { "type": "url", "id": "link_shipping", "label": "Versand & Lieferung" },

    { "type": "header", "content": "Editorial Feature Block" },
    { "type": "text",     "id": "feature_overline",   "label": "Overline",  "default": "EMPFEHLUNG" },
    { "type": "text",     "id": "feature_headline",   "label": "Headline",  "default": "Office, neu gedacht." },
    { "type": "textarea", "id": "feature_body",       "label": "Body",      "default": "Microsoft Office 2024 — die Werkzeuge, die seit Jahrzehnten den Standard definieren." },
    { "type": "text",     "id": "feature_link_label", "label": "Link Label","default": "ENTDECKEN" },
    { "type": "url",      "id": "feature_link",       "label": "Link" },

    { "type": "header", "content": "Footer" },
    { "type": "text", "id": "footer_tagline", "label": "Tagline", "default": "Software, sorgfältig kuratiert." },
    { "type": "text", "id": "footer_legal",   "label": "Legal links (separated by · )", "default": "Impressum · AGB · Datenschutz · Widerruf" }
  ]
}
{% endschema %}

{%- liquid
  assign office_subs_count = 0
  for i in (1..6)
    assign url_key   = 'office_sub_' | append: i | append: '_url'
    assign label_key = 'office_sub_' | append: i | append: '_label'
    assign u = section.settings[url_key]
    assign l = section.settings[label_key]
    if u != blank and l != blank
      assign office_subs_count = office_subs_count | plus: 1
    endif
  endfor

  assign windows_subs_count = 0
  for i in (1..6)
    assign url_key   = 'windows_sub_' | append: i | append: '_url'
    assign label_key = 'windows_sub_' | append: i | append: '_label'
    assign u = section.settings[url_key]
    assign l = section.settings[label_key]
    if u != blank and l != blank
      assign windows_subs_count = windows_subs_count | plus: 1
    endif
  endfor
-%}

<div class="kx-menu-backdrop" id="cmm-backdrop" aria-hidden="true"></div>

<aside
  id="custom-mobile-menu"
  class="kx-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Hauptmenü"
  tabindex="-1"
>
  {%- comment -%} ============== HEADER (dual-state) ============== {%- endcomment -%}
  <header class="kx-menu__header">
    <div class="kx-menu__header-state kx-menu__header-state--l1" data-state="l1">
      <a href="{{ _root }}" class="kx-menu__wordmark" aria-label="KARINEX Startseite">
        <span class="kx-menu__wordmark-text">KARINEX</span>
        <span class="kx-menu__wordmark-dot" aria-hidden="true"></span>
      </a>
    </div>
    <div class="kx-menu__header-state kx-menu__header-state--l2" data-state="l2" aria-hidden="true">
      <button type="button" class="kx-menu__back" id="cmm-back" aria-label="Zurück">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 6 9 12 15 18"/>
        </svg>
        <span class="kx-menu__back-label" id="cmm-back-label">Zurück</span>
      </button>
    </div>
    <button type="button" class="kx-menu__close" id="cmm-close" aria-label="Menü schließen">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>
  </header>

  {%- comment -%} ============== VIEWPORT — horizontal slide track ============== {%- endcomment -%}
  <div class="kx-menu__viewport">
    <div class="kx-menu__track" id="cmm-track">

      {%- comment -%} ====== LEVEL 1 ====== {%- endcomment -%}
      <section class="kx-menu__panel kx-menu__panel--l1" data-level="1">

        <nav class="kx-menu__l1-list kx-menu__stage" data-stage="1" aria-label="Hauptkategorien">
          {%- if office_subs_count > 0 -%}
            <button type="button" class="kx-menu__l1-row" data-drill="office" data-parent-label="{{ section.settings.office_label | escape }}">
              <span class="kx-menu__l1-name">{{ section.settings.office_label }}</span>
              <svg class="kx-menu__l1-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          {%- endif -%}

          {%- if windows_subs_count > 0 -%}
            <button type="button" class="kx-menu__l1-row" data-drill="windows" data-parent-label="{{ section.settings.windows_label | escape }}">
              <span class="kx-menu__l1-name">{{ section.settings.windows_label }}</span>
              <svg class="kx-menu__l1-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          {%- endif -%}

          {%- if section.settings.all_url != blank -%}
            <a href="{{ section.settings.all_url }}" class="kx-menu__l1-row" data-haptic>
              <span class="kx-menu__l1-name">{{ section.settings.all_label | default: 'Alle Produkte' }}</span>
              <svg class="kx-menu__l1-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          {%- endif -%}

          {%- if section.settings.offers_url != blank -%}
            <a href="{{ section.settings.offers_url }}" class="kx-menu__l1-row kx-menu__l1-row--accent" data-haptic>
              <span class="kx-menu__l1-name kx-menu__l1-name--italic">{{ section.settings.offers_label | default: 'Angebote' }}</span>
              <svg class="kx-menu__l1-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          {%- endif -%}
        </nav>

        <ul class="kx-menu__service-list kx-menu__stage" data-stage="2" role="list">
          <li class="kx-menu__service-item">
            <a href="{{ section.settings.link_account | default: routes.account_url }}">
              <span>Mein Konto</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          </li>
          <li class="kx-menu__service-item">
            <a href="{{ section.settings.link_orders | default: routes.account_url }}">
              <span>Bestellungen</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          </li>
          <li class="kx-menu__service-item">
            <a href="{{ section.settings.link_wishlist | default: '/pages/wishlist' }}">
              <span>Merkliste</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          </li>
          <li class="kx-menu__service-item">
            <a href="{{ section.settings.link_support | default: '/pages/contact' }}">
              <span>Kundensupport</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          </li>
          <li class="kx-menu__service-item">
            <a href="{{ section.settings.link_shipping | default: '/pages/versand' }}">
              <span>Versand &amp; Lieferung</span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
            </a>
          </li>
        </ul>

        {%- if section.settings.feature_headline != blank -%}
          <a href="{{ section.settings.feature_link | default: '/' }}" class="kx-menu__feature kx-menu__stage" data-stage="3">
            {%- if section.settings.feature_overline != blank -%}
              <div class="kx-menu__feature-overline">{{ section.settings.feature_overline }}</div>
            {%- endif -%}
            <h3 class="kx-menu__feature-headline">{{ section.settings.feature_headline }}</h3>
            {%- if section.settings.feature_body != blank -%}
              <p class="kx-menu__feature-body">{{ section.settings.feature_body }}</p>
            {%- endif -%}
            {%- if section.settings.feature_link_label != blank -%}
              <span class="kx-menu__feature-link">
                <span>{{ section.settings.feature_link_label }}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="4" y1="12" x2="20" y2="12"/>
                  <polyline points="14 6 20 12 14 18"/>
                </svg>
              </span>
            {%- endif -%}
          </a>
        {%- endif -%}

        <footer class="kx-menu__footer kx-menu__stage" data-stage="4">
          <div class="kx-menu__locale">Deutsch <span aria-hidden="true">⌄</span></div>
          {%- if section.settings.footer_tagline != blank -%}
            <p class="kx-menu__tagline">{{ section.settings.footer_tagline }}</p>
          {%- endif -%}
          {%- if section.settings.footer_legal != blank -%}
            <p class="kx-menu__legal">{{ section.settings.footer_legal }}</p>
          {%- endif -%}
        </footer>

      </section>

      {%- comment -%} ====== LEVEL 2 ====== {%- endcomment -%}
      <section class="kx-menu__panel kx-menu__panel--l2" data-level="2" aria-hidden="true">

        {%- if office_subs_count > 0 -%}
          <nav class="kx-menu__sub" data-sub="office" hidden aria-label="{{ section.settings.office_label | escape }}">
            {%- for i in (1..6) -%}
              {%- assign label_key = 'office_sub_' | append: i | append: '_label' -%}
              {%- assign url_key   = 'office_sub_' | append: i | append: '_url' -%}
              {%- assign sl = section.settings[label_key] -%}
              {%- assign su = section.settings[url_key] -%}
              {%- if sl != blank and su != blank -%}
                <a href="{{ su }}" class="kx-menu__l2-row" data-haptic>
                  <span class="kx-menu__l2-name">{{ sl }}</span>
                  <svg class="kx-menu__l1-chev" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}

        {%- if windows_subs_count > 0 -%}
          <nav class="kx-menu__sub" data-sub="windows" hidden aria-label="{{ section.settings.windows_label | escape }}">
            {%- for i in (1..6) -%}
              {%- assign label_key = 'windows_sub_' | append: i | append: '_label' -%}
              {%- assign url_key   = 'windows_sub_' | append: i | append: '_url' -%}
              {%- assign sl = section.settings[label_key] -%}
              {%- assign su = section.settings[url_key] -%}
              {%- if sl != blank and su != blank -%}
                <a href="{{ su }}" class="kx-menu__l2-row" data-haptic>
                  <span class="kx-menu__l2-name">{{ sl }}</span>
                  <svg class="kx-menu__l1-chev" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}

      </section>

    </div>
  </div>
</aside>

{%- stylesheet -%}
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap');

.kx-menu-backdrop {
  --kx-bg: #FAFAFA;
  --kx-card: #F2EFE9;
  --kx-forest: #1D4739;
  --kx-gold: #C9B486;
  --kx-black: #0A0A0A;
  --kx-charcoal: #3A3A3A;
  --kx-gray: #6A6A6A;
  --kx-hairline: #E5E0D5;
  --kx-beige: #D4CDB8;
  --kx-muted-green: #8FA39A;
  --kx-spring: cubic-bezier(0.32, 0.72, 0, 1);
  --kx-slide:  cubic-bezier(0.22, 0.61, 0.36, 1);
  position: fixed;
  inset: 0;
  background: rgba(10, 10, 10, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 220ms ease, visibility 0s linear 220ms;
  z-index: 9998;
}
.kx-menu-backdrop.is-open {
  opacity: 1;
  visibility: visible;
  transition: opacity 240ms ease, visibility 0s linear 0s;
}

.kx-menu {
  --kx-bg: #FAFAFA;
  --kx-card: #F2EFE9;
  --kx-forest: #1D4739;
  --kx-gold: #C9B486;
  --kx-black: #0A0A0A;
  --kx-charcoal: #3A3A3A;
  --kx-gray: #6A6A6A;
  --kx-hairline: #E5E0D5;
  --kx-beige: #D4CDB8;
  --kx-muted-green: #8FA39A;
  --kx-spring: cubic-bezier(0.32, 0.72, 0, 1);
  --kx-slide:  cubic-bezier(0.22, 0.61, 0.36, 1);
  position: fixed;
  top: 0;
  left: 0;
  height: 100vh;
  height: 100dvh;
  width: 88vw;
  max-width: 380px;
  background: var(--kx-bg);
  color: var(--kx-black);
  font-family: "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  box-shadow: 0 0 0 rgba(0, 0, 0, 0);
  transition:
    transform 520ms var(--kx-spring),
    box-shadow 520ms var(--kx-spring);
  z-index: 9999;
  overflow: hidden;
  visibility: hidden;
}
.kx-menu.is-open {
  transform: translateX(0);
  box-shadow: 24px 0 56px -16px rgba(10, 10, 10, 0.18);
  visibility: visible;
}
.kx-menu *, .kx-menu *::before, .kx-menu *::after { box-sizing: border-box; }
.kx-menu a { color: inherit; text-decoration: none; }
.kx-menu button { font: inherit; color: inherit; background: transparent; border: 0; padding: 0; cursor: pointer; }

/* ---------- Header ---------- */
.kx-menu__header {
  flex-shrink: 0;
  position: relative;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  background: var(--kx-bg);
  border-bottom: 1px solid var(--kx-hairline);
  z-index: 5;
}
.kx-menu__header-state {
  position: absolute;
  left: 24px;
  right: 64px;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  transition: opacity 220ms ease, transform 280ms var(--kx-slide);
}
.kx-menu__header-state--l1 { opacity: 1; transform: translateX(0); }
.kx-menu__header-state--l2 { opacity: 0; transform: translateX(12px); pointer-events: none; }
.kx-menu.is-l2 .kx-menu__header-state--l1 { opacity: 0; transform: translateX(-12px); pointer-events: none; }
.kx-menu.is-l2 .kx-menu__header-state--l2 { opacity: 1; transform: translateX(0); pointer-events: auto; }

.kx-menu__wordmark {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 14px;
  text-transform: uppercase;
  color: var(--kx-black);
  opacity: 0;
  transform: translateY(4px);
  line-height: 1;
  transition: opacity 480ms ease, letter-spacing 640ms var(--kx-spring), transform 480ms var(--kx-spring);
  transition-delay: 220ms;
}
.kx-menu__wordmark-text { display: inline-block; }
.kx-menu__wordmark-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--kx-gold);
  margin-left: -10px;
  flex-shrink: 0;
  transform: translateY(-1px);
}
.kx-menu.is-open .kx-menu__wordmark { opacity: 1; letter-spacing: 8px; transform: translateY(0); }

.kx-menu__back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 18px;
  font-weight: 500;
  color: var(--kx-black);
  line-height: 1;
  transition: color 150ms ease;
}
.kx-menu__back svg { color: var(--kx-charcoal); transition: color 150ms ease, transform 200ms ease; }
.kx-menu__back:hover { color: var(--kx-forest); }
.kx-menu__back:hover svg { color: var(--kx-forest); transform: translateX(-3px); }
.kx-menu__back-label { display: inline-block; }

.kx-menu__close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  margin-right: -8px;
  color: var(--kx-black);
  opacity: 0;
  transition: color 150ms ease, opacity 320ms ease;
  transition-delay: 280ms;
  position: relative;
  z-index: 2;
  margin-left: auto;
}
.kx-menu.is-open .kx-menu__close { opacity: 1; }
.kx-menu__close:hover { color: var(--kx-forest); }

/* ---------- Viewport / Track (horizontal slide L1↔L2) ---------- */
.kx-menu__viewport {
  flex: 1;
  position: relative;
  overflow: hidden;
}
.kx-menu__track {
  display: flex;
  width: 200%;
  height: 100%;
  transform: translateX(0);
  transition: transform 320ms var(--kx-slide);
}
.kx-menu.is-l2 .kx-menu__track { transform: translateX(-50%); }

.kx-menu__panel {
  width: 50%;
  flex-shrink: 0;
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.kx-menu__panel::-webkit-scrollbar { width: 0; height: 0; display: none; background: transparent; }
.kx-menu, .kx-menu * { scrollbar-width: none; -ms-overflow-style: none; }
.kx-menu *::-webkit-scrollbar { width: 0; height: 0; display: none; }

/* ---------- Staged reveal (L1 only) ---------- */
.kx-menu__stage {
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 380ms ease, transform 480ms var(--kx-spring);
}
.kx-menu.is-open .kx-menu__stage { opacity: 1; transform: translateY(0); }
.kx-menu.is-open .kx-menu__stage[data-stage="1"] { transition-delay: 320ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="2"] { transition-delay: 400ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="3"] { transition-delay: 480ms; }
.kx-menu.is-open .kx-menu__stage[data-stage="4"] { transition-delay: 560ms; }

/* ---------- L1 main category list ---------- */
.kx-menu__l1-list {
  margin: 8px 0 0;
  padding: 0;
  display: flex;
  flex-direction: column;
}
.kx-menu__l1-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 22px 24px;
  text-align: left;
  background: transparent;
  border-bottom: 1px solid var(--kx-hairline);
  font: inherit;
  color: var(--kx-black);
  cursor: pointer;
  transition: padding 220ms var(--kx-slide);
}
.kx-menu__l1-row:last-child { border-bottom: 1px solid var(--kx-hairline); }
.kx-menu__l1-name {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 24px;
  font-weight: 500;
  line-height: 1.1;
  color: var(--kx-black);
  transition: color 150ms ease, transform 220ms var(--kx-slide);
  transform: translateX(0);
  display: inline-block;
}
.kx-menu__l1-name--italic { font-style: italic; color: var(--kx-forest); }
.kx-menu__l1-chev {
  color: var(--kx-gray);
  flex-shrink: 0;
  transition: color 200ms ease, transform 220ms var(--kx-slide);
}
.kx-menu__l1-row:hover,
.kx-menu__l1-row:focus-visible,
.kx-menu__l1-row:active {
  outline: none;
}
.kx-menu__l1-row:hover .kx-menu__l1-name,
.kx-menu__l1-row:focus-visible .kx-menu__l1-name,
.kx-menu__l1-row:active .kx-menu__l1-name {
  transform: translateX(4px);
}
.kx-menu__l1-row:hover .kx-menu__l1-chev,
.kx-menu__l1-row:focus-visible .kx-menu__l1-chev,
.kx-menu__l1-row:active .kx-menu__l1-chev {
  color: var(--kx-gold);
  transform: translateX(2px);
}

/* ---------- L2 subcategory list ---------- */
.kx-menu__sub {
  display: flex;
  flex-direction: column;
  padding: 8px 0 24px;
}
.kx-menu__sub[hidden] { display: none; }
.kx-menu__l2-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 20px 24px;
  border-bottom: 1px solid var(--kx-hairline);
  transition: padding 220ms var(--kx-slide);
}
.kx-menu__l2-name {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 22px;
  font-weight: 500;
  line-height: 1.15;
  color: var(--kx-black);
  transition: color 150ms ease, transform 220ms var(--kx-slide);
  display: inline-block;
}
.kx-menu__l2-row:hover .kx-menu__l2-name,
.kx-menu__l2-row:focus-visible .kx-menu__l2-name,
.kx-menu__l2-row:active .kx-menu__l2-name {
  transform: translateX(4px);
}
.kx-menu__l2-row:hover .kx-menu__l1-chev,
.kx-menu__l2-row:focus-visible .kx-menu__l1-chev,
.kx-menu__l2-row:active .kx-menu__l1-chev {
  color: var(--kx-gold);
  transform: translateX(2px);
}

/* ---------- Service list ---------- */
.kx-menu__service-list {
  list-style: none;
  margin: 32px 0 0;
  padding: 0 24px;
}
.kx-menu__service-item a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 0;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  color: var(--kx-charcoal);
  border-bottom: 1px solid var(--kx-hairline);
  transition: color 150ms ease, padding-left 200ms var(--kx-spring);
}
.kx-menu__service-item:last-child a { border-bottom: 0; }
.kx-menu__service-item a svg { color: var(--kx-gray); transition: color 150ms ease, transform 200ms ease; }
.kx-menu__service-item a:hover, .kx-menu__service-item a:focus-visible { color: var(--kx-forest); padding-left: 4px; }
.kx-menu__service-item a:hover svg, .kx-menu__service-item a:focus-visible svg { color: var(--kx-gold); transform: translateX(3px); }

/* ---------- Editorial Feature ---------- */
.kx-menu__feature {
  display: block;
  margin: 40px 0 0;
  background: var(--kx-forest);
  color: var(--kx-beige);
  padding: 48px 24px;
}
.kx-menu__feature-overline {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--kx-gold);
  margin-bottom: 16px;
}
.kx-menu__feature-headline {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-style: italic;
  font-weight: 400;
  font-size: 28px;
  line-height: 1.18;
  color: var(--kx-bg);
  margin: 0 0 12px;
}
.kx-menu__feature-body {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 15px;
  line-height: 1.55;
  color: var(--kx-beige);
  margin: 0;
  font-weight: 400;
}
.kx-menu__feature-link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 24px;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--kx-gold);
  border-bottom: 1px solid var(--kx-gold);
  padding-bottom: 4px;
  transition: gap 200ms ease, color 150ms ease, border-color 150ms ease;
}
.kx-menu__feature:hover .kx-menu__feature-link { gap: 16px; color: var(--kx-bg); border-color: var(--kx-bg); }

/* ---------- Footer ---------- */
.kx-menu__footer { background: var(--kx-bg); padding: 32px 24px 48px; }
.kx-menu__locale { font-family: "Helvetica Neue", Arial, sans-serif; font-size: 12px; color: var(--kx-gray); }
.kx-menu__tagline { font-family: "Cormorant Garamond", Georgia, serif; font-style: italic; font-size: 14px; color: var(--kx-gray); margin: 16px 0 0; }
.kx-menu__legal { font-family: "Helvetica Neue", Arial, sans-serif; font-size: 10px; letter-spacing: 0.5px; color: var(--kx-muted-green); margin: 24px 0 0; }

@media (min-width: 990px) {
  .kx-menu, .kx-menu-backdrop { display: none; }
}

@media (prefers-reduced-motion: reduce) {
  .kx-menu {
    transition: opacity 200ms ease, visibility 0s linear 200ms;
    transform: translateX(0);
    opacity: 0;
  }
  .kx-menu.is-open { opacity: 1; transition: opacity 200ms ease, visibility 0s linear 0s; }
  .kx-menu__wordmark, .kx-menu__close, .kx-menu__stage, .kx-menu__header-state, .kx-menu__track {
    opacity: 1 !important;
    transform: none !important;
    letter-spacing: 8px !important;
    transition: none !important;
  }
  .kx-menu.is-l2 .kx-menu__track { transform: translateX(-50%) !important; }
}
{%- endstylesheet -%}

<script>
(function () {
  function initKarinexMenu() {
    var menu = document.getElementById('custom-mobile-menu');
    var backdrop = document.getElementById('cmm-backdrop');
    var closeBtn = document.getElementById('cmm-close');
    var backBtn = document.getElementById('cmm-back');
    var backLabel = document.getElementById('cmm-back-label');
    if (!menu) return;

    var lastFocused = null;
    var l2Panel = menu.querySelector('.kx-menu__panel--l2');
    var subPanels = menu.querySelectorAll('.kx-menu__sub');
    var l1Panel = menu.querySelector('.kx-menu__panel--l1');

    function lightHaptic() {
      if (window.navigator && window.navigator.vibrate) {
        try { window.navigator.vibrate(8); } catch (e) {}
      }
    }

    function showSub(key) {
      subPanels.forEach(function (s) {
        if (s.getAttribute('data-sub') === key) {
          s.removeAttribute('hidden');
        } else {
          s.setAttribute('hidden', '');
        }
      });
    }

    function drillDown(key, parentLabel) {
      lightHaptic();
      showSub(key);
      if (backLabel) backLabel.textContent = parentLabel || 'Zurück';
      menu.classList.add('is-l2');
      if (l2Panel) {
        l2Panel.setAttribute('aria-hidden', 'false');
        l2Panel.scrollTop = 0;
      }
      if (l1Panel) l1Panel.setAttribute('aria-hidden', 'true');
      setTimeout(function () { if (backBtn) backBtn.focus(); }, 200);
    }

    function goBack() {
      lightHaptic();
      menu.classList.remove('is-l2');
      if (l2Panel) l2Panel.setAttribute('aria-hidden', 'true');
      if (l1Panel) l1Panel.setAttribute('aria-hidden', 'false');
      setTimeout(function () { if (closeBtn) closeBtn.focus(); }, 200);
    }

    function openMenu() {
      lastFocused = document.activeElement;
      menu.classList.add('is-open');
      if (backdrop) backdrop.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      var nativeDrawer = document.getElementById('Details-menu-drawer-container');
      if (nativeDrawer) {
        nativeDrawer.removeAttribute('open');
        nativeDrawer.classList.remove('menu-open');
      }
      document.body.classList.remove('overflow-hidden');
      setTimeout(function () { if (closeBtn) closeBtn.focus(); }, 220);
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      if (backdrop) backdrop.classList.remove('is-open');
      document.body.style.overflow = '';
      setTimeout(function () {
        menu.classList.remove('is-l2');
        if (l2Panel) l2Panel.setAttribute('aria-hidden', 'true');
        if (l1Panel) l1Panel.setAttribute('aria-hidden', 'false');
      }, 540);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    if (closeBtn) closeBtn.addEventListener('click', function (e) { e.preventDefault(); closeMenu(); });
    if (backdrop) backdrop.addEventListener('click', closeMenu);
    if (backBtn) backBtn.addEventListener('click', function (e) { e.preventDefault(); goBack(); });

    menu.querySelectorAll('[data-drill]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        drillDown(btn.getAttribute('data-drill'), btn.getAttribute('data-parent-label'));
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        if (menu.classList.contains('is-l2')) goBack();
        else closeMenu();
      }
    });

    /* Hijack the theme's hamburger trigger */
    document.body.addEventListener('click', function (e) {
      if (window.innerWidth > 990) return;
      var trigger = e.target.closest('.header__icon--menu, [data-header-drawer], .header__drawer summary, .header__icon--menu span');
      if (!trigger) return;
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      openMenu();
      return false;
    }, true);

    /* Haptic on tappable rows */
    menu.querySelectorAll('[data-haptic]').forEach(function (el) {
      el.addEventListener('click', lightHaptic);
    });

    /* Swipe gestures: L1 swipe-left closes; L2 swipe-right goes back */
    var startX = null, startY = null;
    menu.addEventListener('touchstart', function (e) {
      if (e.touches.length === 1) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      }
    }, { passive: true });
    menu.addEventListener('touchend', function (e) {
      if (startX === null) return;
      var t = e.changedTouches[0] || {};
      var dx = (t.clientX || startX) - startX;
      var ady = Math.abs(startY - (t.clientY || startY));
      if (ady < 40) {
        if (menu.classList.contains('is-l2') && dx > 60) {
          goBack();
        } else if (!menu.classList.contains('is-l2') && dx < -60) {
          closeMenu();
        }
      }
      startX = null;
      startY = null;
    });

    /* Focus trap */
    menu.addEventListener('keydown', function (e) {
      if (e.key !== 'Tab' || !menu.classList.contains('is-open')) return;
      var scope = menu.classList.contains('is-l2') ? l2Panel : l1Panel;
      var headerScope = menu.querySelector(menu.classList.contains('is-l2') ? '.kx-menu__header-state--l2' : '.kx-menu__header-state--l1');
      var nodes = [];
      if (headerScope) nodes = nodes.concat(Array.prototype.slice.call(headerScope.querySelectorAll('a[href], button:not([disabled])')));
      if (closeBtn) nodes.push(closeBtn);
      if (scope) {
        var visibleSubs = scope.querySelectorAll('a[href]:not([hidden]), button:not([disabled]):not([hidden])');
        nodes = nodes.concat(Array.prototype.slice.call(visibleSubs).filter(function (n) {
          var p = n.closest('[hidden]');
          return !p;
        }));
      }
      if (!nodes.length) return;
      var first = nodes[0];
      var last = nodes[nodes.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initKarinexMenu);
  } else {
    initKarinexMenu();
  }
})();
</script>
