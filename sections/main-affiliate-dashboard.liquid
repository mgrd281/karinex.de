{%- if customer -%}
<script>
(function(){
  'use strict';
  var GAS = 'https://script.google.com/macros/s/AKfycbz0KQ6sRNj7ZPV8ivb53EPM3kK9Ms5RcUDzaiXkz_Vq8W8DZXaFwBM7oo84U2IY37Wd/exec';
  var CID = '{{ customer.id }}';
  var EMAIL = '{{ customer.email }}';

  /* ── Copy Link ── */
  var copyBtn = document.getElementById('kx-afd-copy');
  if(copyBtn){
    copyBtn.addEventListener('click', function(){
      var inp = document.getElementById('kx-afd-link-input');
      if(navigator.clipboard){
        navigator.clipboard.writeText(inp.value).then(function(){
          copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Kopiert!';
          setTimeout(function(){ copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Kopieren'; }, 2500);
        });
      } else {
        inp.select(); document.execCommand('copy');
      }
    });
  }

  /* ── Telegram Share ── */
  var tgBtn = document.getElementById('kx-afd-share-tg');
  if(tgBtn){
    tgBtn.addEventListener('click', function(){
      var link = document.getElementById('kx-afd-link-input').value;
      window.open('https://t.me/share/url?url=' + encodeURIComponent(link) + '&text=' + encodeURIComponent('Schau dir Karinex an!'), '_blank');
    });
  }

  /* ── Load Dashboard Data ── */
  var loadEl = document.getElementById('kx-afd-loading');
  function loadDashboard(){
    fetch(GAS + '?action=affiliate_dashboard&customer_id=' + CID + '&email=' + encodeURIComponent(EMAIL))
      .then(function(r){ return r.json(); })
      .then(function(d){
        if(loadEl) loadEl.style.display = 'none';
        if(!d.ok) return;
        renderStats(d);
        renderChart(d.clicks ? d.clicks.daily || [] : []);
        renderTable(d.referrals || []);
      })
      .catch(function(){
        if(loadEl) loadEl.innerHTML = '<span style="color:#e74c3c">Fehler beim Laden. Bitte Seite neu laden.</span>';
      });
  }

  /* ── Render Stats ── */
  function renderStats(d){
    setText('kx-st-clicks', fmt(d.clicks ? d.clicks.total : 0));
    setText('kx-st-clicks-today', 'heute: ' + fmt(d.clicks ? d.clicks.today : 0));
    setText('kx-st-referrals', fmt(d.total_referrals || 0));
    setText('kx-st-conversion', 'Conversion: ' + (d.conversion_rate || 0) + '%');
    setText('kx-st-purchases', fmt(d.total_purchases || 0));
    setText('kx-st-earnings', fmt(d.total_earned || 0));
    setText('kx-st-pending', 'ausstehend: ' + fmt(d.pending_points || 0));
  }

  /* ── Render Chart (Canvas bar chart) ── */
  var chartData = [];
  var chartDays = 30;

  function renderChart(daily){
    chartData = daily || [];
    var emptyEl = document.getElementById('kx-afd-chart-empty');
    var canvas = document.getElementById('kx-afd-canvas');
    if(!chartData.length || !canvas){
      if(emptyEl) emptyEl.style.display = 'flex';
      return;
    }
    if(emptyEl) emptyEl.style.display = 'none';
    canvas.style.display = 'block';
    drawChart(chartDays);
  }

  function drawChart(days){
    var canvas = document.getElementById('kx-afd-canvas');
    if(!canvas) return;
    var ctx = canvas.getContext('2d');
    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.parentElement.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = 200 * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = '200px';
    ctx.scale(dpr, dpr);

    var W = rect.width, H = 200;
    var pad = {top:20, right:10, bottom:30, left:40};
    var cW = W - pad.left - pad.right;
    var cH = H - pad.top - pad.bottom;

    var data = chartData.slice(-days);
    if(!data.length) return;
    var max = Math.max.apply(null, data.map(function(d){ return d.count; }));
    if(max === 0) max = 1;
    var barW = Math.max(2, (cW / data.length) - 2);

    ctx.clearRect(0, 0, W, H);

    /* Grid lines */
    ctx.strokeStyle = '#f0f0f0';
    ctx.lineWidth = 1;
    for(var i = 0; i <= 4; i++){
      var y = pad.top + (cH / 4) * i;
      ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
    }

    /* Bars */
    for(var j = 0; j < data.length; j++){
      var bH = (data[j].count / max) * cH;
      var x = pad.left + (cW / data.length) * j + 1;
      var y2 = pad.top + cH - bH;
      ctx.fillStyle = '#c9a84c';
      ctx.beginPath();
      ctx.roundRect(x, y2, barW, bH, [3, 3, 0, 0]);
      ctx.fill();

      /* X labels (every 5th) */
      if(j % Math.ceil(data.length / 6) === 0 || j === data.length - 1){
        ctx.fillStyle = '#999';
        ctx.font = '11px system-ui';
        ctx.textAlign = 'center';
        var label = data[j].date ? data[j].date.slice(5) : '';
        ctx.fillText(label, x + barW / 2, H - 8);
      }
    }

    /* Y axis labels */
    ctx.fillStyle = '#999';
    ctx.font = '11px system-ui';
    ctx.textAlign = 'right';
    for(var k = 0; k <= 4; k++){
      var val = Math.round(max - (max / 4) * k);
      ctx.fillText(val, pad.left - 6, pad.top + (cH / 4) * k + 4);
    }
  }

  /* Chart range toggle */
  document.querySelectorAll('.kx-afd-chip[data-days]').forEach(function(el){
    el.addEventListener('click', function(){
      document.querySelectorAll('.kx-afd-chip[data-days]').forEach(function(c){ c.classList.remove('kx-afd-chip--active'); });
      el.classList.add('kx-afd-chip--active');
      chartDays = parseInt(el.dataset.days, 10);
      drawChart(chartDays);
    });
  });

  /* ── Render Table ── */
  function renderTable(refs){
    var emptyEl = document.getElementById('kx-afd-table-empty');
    var tableEl = document.getElementById('kx-afd-table');
    var tbody = document.getElementById('kx-afd-tbody');
    if(!refs.length){
      if(emptyEl) emptyEl.style.display = 'block';
      return;
    }
    if(emptyEl) emptyEl.style.display = 'none';
    if(tableEl) tableEl.style.display = 'table';
    var html = '';
    for(var i = 0; i < refs.length; i++){
      var r = refs[i];
      var statusClass = r.purchased ? 'purchased' : 'pending';
      var statusText = r.purchased ? '✓ Gekauft' : '⏳ Ausstehend';
      html += '<tr>'
        + '<td>' + esc(r.email_masked || '–') + '</td>'
        + '<td><code style="background:#f5f5f5;padding:2px 8px;border-radius:4px;font-size:.8rem">' + esc(r.code || '–') + '</code></td>'
        + '<td>' + esc(r.date || '–') + '</td>'
        + '<td><span class="kx-afd-status kx-afd-status--' + statusClass + '">' + statusText + '</span></td>'
        + '<td><strong>' + (r.earned_points || 0) + '</strong></td>'
        + '</tr>';
    }
    if(tbody) tbody.innerHTML = html;
  }

  /* ── Helpers ── */
  function setText(id, val){ var el = document.getElementById(id); if(el) el.textContent = val; }
  function fmt(n){ return n >= 1000 ? (n/1000).toFixed(1).replace(/\.0$/,'') + 'k' : String(n); }
  function esc(s){ var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  /* ── Init ── */
  loadDashboard();
})();
</script>
{%- endif -%}

