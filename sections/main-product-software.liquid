{%- comment -%}
  Karinex — Premium "Software" product template (v1).
  Apple/Linear/Vercel-inspired layout. All styles scoped under
  .product-software via assets/product-software.css.
{%- endcomment -%}

<link rel="stylesheet" href="{{ 'product-software.css' | asset_url }}">
{% render 'product-software-schema' %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign price = current_variant.price
  assign compare = current_variant.compare_at_price
  assign on_sale = false
  if compare and compare > price
    assign on_sale = true
  endif

  assign mf_lizenztyp = product.metafields.karinex.lizenztyp
  assign mf_arch      = product.metafields.karinex.architektur
  assign mf_geraete   = product.metafields.karinex.geraeteanzahl
  assign mf_lieferung = product.metafields.karinex.lieferform
  assign mf_shipping  = product.metafields.custom.shipping_content
  assign mf_warranty  = product.metafields.custom.warranty_content
  assign mf_details   = product.metafields.custom.details_content
-%}

<section class="product-software" data-product-software data-product-id="{{ product.id }}">

  {# ────────── STICKY HEADER (desktop, appears after main CTA scrolls out) ────────── #}
  <div class="product-software__sticky-header" data-sticky-header aria-hidden="true">
    <div class="product-software__sticky-header-inner">
      <span class="product-software__sticky-header-title">{{ product.title | truncatewords: 8 }}</span>
      {%- form 'product', product, class: 'product-software__sticky-header-form', data-sticky-header-form: '' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="product-software__btn product-software__btn--primary product-software__btn--compact" data-sticky-header-cta {% unless current_variant.available %}disabled{% endunless %}>
          <span data-cta-default>{% if current_variant.available %}In den Warenkorb · {{ price | money }}{% else %}Ausverkauft{% endif %}</span>
          <span data-cta-success hidden>✓ Hinzugefügt</span>
        </button>
      {%- endform -%}
    </div>
  </div>

  {# ────────── 1. HERO ────────── #}
  <header class="product-software__hero">
    <div class="product-software__hero-grid">

      <div class="product-software__hero-media">
        {%- assign featured = product.featured_media -%}
        <div class="product-software__hero-image" data-gallery-stage>
          {%- if featured.media_type == 'image' -%}
            <img
              src="{{ featured | image_url: width: 1200 }}"
              srcset="{{ featured | image_url: width: 600 }} 600w, {{ featured | image_url: width: 900 }} 900w, {{ featured | image_url: width: 1200 }} 1200w, {{ featured | image_url: width: 1600 }} 1600w"
              sizes="(min-width: 960px) 50vw, 100vw"
              alt="{{ featured.alt | default: product.title | escape }}"
              width="{{ featured.width }}"
              height="{{ featured.height }}"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              data-gallery-main-image>
          {%- else -%}
            {{ product.featured_image | image_url: width: 1200 | image_tag: alt: product.title, loading: 'eager' }}
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <ul class="product-software__hero-thumbs" role="list" data-gallery-thumbs>
            {%- for m in product.media limit: 5 -%}
              <li>
                <button
                  type="button"
                  class="product-software__hero-thumb {% if forloop.first %}is-active{% endif %}"
                  data-gallery-thumb
                  data-full="{{ m | image_url: width: 1200 }}"
                  data-srcset="{{ m | image_url: width: 600 }} 600w, {{ m | image_url: width: 900 }} 900w, {{ m | image_url: width: 1200 }} 1200w"
                  data-alt="{{ m.alt | default: product.title | escape }}"
                  aria-label="Bild {{ forloop.index }} von {{ product.media.size }} anzeigen"
                  aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}">
                  <img src="{{ m | image_url: width: 200 }}" alt="" loading="lazy" decoding="async" width="100" height="100">
                </button>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="product-software__hero-info">
        {%- if product.vendor != blank -%}
          <a class="product-software__eyebrow" href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>
        {%- endif -%}

        <h1 class="product-software__title">{{ product.title }}</h1>

        {%- if product.metafields.custom.short_description != blank -%}
          <p class="product-software__lede">{{ product.metafields.custom.short_description | strip_html | truncate: 200 }}</p>
        {%- elsif product.description != blank -%}
          <p class="product-software__lede">{{ product.description | strip_html | truncatewords: 28 }}</p>
        {%- endif -%}

        <div class="product-software__price-block" data-price-block>
          <div class="product-software__price-row">
            <span class="product-software__price">{{ price | money }}</span>
            {%- if on_sale -%}
              <span class="product-software__price-compare"><s>{{ compare | money }}</s></span>
            {%- endif -%}
          </div>
          <p class="product-software__price-note">inkl. MwSt.{% if on_sale %} · Sie sparen {{ compare | minus: price | money }}{% endif %}</p>
        </div>

        <ul class="product-software__trust-row" role="list">
          <li>Sofort-Lieferung</li>
          <li>Original-Lizenz</li>
          <li>100 Tage Garantie</li>
          <li>Deutscher Support</li>
        </ul>

        {%- form 'product', product, class: 'product-software__buy', data-buy-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button
            type="submit"
            class="product-software__btn product-software__btn--primary"
            data-buy-cta
            {% unless current_variant.available %}disabled{% endunless %}>
            <span data-cta-default>{% if current_variant.available %}In den Warenkorb{% else %}Ausverkauft{% endif %}</span>
            <span data-cta-success hidden>✓ Hinzugefügt</span>
          </button>
          <a class="product-software__btn product-software__btn--ghost" href="#product-software-details">Mehr erfahren ↓</a>
        {%- endform -%}
      </div>

    </div>
  </header>

  {# ────────── 2. KEY-SPECS-BAR ────────── #}
  {%- if mf_lizenztyp != blank or mf_arch != blank or mf_geraete != blank or mf_lieferung != blank -%}
    <div class="product-software__specs">
      <div class="product-software__specs-grid">
        {%- if mf_lizenztyp != blank -%}
          <div class="product-software__spec">
            <dt>Lizenztyp</dt>
            <dd>{{ mf_lizenztyp }}</dd>
          </div>
        {%- endif -%}
        {%- if mf_arch != blank -%}
          <div class="product-software__spec">
            <dt>Plattform</dt>
            <dd>{{ mf_arch }}</dd>
          </div>
        {%- endif -%}
        {%- if mf_geraete != blank -%}
          <div class="product-software__spec">
            <dt>Geräte</dt>
            <dd>{{ mf_geraete }}</dd>
          </div>
        {%- endif -%}
        {%- if mf_lieferung != blank -%}
          <div class="product-software__spec">
            <dt>Lieferung</dt>
            <dd>{{ mf_lieferung }}</dd>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {# ────────── 3. PRODUKTBESCHREIBUNG ────────── #}
  {%- if product.description != blank -%}
    <article class="product-software__description" id="product-software-details">
      <div class="product-software__description-inner">
        {{ product.description }}
      </div>
    </article>
  {%- endif -%}

  {# ────────── 4. DREI-SPALTEN-INFO-BLOCK ────────── #}
  {%- if mf_shipping != blank or mf_warranty != blank or mf_details != blank -%}
    <section class="product-software__info">
      <div class="product-software__info-grid">
        {%- if mf_shipping != blank -%}
          <div class="product-software__info-col">
            <h3>Versand &amp; Lieferung</h3>
            <div class="product-software__info-content">{{ mf_shipping }}</div>
          </div>
        {%- endif -%}
        {%- if mf_warranty != blank -%}
          <div class="product-software__info-col">
            <h3>Rückgabe &amp; Garantie</h3>
            <div class="product-software__info-content">{{ mf_warranty }}</div>
          </div>
        {%- endif -%}
        {%- if mf_details != blank -%}
          <div class="product-software__info-col">
            <h3>Produktdetails</h3>
            <div class="product-software__info-content">{{ mf_details }}</div>
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

</section>

{% render 'product-software-sticky-bar' %}

<script src="{{ 'product-software.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Software Product (Premium)",
  "tag": "section",
  "class": "section-product-software",
  "settings": [
    {
      "type": "color",
      "id": "section_bg",
      "label": "Hintergrund",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
