{% comment %}
  AboutYou-style USP Bar
  Schwarze Leiste unter dem Header mit 3 Benefit-Punkten
{% endcomment %}

<div class="ay-usp-bar">
  <div class="ay-usp-bar__inner">
    <div class="ay-usp-bar__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>{{ section.settings.usp1_text | default: 'Kostenloser Versand* & Rückversand' }}</span>
    </div>
    <div class="ay-usp-bar__divider"></div>
    <div class="ay-usp-bar__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
      </svg>
      <span>{{ section.settings.usp2_text | default: '30 Tage Rückgaberecht' }}</span>
    </div>
    <div class="ay-usp-bar__divider"></div>
    <div class="ay-usp-bar__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
      </svg>
      <span>{{ section.settings.usp3_text | default: 'Kauf auf Rechnung' }}</span>
    </div>
  </div>
</div>

<style>
  .ay-usp-bar {
    background: #111111;
    color: #ffffff;
    width: 100%;
    padding: 12px 0;
    font-family: var(--font-body-family);
  }
  .ay-usp-bar__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--page-margin, 20px);
  }
  .ay-usp-bar__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    flex: 1;
    justify-content: center;
    text-align: center;
    padding: 0 16px;
  }
  .ay-usp-bar__item svg {
    flex-shrink: 0;
    opacity: 0.9;
  }
  .ay-usp-bar__divider {
    width: 1px;
    height: 20px;
    background: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }
  @media screen and (max-width: 749px) {
    .ay-usp-bar__inner {
      flex-direction: column;
      gap: 10px;
      padding: 4px var(--page-margin, 16px);
    }
    .ay-usp-bar__divider {
      display: none;
    }
    .ay-usp-bar__item {
      font-size: 12px;
      padding: 0;
      justify-content: flex-start;
    }
    .ay-usp-bar {
      padding: 12px 0;
    }
  }
</style>

{% schema %}
{
  "name": "AboutYou USP Bar",
  "settings": [
    {
      "type": "text",
      "id": "usp1_text",
      "label": "USP 1 Text",
      "default": "Kostenloser Versand* & Rückversand"
    },
    {
      "type": "text",
      "id": "usp2_text",
      "label": "USP 2 Text",
      "default": "30 Tage Rückgaberecht"
    },
    {
      "type": "text",
      "id": "usp3_text",
      "label": "USP 3 Text",
      "default": "Kauf auf Rechnung"
    }
  ],
  "presets": [
    {
      "name": "AboutYou USP Bar"
    }
  ]
}
{% endschema %}
