{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
<link rel="preload" href="{{ 'main-faq.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'main-faq.css' | asset_url }}"></noscript>

<div class="help-center">
  
  <!-- HERO SECTION -->
  <section class="help-hero">
    <div class="help-hero-content">
      <h1 class="help-hero-title">Wie können wir Ihnen helfen?</h1>
      <p class="help-hero-subtitle">Finden Sie schnelle Antworten oder kontaktieren Sie unseren Support.</p>
      
      <div class="help-search-wrapper">
        <div class="help-search">
          <svg class="help-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <input 
            type="search" 
            id="help-search-input" 
            class="help-search-input"
            placeholder="Suchen Sie nach einer Frage oder einem Thema…" 
            autocomplete="off"
            aria-label="FAQ durchsuchen"
            spellcheck="false"
          >
          <button type="button" id="help-search-clear" class="help-search-clear" aria-label="Suche löschen">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <div class="help-container">
    
    <!-- CATEGORY CARDS -->
    <section class="help-categories" id="categories">
      <div class="category-grid">
        <button class="category-card" data-category="bestellung" aria-pressed="false">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </div>
          <div class="category-content">
            <h3 class="category-title">Bestellung</h3>
            <p class="category-desc">Zahlungsarten, Stornierung, Rechnung</p>
          </div>
        </button>

        <button class="category-card" data-category="versand" aria-pressed="false">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="3" width="15" height="13"/>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <div class="category-content">
            <h3 class="category-title">Versand & Lieferung</h3>
            <p class="category-desc">Lieferzeiten, Tracking, Kosten</p>
          </div>
        </button>

        <button class="category-card" data-category="rueckgabe" aria-pressed="false">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="1 4 1 10 7 10"/>
              <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
            </svg>
          </div>
          <div class="category-content">
            <h3 class="category-title">Rückgabe & Erstattung</h3>
            <p class="category-desc">Widerruf, Retoure, Geld zurück</p>
          </div>
        </button>

        <button class="category-card" data-category="produkte" aria-pressed="false">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="category-content">
            <h3 class="category-title">Produkte</h3>
            <p class="category-desc">Uhren, Garantie, Pflege</p>
          </div>
        </button>

        <button class="category-card" data-category="software" aria-pressed="false">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div class="category-content">
            <h3 class="category-title">Software & Lizenzen</h3>
            <p class="category-desc">Aktivierung, Download, Keys</p>
          </div>
        </button>

        <button class="category-card" data-category="konto" aria-pressed="false">
          <div class="category-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div class="category-content">
            <h3 class="category-title">Konto & Zahlung</h3>
            <p class="category-desc">Login, Passwort, Zahlungen</p>
          </div>
        </button>
      </div>
      
      <button class="category-reset" id="category-reset" style="display: none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
        Alle Kategorien anzeigen
      </button>
    </section>

    <!-- SEARCH RESULTS INFO -->
    <div class="search-results-info" id="search-results-info" style="display: none;">
      <span class="results-count"></span>
      <button class="results-clear" id="results-clear">Filter zurücksetzen</button>
    </div>

    <!-- FAQ ACCORDIONS -->
    <section class="help-faq" id="faq-content">
      
      <!-- Bestellung & Zahlung -->
      <div class="faq-group" data-group="bestellung">
        <h2 class="faq-group-title">
          <span class="faq-group-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </span>
          Bestellung & Zahlung
        </h2>
        
        <div class="faq-list">
          <details class="faq-item" data-keywords="zahlung zahlungsmethoden paypal kreditkarte klarna rechnung">
            <summary class="faq-question">
              <span class="faq-q-text">Welche Zahlungsmethoden werden akzeptiert?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Wir bieten Ihnen folgende sichere Zahlungsmöglichkeiten:</p>
              <ul>
                <li><strong>PayPal</strong> – Schnell und sicher bezahlen</li>
                <li><strong>Kreditkarte</strong> – Visa, Mastercard, American Express</li>
                <li><strong>Klarna</strong> – Rechnung, Ratenzahlung oder Sofortüberweisung</li>
                <li><strong>Apple Pay & Google Pay</strong> – Kontaktlos mit Ihrem Smartphone</li>
                <li><strong>SEPA-Lastschrift</strong> – Bequem per Bankeinzug</li>
              </ul>
              <p>Alle Transaktionen sind SSL-verschlüsselt und 100% sicher.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="rechnung kauf klarna bezahlen später">
            <summary class="faq-question">
              <span class="faq-q-text">Ist die Bezahlung auf Rechnung möglich?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Ja! Mit <strong>Klarna Rechnung</strong> können Sie bequem innerhalb von 14-30 Tagen nach Erhalt der Ware bezahlen. Bei der Zahlung wählen Sie einfach "Klarna" und dann "Rechnung" aus. Klarna prüft automatisch Ihre Bonität – die Entscheidung erfolgt in Sekunden.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="raten ratenzahlung finanzierung klarna monatlich">
            <summary class="faq-question">
              <span class="faq-q-text">Kann ich in Raten zahlen?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Ja, mit <strong>Klarna Ratenkauf</strong> können Sie Ihren Einkauf in 6, 12, 24 oder 36 monatlichen Raten bezahlen. Die Zinsen und Konditionen werden Ihnen transparent vor Abschluss angezeigt.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="bestellung stornieren ändern abbrechen">
            <summary class="faq-question">
              <span class="faq-q-text">Kann ich meine Bestellung stornieren oder ändern?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Solange Ihre Bestellung noch nicht versendet wurde, können Sie diese ändern oder stornieren. Kontaktieren Sie uns schnellstmöglich per E-Mail an <a href="mailto:info@karinex.de">info@karinex.de</a> oder telefonisch. Nach dem Versand können Sie die Ware innerhalb von 100 Tagen zurücksenden.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="rechnung invoice unternehmen firma geschäftskunde">
            <summary class="faq-question">
              <span class="faq-q-text">Wie erhalte ich eine Rechnung für meine Bestellung?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Ihre Rechnung wird automatisch per E-Mail an die bei der Bestellung angegebene Adresse gesendet. Sie finden sie auch in Ihrem <a href="/account">Kundenkonto</a> unter "Bestellungen". Benötigen Sie eine separate Rechnung für Ihr Unternehmen? Kontaktieren Sie uns mit Ihrer Bestellnummer.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>
        </div>
      </div>

      <!-- Versand & Lieferung -->
      <div class="faq-group" data-group="versand">
        <h2 class="faq-group-title">
          <span class="faq-group-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="3" width="15" height="13"/>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </span>
          Versand & Lieferung
        </h2>
        
        <div class="faq-list">
          <details class="faq-item" data-keywords="versandkosten kosten porto gebühren gratis kostenlos">
            <summary class="faq-question">
              <span class="faq-q-text">Wie hoch sind die Versandkosten?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p><strong>Kostenloser Versand!</strong> Wir liefern alle Bestellungen innerhalb Deutschlands versandkostenfrei. Für Lieferungen in andere EU-Länder berechnen wir eine kleine Pauschale – diese wird Ihnen im Checkout transparent angezeigt.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="lieferzeit dauer tage wann kommt schnell">
            <summary class="faq-question">
              <span class="faq-q-text">Wie lange dauert die Lieferung?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Die Lieferzeiten variieren je nach Produkt:</p>
              <ul>
                <li><strong>Software-Lizenzen:</strong> Sofort per E-Mail (innerhalb von Minuten)</li>
                <li><strong>Uhren & physische Produkte:</strong> 1-3 Werktage innerhalb Deutschlands</li>
                <li><strong>EU-Ausland:</strong> 3-7 Werktage</li>
              </ul>
              <p>Bestellungen vor 14:00 Uhr werden in der Regel noch am selben Tag versendet.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="tracking sendungsverfolgung wo ist paket status">
            <summary class="faq-question">
              <span class="faq-q-text">Kann ich meine Sendung verfolgen?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Ja! Sobald Ihre Bestellung versendet wird, erhalten Sie eine E-Mail mit der Sendungsnummer und einem Tracking-Link. Damit können Sie den Lieferstatus in Echtzeit verfolgen. Die Tracking-Informationen finden Sie auch in Ihrem <a href="/account">Kundenkonto</a>.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>

          <details class="faq-item" data-keywords="ausland international eu europa schweiz österreich">
            <summary class="faq-question">
              <span class="faq-q-text">Liefern Sie auch ins Ausland?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Ja, wir liefern in alle EU-Länder sowie in die Schweiz. Die Versandkosten und Lieferzeiten werden Ihnen im Checkout angezeigt. Für Nicht-EU-Länder können zusätzliche Zollgebühren anfallen.</p>
              <div class="faq-feedback">
                <span>War diese Antwort hilfreich?</span>
                <button class="feedback-btn" data-feedback="yes" aria-label="Ja, hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                </button>
                <button class="feedback-btn" data-feedback="no" aria-label="Nein, nicht hilfreich">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
                </button>
              </div>
            </div>
          </details>
        </div>
      </div>

      <!-- Rückgabe & Erstattung -->
      <div class="faq-group" data-group="rueckgabe">
        <h2 class="faq-group-title">
          <span class="faq-group-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="1 4 1 10 7 10"/>
              <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
            </svg>
          </span>
          Rückgabe & Erstattung
        </h2>
        
        <div class="faq-list">
          <details class="faq-item" data-keywords="rückgabe widerruf tage frist umtausch zurückgeben">
            <summary class="faq-question">
              <span class="faq-q-text">Wie lange habe ich Rückgaberecht?</span>
              <span class="faq-toggle-icon"></span>
            </summary>
            <div class="faq-answer">
              <p>Bei KARINEX genießen Sie ein <strong>100-Tage-Rückgaberecht</strong> – weit über das gesetzliche Widerrufsrecht von 14 Tagen hinaus! Sie können die Ware ohne Angabe von Gründen zurücksenden und erhalten den vollen Kaufpreis erstattet.</p>
              <div class="faq-feedback">
