<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('help-search-input');
  const searchClear = document.getElementById('help-search-clear');
  const categoryCards = document.querySelectorAll('.category-card');
  const categoryReset = document.getElementById('category-reset');
  const faqGroups = document.querySelectorAll('.faq-group');
  const faqItems = document.querySelectorAll('.faq-item');
  const noResults = document.getElementById('no-results');
  const searchResultsInfo = document.getElementById('search-results-info');
  const resultsClear = document.getElementById('results-clear');

  /* ── Smooth Accordion ── */
  faqItems.forEach(function(details) {
    var answer = details.querySelector('.faq-answer');
    if (!answer) return;

    // Wrap answer children in an inner div for height animation
    var inner = document.createElement('div');
    inner.className = 'faq-answer-inner';
    while (answer.firstChild) inner.appendChild(answer.firstChild);
    answer.appendChild(inner);

    var summary = details.querySelector('summary');
    var animating = false;

    function afterTransition(cb) {
      var done = false;
      function finish() {
        if (done) return;
        done = true;
        cb();
      }
      inner.addEventListener('transitionend', function onEnd(ev) {
        if (ev.target !== inner) return;
        inner.removeEventListener('transitionend', onEnd);
        finish();
      });
      // Fallback if transitionend doesn't fire
      setTimeout(finish, 350);
    }

    summary.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (animating) return;
      animating = true;

      if (details.open) {
        // === CLOSE ===
        // 1. Lock current height
        inner.style.height = inner.scrollHeight + 'px';
        inner.style.opacity = '1';
        // 2. Force reflow so browser registers the starting point
        inner.offsetHeight;
        // 3. Animate to 0
        inner.style.height = '0px';
        inner.style.opacity = '0';

        afterTransition(function() {
          details.open = false;
          inner.style.height = '';
          inner.style.opacity = '';
          animating = false;
        });

      } else {
        // === OPEN ===
        // 1. Set open but keep inner collapsed
        inner.style.height = '0px';
        inner.style.opacity = '0';
        details.open = true;
        // 2. Measure the natural height
        var targetH = inner.scrollHeight;
        // 3. Force reflow
        inner.offsetHeight;
        // 4. Animate to target height
        inner.style.height = targetH + 'px';
        inner.style.opacity = '1';

        afterTransition(function() {
          inner.style.height = 'auto';
          inner.style.opacity = '';
          animating = false;
        });
      }
    });
  });
  
  let activeCategory = null;

  // Search functionality
  function performSearch(query) {
    query = query.toLowerCase().trim();
    searchClear.style.display = query ? 'flex' : 'none';
    
    let visibleCount = 0;
    
    if (!query && !activeCategory) {
      // Show all
      faqGroups.forEach(g => g.style.display = 'block');
      faqItems.forEach(item => {
        item.style.display = 'block';
        item.open = false;
        // Reset highlight
        const qText = item.querySelector('.faq-q-text');
        qText.innerHTML = qText.textContent;
      });
      noResults.style.display = 'none';
      searchResultsInfo.style.display = 'none';
      return;
    }

    faqGroups.forEach(group => {
      const groupCategory = group.dataset.group;
      let groupHasVisible = false;
      
      if (activeCategory && groupCategory !== activeCategory) {
        group.style.display = 'none';
        return;
      }
      
      const items = group.querySelectorAll('.faq-item');
      items.forEach(item => {
        const qText = item.querySelector('.faq-q-text');
        const questionText = qText.textContent.toLowerCase();
        const answerText = item.querySelector('.faq-answer').textContent.toLowerCase();
        const keywords = item.dataset.keywords || '';
        
        const matchesSearch = !query || 
          questionText.includes(query) || 
          answerText.includes(query) ||
          keywords.includes(query);
        
        if (matchesSearch) {
          item.style.display = 'block';
          groupHasVisible = true;
          visibleCount++;
          
          // Highlight search term
          if (query && questionText.includes(query)) {
            const regex = new RegExp(`(${query})`, 'gi');
            qText.innerHTML = qText.textContent.replace(regex, '<mark>$1</mark>');
          } else {
            qText.innerHTML = qText.textContent;
          }
          
          if (query) item.open = true;
        } else {
          item.style.display = 'none';
        }
      });
      
      group.style.display = groupHasVisible ? 'block' : 'none';
    });

    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    
    if (query || activeCategory) {
      searchResultsInfo.style.display = 'flex';
      searchResultsInfo.querySelector('.results-count').textContent = 
        visibleCount + ' Ergebnis' + (visibleCount !== 1 ? 'se' : '') + ' gefunden';
    } else {
      searchResultsInfo.style.display = 'none';
    }
  }

  // Debounce search
  let searchTimeout;
  searchInput.addEventListener('input', function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => performSearch(this.value), 150);
  });

  searchClear.addEventListener('click', function() {
    searchInput.value = '';
    performSearch('');
    searchInput.focus();
  });

  resultsClear.addEventListener('click', function() {
    searchInput.value = '';
    activeCategory = null;
    categoryCards.forEach(c => c.setAttribute('aria-pressed', 'false'));
    categoryReset.style.display = 'none';
    performSearch('');
  });

  // Category filtering
  categoryCards.forEach(card => {
    card.addEventListener('click', function() {
      const category = this.dataset.category;
      
      if (activeCategory === category) {
        activeCategory = null;
        this.setAttribute('aria-pressed', 'false');
        categoryReset.style.display = 'none';
      } else {
        activeCategory = category;
        categoryCards.forEach(c => c.setAttribute('aria-pressed', 'false'));
        this.setAttribute('aria-pressed', 'true');
        categoryReset.style.display = 'flex';
      }
      
      performSearch(searchInput.value);
      
      // Smooth scroll to FAQ content
      setTimeout(() => {
        document.getElementById('faq-content').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    });
  });

  categoryReset.addEventListener('click', function() {
    activeCategory = null;
    categoryCards.forEach(c => c.setAttribute('aria-pressed', 'false'));
    this.style.display = 'none';
    performSearch(searchInput.value);
  });

  // Feedback buttons
  document.querySelectorAll('.feedback-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const parent = this.closest('.faq-feedback');
      parent.innerHTML = '<span class="feedback-thanks">Danke für Ihr Feedback!</span>';
    });
  });
});
</script>

