{%- comment -%} BlogPosting Schema — Rich Results for Articles {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": "{{ article.url | prepend: shop.url }}#article",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ article.url | prepend: shop.url }}#webpage"
  },
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt_or_content | strip_html | truncate: 160 | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
  "dateModified": "{{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  "publisher": {
    "@id": "{{ shop.url }}/#organization"
  },
  "isPartOf": {
    "@id": "{{ shop.url }}/#website"
  }
  {%- if article.image -%}
  ,"image": {
    "@type": "ImageObject",
    "url": "https:{{ article.image | image_url: width: 1200, format: 'webp' }}",
    "width": 1200,
    "height": 630
  }
  {%- endif -%}
  {%- if article.tags.size > 0 -%}
  ,"keywords": {{ article.tags | join: ', ' | json }}
  {%- endif -%}
  ,"inLanguage": "{{ request.locale.iso_code | replace: 'de', 'de-DE' | replace: 'en', 'en-US' | replace: 'pl', 'pl-PL' }}"
  ,"wordCount": {{ article.content | strip_html | split: ' ' | size }}
}
</script>

<section class="article-layout">
  <!-- Hero Banner -->
  <div class="article-hero">
    {% if article.image %}
      <img
        src="{{ article.image | image_url: width: 800, format: 'webp', quality: 75 }}"
        alt="{{ article.title | escape }}"
        class="article-hero__image"
        width="800"
        height="600"
        loading="eager"
      >
      <div class="article-hero__overlay"></div>
      <div class="article-hero__content">
        <nav class="article-breadcrumb">
          <a href="/">Start</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <a href="{{ blog.url }}">{{ blog.title }}</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <span>{{ article.title | truncate: 40 }}</span>
        </nav>
        <h1 class="article-title">{{ article.title }}</h1>
        <div class="article-meta">
          <span class="article-meta__date">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            {{ article.published_at | date: "%d. %B %Y" }}
          </span>
          {% if article.author %}
            <span class="article-meta__author">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              {{ article.author }}
            </span>
          {% endif %}
          <span class="funktionale-count" data-article-id="{{ article.id }}">1</span>
          <button class="tts-play-btn" onclick="startTTS()" aria-label="Artikel vorlesen">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
          {% if article.tags.size > 0 %}
            <span class="article-meta__tags">
              {% for tag in article.tags limit: 3 %}
                <span class="article-tag">{{ tag }}</span>
              {% endfor %}
            </span>
          {% endif %}
        </div>
      </div>
    {% else %}
      <div class="article-hero--no-image">
        <nav class="article-breadcrumb">
          <a href="/">Start</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <a href="{{ blog.url }}">{{ blog.title }}</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <span>{{ article.title | truncate: 40 }}</span>
        </nav>
        <h1 class="article-title">{{ article.title }}</h1>
        <div class="article-meta">
          <span class="article-meta__date">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            {{ article.published_at | date: "%d. %B %Y" }}
          </span>
          {% if article.author %}
            <span class="article-meta__author">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              {{ article.author }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>

  <!-- Reading Progress Bar -->
  <div class="article-progress" id="articleProgress"></div>

  <!-- Content Area -->
  <div class="article-body">
    <div class="article-content-wrapper">
      <!-- Sticky TOC Sidebar -->
      <aside class="article-toc" id="toc-desktop">
        <div class="article-toc__header">
          <span class="article-toc__label">INHALT</span>
        </div>
        {% render 'toc-generator', content: article.content %}
      </aside>

      <!-- Article Content -->
      <main class="article-content" id="article-content">
        {%- comment -%} Strip any hardcoded meta/title tags accidentally pasted into article content {%- endcomment -%}
        {%- assign clean_content = article.content
          | remove: "<!-- SEO: Meta Description (max. 155 Zeichen) -->"
          | remove: "<!-- SEO: Meta Description -->"
          | remove: "<title>Installationsanleitung: Microsoft Office 2021 & 2024 Standard - Karinex</title>"
          | remove: "<title>Windows 11 Home vs. Pro: Welche Version Maximiert Ihre Unternehmensproduktivit&#228;t?</title>"
          | remove: "<title>Microsoft Office f&#252;r Mac &#8211; Installationsanleitung</title>"
          | remove: "<title>Windows 11 auf alten PC installieren</title>"
        -%}
        {%- comment -%} Remove any remaining standalone title/meta tags {%- endcomment -%}
        {%- assign clean_content = clean_content
          | split: '<meta name="description"'
          | first
        -%}
        {{ clean_content }}

        <!-- Share & Actions -->
        <div class="article-actions">
          <div class="article-share">
            <span class="article-share__label">Teilen:</span>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ article.url | prepend: shop.url }}" target="_blank" rel="noopener" class="share-icon" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://twitter.com/intent/tweet?url={{ article.url | prepend: shop.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="share-icon" aria-label="X/Twitter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://api.whatsapp.com/send?text={{ article.title | url_encode }}%20{{ article.url | prepend: shop.url }}" target="_blank" rel="noopener" class="share-icon" aria-label="WhatsApp">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <button class="share-icon" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),2000)})" aria-label="Link kopieren">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>

        <!-- Related Articles -->
        {% assign related_articles = blog.articles | where: 'id' %}
        <div class="related-articles">
          <h3 class="related-articles__title">Das könnte dich auch interessieren</h3>
          <div class="related-articles__grid">
            {% for related in blog.articles limit: 3 %}
              {% unless related.id == article.id %}
                <a href="{{ related.url }}" class="related-card">
                  {% if related.image %}
                    <img src="{{ related.image | image_url: width: 400, format: 'webp', quality: 80 }}" alt="{{ related.title | escape }}" class="related-card__image" loading="lazy" width="400" height="225">
                  {% else %}
                    <div class="related-card__placeholder"></div>
                  {% endif %}
                  <div class="related-card__body">
                    {% if related.tags.size > 0 %}
                      <span class="related-card__tag">{{ related.tags.first }}</span>
                    {% endif %}
                    <span class="related-card__title">{{ related.title | truncate: 60 }}</span>
                    <span class="related-card__date">{{ related.published_at | date: "%d.%m.%Y" }}</span>
                  </div>
                </a>
              {% endunless %}
            {% endfor %}
          </div>
        </div>
      </main>
    </div>
  </div>
</section>

<style>
/* === Article Layout === */
.article-layout {
  width: 100%;
  margin: 0;
  padding: 0;
}

/* === Hero === */
.article-hero {
  position: relative;
  width: 100%;
  min-height: 420px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}
.article-hero__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.article-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
}
.article-hero__content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 48px clamp(16px, 4vw, 64px);
  color: #fff;
}
.article-hero__content .article-breadcrumb,
.article-hero__content .article-breadcrumb a {
  color: rgba(255,255,255,0.8);
}
.article-hero__content .article-breadcrumb a:hover {
  color: #fff;
}
.article-hero__content .article-title {
  color: #fff;
  text-shadow: 0 2px 12px rgba(0,0,0,0.3);
}
.article-hero__content .article-meta {
  color: rgba(255,255,255,0.85);
}

.article-hero--no-image {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 48px clamp(16px, 4vw, 64px) 32px;
}

/* === Breadcrumb === */
.article-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.9rem;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.article-breadcrumb a {
  color: #5a6270;
  text-decoration: none;
  transition: color 0.2s;
}
.article-breadcrumb a:hover { color: #23272f; }
.article-breadcrumb span { color: #8a8f9c; }
.article-breadcrumb svg { opacity: 0.5; flex-shrink: 0; }

/* === Title & Meta === */
.article-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800;
  line-height: 1.15;
  margin: 0 0 16px 0;
  color: #23272f;
}
.article-meta {
  display: flex;
  align-items: center;
  gap: 20px;
  font-size: 0.95rem;
  color: #5a6270;
  flex-wrap: wrap;
}
.article-meta__date,
.article-meta__author {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.article-tag {
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(4px);
  padding: 2px 10px;
  border-radius: 20px;
  font-size: 0.82rem;
  font-weight: 500;
}
.article-hero--no-image .article-tag {
  background: #f0f1f3;
  color: #5a6270;
}

/* === Reading Progress === */
.article-progress {
  position: sticky;
  top: 0;
  height: 3px;
  background: #c8102e;
  width: 0%;
  z-index: 100;
  transition: width 50ms linear;
}

/* === Body === */
.article-body {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px clamp(16px, 4vw, 64px) 80px;
}

/* === Content Wrapper (TOC + Content) === */
.article-content-wrapper {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 48px;
  align-items: start;
}
@media (max-width: 960px) {
  .article-content-wrapper {
    grid-template-columns: 1fr;
  }
}

/* === TOC Sidebar === */
.article-toc {
  position: sticky;
  top: 24px;
  background: #fafbfc;
  border: 1px solid #e8eaed;
  border-radius: 12px;
  padding: 20px;
  max-height: 75vh;
  overflow-y: auto;
  scrollbar-width: thin;
}
.article-toc__header {
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 3px solid #c8102e;
  display: inline-block;
}
.article-toc__label {
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  color: #c8102e;
}
@media (max-width: 960px) {
  .article-toc { display: none; }
}

/* === Article Content === */
.article-content {
  min-width: 0;
  font-size: 1.1rem;
  line-height: 1.8;
  color: #23272f;
}
.article-content > h1:first-child,
.article-content > h1:first-of-type {
  display: none;
}
.article-content h2 {
  font-size: 1.6rem;
  font-weight: 700;
  margin-top: 2.5em;
  margin-bottom: 0.6em;
  padding-bottom: 8px;
  border-bottom: 2px solid #f0f1f3;
  color: #1a1a1a;
}
.article-content h3 {
  font-size: 1.25rem;
  font-weight: 600;
  margin-top: 1.8em;
  margin-bottom: 0.5em;
  color: #23272f;
}
.article-content p {
  margin-bottom: 1.2em;
}
.article-content img {
  max-width: 100%;
  height: auto;
  border-radius: 12px;
  margin: 24px 0;
}
.article-content ul, .article-content ol {
  padding-left: 1.5em;
  margin-bottom: 1.2em;
}
.article-content li {
  margin-bottom: 0.4em;
}
.article-content a {
  color: #c8102e;
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.2s;
}
.article-content a:hover { color: #8b0a1e; }
.article-content blockquote {
  border-left: 4px solid #c8102e;
  background: #fafbfc;
  padding: 16px 20px;
  margin: 24px 0;
  border-radius: 0 8px 8px 0;
  color: #444;
  font-style: italic;
}
.article-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 24px 0;
  font-size: 0.95rem;
}
.article-content th, .article-content td {
  padding: 10px 14px;
  border: 1px solid #e8eaed;
  text-align: left;
}
.article-content th {
  background: #f7f8fa;
  font-weight: 600;
}

/* === Share === */
.article-actions {
  margin-top: 48px;
  padding-top: 24px;
  border-top: 1px solid #e8eaed;
}
.article-share {
  display: flex;
  align-items: center;
  gap: 12px;
}
.article-share__label {
  font-weight: 600;
  font-size: 0.95rem;
  color: #5a6270;
}
.share-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #f0f1f3;
  color: #444;
  border: none;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.15s;
  text-decoration: none;
}
.share-icon:hover {
  background: #23272f;
  color: #fff;
  transform: scale(1.1);
}
.share-icon.copied {
  background: #10b981;
  color: white;
}

/* === TTS Button === */
.tts-button {
  transition: background 0.3s, color 0.3s;
}
.tts-button.playing {
  background: #10b981;
  color: white;
}
.tts-button.playing svg {
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

/* === Related Articles === */
.related-articles {
  margin-top: 64px;
  padding-top: 40px;
  border-top: 1px solid #e8eaed;
}
.related-articles__title {
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 24px;
  color: #1a1a1a;
}
.related-articles__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
}
.related-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s, transform 0.2s;
  display: flex;
  flex-direction: column;
}
.related-card:hover {
  box-shadow: 0 8px 28px rgba(0,0,0,0.12);
  transform: translateY(-3px);
}
.related-card__image {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
}
.related-card__placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: #f0f1f3;
}
.related-card__body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.related-card__tag {
  font-size: 0.78rem;
  font-weight: 600;
  color: #c8102e;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.related-card__title {
  font-size: 1.05rem;
  font-weight: 600;
  color: #23272f;
  line-height: 1.3;
}
.related-card__date {
  font-size: 0.85rem;
  color: #8a8f9c;
}

/* === Mobile === */
@media (max-width: 600px) {
  .article-hero { min-height: 300px; }
  .article-body { padding: 24px 16px 48px; }
  .related-articles__grid { grid-template-columns: 1fr; }
}
</style>

<!-- Reading Progress Script -->
<script>
(function() {
  var bar = document.getElementById('articleProgress');
  var content = document.getElementById('article-content');
  if (!bar || !content) return;
  function update() {
    var rect = content.getBoundingClientRect();
    var total = content.scrollHeight - window.innerHeight;
    var scrolled = -rect.top;
    var pct = Math.max(0, Math.min(100, (scrolled / total) * 100));
    bar.style.width = pct + '%';
  }
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
})();
</script>

<!-- Text-to-Speech Script -->
<script>
(function() {
  if (!('speechSynthesis' in window)) {
    console.warn('Speech synthesis not supported');
    return;
  }

  var toggleBtn = document.getElementById('tts-toggle');
  var articleContent = document.getElementById('article-content');
  if (!toggleBtn || !articleContent) {
    console.warn('TTS: button or content not found');
    return;
  }

  var utterance = null;
  var isPlaying = false;

  function getText() {
    // Remove unwanted elements and get clean text
    var temp = document.createElement('div');
    temp.innerHTML = articleContent.innerHTML;
    var scripts = temp.querySelectorAll('script,style,noscript');
    scripts.forEach(el => el.remove());
    return temp.innerText || temp.textContent || '';
  }

  function startTTS() {
    if (isPlaying) {
      speechSynthesis.cancel();
      stopTTS();
      return;
    }

    var text = getText();
    if (!text) return;

    utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'de-DE';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    utterance.volume = 1;

    utterance.onstart = function() {
      isPlaying = true;
      toggleBtn.classList.add('playing');
      toggleBtn.setAttribute('aria-label', 'Vorlesen stoppen');
    };

    utterance.onend = function() {
      stopTTS();
    };

    utterance.onerror = function(e) {
      console.error('TTS error:', e);
      stopTTS();
    };

    speechSynthesis.speak(utterance);
  }

  function stopTTS() {
    isPlaying = false;
    toggleBtn.classList.remove('playing');
    toggleBtn.setAttribute('aria-label', 'Artikel vorlesen');
  }

  toggleBtn.addEventListener('click', startTTS);

  // Reset on page unload
  window.addEventListener('beforeunload', function() {
    speechSynthesis.cancel();
  });

  // Debug: log button found
  console.log('TTS button initialized:', toggleBtn);
})();
</script>

