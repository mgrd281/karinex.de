{%- liquid
  assign _root = routes.root_url | default: '/'
  unless _root == '/'
    assign _root = _root | append: '/'
  endunless
-%}
<style>
  /* ══════════════════════════════════════════════════
     Premium Wishlist – AboutYou / Breuninger Style
     ══════════════════════════════════════════════════ */

  .wl-page {
    --wl-card-bg: {{ section.settings.card_bg_color }};
    max-width: 1520px;
    margin: 0 auto;
    padding: 40px 40px 120px;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'Inter', Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Layout: sidebar + main ── */
  .wl-layout {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 1080px) {
    .wl-layout {
      grid-template-columns: 190px 1fr;
      column-gap: 64px;
    }
  }

  /* ── Sidebar ── */
  .wl-sidebar { display: none; }
  @media (min-width: 1080px) {
    .wl-sidebar {
      display: block;
      align-self: start;
      position: sticky;
      top: 28px;
      padding-top: 2px;
    }
  }
  .wl-sidebar__title {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: #b0b0b0;
    margin: 0 0 20px;
  }
  .wl-sidebar__list { list-style: none; margin: 0; padding: 0; }
  .wl-sidebar__item { margin-bottom: 0; }
  .wl-sidebar__link {
    display: block;
    padding: 9px 0;
    font-size: 13.5px;
    font-weight: 400;
    color: #888;
    text-decoration: none;
    transition: color 0.18s;
    letter-spacing: 0.15px;
  }
  .wl-sidebar__link:hover { color: #222; }
  .wl-sidebar__link.is-active { color: #111; font-weight: 600; }
  .wl-sidebar__link-count {
    font-size: 11px; color: #ccc; font-weight: 400; margin-left: 3px;
  }

  /* ── Main ── */
  .wl-main { min-width: 0; }

  /* ── Header ── */
  .wl-page__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 0;
  }
  .wl-page__title {
    font-size: 28px;
    font-weight: 800;
    color: #111;
    margin: 0;
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  .wl-page__count {
    font-size: 16px;
    font-weight: 300;
    color: #bbb;
    margin-left: 8px;
    letter-spacing: -0.2px;
  }
  .wl-page__sort {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: #888;
    cursor: pointer;
    border: 1px solid #e4e4e4;
    border-radius: 24px;
    padding: 8px 18px;
    background: transparent;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    font-family: inherit;
    letter-spacing: 0.1px;
  }
  .wl-page__sort:hover { border-color: #ccc; color: #444; background: #fafafa; }
  .wl-page__sort svg { width: 14px; height: 14px; stroke: #aaa; transition: stroke 0.2s; }
  .wl-page__sort:hover svg { stroke: #666; }

  /* ── Sort dropdown ── */
  .wl-sort-wrap { position: relative; }
  .wl-sort-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 210px;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    z-index: 500;
    padding: 8px 0;
    font-family: inherit;
  }
  .wl-sort-dropdown.is-open { display: block; }
  .wl-sort-dropdown__item {
    display: block;
    width: 100%;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 400;
    color: #555;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    font-family: inherit;
  }
  .wl-sort-dropdown__item:hover { background: #f8f8f8; color: #111; }
  .wl-sort-dropdown__item.is-active { font-weight: 600; color: #111; }

  /* ── Grid ── */
  .wl-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 16px;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: start;
  }
  @media (min-width: 750px) and (max-width: 1079px) {
    .wl-grid { grid-template-columns: repeat(3, 1fr); gap: 28px 20px; }
  }
  @media (min-width: 1080px) {
    .wl-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 36px 24px; }
  }

  /* ── Card entrance animation ── */
  @keyframes wl-fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
      filter: blur(3px);
    }
    60% { filter: blur(0); }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  /* ══ Card ══ */
  .wl-card {
    position: relative;
    background: transparent;
    border: none;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    padding: 0;
    opacity: 0;
    animation: wl-fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .wl-card a.wl-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* Delete icon — tiny, appears on hover */
  .wl-card__delete {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 5;
    width: 26px;
    height: 26px;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    opacity: 0;
    transition: opacity 0.2s, color 0.2s, transform 0.15s, background 0.2s;
    padding: 0;
  }
  .wl-card:hover .wl-card__delete { opacity: 1; }
  .wl-card__delete:hover {
    opacity: 1;
    color: #333;
    background: rgba(255,255,255,0.95);
    transform: scale(1.1);
  }
  .wl-card__delete svg { width: 13px; height: 13px; }

  /* Image area — soft rounded, breathing room */
  .wl-card__img-wrap {
    position: relative;
    width: 100%;
    padding-top: 120%;
    background: var(--wl-card-bg);
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 0;
  }
  .wl-card__img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .wl-card:hover .wl-card__img {
    transform: scale(1.04);
  }

  /* Sale badge — flush, small */
  .wl-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #c0392b;
    color: #fff;
    font-weight: 700;
    font-size: 9px;
    padding: 3px 8px 3.5px;
    border-radius: 20px;
    z-index: 2;
    letter-spacing: 0.2px;
    line-height: 1.2;
  }

  /* Card info — left aligned, editorial */
  .wl-card__info {
    text-align: left;
    padding: 12px 4px 0;
  }
  .wl-card__brand {
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    color: #bbb;
    margin-bottom: 4px;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1;
  }
  .wl-card__title {
    font-size: 13px;
    font-weight: 400;
    color: #333;
    line-height: 1.5;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
  }
  .wl-card__prices {
    font-size: 13.5px;
    font-weight: 700;
    color: #111;
    display: flex;
    gap: 6px;
    align-items: baseline;
    letter-spacing: -0.2px;
  }
  .wl-card__price--sale { color: #c0392b; }
  .wl-card__price--regular { color: #111; }
  .wl-card__price--old {
    color: #ccc;
    text-decoration: line-through;
    font-size: 11px;
    font-weight: 400;
  }

  /* ── AboutYou-style ATC slide-up (desktop) ── */
  .wl-card__atc {
    display: none;
  }

  @media (min-width: 768px) {
    .wl-card__atc {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 44px;
      background: #fff;
      border: none;
      border-radius: 0 0 12px 12px;
      font-size: 13px;
      font-weight: 600;
      color: #111;
      cursor: pointer;
      font-family: inherit;
      letter-spacing: 0.2px;
      z-index: 4;
      transform: translateY(100%);
      opacity: 0;
      transition: transform 0.28s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  opacity 0.22s ease,
                  background 0.15s;
      overflow: hidden;
      box-shadow: 0 -1px 0 rgba(0,0,0,0.04);
    }

    .wl-card:hover .wl-card__atc,
    .wl-card.is-atc-active .wl-card__atc {
      transform: translateY(0);
      opacity: 1;
    }

    .wl-card__atc:hover {
      background: #f0f0f0;
    }
    .wl-card__atc:active {
      transform: translateY(0) scale(0.98);
    }

    .wl-atc__text, .wl-atc__check, .wl-atc__adding {
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .wl-atc__check, .wl-atc__adding {
      position: absolute; opacity: 0; transform: scale(0.5);
    }
    .wl-card__atc.is-adding .wl-atc__text { opacity: 0; transform: translateY(-8px); }
    .wl-card__atc.is-adding .wl-atc__adding { opacity: 1; transform: scale(1); }
    .wl-card__atc.is-added { background: #1d4739; color: #fff; }
    .wl-card__atc.is-added .wl-atc__text { opacity: 0; transform: translateY(-8px); }
    .wl-card__atc.is-added .wl-atc__check { opacity: 1; transform: scale(1); }

    @keyframes wl-spin { to { transform: rotate(360deg); } }
    .wl-atc__spinner { animation: wl-spin 0.7s linear infinite; }
  }

  /* ── Loading / Empty ── */
  .wl-loading {
    grid-column: 1 / -1;
    text-align: center;
    padding: 100px 20px;
    color: #ccc;
    font-size: 13px;
    letter-spacing: 0.5px;
  }
  .wl-empty {
    display: none;
    grid-column: 1 / -1;
    text-align: center;
    padding: 100px 20px 120px;
    flex-direction: column;
    align-items: center;
  }
  .wl-empty__icon {
    width: 48px; height: 48px; color: #ddd; margin-bottom: 24px; stroke-width: 0.6;
  }
  .wl-empty__title {
    font-size: 22px; font-weight: 700; color: #222; margin: 0 0 8px;
    letter-spacing: -0.3px;
  }
  .wl-empty__text {
    font-size: 14px; color: #aaa; margin: 0 0 40px; line-height: 1.6;
  }
  .wl-empty__cta {
    display: inline-flex; align-items: center; justify-content: center;
    height: 48px; padding: 0 48px;
    background: #111; color: #fff;
    border: none; border-radius: 24px;
    font-size: 13px; font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.2s;
    font-family: inherit;
  }
  .wl-empty__cta:hover { background: #333; transform: translateY(-1px); }
  .wl-empty__links {
    display: flex; gap: 28px; margin-top: 32px;
    font-size: 12.5px;
  }
  .wl-empty__links a {
    color: #bbb; text-decoration: none; transition: color 0.2s;
    letter-spacing: 0.2px;
  }
  .wl-empty__links a:hover { color: #333; }

  /* ── Responsive ── */
  @media (max-width: 749px) {
    .wl-page { padding: 24px 16px 60px; }
    .wl-page__title { font-size: 22px; }
    .wl-page__count { font-size: 14px; }
    .wl-page__sort { padding: 7px 14px; font-size: 11px; }
    .wl-card__img-wrap { border-radius: 10px; }
    .wl-card__info { padding: 10px 2px 0; }
    .wl-card__brand { font-size: 8px; letter-spacing: 1.2px; }
    .wl-card__title { font-size: 11.5px; }
    .wl-card__prices { font-size: 12px; }
    .wl-card__delete { opacity: 0.5; width: 24px; height: 24px; }
    .wl-card__delete svg { width: 11px; height: 11px; }
  }
</style>

<div class="wl-page">
  <div class="wl-layout">
    <aside class="wl-sidebar">
      <p class="wl-sidebar__title">Kategorien</p>
      <ul class="wl-sidebar__list">
        <li class="wl-sidebar__item"><a href="#" class="wl-sidebar__link is-active" data-filter="all">Wunschliste <span class="wl-sidebar__link-count" id="wl-sidebar-count"></span></a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/unsere-bestseller" class="wl-sidebar__link">Bestseller</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/sale" class="wl-sidebar__link">Sale</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/software" class="wl-sidebar__link">Software</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/games" class="wl-sidebar__link">Games</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/lego" class="wl-sidebar__link">Lego</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/herrenuhren" class="wl-sidebar__link">Herrenuhren</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/damenuhren" class="wl-sidebar__link">Damenuhren</a></li>
        <li class="wl-sidebar__item"><a href="{{ _root }}collections/spielzeug" class="wl-sidebar__link">Spielzeug</a></li>
      </ul>
    </aside>

    <div class="wl-main">
      <div class="wl-page__header">
        <h1 class="wl-page__title">Wunschliste <span class="wl-page__count" id="wl-count"></span></h1>
        <div class="wl-sort-wrap">
          <button class="wl-page__sort" id="wl-sort" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h12M3 18h6"/></svg>
            Sortierung
          </button>
          <div class="wl-sort-dropdown" id="wl-sort-dropdown">
            <button class="wl-sort-dropdown__item is-active" data-sort="newest" type="button">Neueste zuerst</button>
            <button class="wl-sort-dropdown__item" data-sort="popular" type="button">Beliebteste</button>
            <button class="wl-sort-dropdown__item" data-sort="price-asc" type="button">Preis aufsteigend</button>
            <button class="wl-sort-dropdown__item" data-sort="price-desc" type="button">Preis absteigend</button>
            <button class="wl-sort-dropdown__item" data-sort="brand-az" type="button">Marke A–Z</button>
          </div>
        </div>
      </div>

      <div class="wl-grid" id="wl-grid">
        <div class="wl-loading" id="wl-loading">Laden...</div>
        <div class="wl-empty" id="wl-empty">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="wl-empty__icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
          <h2 class="wl-empty__title">Deine Wunschliste ist noch leer.</h2>
          <p class="wl-empty__text">Speichere deine Lieblingsprodukte für später.</p>
          <a href="{{ _root }}collections/all" class="wl-empty__cta">Jetzt einkaufen</a>
          <div class="wl-empty__links">
            <a href="{{ _root }}collections/unsere-bestseller">Bestseller</a>
            <a href="{{ _root }}collections/sale">Sale</a>
            <a href="{{ _root }}collections/all">Alle Produkte</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  document.addEventListener('DOMContentLoaded', async function() {
    var grid = document.getElementById('wl-grid');
    var loading = document.getElementById('wl-loading');
    var empty = document.getElementById('wl-empty');
    var countEl = document.getElementById('wl-count');

    var raw = localStorage.getItem('wishlist');
    var wishlist = raw ? JSON.parse(raw) : [];
    wishlist = wishlist.filter(function(h) { return h && typeof h === 'string'; });
    wishlist = [...new Set(wishlist.map(function(h) { return h.trim(); }))];
    localStorage.setItem('wishlist', JSON.stringify(wishlist));

    if (countEl) countEl.textContent = '(' + wishlist.length + ')';

    if (!wishlist.length) {
      loading.style.display = 'none';
      empty.style.display = 'flex';
      return;
    }

    /* Fetch product JSON for each handle */
    var products = await Promise.all(wishlist.map(async function(handle) {
      try {
        var res = await fetch('/products/' + encodeURIComponent(handle) + '.js');
        if (!res.ok) return null;
        return await res.json();
      } catch(e) { return null; }
    }));

    loading.style.display = 'none';
    products = products.filter(Boolean);

    if (!products.length) {
      empty.style.display = 'flex';
      return;
    }

    var resizeImage = function(url, size) {
      try { return url.replace(/(\.[^.]*)$/, '_' + size + '$1'); } catch(e) { return url; }
    };

    function renderCard(product, idx) {
      var handle = product.handle;
      var brand = product.vendor || '';
      var title = product.title || '';
      var img = product.featured_image ? resizeImage(product.featured_image, '500x') : '';
      var url = '/products/' + handle;

      /* Price */
      var price = product.price;
      var compare = product.compare_at_price;
      var badgeHtml = '';
      var priceHtml = '';

      if (compare && compare > price) {
        var pct = Math.round(((compare - price) / compare) * 100);
        badgeHtml = '<div class="wl-card__badge">-' + pct + '%</div>';
        priceHtml = '<span class="wl-card__price--sale">' + (price / 100).toFixed(2).replace('.', ',') + ' €</span>' +
                    '<span class="wl-card__price--old">' + (compare / 100).toFixed(2).replace('.', ',') + ' €</span>';
      } else {
        priceHtml = '<span class="wl-card__price--regular">' + (price / 100).toFixed(2).replace('.', ',') + ' €</span>';
      }

      /* Sizes */
      var sizeIdx = (product.options || []).findIndex(function(o) { return /gr[öo]ße|size/i.test(o); });
      var sizesHtml = '';
      var firstVariantId = product.variants && product.variants.length ? product.variants[0].id : '';
      if (product.variants) {
        var avail = product.variants.find(function(v) { return v.available; });
        if (avail) firstVariantId = avail.id;
        if (sizeIdx >= 0) {
          var sizeKey = 'option' + (sizeIdx + 1);
          var allSizes = [];
          var seen = {};
          product.variants.forEach(function(v) {
            var s = v[sizeKey];
            if (s && !seen[s]) { seen[s] = true; allSizes.push(s); }
          });
          var shown = allSizes.slice(0, 4);
          var rest = allSizes.length - shown.length;
          sizesHtml = '<div class="wl-card__hover-sizes">' +
            shown.map(function(s) { return '<span class="wl-card__size-dot">' + s + '</span>'; }).join('') +
            (rest > 0 ? '<span class="wl-card__size-more">+' + rest + '</span>' : '') +
            '</div>';
        }
      }

      var cardHtml =
        '<a href="' + url + '" class="wl-card__link" aria-label="' + title + '"></a>' +
        '<button type="button" class="wl-card__delete" data-handle="' + handle + '" aria-label="Entfernen">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
        '</button>' +
        '<div class="wl-card__img-wrap">' +
          '<img src="' + img + '" alt="' + title.replace(/"/g,'&quot;') + '" class="wl-card__img" loading="lazy" width="500" height="500">' +
          badgeHtml +
          '<button type="button" class="wl-card__atc" data-variant-id="' + firstVariantId + '">' +
            '<span class="wl-atc__text">In den Warenkorb</span>' +
            '<span class="wl-atc__check"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>' +
            '<span class="wl-atc__adding"><svg class="wl-atc__spinner" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#fff" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4" stroke-dashoffset="10"/></svg></span>' +
          '</button>' +
        '</div>' +
        '<div class="wl-card__info" style="pointer-events:none;">' +
          '<span class="wl-card__brand">' + brand + '</span>' +
          '<span class="wl-card__title">' + title + '</span>' +
          '<div class="wl-card__prices">' + priceHtml + '</div>' +
        '</div>';

      var el = document.createElement('div');
      el.className = 'wl-card';
      el.style.animationDelay = (idx * 0.07) + 's';
      el.innerHTML = cardHtml;
      grid.appendChild(el);
    }

    products.forEach(function(product, idx) {
      renderCard(product, idx);
    });

    /* Update sidebar count */
    var sidebarCount = document.getElementById('wl-sidebar-count');
    if (sidebarCount) sidebarCount.textContent = '(' + products.length + ')';

    /* ── Sort logic ── */
    var sortBtn = document.getElementById('wl-sort');
    var sortDropdown = document.getElementById('wl-sort-dropdown');
    var currentSort = 'newest';

    sortBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      sortDropdown.classList.toggle('is-open');
    });

    document.addEventListener('click', function(e) {
      if (!e.target.closest('.wl-sort-wrap')) {
        sortDropdown.classList.remove('is-open');
      }
    });

    sortDropdown.addEventListener('click', function(e) {
      var item = e.target.closest('.wl-sort-dropdown__item');
      if (!item) return;
      e.stopPropagation();
      currentSort = item.dataset.sort;
      sortDropdown.querySelectorAll('.wl-sort-dropdown__item').forEach(function(el) {
        el.classList.remove('is-active');
      });
      item.classList.add('is-active');
      sortDropdown.classList.remove('is-open');
      applySortAndRender();
    });

    function applySortAndRender() {
      var sorted = products.slice();
      switch (currentSort) {
        case 'popular':
          sorted.sort(function(a, b) {
            var aDiscount = (a.compare_at_price || 0) - a.price;
            var bDiscount = (b.compare_at_price || 0) - b.price;
            return bDiscount - aDiscount;
          });
          break;
        case 'price-asc':
          sorted.sort(function(a, b) { return a.price - b.price; });
          break;
        case 'price-desc':
          sorted.sort(function(a, b) { return b.price - a.price; });
          break;
        case 'brand-az':
          sorted.sort(function(a, b) {
            return (a.vendor || '').localeCompare(b.vendor || '', 'de');
          });
          break;
        default: /* newest – original wishlist order */
          break;
      }
      /* Clear existing cards */
      grid.querySelectorAll('.wl-card').forEach(function(c) { c.remove(); });
      sorted.forEach(function(product, idx) { renderCard(product, idx); });
    }

    /* Delete handlers */
    grid.addEventListener('click', function(e) {
      var btn = e.target.closest('.wl-card__delete');
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      var handle = btn.dataset.handle;
      if (!handle) return;

      var card = btn.closest('.wl-card');
      if (card) {
        card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
        card.style.opacity = '0';
        card.style.transform = 'scale(0.92) translateY(8px)';
        setTimeout(function() {
          card.remove();
          var remaining = grid.querySelectorAll('.wl-card');
          if (countEl) countEl.textContent = '(' + remaining.length + ')';
          if (!remaining.length) empty.style.display = 'flex';
        }, 300);
      }

      var wl = JSON.parse(localStorage.getItem('wishlist') || '[]');
      wl = wl.filter(function(h) { return h !== handle; });
      localStorage.setItem('wishlist', JSON.stringify(wl));
      window.dispatchEvent(new Event('wishlist-updated'));
      document.dispatchEvent(new CustomEvent('wishlist:update', { detail: { handle: handle, saved: false } }));
    });

    /* AJAX ATC handler */
    grid.addEventListener('click', async function(e) {
      var btn = e.target.closest('.wl-card__atc');
      if (!btn || btn.disabled || btn.classList.contains('is-adding')) return;

      var variantId = btn.getAttribute('data-variant-id');
      var card = btn.closest('.wl-card');
      if (!variantId) return;

      e.preventDefault();
      e.stopPropagation();

      if (card) card.classList.add('is-atc-active');
      btn.classList.add('is-adding');
      btn.classList.remove('is-added');

      try {
        var formData = new FormData();
        formData.append('id', variantId);
        formData.append('quantity', 1);

        var addRes = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/javascript' },
          body: formData
        });
        if (!addRes.ok) throw new Error('Add failed');
        await addRes.json();

        btn.classList.remove('is-adding');
        btn.classList.add('is-added');

        var cartDrawer = document.querySelector('cart-drawer-component');
        var drawerSectionId = cartDrawer ? cartDrawer.dataset.sectionId : null;
        var sections = {};
        if (drawerSectionId) {
          var sectionsRes = await fetch(window.location.pathname + '?sections=' + drawerSectionId);
          sections = await sectionsRes.json();
        }
        var cartRes = await fetch('/cart.js');
        var cart = await cartRes.json();

        document.dispatchEvent(new CustomEvent('cart:update', {
          bubbles: true,
          detail: { resource: cart, sourceId: 'wl-atc', data: { sections: sections, itemCount: cart.item_count } }
        }));

        setTimeout(function() {
          btn.classList.remove('is-added');
          if (card) card.classList.remove('is-atc-active');
        }, 2000);

      } catch(err) {
        btn.classList.remove('is-adding');
        btn.textContent = 'Fehler';
        setTimeout(function() {
          btn.innerHTML = '<span class="wl-atc__text">In den Warenkorb</span><span class="wl-atc__check"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span class="wl-atc__adding"><svg class="wl-atc__spinner" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#fff" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4" stroke-dashoffset="10"/></svg></span>';
          if (card) card.classList.remove('is-atc-active');
        }, 1500);
      }
    });
  });
})();
</script>

