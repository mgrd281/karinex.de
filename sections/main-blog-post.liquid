<!-- Text-to-Speech Script for Blog Posts -->
<script>
(function() {
  if (!('speechSynthesis' in window)) {
    console.warn('Speech synthesis not supported');
    return;
  }

  // Preload voices to ensure they're available
  speechSynthesis.getVoices();
  if (speechSynthesis.onvoiceschanged !== undefined) {
    speechSynthesis.onvoiceschanged = function() {
      speechSynthesis.getVoices();
    };
  }

  var toggleBtn = document.getElementById('tts-toggle');
  var articleContent = document.querySelector('.blog-main-content');
  if (!toggleBtn || !articleContent) {
    console.warn('TTS: button or content not found');
    return;
  }

  var utterance = null;
  var isPlaying = false;

  function getText() {
    var temp = document.createElement('div');
    temp.innerHTML = articleContent.innerHTML;
    
    // Remove unwanted elements
    var scripts = temp.querySelectorAll('script,style,noscript,iframe,video,audio');
    scripts.forEach(el => el.remove());
    
    // Replace block elements with proper spacing
    var blocks = temp.querySelectorAll('p,div,h1,h2,h3,h4,h5,h6,li,br');
    blocks.forEach(el => {
      if (el.tagName === 'BR') {
        el.replaceWith(' ');
      } else {
        el.insertAdjacentHTML('afterend', ' ');
      }
    });
    
    // Get clean text with proper spacing
    var text = temp.innerText || temp.textContent || '';
    
    // Clean up extra whitespace
    text = text.replace(/\s+/g, ' ').trim();
    
    return text;
  }

  function startTTS() {
    if (isPlaying) {
      speechSynthesis.cancel();
      stopTTS();
      return;
    }

    var text = getText();
    if (!text) return;

    // Add pauses after paragraphs for better rhythm
    text = text.replace(/([.!?])\s+/g, '$1... ');
    
    utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'de-DE';
    utterance.rate = 0.85;  // Slower, more professional
    utterance.pitch = 0.95; // Slightly deeper, clearer
    utterance.volume = 0.95; // Slightly reduced for comfort

    // Try to get the best German voice
    var voices = speechSynthesis.getVoices();
    var germanVoice = voices.find(voice => 
      voice.lang.startsWith('de-') && 
      (voice.name.includes('Google') || voice.name.includes('Microsoft') || voice.name.includes('Amazon'))
    );
    if (germanVoice) {
      utterance.voice = germanVoice;
      console.log('TTS using voice:', germanVoice.name, germanVoice.lang);
    } else {
      // Fallback to any German voice
      var anyGerman = voices.find(voice => voice.lang.startsWith('de-'));
      if (anyGerman) {
        utterance.voice = anyGerman;
        console.log('TTS using fallback voice:', anyGerman.name, anyGerman.lang);
      }
    }

    utterance.onstart = function() {
      isPlaying = true;
      toggleBtn.classList.add('playing');
      toggleBtn.setAttribute('aria-label', 'Vorlesen stoppen');
    };

    utterance.onend = function() {
      stopTTS();
    };

    utterance.onerror = function(e) {
      console.error('TTS error:', e);
      stopTTS();
    };

    speechSynthesis.speak(utterance);
  }

  function stopTTS() {
    isPlaying = false;
    toggleBtn.classList.remove('playing');
    toggleBtn.setAttribute('aria-label', 'Artikel vorlesen');
  }

  toggleBtn.addEventListener('click', startTTS);

  window.addEventListener('beforeunload', function() {
    speechSynthesis.cancel();
  });

  console.log('TTS button initialized in main-blog-post:', toggleBtn);
})();
</script>
