<!-- Reading Progress Script -->
<script>
(function() {
  var progressBar = document.getElementById('readingProgress');
  var content = document.querySelector('.blog-main-content');
  
  if (!progressBar || !content) {
    console.warn('Reading progress: elements not found');
    return;
  }

  function updateProgress() {
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    var windowHeight = window.innerHeight;
    var documentHeight = document.documentElement.scrollHeight;
    var contentTop = content.offsetTop;
    var contentHeight = content.offsetHeight;
    
    // Calculate progress within content area only
    var progressStart = contentTop - windowHeight;
    var progressEnd = contentTop + contentHeight;
    var progressRange = progressEnd - progressStart;
    
    if (scrollTop <= progressStart) {
      progressBar.style.width = '0%';
    } else if (scrollTop >= progressEnd) {
      progressBar.style.width = '100%';
    } else {
      var progress = ((scrollTop - progressStart) / progressRange) * 100;
      progressBar.style.width = Math.max(0, Math.min(100, progress)) + '%';
    }
  }

  // Throttle scroll events for performance
  var ticking = false;
  function requestTick() {
    if (!ticking) {
      window.requestAnimationFrame(updateProgress);
      ticking = true;
      setTimeout(function() { ticking = false; }, 100);
    }
  }

  window.addEventListener('scroll', requestTick, { passive: true });
  window.addEventListener('resize', updateProgress);
  updateProgress();
  
  console.log('Reading progress bar initialized');
})();

