<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section color-{{ section.settings.color_scheme }}">
  {%- comment -%} BlogPosting schema moved to article-layout.liquid — single source of truth {%- endcomment -%}
  
  <!-- Performance Optimizations -->
  {%- if article -%}
    <!-- Preload critical resources -->
    <link rel="preload" href="{{ 'section-main-blog-post.css' | asset_url }}" as="style">
    {%- if article.image -%}
      <link rel="preload" as="image" href="{{ article.image | image_url: width: 800, format: 'webp' }}" imagesrcset="{{ article.image | image_url: width: 400, format: 'webp' }} 400w, {{ article.image | image_url: width: 600, format: 'webp' }} 600w, {{ article.image | image_url: width: 800, format: 'webp' }} 800w" imagesizes="(max-width: 768px) 100vw, 50vw">
    {%- endif -%}
    
    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="//www.facebook.com">
    <link rel="dns-prefetch" href="//twitter.com">
    <link rel="dns-prefetch" href="//www.linkedin.com">
    <link rel="dns-prefetch" href="//wa.me">
  {%- endif -%}
  
  <!-- Article-specific Open Graph (not covered by global meta-tags.liquid) -->
  {%- if article -%}
    <meta property="article:published_time" content="{{ article.published_at | date: "%Y-%m-%dT%H:%M:%S%z" }}">
    <meta property="article:modified_time" content="{{ article.updated_at | date: "%Y-%m-%dT%H:%M:%S%z" }}">
    <meta property="article:author" content="{{ article.author }}">
    <meta property="article:section" content="{{ blog.title }}">
    {%- for tag in article.tags limit: 5 -%}
      <meta property="article:tag" content="{{ tag | escape }}">
    {%- endfor -%}
  {%- endif -%}
  
  <!-- Reading Progress Bar -->
  <div class="reading-progress-bar" id="readingProgress"></div>
  
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
      max-width: 1600px !important;
    "
  >
    {%- comment -%} Title rendered by article-layout.liquid {%- endcomment -%}


    
    <div class="blog-post-content-wrapper" style="max-width: 1600px; margin: 0 auto; line-height: 1.9; font-size: 17px; color: #333; position: relative;">
      
      {%- comment -%} SEO ENHANCEMENT: Table of Contents & Social Share {%- endcomment -%}
      <div class="blog-seo-container">
        <!-- Sticky TOC -->
        <aside class="blog-toc-sidebar">
          <div class="blog-toc-sticky">
            <h3 class="toc-title">Inhalt</h3>
            <nav id="TableOfContents">
              <!-- JS will populate this -->
            </nav>
            
            <div class="blog-share-buttons">
              <span class="share-title">Teilen:</span>
              <button id="tts-toggle" class="share-btn tts-button" aria-label="Artikel vorlesen">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
              </button>
              <a href="https://api.whatsapp.com/send?text={{ article.title | url_encode }}%20{{ shop.url | append: article.url | url_encode }}" target="_blank" class="share-btn whatsapp" aria-label="Share on WhatsApp">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.304-5.291c0-5.45 4.435-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
              <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ shop.url | append: article.url | url_encode }}&title={{ article.title | url_encode }}" target="_blank" class="share-btn linkedin" aria-label="Share on LinkedIn">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: article.url | url_encode }}" target="_blank" class="share-btn facebook" aria-label="Share on Facebook">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ shop.url | append: article.url | url_encode }}" target="_blank" class="share-btn twitter" aria-label="Share on Twitter">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
              </a>
            </div>
          </div>
        </aside>

        <div class="blog-main-content">
          {%- content_for 'block', id: 'blog-post-content', type: '_blog-post-content' %}
          
          {%- comment -%} Author Bio {%- endcomment -%}
          <div class="author-bio-box" data-nosnippet>
            <div class="author-image">
              {% if article.user.image %}
                <img src="{{ article.user.image | image_url: width: 100, height: 100 }}" alt="{{ article.author | escape }}" loading="lazy" width="80" height="80">
              {% else %}
                <div class="initials-avatar">{{ article.author | slice: 0, 1 }}</div>
              {% endif %}
            </div>
            <div class="author-info">
              <h4>{{ article.user.first_name | default: article.author }}</h4>
              <p>{{ article.user.bio | default: 'Experte für Software und Technologie' }}</p>
              <div class="article-stats">
                <span class="funktionale-count" data-article-id="{{ article.id }}">1</span>
                <span class="deutsches-datum">{{ article.published_at | date: "%d.%m.%Y" }}</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    {% comment %} Dynamic area for @app blocks only, at the bottom {% endcomment %}
    {% content_for 'blocks' %}

    {%- comment -%} Related Products (Metafield per Article + Tag Fallback) {%- endcomment -%}
    {%- assign meta_products = article.metafields.custom.related_products.value -%}
    {%- assign has_meta_products = false -%}
    {%- if meta_products != blank and meta_products.size > 0 -%}
      {%- for p in meta_products -%}
        {%- if p.available -%}
          {%- assign has_meta_products = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if has_meta_products -%}
      <div class="blog-related-products">
        <div class="blog-rp-header">
          <span class="blog-rp-subtitle">{{ section.settings.related_products_subtitle }}</span>
          <h3 class="blog-rp-title">{{ section.settings.related_products_title }}</h3>
        </div>
        <div class="blog-rp-grid">
          {%- for product in meta_products -%}
            {%- if product.available -%}
              <a href="{{ product.url }}" class="blog-rp-card">
                <div class="article-card__info">
                  {%- if section.settings.show_date -%}
                    <span>{{ article.published_at | time_tag: format: 'date' }}</span>
                  {%- endif -%}
                  {%- if section.settings.show_author -%}
                    <span>&bull; {{ article.author }}</span>
                  {%- endif -%}
                  <span>&bull; 
                    {%- assign word_count = article.content | strip_html | split: ' ' | size -%}
                    {%- assign reading_time = word_count | divided_by: 200 | ceil -%}
                    {{ reading_time }} Min. Lesezeit
                  </span>
                  <span class="article-meta-views">
                    <svg class="view-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                      <circle cx="12" cy="12" r="3"/>
                    </svg>
                    <span class="article-view-count" data-article-id="{{ article.id }}">...</span>
                  </span>
                </div>
                <div class="blog-rp-card__image">
                  {%- if product.compare_at_price > product.price -%}
                    {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                    <span class="blog-rp-card__badge">-{{ discount }}%</span>
                  {%- endif -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.title | escape }}"
                    width="400"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  >
                </div>
                <div class="blog-rp-card__info">
                  {%- if product.vendor != blank -%}
                    <span class="blog-rp-card__vendor">{{ product.vendor }}</span>
                  {%- endif -%}
                  <span class="blog-rp-card__title">{{ product.title }}</span>
                  <div class="blog-rp-card__prices">
                    <span class="blog-rp-card__price{% if product.compare_at_price > product.price %} blog-rp-card__price--sale{% endif %}">{{ product.price | money }}</span>
                    {%- if product.compare_at_price > product.price -%}
                      <span class="blog-rp-card__compare-price">{{ product.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      {%- comment -%} Fallback: Search products via Shopify Search API (JS) {%- endcomment -%}
      <div class="blog-related-products" id="blog-auto-products">
        <div class="blog-rp-header">
          <span class="blog-rp-subtitle">{{ section.settings.related_products_subtitle }}</span>
          <h3 class="blog-rp-title">{{ section.settings.related_products_title }}</h3>
        </div>
        <div class="blog-rp-grid" id="blog-rp-grid-auto"></div>
      </div>

      <script>
        (function() {
          const articleTitle = {{ article.title | json }};
          const moneyFormat = {{ shop.money_format | json }};

          // Extract meaningful keywords from title
          const stopWords = new Set([
            'der','die','das','ein','eine','und','oder','aber','ist','sind','wird','hat','haben',
            'für','von','mit','auf','aus','bei','nach','über','unter','vor','zwischen','durch',
            'ihre','sein','seine','sich','nicht','auch','noch','mehr','sehr','wenn','dann','dass',
            'dies','diese','dieser','alle','beim','einem','einen','einer','neue','neues','große',
            'grosse','update','updates','sicherheitsupdate','patch','patchday','day',
            'januar','februar','märz','april','mai','juni','juli','august','september',
            'oktober','november','dezember','2024','2025','2026','2027',
            'the','and','for','with','from','that','this','what','your','will','have','how',
            'can','are','was','were','been','being','you','they','them','their','our'
          ]);

          const words = articleTitle
            .replace(/[:\-–?!,.()\/\[\]"']/g, ' ')
            .split(/\s+/)
            .map(w => w.trim().toLowerCase())
            .filter(w => w.length > 2 && !stopWords.has(w) && !/^\d+$/.test(w));

          // Take first 3 meaningful keywords for search
          const keywords = [...new Set(words)].slice(0, 3);
          if (!keywords.length) {
            document.getElementById('blog-auto-products').style.display = 'none';
            return;
          }

          const query = keywords.join(' ');
          const url = `/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=12&resources[options][unavailable_products]=hide`;

          fetch(url)
            .then(r => r.json())
            .then(data => {
              const products = data.resources?.results?.products || [];
              if (!products.length) {
                document.getElementById('blog-auto-products').style.display = 'none';
                return;
              }

              const grid = document.getElementById('blog-rp-grid-auto');
              const fmt = (v) => parseFloat(v).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' \u20ac';

              grid.innerHTML = products.map(product => {
                const price = parseFloat(product.price);
                const comparePrice = parseFloat(product.compare_at_price_max || product.compare_at_price || 0);
                const hasDiscount = comparePrice > price;
                const discountPct = hasDiscount ? Math.round((comparePrice - price) / comparePrice * 100) : 0;
                const img = product.image || product.featured_image?.url || '';
                const vendor = product.vendor || '';
                const title = product.title || '';

                return `
                  <a href="${product.url}" class="blog-rp-card">
                    <div class="blog-rp-card__image">
                      ${hasDiscount ? `<span class="blog-rp-card__badge">-${discountPct}%</span>` : ''}
                      <img src="${img}" alt="${title.replace(/\"/g,'&quot;')}" width="400" height="400" loading="lazy" decoding="async">
                    </div>
                    <div class="blog-rp-card__info">
                      ${vendor ? `<span class="blog-rp-card__vendor">${vendor}</span>` : ''}
                      <span class="blog-rp-card__title">${title}</span>
                      <div class="blog-rp-card__prices">
                        <span class="blog-rp-card__price${hasDiscount ? ' blog-rp-card__price--sale' : ''}">${fmt(price)}</span>
                        ${hasDiscount ? `<span class="blog-rp-card__compare-price">${fmt(comparePrice)}</span>` : ''}
                      </div>
                    </div>
                  </a>
                `;
              }).join('');
            })
            .catch(() => {
              document.getElementById('blog-auto-products').style.display = 'none';
            });
        })();
      </script>
    {%- endif -%}

    {% if blog.comments_enabled? %}
      <div class="blog-post-comments-container">
        <h2 class="h3">{{- 'blogs.article.comments_heading' | t: count: article.comments_count -}}</h2>

        <div class="blog-post-comments">
          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="blog-post-comment">
                {{ comment.content }}
                <div class="blog-post-comment__author">
                  <span class="blog-post-comment__author-name">{{- comment.author -}}</span>
                  <span>{{- 'blogs.article.comment_author_separator' | t -}}</span>
                  <span class="blog-post-comment__date">
                    {{- comment.created_at | time_tag: format: 'date' -}}
                  </span>
                </div>
              </div>
            {% endfor %}

            <div class="blog-post-comments-pagination">
              {{- paginate | default_pagination -}}
            </div>
          {% endpaginate %}
        </div>

        {% render 'blog-comment-form', article: article, section_id: section.id %}
      </div>
    {% endif %}
  </div>
</div>



{% stylesheet %}
  .blog-post-comments-container {
    width: 100%;
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  .blog-post-comments {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
  }

  .blog-post-comment__author {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    margin-top: var(--margin-md);
    font-size: var(--font-size--body-sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .blog-post-comments-pagination {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .blog-post-comments-pagination,
  .blog-post-comments-pagination a {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a {
    display: block;
    padding: var(--padding-2xs) var(--padding-xs);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a:hover {
    border-bottom: 1px solid var(--color-foreground);
  }

  /* Enhanced Blog Typography & Layout */
  .blog-post-content-wrapper p {
    margin-bottom: 1.5em;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
  }
  .blog-post-content-wrapper h2 {
    margin-top: 2em;
    margin-bottom: 0.75em;
    font-weight: 800;
    scroll-margin-top: 100px;
  }
  .blog-post-content-wrapper h3 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-weight: 700;
    scroll-margin-top: 100px;
  }
  .blog-post-content-wrapper a {
    color: #e30613; /* Accent color */
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-post-content-wrapper blockquote {
    border-left: 4px solid #e30613;
    padding-left: 20px;
    font-style: italic;
    color: #555;
    margin: 30px 0;
    background: #f9f9f9;
    padding: 20px;
    border-radius: 0 8px 8px 0;
  }

  /* SEO Layout: Sidebar + Content */
  .blog-seo-container {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    position: relative;
  }
  
  .blog-toc-sidebar {
    flex: 0 0 250px;
    display: none; /* Mobile first hidden, shown on desktop */
  }

  @media (min-width: 1024px) {
    .blog-toc-sidebar {
      display: block;
    }
    .blog-main-content {
      flex: 1;
      max-width: calc(100% - 290px);
    }
  }

  .blog-main-content {
    width: 100%;
  }

  /* Sticky Element */
  .blog-toc-sticky {
    position: sticky;
    top: 120px;
    background: #fff;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    border: 1px solid #eee;
  }

  .toc-title {
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 15px 0;
    padding-bottom: 10px;
    border-bottom: 2px solid #e30613;
    display: inline-block;
  }

  #TableOfContents {
    font-size: 14px;
    margin-bottom: 30px;
  }

  #TableOfContents ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #TableOfContents li {
    margin-bottom: 10px;
  }

  #TableOfContents a {
    text-decoration: none;
    color: #666;
    transition: all 0.2s;
    display: block;
  }

  #TableOfContents a:hover,
  #TableOfContents a.active {
    color: #e30613;
    padding-left: 5px;
  }

  /* Share Buttons */
  .share-title {
    display: block;
    font-size: 13px;
    color: #999;
    margin-bottom: 10px;
    font-weight: 600;
  }
  
  .blog-share-buttons {
    display: flex;
    gap: 10px;
  }
  
  .share-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: #fff;
    transition: transform 0.2s;
    text-decoration: none !important;
  }

  .share-btn.whatsapp { background: #25D366; }
  .share-btn.linkedin { background: #0077b5; }
  .share-btn.facebook { background: #1877f2; }
  .share-btn.twitter { background: #1da1f2; }
  
  .tts-button {
    background: #6b7280;
    border: none;
    cursor: pointer;
  }
  .tts-button.playing {
    background: #10b981;
    animation: ttsPulse 1.5s infinite;
  }
  @keyframes ttsPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* Reading Progress Bar */
  .reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, #e30613 0%, #ff4458 100%);
    z-index: 1000;
    transition: width 0.1s ease-out;
    box-shadow: 0 0 10px rgba(227, 6, 19, 0.3);
  }

  /* Ensure progress bar is visible on mobile */
  @media screen and (max-width: 749px) {
    .reading-progress-bar {
      height: 4px;
    }
  }

  /* Author Bio */
  .author-bio-box {
    display: flex;
    gap: 20px;
    background: #f5f5f7;
    padding: 30px;
    border-radius: 12px;
    margin-top: 60px;
    align-items: flex-start;
  }

  .author-image img {
    border-radius: 50%;
    object-fit: cover;
  }

  .initials-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #e30613;
    color: #fff;
