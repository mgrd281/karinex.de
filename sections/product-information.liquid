         setShareCount(newShares);
         animCount(shareCountEl);
         if (current) { current.shares = newShares; prefetchStore[vid] = current; setCache(vid, current); }
         apiCall('share', vid, function(data) {
           var serverShares = data.shares !== undefined ? data.shares : newShares;
           setShareCount(serverShares);
           data.shares = serverShares;
           prefetchStore[vid] = data; setCache(vid, data);
         });
       }

