<script>

(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.querySelector('.kx-buybox-actions .kx-atc-btn');
    if (!btn) return;

    var textEl = btn.querySelector('.add-to-cart-text__content span span');
    var textWrap = btn.querySelector('.add-to-cart-text');
    var iconWrap = btn.querySelector('.add-to-cart-icon');
    if (!textEl || !textWrap) return;

    var animating = false;

    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        if (m.attributeName !== 'data-added') return;
        var isAdded = btn.getAttribute('data-added') === 'true';

        if (isAdded && !animating) {
          animating = true;

          textWrap.style.animation = 'kx-text-out 0.2s ease forwards';
          if (iconWrap) iconWrap.style.animation = 'kx-text-out 0.18s ease forwards';

          setTimeout(function() {

            textEl.textContent = 'Hinzugefügt \u2713';
            btn.classList.add('kx-atc--added');
            if (iconWrap) iconWrap.style.cssText = 'opacity:0!important;width:0!important;overflow:hidden!important';
            textWrap.style.animation = 'kx-text-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards';
            animating = false;
          }, 200);

        } else if (!isAdded) {

          textWrap.style.animation = 'kx-text-out 0.2s ease forwards';

          setTimeout(function() {

            textEl.textContent = 'In den Warenkorb';
            btn.classList.remove('kx-atc--added');
            if (iconWrap) {
              iconWrap.style.cssText = '';
              iconWrap.style.animation = 'kx-text-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards';
            }
            textWrap.style.animation = 'kx-text-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards';
          }, 200);
        }
      });
    });

    observer.observe(btn, { attributes: true, attributeFilter: ['data-added'] });
  });
})();
</script>

