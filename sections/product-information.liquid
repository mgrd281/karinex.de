  {%- assign is_digital = true -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if collections_csv contains 'software' or collections_csv contains 'digital' or collections_csv contains 'microsoft' or collections_csv contains 'office' or collections_csv contains 'windows' or collections_csv contains 'download' or collections_csv contains 'key' or collections_csv contains 'esd' or collections_csv contains 'lizenz' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if handle_lc contains 'key' or handle_lc contains 'software' or handle_lc contains 'digital' or handle_lc contains 'esd' or handle_lc contains 'lizenz' or handle_lc contains 'license' or handle_lc contains 'download' or handle_lc contains 'office' or handle_lc contains 'microsoft' or handle_lc contains 'windows' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if title_lc contains 'key' or title_lc contains 'download' or title_lc contains 'lizenzschlüssel' or title_lc contains 'aktivierungsschlüssel' or title_lc contains 'produktschlüssel' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}

