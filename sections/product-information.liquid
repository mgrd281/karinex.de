                elsif key_lower contains 'uhrwerk' or key_lower contains 'movement'
                  assign desc_movement = value
                elsif key_lower contains 'kaliber' or key_lower contains 'caliber'
                  assign desc_caliber = value
                elsif key_lower contains 'gangreserve' or key_lower contains 'power'
                  assign desc_power_reserve = value
                elsif key_lower contains 'wasserdichtigkeit' or key_lower contains 'water'
                  assign desc_water_resistance = value
                elsif key_lower contains 'gehäuseform' or key_lower contains 'case shape'
                  assign desc_case_shape = value
                elsif key_lower contains 'gehäusedurchmesser' or key_lower contains 'diameter'
                  assign desc_case_diameter = value
                elsif key_lower contains 'gehäusehöhe' or key_lower contains 'thickness' or key_lower contains 'höhe'
                  assign desc_case_thickness = value
                elsif key_lower contains 'gehäusematerial' or key_lower contains 'case material'
                  assign desc_material = value
                elsif key_lower contains 'material' and key_lower != 'armbandmaterial'
                  assign desc_material = value
                elsif key_lower contains 'zifferblatt' or key_lower contains 'dial'
                  assign desc_color = value
                elsif key_lower contains 'glas' or key_lower contains 'glass' or key_lower contains 'uhrenglas'
                  assign desc_glass = value
                elsif key_lower contains 'armbandmaterial' or key_lower contains 'armband material'
                  assign desc_strap = value
                elsif key_lower contains 'armbandfarbe' or key_lower contains 'armband farbe' or key_lower contains 'strap color'
                  assign desc_strap_color = value
                elsif key_lower contains 'armband' or key_lower contains 'strap' or key_lower contains 'band'
                  assign desc_strap = value
                elsif key_lower contains 'verschluss' or key_lower contains 'clasp' or key_lower contains 'schließe'
                  assign desc_clasp = value
                elsif key_lower contains 'funktion' or key_lower contains 'function'
                  assign desc_functions = value
                elsif key_lower contains 'garantie' or key_lower contains 'warranty'
                  assign desc_warranty = value
                elsif key_lower contains 'referenz' or key_lower contains 'reference' or key_lower contains 'sku' or key_lower contains 'artikelnummer' or key_lower contains 'ref'
                  assign desc_ref_nr = value
                elsif key_lower contains 'swiss' or key_lower contains 'hergestellt' or key_lower contains 'made in'
                  assign desc_swiss_made = value
                elsif key_lower contains 'detail' or key_lower contains 'weitere'
                  assign desc_details = value
                elsif key_lower contains 'größe' or key_lower contains 'size'
                  assign desc_size = value
                elsif key_lower contains 'modell' or key_lower contains 'model'
                  assign desc_modell = value
                elsif key_lower contains 'ean' or key_lower contains 'gtin'
                  assign desc_ean = value
                elsif key_lower contains 'anzeige' or key_lower contains 'display'
                  assign desc_anzeige = value
                endif
              endif
            endif
          endif
        endfor

      # Clean description = everything BEFORE the specs keyword
      assign clean_description = product.description | split: specs_keyword | first
      endif

      # Priority system - metafields > description parsing > defaults
      assign final_marke = product.metafields.custom.brand | default: product.vendor
      if desc_marke != blank and product.metafields.custom.brand == blank
        assign final_marke = desc_marke
      endif
      assign final_style = product.metafields.custom.style | default: desc_style | default: 'Sportlich, Klassisch'
      assign final_target_group = product.metafields.custom.target_group | default: desc_target_group | default: 'Herren'
      assign final_movement = product.metafields.custom.movement | default: desc_movement | default: 'Automatik'
      assign final_caliber = product.metafields.custom.caliber | default: desc_caliber | default: '-'
      assign final_power_reserve = product.metafields.custom.power_reserve | default: desc_power_reserve | default: '-'
      assign final_water_resistance = product.metafields.custom.water_resistance | default: desc_water_resistance | default: '200m'
      assign final_case_shape = product.metafields.custom.case_shape | default: desc_case_shape | default: 'Rund'
      assign final_case_diameter = product.metafields.custom.case_diameter | default: desc_case_diameter | default: '41mm'
      assign final_case_thickness = product.metafields.custom.case_thickness | default: desc_case_thickness | default: '13.8mm'
      assign final_material = product.metafields.custom.case_material | default: desc_material | default: 'Edelstahl'
      assign final_color = product.metafields.custom.dial_color | default: desc_color | default: 'Blau'
      assign final_glass = product.metafields.custom.glass | default: desc_glass | default: 'Saphirglas'
      assign final_strap = product.metafields.custom.strap_material | default: desc_strap | default: 'Edelstahl'
      assign final_strap_color = product.metafields.custom.strap_color | default: desc_strap_color | default: 'Silber'
      assign final_clasp = product.metafields.custom.clasp | default: desc_clasp | default: 'Faltschließe'
      assign final_functions = product.metafields.custom.functions | default: desc_functions | default: 'Datumsanzeige'
      assign final_warranty = product.metafields.custom.warranty | default: desc_warranty | default: '24 Monate'
      assign final_ref_nr = product.metafields.custom.referenz_nr | default: desc_ref_nr | default: product.sku
      assign final_swiss_made = product.metafields.custom.swiss_made | default: desc_swiss_made | default: 'Ja'
      assign final_details = product.metafields.custom.details | default: desc_details | default: '-'
      assign final_modell = product.metafields.custom.modell | default: desc_modell | default: product.sku
      assign final_ean = product.metafields.custom.ean | default: desc_ean | default: product.barcode
      assign final_anzeige = product.metafields.custom.anzeige | default: desc_anzeige | default: 'Analog'

      # Check if clean_description has actual content (not just whitespace/tags)
      assign clean_desc_text = clean_description | strip_html | strip
      assign show_description_box = true
      if clean_desc_text == blank or clean_desc_text.size < 10
        assign show_description_box = false
      endif
    %}

