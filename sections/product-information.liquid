    {%- if _sold_city and _sold_city != blank -%}
      <span class="kx-psp-sep"> · </span>
      <span class="kx-psp-city">Letzter Kauf aus <strong>{{ _sold_city }}</strong></span>
    {%- endif -%}
  </span>
</div>
{%- else -%}
<div class="kx-premium-social-proof">
  <div class="kx-psp-icon-wrapper">
    <svg class="kx-trend-icon-sequence" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline class="kx-seq-line" points="1 18 8.5 10.5 13.5 15.5 23 6"></polyline>
      <polyline class="kx-seq-arrow" points="17 6 23 6 23 12"></polyline>
