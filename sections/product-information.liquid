     <script>
     (function() {
       var modal = document.getElementById('videoModal');
       var backdrop = modal.querySelector('.video-modal__backdrop');
       var closeBtn = modal.querySelector('.video-modal__close');
       var nativeVid = document.getElementById('videoModalNative');
       var iframe = document.getElementById('videoModalFrame');
       var sidebar = document.getElementById('videoModalSidebar');
       var listEl = document.getElementById('videoModalList');
       var infoEl = document.getElementById('videoModalInfo');
       var playOverlay = document.getElementById('videoPlayOverlay');
       var productTitle = '{{ product.title | escape }}';
       var productVendor = '{{ product.vendor | escape }}';

       // Play overlay logic – Amazon style: only play button, hidden when playing
       function updateOverlay(playing) {
         if (playing) {
           playOverlay.classList.add('is-playing');
         } else {
           playOverlay.classList.remove('is-playing');
         }
       }
       playOverlay.addEventListener('click', function() {
         if (nativeVid.classList.contains('is-active')) {
           nativeVid.play().catch(function(){});
         } else if (iframe.classList.contains('is-active') && iframe.contentWindow) {
           try {
             iframe.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
             iframe.contentWindow.postMessage('{"method":"play"}', '*');
             updateOverlay(true);
           } catch(e) {}
         }
       });
       nativeVid.addEventListener('play', function() { updateOverlay(true); });
       nativeVid.addEventListener('pause', function() { updateOverlay(false); });
       nativeVid.addEventListener('ended', function() { updateOverlay(false); });

       // Tab switching
       modal.querySelectorAll('.video-modal__tab').forEach(function(tab) {
         tab.addEventListener('click', function() {
           var target = this.getAttribute('data-tab');
           modal.querySelectorAll('.video-modal__tab').forEach(function(t) { t.classList.remove('is-active'); });
           modal.querySelectorAll('.video-modal__panel').forEach(function(p) { p.classList.remove('is-active'); });
           this.classList.add('is-active');
           modal.querySelector('[data-panel="' + target + '"]').classList.add('is-active');
           // Pause video if switching to images, resume if switching back
           if (target === 'bilder') {
             nativeVid.pause && nativeVid.pause();
             // Pause YouTube/Vimeo iframe via postMessage
             if (iframe.classList.contains('is-active') && iframe.contentWindow) {
               try {
                 iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
                 iframe.contentWindow.postMessage('{"method":"pause"}', '*');
               } catch(e) {}
             }
           } else if (target === 'videos') {
             // Resume native video from where it stopped
             if (nativeVid.classList.contains('is-active') && nativeVid.src) {
               nativeVid.play().catch(function(){});
             }
             // Resume YouTube/Vimeo iframe via postMessage
             if (iframe.classList.contains('is-active') && iframe.contentWindow) {
               try {
                 iframe.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
                 iframe.contentWindow.postMessage('{"method":"play"}', '*');
               } catch(e) {}
             }
           }
         });
       });

       // Lazy collect video items (gallery thumbs may not be ready at script load)
       var videoItems = [];
       function getVideoPosterFallback() {
         var firstImageThumb = document.querySelector('.thumb-item[data-type="image"]');
         if (!firstImageThumb) return '';
         return firstImageThumb.getAttribute('data-src') || (firstImageThumb.querySelector('img') ? firstImageThumb.querySelector('img').src : '');
       }

       function updateSidebarThumb(idx, src) {
         if (!src) return;
         listEl.querySelectorAll('.video-modal__list-item[data-video-idx="' + idx + '"] img').forEach(function(img) {
           img.src = src;
         });
       }

       function tryGenerateAutoPoster(v, idx, onDone) {
         if (!v || v.type !== 'video' || !v.video) {
           onDone && onDone('');
           return;
         }
         if (v._autoPosterTried) {
           onDone && onDone(v._autoPoster || '');
           return;
         }
         v._autoPosterTried = true;

         var probe = document.createElement('video');
         var done = false;
         var timeoutId = setTimeout(function() {
           finalize('');
         }, 3000);

         function finalize(result) {
           if (done) return;
           done = true;
           clearTimeout(timeoutId);
           try {
             probe.pause();
             probe.removeAttribute('src');
             probe.load();
           } catch(e) {}
           v._autoPoster = result || '';
           onDone && onDone(v._autoPoster);
         }

         probe.muted = true;
         probe.playsInline = true;
         probe.preload = 'auto';
         probe.crossOrigin = 'anonymous';

         probe.addEventListener('error', function() {
           finalize('');
         }, { once: true });

         probe.addEventListener('loadeddata', function() {
           try {
             var seekTo = 1.2;
             if (isFinite(probe.duration) && probe.duration > 0) {
               seekTo = Math.min(2.5, Math.max(0.4, probe.duration * 0.25));
             }
             probe.currentTime = seekTo;
           } catch(e) {
             finalize('');
           }
         }, { once: true });

         probe.addEventListener('seeked', function() {
           try {
             var w = probe.videoWidth || 0;
             var h = probe.videoHeight || 0;
             if (!w || !h) {
               finalize('');
               return;
             }

             var maxW = 960;
             var outW = Math.min(w, maxW);
             var outH = Math.round((h / w) * outW);

             var canvas = document.createElement('canvas');
             canvas.width = outW;
             canvas.height = outH;

             var ctx = canvas.getContext('2d');
             if (!ctx) {
               finalize('');
               return;
             }

             ctx.drawImage(probe, 0, 0, outW, outH);
             var dataUrl = canvas.toDataURL('image/jpeg', 0.82);
             finalize(dataUrl);
           } catch(e) {
             finalize('');
           }
         }, { once: true });

         try {
           probe.src = v.video;
           probe.load();
         } catch(e) {
           finalize('');
         }
       }

       function collectVideoItems() {
         videoItems = [];
         var fallbackPoster = getVideoPosterFallback();
         document.querySelectorAll('.thumb-item[data-type="video"], .thumb-item[data-type="external_video"]').forEach(function(t) {
           var img = t.querySelector('img');
           var src = t.getAttribute('data-src') || (img ? img.src : '');
           var poster = t.getAttribute('data-poster') || src || fallbackPoster;
           videoItems.push({
             type: t.getAttribute('data-type'),
             video: t.getAttribute('data-video'),
             videoSources: t.getAttribute('data-video-sources'),
             src: src,
             poster: poster,
             alt: img ? img.alt : '',
             created: t.getAttribute('data-created') || '',
             index: parseInt(t.getAttribute('data-index'), 10)
           });
         });
         console.log('[VideoModal] Collected', videoItems.length, 'video items');
       }

       var currentVideoIdx = 0;

       function buildSidebar() {
         sidebar.style.display = '';
         listEl.innerHTML = '';
         videoItems.forEach(function(v, i) {
           var item = document.createElement('div');
           item.className = 'video-modal__list-item' + (i === currentVideoIdx ? ' is-active' : '');
           item.setAttribute('data-video-idx', i);
           item.innerHTML =
             '<div class="video-modal__list-thumb">' +
               '<img src="' + (v.poster || v.src) + '" alt="" loading="lazy">' +
               '<span class="video-modal__list-thumb-play"><i class="fa-solid fa-play"></i></span>' +
             '</div>' +
             '<div class="video-modal__list-info">' +
               '<span class="video-modal__list-title">' + (v.alt || productTitle) + '</span>' +
               '<span class="video-modal__list-vendor">' + productVendor + '</span>' +
             '</div>';
           item.addEventListener('click', function() { playVideo(i); });
           listEl.appendChild(item);

           if (!v.poster) {
             tryGenerateAutoPoster(v, i, function(generated) {
               if (!generated) return;
               updateSidebarThumb(i, generated);
               if (i === currentVideoIdx && nativeVid.classList.contains('is-active')) {
                 nativeVid.setAttribute('poster', generated);
               }
             });
           }
         });
       }

       function playVideo(idx) {
         currentVideoIdx = idx;
         var v = videoItems[idx];
         // Reset overlay
         updateOverlay(false);
         // Reset both — clear inline display and use classes only
         nativeVid.pause && nativeVid.pause();
         nativeVid.removeAttribute('src');
         iframe.removeAttribute('src');
         nativeVid.classList.remove('is-active');
         iframe.classList.remove('is-active');
         nativeVid.style.removeProperty('display');
         iframe.style.removeProperty('display');

         if (v.type === 'video') {
           var posterSrc = v.poster || v.src || getVideoPosterFallback();
           if (posterSrc) nativeVid.setAttribute('poster', posterSrc);
           else nativeVid.removeAttribute('poster');

           if (!v.poster) {
             tryGenerateAutoPoster(v, idx, function(generated) {
               if (!generated) return;
               updateSidebarThumb(idx, generated);
               if (currentVideoIdx === idx && nativeVid.classList.contains('is-active')) {
                 nativeVid.setAttribute('poster', generated);
               }
             });
           }

           // Clear old sources
           while (nativeVid.firstChild) nativeVid.removeChild(nativeVid.firstChild);
           nativeVid.removeAttribute('src');
           // Add all sources for format compatibility
           var sources = [];
           try { sources = JSON.parse(v.videoSources || '[]'); } catch(e) {}
           if (sources.length > 0) {
             sources.forEach(function(s) {
               var sourceEl = document.createElement('source');
               sourceEl.src = s.url;
               if (s.type) sourceEl.type = s.type;
               nativeVid.appendChild(sourceEl);
             });
           } else {
             nativeVid.src = v.video;
           }
           nativeVid.classList.add('is-active');
           nativeVid.load();
           nativeVid.play().catch(function(){});
         } else {
           var url = v.video;
           if (url.indexOf('youtube.com') > -1) {
             url = url.replace('autoplay=0', 'autoplay=1');
             if (url.indexOf('enablejsapi') === -1) {
               url += (url.indexOf('?') > -1 ? '&' : '?') + 'enablejsapi=1';
             }
           } else if (url.indexOf('vimeo.com') > -1) {
             url = url.replace('autoplay=0', 'autoplay=1');
           }
           iframe.src = url;
           iframe.classList.add('is-active');
           // Autoplay → mark overlay as playing after small delay
           setTimeout(function() { updateOverlay(true); }, 500);
         }
         // Update sidebar active
         listEl.querySelectorAll('.video-modal__list-item').forEach(function(el, i) {
           el.classList.toggle('is-active', i === idx);
         });
       }

       window.openVideoModal = function(galleryIndex) {
         // Collect items fresh each time (thumbs may not exist at script load)
         collectVideoItems();
         if (videoItems.length === 0) {
           console.warn('[VideoModal] No video items found');
           return;
         }
         var idx = 0;
         for (var i = 0; i < videoItems.length; i++) {
           if (videoItems[i].index === galleryIndex) { idx = i; break; }
         }
         // Reset to videos tab
         modal.querySelectorAll('.video-modal__tab').forEach(function(t) { t.classList.remove('is-active'); });
         modal.querySelectorAll('.video-modal__panel').forEach(function(p) { p.classList.remove('is-active'); });
         modal.querySelector('[data-tab="videos"]').classList.add('is-active');
         modal.querySelector('[data-panel="videos"]').classList.add('is-active');

         buildSidebar();
         modal.classList.add('is-open');
         modal.setAttribute('aria-hidden', 'false');
         document.body.style.overflow = 'hidden';
         playVideo(idx);
       };

       window.closeVideoModal = function() {
         modal.classList.remove('is-open');
         modal.setAttribute('aria-hidden', 'true');
         document.body.style.overflow = '';
         nativeVid.pause && nativeVid.pause();
         nativeVid.removeAttribute('src');
         iframe.removeAttribute('src');
         nativeVid.classList.remove('is-active');
         iframe.classList.remove('is-active');
       };

