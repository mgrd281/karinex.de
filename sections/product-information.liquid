                                                <div class="badge-group">
                          {% liquid
                            assign is_unisex = false
                            if product.tags contains 'unisex' or product.tags contains 'Unisex' or product.title contains 'Unisex'
                              assign is_unisex = true
                            endif

                            assign is_in_cart = false
                            for item in cart.items
                              if item.product.id == product.id
                                assign is_in_cart = true
                                break
                              endif
                            endfor

                            assign is_sold_out = false
                            if product.available == false
                              assign is_sold_out = true
                            endif
                            assign is_low_stock = false
                            assign low_stock_threshold = 10
                            assign current_inventory = 0
                            for variant in product.variants
                              if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny'
                                assign current_inventory = current_inventory | plus: variant.inventory_quantity
                              endif
                            endfor
                            assign has_low_stock_tag = false
                            assign has_sold_out_tag = false
                            if product.tags contains 'ausverkauft' or product.tags contains 'Ausverkauft'
                              assign has_sold_out_tag = true
                            endif
                            if product.tags contains 'tages' or product.tags contains 'Tages' or product.tags contains 'fast-ausverkauft'
                              assign has_low_stock_tag = true
                            endif
                            if has_sold_out_tag
                              assign is_sold_out = true
                            endif
                            if product.available and has_low_stock_tag and is_sold_out == false
                              assign is_low_stock = true
                            elsif product.available and current_inventory > 0 and current_inventory <= low_stock_threshold and is_sold_out == false
                              assign is_low_stock = true
                            endif
                          %}

