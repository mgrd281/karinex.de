<script>

(function() {
  function styleStars(root) {
    var gold = getComputedStyle(document.documentElement).getPropertyValue('--rating-star-color').trim() || '{{ settings.global_rating_star_color | default: "#D4A017" }}';
    var shadow = getComputedStyle(document.documentElement).getPropertyValue('--rating-star-shadow').trim() || '0 1px 3px rgba(212,160,23,0.4)';

    root = root || document;
    var containers = root.querySelectorAll('.rechnung-profi-stars, .ts-rating-stars, .ts-stars, .jdgm-prev-badge, .loox-rating, .spr-starrating');
    containers.forEach(function(c) {
      var icons = c.querySelectorAll('i, [class*="fa-star"], svg, path');
      icons.forEach(function(icon) {
        var isFar = icon.classList.contains('far') || icon.classList.contains('fa-regular') || icon.classList.contains('empty');
        icon.style.setProperty('color', gold, 'important');
        icon.style.setProperty('fill', gold, 'important');
        icon.style.setProperty('opacity', isFar ? '0.25' : '1', 'important');
        icon.style.setProperty('text-shadow', isFar ? 'none' : shadow, 'important');
      });
    });
  }

  /* Show rating stars only when review count > 0, otherwise show "Bewertung schreiben" */
  function toggleRatingVisibility() {
    var wrapper = document.getElementById('pdp-product-rating');
    var writeBox = document.getElementById('pdp-write-review');
    if (!wrapper) return;
    var stars = wrapper.querySelector('.rechnung-profi-stars');
    if (!stars || stars.children.length === 0) return;
    var txt = stars.textContent || '';
    var match = txt.match(/\((\d+)/);
    var count = match ? parseInt(match[1], 10) : 0;
    if (count > 0) {
      wrapper.style.display = '';
      if (writeBox) writeBox.style.display = 'none';
    } else {
      wrapper.style.display = 'none';
      if (writeBox) writeBox.style.display = '';
    }
  }

  styleStars();
  toggleRatingVisibility();
  var obs = new MutationObserver(function() { styleStars(); toggleRatingVisibility(); });
  obs.observe(document.body, { childList: true, subtree: true });

  // Theme Editor Re-init
  document.addEventListener('shopify:section:load', function() { styleStars(); toggleRatingVisibility(); });

  // Also run after widget script finishes
  document.addEventListener('DOMContentLoaded', function() { styleStars(); toggleRatingVisibility(); });
  window.addEventListener('load', function() {
    styleStars();
    toggleRatingVisibility();
    setTimeout(function() { styleStars(); toggleRatingVisibility(); }, 500);
    setTimeout(function() { styleStars(); toggleRatingVisibility(); }, 1500);
  });
})();
</script>
