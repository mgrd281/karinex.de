  .krx-drawer__body{padding:8px 14px 14px;color:#1a1a1a;font-size:14px;line-height:1.6;font-weight:400}
  .krx-drawer__body p{margin:0 0 10px}
  .krx-drawer__body strong{font-weight:700}
  .krx-sectionTitle{margin:14px 0 8px;font-size:16px;line-height:1.35;font-weight:700;letter-spacing:.1px;color:#1a1a1a}
  .krx-steps{margin:0 0 10px;padding-left:20px;list-style:decimal}
  .krx-steps li{margin:5px 0}
  .krx-steps li::marker{font-weight:600;color:#1a1a1a}
  .krx-note{background:#E9E9E9;border:none;border-radius:10px;padding:10px 12px;margin-top:8px}
  .krx-note strong,.krx-note-title{display:block;margin-bottom:6px;font-weight:700}
  .krx-note ul{margin:0;padding-left:18px}
  .krx-note li{margin:6px 0}
  .krx-note--small{font-size:13px;line-height:1.5;padding:8px 10px;border-radius:8px}
  .krx-note--small strong,.krx-note--small .krx-note-title{margin-bottom:6px}
  .krx-note--small li{margin:6px 0}
  .delivery-highlight{font-weight:700;color:#1D4739}
  .krx-drawer__footer{padding:0 14px 14px;display:flex;justify-content:flex-end}
  .krx-btn{appearance:none;border:0;border-radius:999px;padding:7px 12px;cursor:pointer;background:var(--brand);color:#fff;font-weight:700;font-size:13px;font-family:inherit}
  @media (max-width:480px){
    .krx-drawer__title{font-size:19px}
    :root{ --drawer-width:92vw; }
  }
</style>
{%- assign is_digital = false -%}
{%- assign ptype = product.type | downcase -%}
{%- assign phandle = product.handle | downcase -%}
{%- assign ptitle = product.title | downcase -%}
{%- assign tags_csv = product.tags | join: ',' | downcase -%}
{%- assign col_csv = product.collections | map: 'handle' | join: ',' | downcase -%}
{%- if ptype contains 'software' or ptype contains 'digital' or ptype contains 'microsoft' or ptype contains 'office' or ptype contains 'windows' or ptype contains 'esd' or ptype contains 'key' or ptype contains 'lizenz' or ptype contains 'license' or ptype contains 'download' -%}
  {%- assign is_digital = true -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if phandle contains 'software' or phandle contains 'digital' or phandle contains 'microsoft' or phandle contains 'office' or phandle contains 'windows' or phandle contains 'esd' or phandle contains 'key' or phandle contains 'lizenz' or phandle contains 'license' or phandle contains 'download' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if ptitle contains 'software' or ptitle contains 'digital' or ptitle contains 'microsoft' or ptitle contains 'office' or ptitle contains 'windows' or ptitle contains 'esd' or ptitle contains 'key' or ptitle contains 'lizenz' or ptitle contains 'license' or ptitle contains 'download' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if tags_csv contains 'software' or tags_csv contains 'digital' or tags_csv contains 'microsoft' or tags_csv contains 'office' or tags_csv contains 'windows' or tags_csv contains 'esd' or tags_csv contains 'key' or tags_csv contains 'lizenz' or tags_csv contains 'license' or tags_csv contains 'download' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}
{%- if is_digital == false -%}
  {%- if col_csv contains 'software' or col_csv contains 'digital' or col_csv contains 'microsoft' or col_csv contains 'office' or col_csv contains 'windows' or col_csv contains 'esd' or col_csv contains 'key' or col_csv contains 'lizenz' or col_csv contains 'license' or col_csv contains 'download' -%}
    {%- assign is_digital = true -%}
  {%- endif -%}
{%- endif -%}

{%- assign is_watch = false -%}
{%- assign is_lego = false -%}
{%- assign is_game = false -%}

{%- if tags_csv contains 'cat_watch' -%}
  {%- assign is_watch = true -%}
{%- elsif tags_csv contains 'cat_lego' -%}
  {%- assign is_lego = true -%}
{%- elsif tags_csv contains 'cat_games' -%}
  {%- assign is_game = true -%}
{%- elsif tags_csv contains 'cat_digital' -%}
  {%- assign is_digital = true -%}
{%- endif -%}

{%- if is_watch == false and is_lego == false and is_game == false and is_digital == false -%}
  {%- if ptype contains 'uhr' or ptype contains 'watch' or ptype contains 'herrenuhren' or ptype contains 'damenuhren' -%}
    {%- assign is_watch = true -%}
  {%- endif -%}
  {%- for col in product.collections -%}
    {%- assign col_h = col.handle | downcase -%}
    {%- if col_h contains 'uhren' or col_h contains 'herrenuhren' or col_h contains 'damenuhren' or col_h contains 'watch' -%}
      {%- assign is_watch = true -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if is_watch == false and is_lego == false and is_game == false and is_digital == false -%}
  {%- if ptype contains 'lego' -%}
    {%- assign is_lego = true -%}
  {%- endif -%}
  {%- for col in product.collections -%}
    {%- assign col_h = col.handle | downcase -%}
    {%- if col_h contains 'lego' -%}
      {%- assign is_lego = true -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign vendor_lower = product.vendor | downcase -%}
  {%- if vendor_lower contains 'lego' -%}
    {%- assign is_lego = true -%}
  {%- endif -%}
{%- endif -%}

{%- if is_watch == false and is_lego == false and is_game == false and is_digital == false -%}
  {%- if ptype contains 'game' or ptype contains 'spiel' or ptype contains 'ps5' or ptype contains 'ps4' or ptype contains 'xbox' or ptype contains 'nintendo' -%}
    {%- assign is_game = true -%}
  {%- endif -%}
  {%- for col in product.collections -%}
    {%- assign col_h = col.handle | downcase -%}
    {%- if col_h contains 'game' or col_h contains 'ps5' or col_h contains 'ps4' or col_h contains 'xbox' or col_h contains 'nintendo' -%}
      {%- assign is_game = true -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if is_watch == false and is_lego == false and is_game == false and is_digital == false -%}
  {%- assign is_watch = true -%}
{%- endif -%}

<div class="price-box" aria-live="polite">
  <div class="price-horizontal">
    {% assign cap = product.selected_or_first_available_variant.compare_at_price | default: product.compare_at_price %}
    {% assign cur = product.selected_or_first_available_variant.price | default: product.price %}
    {% assign pct = 0 %}
    {% assign promo_badge_text = blank %}
    {% assign promo_badge_text_raw = product.metafields.custom.promo_badge_text.value | default: product.metafields.custom.promo_badge_text %}
    {% if promo_badge_text_raw != blank %}
      {% assign promo_badge_text = promo_badge_text_raw | strip %}
    {% endif %}
    {% assign promo_badge_until_raw = product.metafields.custom.promo_badge_until.value | default: product.metafields.custom.promo_badge_until | default: product.metafields.custom.promo_badge_bis.value | default: product.metafields.custom.promo_badge_bis %}
    {% if promo_badge_until_raw != blank %}
      {% assign promo_badge_until_date = promo_badge_until_raw | date: '%Y-%m-%d' %}
    {% endif %}
    {% assign now_date = 'now' | date: '%Y-%m-%d' %}

    {% assign promo_badge_metaobject = product.metafields.custom.promo_badge.value %}
    {% if promo_badge_metaobject != blank %}
      {% assign promo_badge_meta_text = promo_badge_metaobject.text.value | default: promo_badge_metaobject.text %}
      {% if promo_badge_meta_text != blank %}
        {% assign promo_badge_text = promo_badge_meta_text | strip %}
      {% endif %}
      {% assign promo_badge_meta_until = promo_badge_metaobject.until.value | default: promo_badge_metaobject.until %}
      {% if promo_badge_meta_until != blank %}
        {% assign promo_badge_until_date = promo_badge_meta_until | date: '%Y-%m-%d' %}
      {% endif %}
    {% endif %}

    {% assign show_promo_badge = false %}
    {% if promo_badge_text != blank %}
      {% if promo_badge_until_date == blank or promo_badge_until_date >= now_date %}
        {% assign show_promo_badge = true %}
      {% endif %}
    {% endif %}
    {% if cap and cap > cur %}
      {% assign diff = cap | minus: cur %}
      {% assign pct_raw = diff | times: 100.0 | divided_by: cap %}
      {% assign pct = pct_raw | round %}
    {% endif %}
    {% assign pct_string = pct | prepend: '-' | append: '%' %}

    <div class="price-container">
      {% if show_promo_badge %}
        <span class="sale-badge sale-badge--promo" data-static-badge="true">{{ promo_badge_text }}</span>
      {% elsif cap and cap > cur %}
        <span class="sale-badge" data-static-badge="false">SALE</span>
      {% endif %}
      <div class="price-main-row">
        <span class="current-price">{{ cur | money }}</span>
        {% if cap and cap > cur %}
          <span class="discount-pill-simple">-{{ pct }}%</span>
        {% endif %}
      </div>

      {% if cap and cap > cur %}
        <div class="price-sub-row">
          <span class="old-price">{{ cap | money }}</span>
          <span class="price-sep">•</span>
          <span class="savings-text">Preisvorteil: <strong>{{ cap | minus: cur | money }}</strong></span>
        </div>
      {% endif %}
    </div>
  </div>

  {% if is_digital %}
    <div class="price-meta" style="margin-top:-6px; padding-bottom: 4px;">inkl. MwSt.</div>
  {% else %}
    <div class="price-meta" style="margin-top:-6px; padding-bottom: 4px;">inkl. MwSt. zzgl. Versandkosten</div>
  {% endif %}

  {%- if is_watch -%}
  <div class="trust-reassurance-block" style="margin-top: 15px; margin-bottom: -5px;">
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Geprüfte Originalware & Echtheits-Garantie</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Offizielle Markenrechnung mit MwSt.</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Versicherter Expressversand aus DE</div>
    <div class="trust-reassurance-item trust-countdown-inline"><span class="trust-check" style="color: #E30613;"><i class="fa-solid fa-clock"></i></span>{%- render 'shipping-countdown', is_digital: is_digital, product: product -%}</div>
  </div>
  {%- elsif is_lego -%}
  <div class="trust-reassurance-block" style="margin-top: 15px; margin-bottom: -5px;">
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> 100% Neuware in versiegelter OVP</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Sammlerschutz: Sicher verpackt</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Versand in 1–3 Werktagen aus DE</div>
    <div class="trust-reassurance-item trust-countdown-inline"><span class="trust-check" style="color: #E30613;"><i class="fa-solid fa-clock"></i></span>{%- render 'shipping-countdown', is_digital: is_digital, product: product -%}</div>
  </div>
  {%- elsif is_game -%}
  <div class="trust-reassurance-block" style="margin-top: 15px; margin-bottom: -5px;">
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Fabrikneu & werkseitig versiegelt</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Deutsche Handelsversion (USK)</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Sicherer Versand aus Deutschland</div>
    <div class="trust-reassurance-item trust-countdown-inline"><span class="trust-check" style="color: #E30613;"><i class="fa-solid fa-clock"></i></span>{%- render 'shipping-countdown', is_digital: is_digital, product: product -%}</div>
  </div>
  {%- elsif is_digital -%}
  <div class="trust-reassurance-block" style="margin-top: 15px; margin-bottom: -5px;">
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Produktschlüssel sofort per E-Mail</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> 100% Legale & ungenutzte Lizenz</div>
    <div class="trust-reassurance-item"><span class="trust-check">✔</span> Support-Garantie bei Aktivierung</div>
  </div>
  {%- endif -%}

  <div class="kx-selection-group" style="margin-top: 15px;">
    {%- assign _sel_var = product.selected_or_first_available_variant -%}
    {%- assign sibling_legend_label = 'Ausfuehrung' -%}
    {%- assign sibling_legend_value = blank -%}
    {%- assign sibling_color_value = product.metafields.custom.display_color.value | default: product.metafields.custom.display_color | strip -%}
    {%- if sibling_color_value != blank -%}
      {%- assign sibling_legend_label = 'Farbe' -%}
      {%- assign sibling_legend_value = sibling_color_value -%}
    {%- endif -%}
    {%- for option in product.options_with_values -%}
      {%- assign sibling_option_name_dc = option.name | downcase -%}
      {%- if sibling_option_name_dc == 'farbe' or sibling_option_name_dc == 'color' or sibling_option_name_dc == 'größe' or sibling_option_name_dc == 'size' or sibling_option_name_dc == 'modell' or sibling_option_name_dc == 'model' or sibling_option_name_dc == 'stil' or sibling_option_name_dc == 'style' -%}
        {%- assign sibling_legend_label = option.name -%}
        {%- assign sibling_legend_value = _sel_var.options[forloop.index0] -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

        {%- assign sibling_products = product.metafields.custom.siblings.value -%}
    {%- if sibling_products != blank -%}
      <div class="kvp-pro__group" id="productSiblings" style="margin-top: 5px; margin-bottom: 25px;">
        <p class="kvp-pro__legend">
          <span class="kvp-pro__legend-label">{{ sibling_legend_label }}:</span>
          {%- if sibling_legend_value != blank -%}
            <strong>{{ sibling_legend_value }}</strong>
          {%- endif -%}
        </p>
        <div class="kvp-pro__grid">
          {%- for sibling in sibling_products -%}
            {%- assign is_current = false -%}
            {%- if sibling.id == product.id -%}{%- assign is_current = true -%}{%- endif -%}
            <a href="{{ sibling.url }}"
               class="kvp-pro__card{% if is_current %} is-active{% endif %}"
               title="{{ sibling.title | escape }}"
               style="text-decoration: none;">
              <img class="kvp-pro__thumb"
                   src="{{ sibling.featured_image | image_url: width: 300, format: 'webp', quality: 65 }}"
                   width="300" height="300"
                   alt="{{ sibling.title | escape }}"
                   loading="lazy"
                   decoding="async">
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if product.variants.size > 1 -%}
      {%- for option in product.options_with_values -%}
        {%- assign option_index = forloop.index0 -%}
        {%- assign option_name = option.name -%}
        {%- assign option_name_dc = option_name | downcase -%}
        {%- if option_name_dc != 'farbe' and option_name_dc != 'color' and option_name_dc != 'modell' and option_name_dc != 'model' and option_name_dc != 'stil' and option_name_dc != 'style' and option_name_dc != 'größe' and option_name_dc != 'size' -%}
          {%- continue -%}
        {%- endif -%}

        {% assign max_visible = 11 %}
        {% assign total_values = option.values.size %}
        {% assign remaining = total_values | minus: max_visible %}
        <div class="kvp-pro__group" id="variantPicker-{{ option_index }}" aria-label="{{ option_name }} Auswahl" style="margin-top: 15px;">
          <p class="kvp-pro__legend">
            <span class="kvp-pro__legend-label">{{ option_name }}:</span>
            <strong class="variantLegendValue" data-option-index="{{ option_index }}">
              {{ _sel_var.options[option_index] }}
            </strong>
          </p>
          <div class="kvp-pro__grid" role="radiogroup" aria-label="{{ option_name }}" data-option-index="{{ option_index }}">
          {%- assign max_visible_plus_one = max_visible | plus: 1 -%}
          {%- for val in option.values -%}
            {%- if forloop.index > max_visible -%}
              {%- if forloop.index == max_visible_plus_one -%}
                <div class="kvp-pro__more">+{{ remaining }}</div>
              {%- endif -%}
              {%- continue -%}
            {%- endif -%}

            {%- assign variant_for_thumb = nil -%}
            {%- for v in product.variants -%}
              {%- if v.options[option_index] == val and v.featured_image != blank -%}
                {%- assign variant_for_thumb = v -%}{%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- assign is_active = false -%}
            {%- if _sel_var.options[option_index] == val -%}{%- assign is_active = true -%}{%- endif -%}

            {%- assign any_variant_available = false -%}
            {%- for v in product.variants -%}
              {%- if v.options[option_index] == val and v.available -%}
                {%- assign any_variant_available = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            <label class="kvp-pro__card{% if is_active %} is-active{% endif %}{% unless any_variant_available %} is-oos{% endunless %}"
                   data-option-index="{{ option_index }}"
                   data-option-value="{{ val | escape }}"
                   role="radio"
                   aria-checked="{{ is_active }}"
                   {% unless any_variant_available %}aria-disabled="true"{% endunless %}
                   tabindex="0">
              <input class="kvp-pro__radio" type="radio" name="option-{{ option_index }}" value="{{ val | escape }}" {% if is_active %}checked{% endif %} aria-label="{{ option_name }} {{ val }}">
              {% if variant_for_thumb %}
                <img class="kvp-pro__thumb" src="{{ variant_for_thumb.featured_image | image_url: width: 300, format: 'webp', quality: 65 }}" width="300" height="300" alt="{{ val }}" loading="lazy" decoding="async">
              {% else %}
                <img class="kvp-pro__thumb" src="{{ product.featured_image | image_url: width: 300, format: 'webp', quality: 65 }}" width="300" height="300" alt="{{ val }}" loading="lazy" decoding="async">
              {% endif %}
              {% unless any_variant_available %}
                <div class="kvp-pro__oos-icon">
                  <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
              {% endunless %}
            </label>
          {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}

    {% if is_digital and product.options.size > 0 %}
      {% for option in product.options %}
        {% if option.name == 'Betriebssystem' or option.name == 'Operating System' or option.name == 'OS' %}
          {% assign os_option_index = forloop.index0 %}
          {% assign os_values = option.values %}
          <div class="os-selector-container" id="osSelectorContainer" style="margin-top: 15px;">
            <p class="os-selector-label">Betriebssystem wählen:</p>
            <div class="os-pills" role="radiogroup" aria-label="Betriebssystem Auswahl">
              {% for value in option.values %}
                {% assign variant_for_os = nil %}
                {% for v in product.variants %}
                  {% if v.options[os_option_index] == value %}
                    {% assign variant_for_os = v %}
                    {% break %}
                  {% endif %}
                {% endfor %}
                {% if variant_for_os %}
                  <button type="button"
                          class="os-pill{% if forloop.first %} is-active{% endif %}"
                          data-os-value="{{ value | escape }}"
                          data-variant-id="{{ variant_for_os.id }}"
                          data-option-index="{{ os_option_index }}"
                          role="radio"
                          aria-checked="{% if forloop.first %}true{% else %}false{% endif %}"
                          {% unless variant_for_os.available %}disabled{% endunless %}>
                    {% if value contains 'Windows' %}
                      <i class="fa-brands fa-windows"></i>
                    {% elsif value contains 'Mac' %}
                      <i class="fa-brands fa-apple"></i>
                    {% endif %}
                    <span>{{ value }}</span>
                  </button>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}

        <div class="kx-back-in-stock-form" id="backInStockForm" style="margin-top: 15px; {% if product.selected_or_first_available_variant.available %}display: none;{% endif %}">
      <div class="kx-bis-title" id="kx-bis-title">Deine Farbe ist ausverkauft</div>
      <div class="kx-bis-desc" id="kx-bis-desc">Wir können Dich benachrichtigen, sobald das Produkt wieder verfügbar ist.</div>

      {%- form 'contact', id: 'back-in-stock-contact-form' -%}
        <div id="kx-bis-form-group">
          <input type="hidden" name="contact[body]" id="kx-bis-body" value="Bitte benachrichtigen, wenn wieder verfügbar: {{ product.title }} - {{ product.selected_or_first_available_variant.title }}">
          <div class="kx-bis-input-wrapper">
            <input type="email" id="kx-bis-email" name="contact[email]" class="kx-bis-input" placeholder=" " required autocomplete="email">
            <label for="kx-bis-email" class="kx-bis-label">Deine E-Mail-Adresse</label>
            <div class="kx-bis-error-icon">!</div>
          </div>
          <div id="kx-bis-error-msg" class="kx-bis-error-text">Bitte gib Deine E-Mail-Adresse an</div>
          <button type="button" class="kx-bis-btn" id="kx-bis-submit-btn" onclick="
            var wrapper = document.querySelector('.kx-bis-input-wrapper');
            var input = document.getElementById('kx-bis-email');
            var errorMsg = document.getElementById('kx-bis-error-msg');
            var successMsg = document.getElementById('kx-bis-success-msg');
            var form = document.getElementById('back-in-stock-contact-form');

            if (!input.value || !input.value.includes('@')) {
              wrapper.classList.add('has-error');
              errorMsg.classList.add('is-visible');
            } else {
              wrapper.classList.remove('has-error');
              errorMsg.classList.remove('is-visible');
              var formData = new FormData(form);
              fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                  'X-Requested-With': 'XMLHttpRequest'
                 }
              }).then(function() {
                successMsg.style.display = 'flex';
                input.value = '';
                setTimeout(function() {
                  successMsg.style.display = 'none';
                }, 3000);
              }).catch(function(error) {
                console.error('Error submitting form:', error);
              });
            }
          ">
            <svg class="kx-bis-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            Bei Verfügbarkeit erinnern
          </button>
        </div>
      {%- endform -%}
