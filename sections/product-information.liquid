<script>
(function () {
  function init() {
    // Mobile gallery action buttons (Cart & Wishlist)
    const mobileCartBtn = document.querySelector('.mobile-cart-btn');
    const mobileWishlistBtn = document.querySelector('.mobile-wishlist-btn');
    const desktopWishlistBtn = document.querySelector('.wishlist-pdp-btn');

    // Mobile Cart Button
    if (mobileCartBtn) {
      mobileCartBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        const mainForm = document.getElementById('add-to-cart-form');
        const mainCartBtn = mainForm ? mainForm.querySelector('button[type="submit"]') : null;

        if (mainCartBtn) {
          mainCartBtn.click();
        } else if (mainForm) {
          mainForm.submit();
        }
      });
    }

    // Mobile Wishlist Button
    if (mobileWishlistBtn) {
      const handle = mobileWishlistBtn.dataset.handle;

      const syncMobileWishlistState = () => {
        const list = JSON.parse(localStorage.getItem('wishlist') || '[]');
        mobileWishlistBtn.classList.toggle('active', list.includes(handle));
      };

      syncMobileWishlistState();
      window.addEventListener('wishlist-updated', syncMobileWishlistState);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

