       shareBtn.addEventListener('click', function() {
         var url = window.location.href.split('#')[0];
         openSharePanel(url);
         popBtn(shareBtn);
       });

       var VIDEO_ENGAGEMENT_API = 'https://script.google.com/macros/s/AKfycbzRAE7_bK9_m1-nEhAfpHVmsDqHkqCmR-qSMlkSLc8F8_k61H-scIQiMUnNXdYZnUHnYQ/exec';
       var viewsEl = document.getElementById('videoModalViews');
       var likeBtn = document.getElementById('videoLikeBtn');
       var dislikeBtn = document.getElementById('videoDislikeBtn');
       var likeCountEl = document.getElementById('videoLikeCount');
       var dislikeCountEl = document.getElementById('videoDislikeCount');
       var publishDateEl = document.getElementById('videoPublishDate');
       var CACHE_KEY = 'kx_vid_cache';

       function timeAgo(iso) {
         if (!iso) return '';

         var s = String(iso).trim();

         var datePart = s.slice(0, 10);
         var d = new Date(datePart + 'T00:00:00');
         if (isNaN(d.getTime())) return '';
         var diff = Math.floor((Date.now() - d) / 1000);
         if (diff < 0)        return 'Gerade hochgeladen';
         if (diff < 86400)    return 'Heute';
         if (diff < 2592000)  return 'Vor ' + Math.floor(diff / 86400)   + ' Tagen';
         if (diff < 31536000) return 'Vor ' + Math.floor(diff / 2592000) + ' Monaten';
         return 'Vor ' + Math.floor(diff / 31536000) + ' Jahren';
       }

       var prefetchStore = {};
       var prefetchDone  = {};

       function getCached(vid) {
         try { var c = JSON.parse(localStorage.getItem(CACHE_KEY) || '{}'); return c[vid] || null; } catch(e) { return null; }
       }
       function setCache(vid, data) {
         try {
           var c = JSON.parse(localStorage.getItem(CACHE_KEY) || '{}');

           if (data.shares === undefined && c[vid] && c[vid].shares) data.shares = c[vid].shares;
           c[vid] = data;
           localStorage.setItem(CACHE_KEY, JSON.stringify(c));
         } catch(e) {}
       }

       function getVisitorId() {
         var id = localStorage.getItem('kx_visitor_id');
         if (!id) {
           id = 'v_' + Math.random().toString(36).substr(2,12) + '_' + Date.now();
           localStorage.setItem('kx_visitor_id', id);
         }
         return id;
       }

       function videoId() {
         var v = videoItems[currentVideoIdx];
         return v ? (v.video || '').replace(/[^a-zA-Z0-9_-]/g,'').slice(0,80) : '';
       }

       function vidKey(v) {
         return v ? (v.video || '').replace(/[^a-zA-Z0-9_-]/g,'').slice(0,80) : '';
       }

       function formatViews(n) {
         if (n >= 1000000) return (n / 1000000).toFixed(1).replace('.0','') + ' Mio.';
         if (n >= 1000) return (n / 1000).toFixed(1).replace('.0','') + ' Tsd.';
         return n.toLocaleString('de-DE');
       }

       function renderEngagement(data) {
         var vid = videoId();
         var prev = prefetchStore[vid] || getCached(vid) || {};

         var shares = data.shares !== undefined ? data.shares : (prev.shares || 0);
         viewsEl.textContent = formatViews(data.views || 0) + ' Aufrufe';
         likeCountEl.textContent = data.likes || 0;
         dislikeCountEl.textContent = data.dislikes || 0;
         setShareCount(shares);
         likeBtn.classList.toggle('is-active', data.myAction === 'like');
         dislikeBtn.classList.toggle('is-active', data.myAction === 'dislike');
         data.shares = shares;
         prefetchStore[vid] = data;
         setCache(vid, data);
       }

       function apiCall(action, vid, cb) {
         if (!vid || !VIDEO_ENGAGEMENT_API) return;
         var url = VIDEO_ENGAGEMENT_API + '?action=' + action
           + '&vid=' + encodeURIComponent(vid)
           + '&uid=' + encodeURIComponent(getVisitorId());
         fetch(url)
           .then(function(r) { return r.json(); })
           .then(function(data) { if (cb) cb(data); })
           .catch(function() {});
       }

       function prefetchAll() {
         if (!VIDEO_ENGAGEMENT_API) return;

         collectVideoItems();
         videoItems.forEach(function(v) {
           var key = vidKey(v);
           if (!key || prefetchDone[key]) return;
           prefetchDone[key] = true;

           var url = VIDEO_ENGAGEMENT_API + '?action=get'
             + '&vid=' + encodeURIComponent(key)
             + '&uid=' + encodeURIComponent(getVisitorId());
           fetch(url)
             .then(function(r) { return r.json(); })
             .then(function(data) {
               var prev = prefetchStore[key] || getCached(key) || {};
               if (data.shares === undefined) data.shares = prev.shares || 0;
               prefetchStore[key] = data;
               setCache(key, data);
             })
             .catch(function() {});
         });
       }

       prefetchAll();

       function initEngagement() {
         var vid = videoId();

         var v = videoItems[currentVideoIdx];
         if (publishDateEl) {
           publishDateEl.textContent = (v && v.created) ? timeAgo(v.created) : '';
         }

         if (prefetchStore[vid]) {
           renderEngagement(prefetchStore[vid]);

           apiCall('view', vid, function(data) { renderEngagement(data); });
           return;
         }

         var cached = getCached(vid);
         if (cached) renderEngagement(cached);

         if (!prefetchDone[vid]) prefetchAll();
         apiCall('view', vid, function(data) { renderEngagement(data); });
       }

       var _engagementSeq = 0;

       function popBtn(btn) {
         btn.classList.remove('kx-pop');
         void btn.offsetWidth;
         btn.classList.add('kx-pop');
         btn.addEventListener('animationend', function h() {
           btn.classList.remove('kx-pop');
           btn.removeEventListener('animationend', h);
         });
       }

       function animCount(el) {
         el.classList.remove('kx-count-anim');
         void el.offsetWidth;
         el.classList.add('kx-count-anim');
         el.addEventListener('animationend', function h() {
           el.classList.remove('kx-count-anim');
           el.removeEventListener('animationend', h);
         });
       }

       function optimisticReact(action) {
         var seq = ++_engagementSeq;
         var vid = videoId();
         var current = prefetchStore[vid] || getCached(vid) || { views: 0, likes: 0, dislikes: 0, shares: 0, myAction: '' };
         var optimistic = { views: current.views, likes: current.likes, dislikes: current.dislikes, shares: current.shares || 0, myAction: current.myAction };

         if (action === 'like') {
           if (optimistic.myAction === 'like') {
             optimistic.likes = Math.max(0, optimistic.likes - 1);
             optimistic.myAction = '';
           } else {
             if (optimistic.myAction === 'dislike') optimistic.dislikes = Math.max(0, optimistic.dislikes - 1);
             optimistic.likes += 1;
             optimistic.myAction = 'like';
           }
           popBtn(likeBtn);
         } else {
           if (optimistic.myAction === 'dislike') {
             optimistic.dislikes = Math.max(0, optimistic.dislikes - 1);
             optimistic.myAction = '';
           } else {
             if (optimistic.myAction === 'like') optimistic.likes = Math.max(0, optimistic.likes - 1);
             optimistic.dislikes += 1;
             optimistic.myAction = 'dislike';
           }
           popBtn(dislikeBtn);
         }

         likeCountEl.textContent = optimistic.likes;
         dislikeCountEl.textContent = optimistic.dislikes;
         animCount(action === 'like' ? likeCountEl : dislikeCountEl);
         likeBtn.classList.toggle('is-active', optimistic.myAction === 'like');
         dislikeBtn.classList.toggle('is-active', optimistic.myAction === 'dislike');
         prefetchStore[vid] = optimistic;
         setCache(vid, optimistic);

         apiCall(action, vid, function(data) {
           if (seq !== _engagementSeq) return;

           if (data.shares === undefined) data.shares = prefetchStore[vid] ? (prefetchStore[vid].shares || 0) : 0;
           likeCountEl.textContent = data.likes || 0;
           dislikeCountEl.textContent = data.dislikes || 0;
           likeBtn.classList.toggle('is-active', data.myAction === 'like');
           dislikeBtn.classList.toggle('is-active', data.myAction === 'dislike');
           prefetchStore[vid] = data;
           setCache(vid, data);
         });
       }

       likeBtn.addEventListener('click', function() { optimisticReact('like'); });
       dislikeBtn.addEventListener('click', function() { optimisticReact('dislike'); });

       var _origPlayVideo = playVideo;
       playVideo = function(idx) {
         currentVideoIdx = idx;
         initEngagement();
         _origPlayVideo(idx);
       };
     })();
     </script>

                 <div class="product-info">

                {% render 'deal-countdown', product: product %}

                <h1 class="product-title" style="margin-bottom: 6px;">{{ product.title | remove: ' - Default Title' | remove: '- Default Title' | remove: ' - Erwachsene / Männlich' | remove: ' - Erwachsene / Weiblich' | remove: ' - Männlich' | remove: ' - Weiblich' }}</h1>

                                <div class="desktop-stock-badge">
                  {% liquid
                    assign is_sold_out = false
                    if product.available == false
                      assign is_sold_out = true
                    endif

                    assign is_low_stock = false
                    assign low_stock_threshold = 10
                    assign current_inventory = 0
                    for variant in product.variants
                      if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny'
                        assign current_inventory = current_inventory | plus: variant.inventory_quantity
                      endif
                    endfor

                    # Check for tags
                    assign has_low_stock_tag = false
                    assign has_sold_out_tag = false

                    if product.tags contains 'ausverkauft' or product.tags contains 'Ausverkauft'
                      assign has_sold_out_tag = true
                    endif

                    if product.tags contains 'tages' or product.tags contains 'Tages' or product.tags contains 'fast-ausverkauft'
                      assign has_low_stock_tag = true
                    endif

                    # Force Sold Out if tag is present
                    if has_sold_out_tag
                       assign is_sold_out = true
                    endif

                    # Logic for low stock: specific tags OR global inventory threshold (if tracking is enabled)
                    if product.available and has_low_stock_tag and is_sold_out == false
                       assign is_low_stock = true
                    elsif product.available and current_inventory > 0 and current_inventory <= low_stock_threshold and is_sold_out == false
                       assign is_low_stock = true
                    endif
                  %}

                  {%- if is_sold_out -%}
                     <span class="stock-badge stock-badge--sold-out">Ausverkauft</span>
                  {%- elsif is_low_stock -%}
                     <span class="stock-badge stock-badge--low-stock">Fast ausverkauft</span>
                  {%- endif -%}
                </div>

{%- unless is_digital -%}
<p class="trust-authorized-dealer">Autorisierter Händler – geprüfte Originalware</p>
{%- endunless -%}
<div class="product-rating" id="pdp-product-rating" style="margin-bottom: 12px; display: none;">
  <div class="rechnung-profi-stars" data-product-id="{{ product.id }}"></div>
</div>
<div class="product-write-review" id="pdp-write-review" style="display: none; margin-bottom: 12px;">
  <a href="#bewertung" style="color: #1D4739; font-size: 14px; text-decoration: underline;">Bewertung schreiben</a>
</div>
{% assign product_collections = product.collections | map: 'handle' %}
{% assign digital = false %}
{% if product_collections contains 'software' or product_collections contains 'digitale-produkte' or product_collections contains 'digital' or product_collections contains 'keys' %}{% assign digital = true %}{% endif %}
{% assign title_l = product.title | downcase %}
{% assign tags_l = product.tags | join: ',' | downcase %}
{% assign type_l = product.type | downcase %}
{% assign is_win = false %}
{% assign is_mac = false %}
{% if title_l contains 'windows' or tags_l contains 'windows' or type_l contains 'windows' %}{% assign is_win = true %}{% endif %}
{% if title_l contains 'mac' or title_l contains 'macos' or tags_l contains 'mac' or tags_l contains 'macos' or type_l contains 'mac' %}{% assign is_mac = true %}{% endif %}
{% if digital %}
  <p class="product-subtitle" style="margin-bottom: 8px;">
    {% if is_win and is_mac == false %}Dauerlizenz für Windows – Kein Abo – Sofort per E-Mail
    {% elsif is_mac and is_win == false %}Dauerlizenz für macOS – Kein Abo – Sofort per E-Mail
    {% elsif is_win and is_mac %}Dauerlizenz für Windows & macOS – Kein Abo – Sofort per E-Mail
    {% else %}Dauerlizenz – Kein Abo – Sofort per E-Mail{% endif %}
  </p>
{% endif %}

{%- assign _sold_count = product.metafields.custom.recently_sold_count.value | default: product.metafields.custom.recently_sold_count | plus: 0 -%}
{%- assign _sold_hours = product.metafields.custom.recently_sold_hours.value | default: product.metafields.custom.recently_sold_hours | plus: 0 -%}
{%- assign _sold_city = product.metafields.custom.recently_sold_city.value | default: product.metafields.custom.recently_sold_city -%}

{%- if _sold_hours == 0 -%}
  {%- assign _sold_hours = 24 -%}
{%- endif -%}

{%- if _sold_count >= 1 -%}
<div class="kx-premium-social-proof">
  <div class="kx-psp-icon-wrapper">
    <svg class="kx-trend-icon-sequence" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
