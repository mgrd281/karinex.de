<script>
  (function() {
    // Read More Toggle Logic
    var mask = document.getElementById('desc-mask');
    var desc = document.getElementById('product-description');
    var btn = document.getElementById('read-more-toggle');
    var txt = btn ? btn.querySelector('.read-more-text') : null;

    if(mask && desc && btn) {
      var expandState = 0; // 0=collapsed, 1=half, 2=full

      function checkContentHeight() {
        var isDesktop = window.innerWidth >= 990;
        var maxHeight = isDesktop ? 380 : 250;

        // Temporarily reset to measure
        var prevMaskStyle = mask.style.maxHeight;
        mask.style.maxHeight = 'none';
        var actualHeight = desc.scrollHeight;
        mask.style.maxHeight = prevMaskStyle;

        if(actualHeight > maxHeight + 60) {
          btn.style.display = 'inline-flex';
          if(expandState === 0) {
            mask.style.maxHeight = maxHeight + 'px';
          }
        } else {
          mask.classList.add('is-expanded');
          mask.style.maxHeight = 'none';
          btn.style.display = 'none';
          expandState = 2;
        }
      }

      // Initial check — multiple passes to catch late-loading content/fonts
      setTimeout(checkContentHeight, 300);
      setTimeout(checkContentHeight, 800);
      setTimeout(checkContentHeight, 1500);
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(checkContentHeight);
      }
      window.addEventListener('resize', checkContentHeight);

      btn.addEventListener('click', function() {
        var isDesktop = window.innerWidth >= 990;
        var step1 = isDesktop ? 380 : 250;

        // Measure true content height
        var prevMax = mask.style.maxHeight;
        var prevOverflow = mask.style.overflow;
        mask.style.maxHeight = 'none';
        mask.style.overflow = 'hidden';
        var fullHeight = desc.scrollHeight;
        mask.style.maxHeight = prevMax;
        mask.style.overflow = prevOverflow;

        var step60 = Math.round(fullHeight * 0.6);

        if(expandState === 0) {
          // First click → 60%
          if(fullHeight <= step60 + 60) {
            // Content small enough → go full directly
            expandState = 2;
            mask.classList.add('is-expanded');
            mask.style.maxHeight = fullHeight + 'px';
            btn.setAttribute('aria-expanded', 'true');
            txt.textContent = "Weniger anzeigen";
            setTimeout(function() { if(expandState === 2) mask.style.maxHeight = 'none'; }, 550);
          } else {
            expandState = 1;
            mask.style.maxHeight = step60 + 'px';
            // Keep "Mehr anzeigen" visible for second click
          }
        } else if(expandState === 1) {
          // Second click → full
          expandState = 2;
          mask.classList.add('is-expanded');
          mask.style.maxHeight = fullHeight + 'px';
          btn.setAttribute('aria-expanded', 'true');
          txt.textContent = "Weniger anzeigen";
          setTimeout(function() { if(expandState === 2) mask.style.maxHeight = 'none'; }, 550);
        } else {
          // Collapse back
          expandState = 0;
          mask.classList.remove('is-expanded');
          mask.style.maxHeight = step1 + 'px';
          btn.setAttribute('aria-expanded', 'false');
          txt.textContent = "Mehr anzeigen";
          mask.closest('.tab-content').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }

    // Tab Switching Global Function (kept for desktop mainly)
    window.switchTab = function(btn) {
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('active');
      });
      btn.classList.add('active');

      document.querySelectorAll('.tab-content').forEach(function(p) {
        p.classList.remove('active');
        p.style.display = 'none';
      });

      var targetId = btn.getAttribute('data-tab');
      var target = document.getElementById(targetId);
      if(target) {
        target.classList.add('active');
        target.style.display = 'block';
        // Re-check height on switch in case it was hidden
        if(typeof checkContentHeight === 'function') checkContentHeight();
      }
    };
  })();
</script>

