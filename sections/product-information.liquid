<script>
var watchExpandState = 0; // 0=collapsed, 1=half, 2=full
function toggleDesc() {
  var t = document.getElementById('watchDescText');
  var g = document.getElementById('watchDescGradient');
  var b = document.getElementById('watchMehrBtn');
  var isDesktop = window.innerWidth >= 990;
  var step1 = isDesktop ? 380 : 250;
  var step2 = isDesktop ? 800 : 550;
  var fullHeight = t.scrollHeight;
  var textMore = 'weiterlesen &raquo;';
  var textLess = 'weniger anzeigen &laquo;';

  if (watchExpandState === 0) {
    // If content fits in step2, skip to full
    if (fullHeight <= step2 + 60) {
      watchExpandState = 2;
      t.classList.add('open');
      t.style.maxHeight = fullHeight + 'px';
      g.classList.add('hide');
      b.classList.add('open');
      b.innerHTML = textLess;
      setTimeout(function() { if(t.classList.contains('open')) t.style.maxHeight = 'none'; }, 550);
    } else {
      watchExpandState = 1;
      t.style.maxHeight = step2 + 'px';
    }
  } else if (watchExpandState === 1) {
    watchExpandState = 2;
    t.classList.add('open');
    t.style.maxHeight = fullHeight + 'px';
    g.classList.add('hide');
    b.classList.add('open');
    b.innerHTML = textLess;
    setTimeout(function() { if(t.classList.contains('open')) t.style.maxHeight = 'none'; }, 550);
  } else {
    watchExpandState = 0;
    t.classList.remove('open');
    t.style.maxHeight = step1 + 'px';
    g.classList.remove('hide');
    b.classList.remove('open');
    b.innerHTML = textMore;
    var scrollTarget = t.closest('.watch-description-box') || t.closest('.watch-layout');
    if (scrollTarget) scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

// Auto-init for physical layout
(function() {
  var SF = "'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif";
  function forceDescFont(container) {
    if (!container) return;
    container.style.setProperty('font-family', SF, 'important');
    var els = container.querySelectorAll('*');
    for (var i = 0; i < els.length; i++) {
      els[i].style.setProperty('font-family', SF, 'important');
      els[i].removeAttribute('face');
      els[i].removeAttribute('color');
      els[i].removeAttribute('size');
      // Strip font tags by replacing with span
      if (els[i].tagName === 'FONT') {
        var span = document.createElement('span');
        span.innerHTML = els[i].innerHTML;
        span.style.setProperty('font-family', SF, 'important');
        els[i].parentNode.replaceChild(span, els[i]);
      }
    }
    // Remove any <style> blocks inside description
    container.querySelectorAll('style').forEach(function(s) { s.remove(); });
  }
  function initWatchDesc() {
    var t = document.getElementById('watchDescText');
    var b = document.getElementById('watchMehrBtn');
    if(!t || !b) return;

    // Force font on desktop watch description
    forceDescFont(t);

    var isDesktop = window.innerWidth >= 990;
    var maxHeight = isDesktop ? 380 : 250;

    if(t.scrollHeight > maxHeight + 60) {
      b.style.display = 'inline-flex';
      if(!t.classList.contains('open')) t.style.maxHeight = maxHeight + 'px';
    } else {
      b.style.display = 'none';
      t.style.maxHeight = 'none';
      t.classList.add('open');
      var g = document.getElementById('watchDescGradient');
      if(g) g.classList.add('hide');
    }
  }
  // Also force font on mobile accordion descriptions
  function initMobileDescFont() {
    var mobileDescs = document.querySelectorAll('.w-accordion-content .product-description-text');
    for (var i = 0; i < mobileDescs.length; i++) {
      forceDescFont(mobileDescs[i]);
    }
  }
  setTimeout(function() { initWatchDesc(); initMobileDescFont(); }, 300);
  window.addEventListener('resize', initWatchDesc);
})();
</script>

