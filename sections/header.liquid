<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="cart-drawer"
  data-section-id="{{ section.id }}"
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
    <dialog
      ref="dialog"
      class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
      aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
      scroll-lock
      cart-summary-sticky="true"
      data-skip-node-update
    >
      <div class="cart-drawer__inner">
        <cart-items-component
          class="cart-items-component"
          data-section-id="{{ section.id }}"
        >
          {%- if cart.empty? -%}
            <div class="cart-drawer__header">
              <h2
                class="cart-drawer__heading h4"
                id="cart-drawer-heading-empty"
              >
                Warenkorb
              </h2>

              <button
                ref="closeButton"
                on:click="cart-drawer-component/close"
                class="button close-button cart-drawer__close-button button-unstyled"
                aria-label="{{ 'actions.close_dialog' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>

            <div
              class="cart-drawer__content motion-reduce"
              aria-label="{{ 'accessibility.cart' | t }}"
            >
              <div class="cart-drawer__items">
                {% render 'cart-products', drawer_context: 'drawer' %}
              </div>
            </div>
          {%- else -%}
            <div
              class="cart-drawer__header cart-section cart-section--1"
              id="cart-drawer-header"
            >
              <h2
                class="cart-drawer__heading h4"
                id="cart-drawer-heading"
              >
                Warenkorb
                {%- unless cart == empty -%}
                  <span class="cart-drawer__count">{{ cart.item_count }}</span>
                {%- endunless -%}
              </h2>

              <button
                ref="closeButton"
                on:click="cart-drawer-component/close"
                class="button close-button cart-drawer__close-button button-unstyled"
                aria-label="{{ 'actions.close_dialog' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>

            <div
              class="cart-drawer__content motion-reduce"
              aria-label="{{ 'accessibility.cart' | t }}"
            >
              <div class="cart-drawer__items">
                {% render 'cart-products', drawer_context: 'drawer' %}
                {%- comment -%}
                  "Wird oft zusammen gekauft" — collected from each cart item's
                  custom.wird_oft_zusammen_gekauft (List of products) metafield.
                  We deduplicate and exclude products already in the cart.
                {%- endcomment -%}
                {%- assign _cart_ids = '' -%}
                {%- for _ci in cart.items -%}
                  {%- assign _cart_ids = _cart_ids | append: '|' | append: _ci.product_id | append: '|' -%}
                {%- endfor -%}
                {%- assign _reco_seen = '' -%}
                {%- assign _reco_count = 0 -%}
                {%- capture _reco_cards -%}
                  {%- for _ci in cart.items -%}
                    {%- assign _recos = _ci.product.metafields.custom.wird_oft_zusammen_gekauft.value -%}
                    {%- if _recos -%}
                      {%- for _rp in _recos -%}
                        {%- assign _rp_key = '|' | append: _rp.id | append: '|' -%}
                        {%- unless _reco_seen contains _rp_key or _cart_ids contains _rp_key -%}
                          {%- assign _reco_seen = _reco_seen | append: _rp_key -%}
                          {%- assign _reco_count = _reco_count | plus: 1 -%}
                          {%- assign _rv = _rp.selected_or_first_available_variant -%}
                          <div class="cart-reco-card" data-product-id="{{ _rp.id }}" data-variant-id="{{ _rv.id }}" style="animation-delay: {{ _reco_count | times: 150 }}ms;">
                            <a href="{{ _rp.url }}" class="cart-reco-img-link" tabindex="-1" aria-hidden="true">
                              {%- if _rp.featured_image -%}
                                <img
                                  src="{{ _rp.featured_image | image_url: width: 120 }}"
                                  alt="{{ _rp.featured_image.alt | default: _rp.title | escape }}"
                                  width="120"
                                  height="{{ 120 | divided_by: _rp.featured_image.aspect_ratio | round }}"
                                  loading="lazy"
                                  class="cart-reco-img"
                                >
                              {%- endif -%}
                            </a>
                            <div class="cart-reco-body">
                              <a href="{{ _rp.url }}" class="cart-reco-name">{{ _rp.title | truncate: 44 }}</a>
                              <div class="cart-reco-meta">
                                {%- if _rp.compare_at_price > _rp.price -%}
                                  <span class="cart-reco-now cart-reco-now--sale">{{ _rp.price | money }}</span>
                                  <s class="cart-reco-was">{{ _rp.compare_at_price | money }}</s>
                                {%- else -%}
                                  <span class="cart-reco-now">{{ _rp.price | money }}</span>
                                {%- endif -%}
                              </div>
                            </div>
                            <button
                              type="button"
                              class="cart-reco-btn"
                              data-variant-id="{{ _rv.id }}"
                              aria-label="In den Warenkorb"
                              {%- unless _rv.available -%} disabled aria-disabled="true"{%- endunless -%}
                            >
                              <svg class="cart-reco-btn__plus" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><line x1="6.5" y1="1" x2="6.5" y2="12"/><line x1="1" y1="6.5" x2="12" y2="6.5"/></svg>
                              <svg class="cart-reco-btn__check" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 7 5.5 10.5 11 4"/></svg>
                            </button>
                          </div>
                        {%- endunless -%}
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endcapture -%}
                {%- if _reco_count > 0 -%}
                  <div id="cart-drawer-recommendations" class="cart-section cart-section--4 cart-reco-wrapper">
                    <p class="cart-reco-header">Wird oft zusammen gekauft</p>
                    <div class="cart-reco-scroll">
                      {{ _reco_cards }}
                    </div>
                  </div>
                {%- endif -%}

                <!-- Zuletzt angesehen – always visible when cart has items -->
                <div id="cart-drawer-rv-items" class="cart-drawer-rv-container"></div>
              </div>
            </div>

            <div class="cart-drawer__summary cart-section cart-section--5">
              {% render 'cart-summary', is_drawer: true %}
            </div>
          {%- endif -%}
        </cart-items-component>
      </div>
    </dialog>
</cart-drawer-component>

<script>
  /* Toast overlays — created once via JS, appended to <body>.
     Never in server-rendered HTML → no FOUC, no section re-render risk. */
  (function () {
    if (document.getElementById('swipe-undo-snackbar')) return;
    var b = document.body;

    var undo = document.createElement('div');
    undo.id = 'swipe-undo-snackbar';
    undo.className = 'swipe-snackbar';
    undo.setAttribute('aria-live', 'polite');
    undo.innerHTML = '<span>Artikel entfernt<\/span><button type="button" id="swipe-undo-btn">R\u00fckg\u00e4ngig<\/button>';
    b.appendChild(undo);

    var wish = document.createElement('div');
    wish.id = 'swipe-wish-snackbar';
    wish.className = 'swipe-snackbar swipe-snackbar--wish';
    wish.setAttribute('aria-live', 'polite');
    wish.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="#5A8068" stroke="none"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"\/><\/svg><span>Zur Wunschliste hinzugef\u00fcgt<\/span>';
    b.appendChild(wish);

    var toast = document.createElement('div');
    toast.id = 'wishlist-toast';
    toast.className = 'wishlist-toast';
    toast.setAttribute('aria-hidden', 'true');
    toast.innerHTML = '<div class="wishlist-toast__content"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"><\/path><\/svg><span>Der Artikel wurde erfolgreich zum Wunschzettel hinzugef\u00fcgt.<\/span><\/div>';
    b.appendChild(toast);
  })();
</script>

