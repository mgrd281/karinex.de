    data-end="{{ section.settings.countdown_end_datetime }}"
    data-timezone="{{ section.settings.countdown_timezone }}"
    data-expired="{{ section.settings.when_expired }}"
    data-expired-text="{{ section.settings.countdown_expired_text | escape }}"
    {% if section.settings.enable_countdown == false %}style="display:none"{% endif %}
>
        <div class="headline">
            {{ section.settings.countdown_left_label | default: 'Final Winter Sale' }}
        </div>

    <div class="timer" aria-live="polite" aria-atomic="true">
        <div class="unit" data-unit="days">
            <div class="block">
                <div class="num" id="days-{{ section.id }}">00</div>
                <div class="label">Tage</div>
            </div>
            <div class="sep">:</div>
        </div>
        <div class="unit" data-unit="hours">
            <div class="block">
                <div class="num" id="hours-{{ section.id }}">00</div>
                <div class="label">Stunden</div>
            </div>
            <div class="sep">:</div>
        </div>
        <div class="unit" data-unit="minutes">
            <div class="block">
                <div class="num" id="minutes-{{ section.id }}">00</div>
                <div class="label">Minuten</div>
            </div>
            <div class="sep">:</div>
        </div>
        <div class="unit" data-unit="seconds">
            <div class="block">
                <div class="num" id="seconds-{{ section.id }}">00</div>
                <div class="label">Sekunden</div>
            </div>
        </div>
    </div>

    <div class="cta">
        <button class="btn" id="shop-button-{{ section.id }}">
          {{ section.settings.countdown_button_label | default: 'JETZT KAUFEN' }}
        </button>
    </div>
</section>

<script>
/* Slider Code */
(function(){
    const sectionId = "{{ section.id }}";
    const slider = document.getElementById('slider-' + sectionId);
    const slides = [...slider.querySelectorAll('.slide')];
    const dotsWrap = document.getElementById('dots-' + sectionId);
    let i = 0, lock = false;
    let progressTimeout;
    
    // Create Dots (Accessibility Optimized: Buttons)
    slides.forEach((_, idx) => {
        const d = document.createElement('button');
        d.type = 'button';
        d.className = 'dot' + (idx === 0 ? ' active' : '');
        d.setAttribute('aria-label', `Gehe zu Slide ${idx + 1}`);
        if (idx === 0) d.setAttribute('aria-current', 'true');
        d.onclick = () => go(idx);
        dotsWrap.appendChild(d);
    });
    
    const dots = [...dotsWrap.querySelectorAll('.dot')];
    
    function setActive(n) {
        // Update slides classes
        slides.forEach((s, k) => {
            s.classList.remove('active', 'prev');
            
            // Fix Ghosting: Ensure z-index management handles visibility, 
            // but strict hiding logic can be added if needed. 
            // The previous Z-Index fix covering this is sufficient.
            
            if (k === n) {
                s.classList.add('active');
            } else if (k === (n - 1 + slides.length) % slides.length) {
                s.classList.add('prev');
            }
        });
        
        // Update Dots
        dots.forEach((d, k) => {
            d.classList.remove('active');
            d.removeAttribute('aria-current');
            
            if (k === n) {
                d.classList.add('active');
                d.setAttribute('aria-current', 'true');
            }
        });
        
        // Reset auto-play timeout
        clearTimeout(progressTimeout);
        progressTimeout = setTimeout(() => {
            go(i + 1);
        }, 7000);
    }
    
    function go(n) {
        if (lock || n === i) return;
        lock = true;
        i = (n + slides.length) % slides.length;
        setActive(i);
        setTimeout(() => lock = false, 600);
    }
    
    // Klick-Events für Pfeile hinzufügen
    document.getElementById('arrow-prev-' + sectionId).onclick = () => go(i - 1);
    document.getElementById('arrow-next-' + sectionId).onclick = () => go(i + 1);
    
    // Auto-advance on hover (Desktop only - MacBook/Desktop)
    let hoverInterval;
    
    slider.addEventListener('mouseenter', () => {
        clearTimeout(progressTimeout);
        
        // Only enable auto-advance on desktop (width > 1024px)
        if (window.innerWidth > 1024) {
            hoverInterval = setInterval(() => {
                go(i + 1);
            }, 3000); // Wechsel alle 3 Sekunden
        }
    });
    
    slider.addEventListener('mouseleave', () => {
        clearInterval(hoverInterval);
        progressTimeout = setTimeout(() => {
            go(i + 1);
        }, 7000);
    });
    
    // Swipe-Funktionalität für Mobilgeräte hinzufügen (Robust Implementation)
    let touchStartX = 0;
    let touchStartY = 0;
    let touchEndX = 0;
    let touchEndY = 0;
    
    slider.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
        clearTimeout(progressTimeout);
    }, {passive: true});
    
    slider.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        touchEndY = e.changedTouches[0].screenY;
        handleSwipe();
        
        progressTimeout = setTimeout(() => {
            go(i + 1);
        }, 7000);
    }, {passive: true});
    
    function handleSwipe() {
        const diffX = touchStartX - touchEndX;
        const diffY = touchStartY - touchEndY;
        const swipeThreshold = 50; // Minimum distance for swipe
        
        // Check if movement is primarily horizontal (X diff > Y diff)
        // AND distance is greater than threshold
        if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > swipeThreshold) {
            if (diffX > 0) {
                // Swiped Left -> Next Slide
                go(i + 1);
            } else {
                // Swiped Right -> Previous Slide
                go(i - 1);
            }
        }
    }
    
    // Slider starten
    setActive(i);
})();

/* Zusaetzliche Mobile-Optimierungen - Touch-Effekte */
document.addEventListener('DOMContentLoaded', function() {
    // Button-Touch-Feedback verbessern
    const buttons = document.querySelectorAll('.btn, .btn-slider, .btn-secondary, .nextend-arrow');
    
    buttons.forEach(button => {
        button.addEventListener('touchstart', function() {
            if (this.classList.contains('nextend-arrow')) {
                this.style.transform = 'translateY(-50%) scale(0.95)';
            } else {
                this.style.transform = 'scale(0.95)';
            }
        });
        
        button.addEventListener('touchend', function() {
            this.style.transform = '';
        });
    });
    
    // Dot-Klickbarkeit verbessern
    const dots = document.querySelectorAll('.dot');
    dots.forEach(dot => {
        dot.addEventListener('touchstart', function() {
            this.style.transform = 'scale(1.2)';
        });
        
        dot.addEventListener('touchend', function() {
            this.style.transform = '';
        });
    });
});
</script>

<script>
/* Adaptive Countdown Timer v2 — works with both old and new HTML */
(() => {
  const banners = document.querySelectorAll('[data-countdown]');
  if (!banners.length) return;

  const pad = (n) => String(n).padStart(2, '0');
  const getNowInTimeZone = (tz) => {
    try { return new Date(new Date().toLocaleString('en-US', { timeZone: tz })); }
    catch(e) { return new Date(); }
  };

  banners.forEach((banner) => {
    if (banner.dataset.enabled !== 'true') { banner.style.display = 'none'; return; }

    const sid = banner.dataset.sectionId;
    const mode = banner.dataset.mode || 'fixed_end_datetime';
    const endRaw = banner.dataset.end || '';
    const tz = banner.dataset.timezone || 'Europe/Berlin';
    const expBehavior = banner.dataset.expired || 'show';
    const expText = banner.dataset.expiredText || 'Aktion beendet';

    const timerEl = banner.querySelector('.timer');
    const headline = banner.querySelector('.headline');

    /* Find num elements by ID */
    const numEls = {
      d: document.getElementById('days-' + sid),
      h: document.getElementById('hours-' + sid),
      m: document.getElementById('minutes-' + sid),
      s: document.getElementById('seconds-' + sid),
    };

    /* Find hide-targets: data-unit wrapper OR parent .block + adjacent .sep */
    const getHideTarget = (numEl) => {
      if (!numEl) return null;
      const unit = numEl.closest('[data-unit]');
      if (unit) return { el: unit, type: 'unit' };
      const block = numEl.closest('.block');
      if (block) return { el: block, type: 'block', sep: block.nextElementSibling };
      return null;
    };

    const targets = {
      d: getHideTarget(numEls.d),
      h: getHideTarget(numEls.h),
      m: getHideTarget(numEls.m),
      s: getHideTarget(numEls.s),
    };

    let prevVis = '';

    const getTargetDate = () => {
      if (!endRaw) return null;
      if (mode === 'daily_reset') {
        const nowTz = getNowInTimeZone(tz);
        let tp = endRaw.includes('T') ? endRaw.split('T')[1] : endRaw;
        tp = tp.replace(/Z|[+-].*$/, '');
        const p = tp.split(':');
        const target = new Date(nowTz);
        target.setHours(parseInt(p[0]||'23',10), parseInt(p[1]||'59',10), parseInt(p[2]||'59',10), 0);
        if (target <= nowTz) target.setDate(target.getDate() + 1);
        return target;
      }
      const parsed = new Date(endRaw);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    };

    let targetDate = getTargetDate();

    const showHide = (key, val, show) => {
      if (numEls[key]) numEls[key].textContent = pad(val);
      const t = targets[key];
      if (!t) return;
      if (t.type === 'unit') {
        t.el.style.display = show ? '' : 'none';
      } else {
        t.el.style.display = show ? '' : 'none';
        if (t.sep && t.sep.classList.contains('sep')) t.sep.style.display = show ? '' : 'none';
      }
    };

    const handleExpired = () => {
      if (expBehavior === 'hide') { banner.style.display = 'none'; return; }
      if (headline) headline.textContent = expText;
      if (timerEl) timerEl.style.display = 'none';
    };

    const tick = () => {
      if (!targetDate) { handleExpired(); return; }
      if (mode === 'daily_reset') targetDate = getTargetDate();
      const now = getNowInTimeZone(tz);
      let diff = targetDate - now;
      if (diff <= 0) { handleExpired(); return; }

      const ts = Math.floor(diff / 1000);
      const d = Math.floor(ts / 86400);
      const h = Math.floor((ts % 86400) / 3600);
      const m = Math.floor((ts % 3600) / 60);
      const s = ts % 60;

      const sD = ts >= 86400, sH = ts >= 60, sM = ts >= 60, sS = ts < 86400;
      if (ts >= 86400)      { showHide('d',d,true);  showHide('h',h,true);  showHide('m',m,true);  showHide('s',s,false); }
      else if (ts >= 3600)  { showHide('d',d,false); showHide('h',h,true);  showHide('m',m,true);  showHide('s',s,true);  }
      else if (ts >= 60)    { showHide('d',d,false); showHide('h',h,false); showHide('m',m,true);  showHide('s',s,true);  }
      else                  { showHide('d',d,false); showHide('h',h,false); showHide('m',m,false); showHide('s',s,true);  }

      /* Also hide the separator BEFORE the first visible block (for old HTML) */
      if (timerEl) {
        const seps = timerEl.querySelectorAll('.sep');
        seps.forEach(sep => {
          const prev = sep.previousElementSibling;
          const next = sep.nextElementSibling;
          const prevHidden = prev && prev.style.display === 'none';
          const nextHidden = next && next.style.display === 'none';
          if (prevHidden || nextHidden) sep.style.display = 'none';
          else sep.style.display = '';
        });
      }

      const vis = ts >= 86400 ? 'normal' : ts >= 3600 ? 'no-days' : ts >= 60 ? 'urgent' : 'critical';
      if (vis !== prevVis) { banner.dataset.urgency = vis; prevVis = vis; }
    };

    let tmr = setInterval(tick, 1000);
    tick();

    document.addEventListener('visibilitychange', () => {
      clearInterval(tmr);
      if (!document.hidden) { tick(); tmr = setInterval(tick, 1000); }
    });

    const btn = document.getElementById('shop-button-' + sid);
    if (btn) {
      btn.addEventListener('click', () => {
        const sl = document.getElementById('slider-' + sid);
        const a = sl && sl.querySelector('.slide.active a');
        if (a && a.href) window.location.href = a.href;
      });
    }
  });
})();
</script>

