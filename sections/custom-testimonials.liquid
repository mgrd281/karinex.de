{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 40px;
  }

  @media screen and (min-width: 750px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }
  }

  .testimonial-card {
    background: #f9f9f9;
    border-radius: 12px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid #eee;
  }

  .testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .testimonial-stars {
    color: #FFB800;
    font-size: 18px;
    letter-spacing: 2px;
  }

  .testimonial-quote {
    font-size: 16px;
    line-height: 1.6;
    color: #333;
    font-style: italic;
    flex-grow: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 10px;
    border-top: 1px solid #eee;
    padding-top: 15px;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #1D4739;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 18px;
    overflow: hidden;
  }

  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-details h4 {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: #1D4739;
  }

  .verified-badge {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #27AE60;
    margin-top: 2px;
  }

  .verified-badge svg {
    width: 14px;
    height: 14px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2 class="title {{ section.settings.heading_size }}">
          {{ section.settings.title | escape }}
        </h2>
        {%- if section.settings.button_label != blank and section.settings.show_view_all -%}
          <a href="{{ section.settings.button_link }}" class="link underlined-link large-up-hide">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card">
          <div class="testimonial-stars">
            {%- for i in (1..block.settings.stars) -%}★{%- endfor -%}
          </div>
          <div class="testimonial-quote">
            "{{ block.settings.quote }}"
          </div>
          <div class="testimonial-author">
            <div class="author-avatar">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 100 }}" alt="{{ block.settings.author }}" width="50" height="50" loading="lazy" decoding="async">
              {%- else -%}
                {{ block.settings.author | slice: 0, 1 }}
              {%- endif -%}
            </div>
            <div class="author-details">
              <h4>{{ block.settings.author }}</h4>
              {%- if block.settings.verified -%}
                <span class="verified-badge">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  Verifizierter Käufer
                </span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Kundenstimmen (Manuell)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Das sagen unsere Kunden",
      "label": "Überschrift"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Klein" },
        { "value": "h1", "label": "Mittel" },
        { "value": "h0", "label": "Groß" }
      ],
      "default": "h1",
      "label": "Überschrift Größe"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Bewertung",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Sterne",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Bewertungstext",
          "default": "Schnelle Lieferung und top Service. Bin sehr zufrieden!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name des Kunden",
          "default": "Max Mustermann"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verifizierter Käufer Badge",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Kundenbild (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kundenstimmen (Manuell)",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
