<script>
  (function () {
    var section = document.querySelector('.lux-blog[data-section-id="{{ section.id }}"]');
    if (!section) return;
    var track = section.querySelector('[data-lux-blog-track]');
    var prev = section.querySelector('[data-lux-blog-prev]');
    var next = section.querySelector('[data-lux-blog-next]');
    if (!track || !prev || !next) return;

    function update() {
      var max = track.scrollWidth - track.clientWidth - 4;
      prev.hidden = track.scrollLeft <= 4;
      next.hidden = track.scrollLeft >= max;
    }
    function step(dir) {
      var card = track.querySelector('.lux-blog__card');
      var amount = card ? card.getBoundingClientRect().width + 20 : track.clientWidth * 0.8;
      track.scrollBy({ left: dir * amount, behavior: 'smooth' });
    }
    prev.addEventListener('click', function () { step(-1); });
    next.addEventListener('click', function () { step(1); });
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
    setTimeout(update, 80);

    /* Hide section heading once user scrolls past it (no sticky / no overlap). */
    var headerEl = section.querySelector('.lux-blog__header');
    if (headerEl) {
      var ticking = false;
      function checkHeader() {
        ticking = false;
        var rect = headerEl.getBoundingClientRect();
        if (rect.bottom < 80) {
          headerEl.classList.add('is-hidden');
        } else {
          headerEl.classList.remove('is-hidden');
        }
      }
      window.addEventListener('scroll', function () {
        if (!ticking) {
          window.requestAnimationFrame(checkHeader);
          ticking = true;
        }
      }, { passive: true });
      checkHeader();
    }

    /* Stagger fade-in cards as they enter the viewport */
    if ('IntersectionObserver' in window) {
      var cards = section.querySelectorAll('.lux-blog__grid > .lux-blog__card');
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
      cards.forEach(function (c) { io.observe(c); });
    } else {
      section.querySelectorAll('.lux-blog__grid > .lux-blog__card').forEach(function (c) {
        c.classList.add('is-revealed');
      });
    }

    /* Carousel scroll progress indicator */
    var progressBar = section.querySelector('[data-lux-blog-progress-bar]');
    if (progressBar && track) {
      function updateProgress() {
        var max = track.scrollWidth - track.clientWidth;
        if (max <= 0) {
          progressBar.style.width = '100%';
          progressBar.style.transform = 'translateX(0)';
          return;
        }
        var visibleRatio = track.clientWidth / track.scrollWidth;
        var w = Math.max(visibleRatio * 100, 12);
        progressBar.style.width = w + '%';
        var availablePct = 100 - w;
        var progressPct = (track.scrollLeft / max) * availablePct;
        progressBar.style.transform = 'translateX(' + (progressPct / w * 100) + '%)';
      }
      track.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress);
      setTimeout(updateProgress, 100);
    }
  })();
</script>

