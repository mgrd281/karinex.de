{%- liquid
  assign source_mode = section.settings.source_mode | default: 'automatic'

  assign source_blog = blogs[section.settings.blog]
  if source_blog == blank or source_blog.articles_count == 0
    assign source_blog = blogs.news
  endif
  if source_blog == blank or source_blog.articles_count == 0
    for b in blogs
      if b.articles_count > 0
        assign source_blog = b
        break
      endif
    endfor
  endif

  assign post_limit = section.settings.post_limit | default: 3
  assign articles = source_blog.articles | slice: 0, post_limit

  assign manual_count = 0
  if source_mode == 'manual'
    for block in section.blocks
      if block.settings.article != blank
        assign manual_count = manual_count | plus: 1
      endif
    endfor
    assign article_count = manual_count
  else
    assign article_count = articles.size
  endif

  assign layout_mode = section.settings.layout_mode | default: 'grid'
  assign card_style = section.settings.card_style | default: 'framed'
  assign cols = section.settings.posts_per_row | default: 3
  assign desktop_cols = cols | at_most: article_count
  if desktop_cols < 1
    assign desktop_cols = 1
  endif
  if article_count > cols
    assign layout_mode = 'carousel'
  endif
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow
  assign description = section.settings.description
  assign cta_label = section.settings.cta_label
  assign cta_link = section.settings.cta_link
  if cta_link == blank and source_blog
    assign cta_link = source_blog.url
  endif
-%}

<section
  class="lux-blog"
  data-section-id="{{ section.id }}"
  style="
    --lux-bg: {{ section.settings.bg_color }};
    --lux-card-bg: {{ section.settings.card_bg }};
    --lux-text: {{ section.settings.text_color }};
    --lux-muted: {{ section.settings.muted_color }};
    --lux-accent: {{ section.settings.accent_color }};
    --lux-border: {{ section.settings.border_color }};
  ">
  <div class="lux-blog__container">
    <header class="lux-blog__header">
      <div class="lux-blog__header-text">
        {%- if eyebrow != blank -%}
          <span class="lux-blog__eyebrow">{{ eyebrow }}</span>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="lux-blog__heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if description != blank -%}
          <p class="lux-blog__description">{{ description }}</p>
        {%- endif -%}
      </div>
      {%- if cta_label != blank and cta_link != blank -%}
        <a href="{{ cta_link }}" class="lux-blog__cta lux-blog__cta--header">
          <span>{{ cta_label }}</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="12" x2="20" y2="12"/>
            <polyline points="14 6 20 12 14 18"/>
          </svg>
        </a>
      {%- endif -%}
    </header>

    {%- if article_count > 0 -%}
      <div class="lux-blog__viewport lux-blog__viewport--{{ layout_mode }}">
        {%- if layout_mode == 'carousel' -%}
          <button type="button" class="lux-blog__nav lux-blog__nav--prev" aria-label="Vorherige Beiträge" data-lux-blog-prev hidden>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 6 9 12 15 18"/>
            </svg>
          </button>
          <button type="button" class="lux-blog__nav lux-blog__nav--next" aria-label="Nächste Beiträge" data-lux-blog-next hidden>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 6 15 12 9 18"/>
            </svg>
          </button>
        {%- endif -%}
      <div
        class="lux-blog__grid lux-blog__grid--{{ layout_mode }}"
        style="--lux-cols: {{ desktop_cols }};"
        data-lux-blog-track
      >
        {%- if source_mode == 'manual' -%}
          {%- for block in section.blocks -%}
            {%- assign block_article = block.settings.article -%}
            {%- if block_article != blank -%}
              {%- assign card_image = block.settings.image | default: block_article.image -%}
              {%- if card_image != blank -%}
                {% render 'lux-blog-card', article: block_article, card_image: card_image, card_style: card_style, card_index: forloop.index %}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for article in articles -%}
            {%- liquid
              assign idx = forloop.index
              assign override_image = nil
              case idx
                when 1
                  assign override_image = section.settings.image_1
                when 2
                  assign override_image = section.settings.image_2
                when 3
                  assign override_image = section.settings.image_3
                when 4
                  assign override_image = section.settings.image_4
              endcase
              assign card_image = override_image | default: article.image
            -%}
            {%- if card_image != blank -%}
              {% render 'lux-blog-card', article: article, card_image: card_image, card_style: card_style, card_index: forloop.index %}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      </div>
      {%- if layout_mode == 'carousel' -%}
        <div class="lux-blog__progress" data-lux-blog-progress aria-hidden="true">
          <span class="lux-blog__progress-bar" data-lux-blog-progress-bar></span>
        </div>
      {%- endif -%}

    {%- else -%}
      <p class="lux-blog__empty">Noch keine Artikel verfügbar.</p>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.lux-blog {
  background: var(--lux-bg, transparent);
  color: var(--lux-text, #111);
  padding: 80px 0 88px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}
.lux-blog__container {
  max-width: none;
  margin: 0;
  padding: 0 clamp(16px, 4vw, 56px);
}
.lux-blog__header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: end;
  column-gap: 48px;
  row-gap: 20px;
  text-align: left;
  max-width: none;
  margin: 0 0 56px;
  background: transparent !important;
  padding: 0;
  position: static !important;
  top: auto !important;
  z-index: auto !important;
  transition: opacity 280ms ease, transform 320ms ease, max-height 360ms ease, margin 360ms ease;
  overflow: hidden;
  will-change: opacity, transform;
}
.lux-blog__header.is-hidden {
  opacity: 0;
  transform: translateY(-12px);
  max-height: 0;
  margin-bottom: 0;
  pointer-events: none;
}
.lux-blog__header-text {
  max-width: 680px;
}
.lux-blog__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--lux-muted, #999);
  margin-bottom: 22px;
}
.lux-blog__eyebrow::before {
  content: "";
  display: inline-block;
  width: 36px;
  height: 1px;
  background: currentColor;
  opacity: 0.6;
}
.lux-blog__heading {
  font-family: Georgia, "Times New Roman", "Playfair Display", serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin: 0 0 18px;
  color: var(--lux-text, #111);
}
.lux-blog__description {
  font-size: 15px;
  line-height: 1.7;
  color: var(--lux-muted, #6b6b6b);
  margin: 0;
  font-weight: 300;
  max-width: 560px;
}
.lux-blog__viewport { position: relative; }
.lux-blog__grid {
  display: grid;
  gap: 24px;
  grid-template-columns: minmax(0, 1fr);
}
@media (min-width: 600px) {
  .lux-blog__grid--grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (min-width: 990px) {
  .lux-blog__grid--grid { grid-template-columns: repeat(var(--lux-cols, 3), minmax(0, 1fr)); }
}

/* ===== Carousel mode ===== */
.lux-blog__grid--carousel {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(82vw, 320px);
  gap: 20px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scroll-padding-inline: clamp(16px, 4vw, 56px);
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  margin-inline: calc(-1 * clamp(16px, 4vw, 56px));
  padding-inline: clamp(16px, 4vw, 56px);
}
.lux-blog__grid--carousel::-webkit-scrollbar { display: none; }
.lux-blog__grid--carousel > .lux-blog__card {
  scroll-snap-align: start;
  scroll-snap-stop: always;
}

/* Uniform card sizing across BOTH grid and carousel modes ----- */
.lux-blog__grid > .lux-blog__card,
.lux-blog__grid--carousel > .lux-blog__card {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}
.lux-blog__grid > .lux-blog__card .lux-blog__media,
.lux-blog__grid--carousel > .lux-blog__card .lux-blog__media {
  width: 100%;
  max-width: 100%;
}
.lux-blog__grid > .lux-blog__card .lux-blog__img,
.lux-blog__grid--carousel > .lux-blog__card .lux-blog__img {
  width: 100%;
  height: 100%;
  max-width: 100%;
  object-fit: cover;
  display: block;
}
/* Force overflow:hidden on styles that opt-in to overflow:visible */
.lux-blog__grid > .lux-blog__card--editorial,
.lux-blog__grid > .lux-blog__card--karinex-numbered,
.lux-blog__grid--carousel > .lux-blog__card--editorial,
.lux-blog__grid--carousel > .lux-blog__card--karinex-numbered {
  overflow: hidden;
}
@media (min-width: 600px) {
  .lux-blog__grid--carousel { grid-auto-columns: minmax(0, calc((100% - 40px) / 2)); }
}
@media (min-width: 990px) {
  .lux-blog__grid--carousel { grid-auto-columns: minmax(0, calc((100% - 20px * (var(--lux-cols, 3) - 1)) / var(--lux-cols, 3))); }
}

.lux-blog__nav {
  position: absolute;
  top: 50%;
  z-index: 2;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--lux-border, #ebe9e3);
  background: rgba(255, 255, 255, 0.96);
  color: var(--lux-text, #111);
  border-radius: 999px;
  cursor: pointer;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transform: translateY(-50%);
  transition: opacity 0.3s ease, background 0.2s ease, border-color 0.2s ease;
  box-shadow: 0 6px 24px -8px rgba(17, 17, 17, 0.18);
}
.lux-blog__nav:hover { background: var(--lux-text, #111); color: #fff; border-color: var(--lux-text, #111); }
.lux-blog__nav[hidden] { opacity: 0; pointer-events: none; visibility: hidden; }
.lux-blog__nav:not([hidden]) { display: flex; }
.lux-blog__nav--prev { left: 8px; }
.lux-blog__nav--next { right: 8px; }
@media (max-width: 768px) {
  .lux-blog__nav { display: none !important; }
}
/* Fade-in stagger reveal on scroll */
.lux-blog__grid > .lux-blog__card {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 720ms cubic-bezier(0.22, 0.61, 0.36, 1), transform 720ms cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__grid > .lux-blog__card.is-revealed {
  opacity: 1;
  transform: translateY(0);
}
.lux-blog__grid > .lux-blog__card.is-revealed:nth-child(2) { transition-delay: 80ms; }
.lux-blog__grid > .lux-blog__card.is-revealed:nth-child(3) { transition-delay: 160ms; }
.lux-blog__grid > .lux-blog__card.is-revealed:nth-child(4) { transition-delay: 240ms; }
.lux-blog__grid > .lux-blog__card.is-revealed:nth-child(5) { transition-delay: 320ms; }
.lux-blog__grid > .lux-blog__card.is-revealed:nth-child(6) { transition-delay: 400ms; }

/* Carousel scroll progress indicator */
.lux-blog__progress {
  position: relative;
  margin: 28px clamp(16px, 4vw, 56px) 0;
  height: 2px;
  background: rgba(201, 180, 134, 0.18);
  border-radius: 999px;
  overflow: hidden;
  display: none;
}
.lux-blog__viewport--carousel + .lux-blog__progress { display: block; }
.lux-blog__progress-bar {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 30%;
  background: linear-gradient(to right, #C9B486, #1D4739);
  border-radius: 999px;
  transform-origin: left center;
  transition: transform 220ms cubic-bezier(0.22, 0.61, 0.36, 1), width 320ms ease;
}

@media (prefers-reduced-motion: reduce) {
  .lux-blog__grid > .lux-blog__card,
  .lux-blog__grid > .lux-blog__card.is-revealed {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
}

.lux-blog__card {
  display: flex;
  flex-direction: column;
  background: var(--lux-card-bg, #ffffff);
  border: 1px solid var(--lux-border, #ebe9e3);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
  transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
}
.lux-blog__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px -16px rgba(17, 17, 17, 0.14);
  border-color: #cfcdc6;
}

/* ===== Style: editorial (frameless) ===== */
.lux-blog__card--editorial {
  background: transparent;
  border: 0;
  border-radius: 0;
  overflow: visible;
}
.lux-blog__card--editorial:hover {
  transform: translateY(-3px);
  box-shadow: none;
  border-color: transparent;
}
.lux-blog__card--editorial .lux-blog__media {
  aspect-ratio: 4 / 5;
  border-radius: 2px;
  margin-bottom: 20px;
}
.lux-blog__card--editorial .lux-blog__body { padding: 0; }
.lux-blog__card--editorial .lux-blog__category {
  background: transparent;
  color: #fff;
  padding: 0;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}
.lux-blog__card--editorial .lux-blog__title {
  font-size: 22px;
  -webkit-line-clamp: 3;
}
.lux-blog__card--editorial .lux-blog__readmore {
  border-bottom: 0;
  padding-bottom: 0;
}

/* ===== Style: overlay (text on image) ===== */
.lux-blog__card--overlay {
  background: #111;
  border: 0;
  border-radius: 4px;
  min-height: 460px;
  color: #fff;
}
.lux-blog__card--overlay:hover { box-shadow: 0 28px 56px -20px rgba(0, 0, 0, 0.4); }
.lux-blog__card--overlay .lux-blog__media-link {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.lux-blog__card--overlay .lux-blog__media {
  aspect-ratio: auto;
  height: 100%;
  width: 100%;
}
.lux-blog__card--overlay .lux-blog__media::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 25%, rgba(0,0,0,0.85) 100%);
  pointer-events: none;
}
.lux-blog__card--overlay .lux-blog__body {
  position: relative;
  z-index: 1;
  margin-top: auto;
  padding: 28px 26px 28px;
  color: #fff;
}
.lux-blog__card--overlay .lux-blog__category {
  position: relative;
  inset: auto;
  display: inline-block;
  background: transparent;
  color: rgba(255,255,255,0.85);
  padding: 0;
  margin-bottom: 8px;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}
.lux-blog__card--overlay .lux-blog__title { color: #fff; -webkit-line-clamp: 3; font-size: 22px; }
.lux-blog__card--overlay .lux-blog__title a { color: #fff; }
.lux-blog__card--overlay .lux-blog__title a:hover { color: rgba(255,255,255,0.85); }
.lux-blog__card--overlay .lux-blog__meta { color: rgba(255,255,255,0.75); }
.lux-blog__card--overlay .lux-blog__excerpt { color: rgba(255,255,255,0.85); -webkit-line-clamp: 2; }
.lux-blog__card--overlay .lux-blog__readmore {
  color: #fff;
  border-color: #fff;
}
.lux-blog__card--overlay .lux-blog__readmore:hover { color: #fff; border-color: #fff; opacity: 0.8; }

/* ===== Style: minimal (image + title + date only) ===== */
.lux-blog__card--minimal {
  background: transparent;
  border: 0;
  border-radius: 0;
  overflow: visible;
}
.lux-blog__card--minimal:hover { transform: translateY(-2px); box-shadow: none; border-color: transparent; }
.lux-blog__card--minimal .lux-blog__media {
  aspect-ratio: 1 / 1;
  border-radius: 0;
  margin-bottom: 16px;
}
.lux-blog__card--minimal .lux-blog__body { padding: 0; gap: 6px; }
.lux-blog__card--minimal .lux-blog__category,
.lux-blog__card--minimal .lux-blog__excerpt,
.lux-blog__card--minimal .lux-blog__readmore { display: none; }
.lux-blog__card--minimal .lux-blog__title { font-size: 17px; -webkit-line-clamp: 2; }

/* ============================================================
   KARINEX BRAND STYLES — Cormorant Garamond + brand palette
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&display=swap');

/* Shared KARINEX card base */
.lux-blog__card--karinex-cream,
.lux-blog__card--karinex-forest,
.lux-blog__card--karinex-numbered {
  border-radius: 0;
  overflow: visible;
  font-family: "Helvetica Neue", Arial, sans-serif;
}
.lux-blog__card--karinex-cream .lux-blog__title,
.lux-blog__card--karinex-forest .lux-blog__title,
.lux-blog__card--karinex-numbered .lux-blog__title {
  font-family: "Cormorant Garamond", Georgia, "Times New Roman", serif;
  font-weight: 400;
  letter-spacing: 0;
}

/* ===== Style: karinex-cream (cream linen background + gold) ===== */
.lux-blog__card--karinex-cream {
  background: #F5F2EC;
  border: 0;
  padding: 0;
}
.lux-blog__card--karinex-cream:hover {
  transform: translateY(-3px);
  box-shadow: 0 30px 60px -28px rgba(29, 71, 57, 0.18);
  border-color: transparent;
}
.lux-blog__card--karinex-cream .lux-blog__media {
  aspect-ratio: 4 / 5;
  margin: 0;
  border-radius: 0;
}
.lux-blog__card--karinex-cream .lux-blog__body {
  padding: 28px 28px 32px;
  gap: 14px;
}
.lux-blog__card--karinex-cream .lux-blog__category {
  position: relative;
  inset: auto;
  display: inline-block;
  background: transparent;
  color: #C9B486;
  padding: 0;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  font-weight: 500;
  text-transform: uppercase;
  margin-bottom: 4px;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}
.lux-blog__card--karinex-cream .lux-blog__category::after {
  content: "";
  display: inline-block;
  width: 24px;
  height: 1px;
  background: #C9B486;
  margin-left: 12px;
  vertical-align: middle;
}
.lux-blog__card--karinex-cream .lux-blog__title {
  font-size: 26px;
  line-height: 1.18;
  color: #0A0A0A;
  -webkit-line-clamp: 3;
}
.lux-blog__card--karinex-cream .lux-blog__title a { color: #0A0A0A; }
.lux-blog__card--karinex-cream .lux-blog__title a:hover { color: #1D4739; }
.lux-blog__card--karinex-cream .lux-blog__meta {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  color: #6A6A6A;
}
.lux-blog__card--karinex-cream .lux-blog__excerpt {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-style: italic;
  font-size: 16px;
  line-height: 1.5;
  color: #3A3A3A;
  -webkit-line-clamp: 2;
}
.lux-blog__card--karinex-cream .lux-blog__readmore {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  font-weight: 500;
  color: #1D4739;
  border-bottom: 1px solid #C9B486;
  padding-bottom: 4px;
  margin-top: 8px;
}
.lux-blog__card--karinex-cream .lux-blog__readmore:hover {
  color: #1D4739;
  border-color: #1D4739;
  gap: 14px;
}

/* ===== Style: karinex-forest (forest green bg + gold + cream) ===== */
.lux-blog__card--karinex-forest {
  background: #1D4739;
  border: 0;
  color: #D4CDB8;
  padding: 0;
}
.lux-blog__card--karinex-forest:hover {
  transform: translateY(-3px);
  box-shadow: 0 36px 72px -28px rgba(10, 10, 10, 0.55);
  border-color: transparent;
}
.lux-blog__card--karinex-forest .lux-blog__media {
  aspect-ratio: 3 / 2;
  margin: 0;
  border-radius: 0;
}
.lux-blog__card--karinex-forest .lux-blog__body {
  padding: 30px 30px 34px;
  gap: 14px;
}
.lux-blog__card--karinex-forest .lux-blog__category {
  position: relative;
  inset: auto;
  display: inline-block;
  background: transparent;
  color: #C9B486;
  padding: 0;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  font-weight: 500;
  text-transform: uppercase;
  margin-bottom: 6px;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}
.lux-blog__card--karinex-forest .lux-blog__title {
  font-size: 28px;
  line-height: 1.15;
  color: #F5F2EC;
  -webkit-line-clamp: 3;
}
.lux-blog__card--karinex-forest .lux-blog__title a { color: #F5F2EC; }
.lux-blog__card--karinex-forest .lux-blog__title a:hover { color: #C9B486; }
.lux-blog__card--karinex-forest .lux-blog__meta {
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 2px;
  color: #8FA39A;
}
.lux-blog__card--karinex-forest .lux-blog__dot { color: #8FA39A; }
