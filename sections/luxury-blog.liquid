.lux-blog__card--karinex-numbered .lux-blog__excerpt {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-style: italic;
  font-size: 16px;
  line-height: 1.5;
  color: #3A3A3A;
  -webkit-line-clamp: 3;
}
.lux-blog__card--karinex-numbered .lux-blog__readmore {
