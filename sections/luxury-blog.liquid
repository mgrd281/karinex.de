{%- liquid
  assign source_mode = section.settings.source_mode | default: 'automatic'

  assign source_blog = blogs[section.settings.blog]
  if source_blog == blank or source_blog.articles_count == 0
    assign source_blog = blogs.news
  endif
  if source_blog == blank or source_blog.articles_count == 0
    for b in blogs
      if b.articles_count > 0
        assign source_blog = b
        break
      endif
    endfor
  endif

  assign post_limit = section.settings.post_limit | default: 3
  assign articles = source_blog.articles | slice: 0, post_limit

  assign manual_count = 0
  if source_mode == 'manual'
    for block in section.blocks
      if block.settings.article != blank
        assign manual_count = manual_count | plus: 1
      endif
    endfor
    assign article_count = manual_count
  else
    assign article_count = articles.size
  endif

  assign layout_mode = section.settings.layout_mode | default: 'grid'
  assign cols = section.settings.posts_per_row | default: 3
  assign desktop_cols = cols | at_most: article_count
  if desktop_cols < 1
    assign desktop_cols = 1
  endif
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow
  assign description = section.settings.description
  assign cta_label = section.settings.cta_label
  assign cta_link = section.settings.cta_link
  if cta_link == blank and source_blog
    assign cta_link = source_blog.url
  endif
-%}

<section
  class="lux-blog"
  data-section-id="{{ section.id }}"
  style="
    --lux-bg: {{ section.settings.bg_color }};
    --lux-card-bg: {{ section.settings.card_bg }};
    --lux-text: {{ section.settings.text_color }};
    --lux-muted: {{ section.settings.muted_color }};
    --lux-accent: {{ section.settings.accent_color }};
    --lux-border: {{ section.settings.border_color }};
  ">
  <div class="lux-blog__container">
    <header class="lux-blog__header">
      <div class="lux-blog__header-text">
        {%- if eyebrow != blank -%}
          <span class="lux-blog__eyebrow">{{ eyebrow }}</span>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="lux-blog__heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if description != blank -%}
          <p class="lux-blog__description">{{ description }}</p>
        {%- endif -%}
      </div>
      {%- if cta_label != blank and cta_link != blank -%}
        <a href="{{ cta_link }}" class="lux-blog__cta lux-blog__cta--header">
          <span>{{ cta_label }}</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="12" x2="20" y2="12"/>
            <polyline points="14 6 20 12 14 18"/>
          </svg>
        </a>
      {%- endif -%}
    </header>

    {%- if article_count > 0 -%}
      <div class="lux-blog__viewport lux-blog__viewport--{{ layout_mode }}">
        {%- if layout_mode == 'carousel' -%}
          <button type="button" class="lux-blog__nav lux-blog__nav--prev" aria-label="Vorherige Beiträge" data-lux-blog-prev hidden>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 6 9 12 15 18"/>
            </svg>
          </button>
          <button type="button" class="lux-blog__nav lux-blog__nav--next" aria-label="Nächste Beiträge" data-lux-blog-next hidden>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 6 15 12 9 18"/>
            </svg>
          </button>
        {%- endif -%}
      <div
        class="lux-blog__grid lux-blog__grid--{{ layout_mode }}"
        style="--lux-cols: {{ desktop_cols }};"
        data-lux-blog-track
      >
        {%- if source_mode == 'manual' -%}
          {%- for block in section.blocks -%}
            {%- assign block_article = block.settings.article -%}
            {%- if block_article != blank -%}
              {%- assign card_image = block.settings.image | default: block_article.image -%}
              {% render 'lux-blog-card', article: block_article, card_image: card_image %}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for article in articles -%}
            {%- liquid
              assign idx = forloop.index
              assign override_image = nil
              case idx
                when 1
                  assign override_image = section.settings.image_1
                when 2
                  assign override_image = section.settings.image_2
                when 3
                  assign override_image = section.settings.image_3
                when 4
                  assign override_image = section.settings.image_4
              endcase
              assign card_image = override_image | default: article.image
            -%}
            {% render 'lux-blog-card', article: article, card_image: card_image %}
          {%- endfor -%}
        {%- endif -%}
      </div>
      </div>

    {%- else -%}
      <p class="lux-blog__empty">Noch keine Artikel verfügbar.</p>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.lux-blog {
  background: var(--lux-bg, transparent);
  color: var(--lux-text, #111);
  padding: 80px 0 88px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}
.lux-blog__container {
  max-width: none;
  margin: 0;
  padding: 0 clamp(16px, 4vw, 56px);
}
.lux-blog__header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: end;
  column-gap: 48px;
  row-gap: 20px;
  text-align: left;
  max-width: none;
  margin: 0 0 56px;
  background: transparent !important;
  padding: 0;
}
.lux-blog__header-text {
  max-width: 680px;
}
.lux-blog__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--lux-muted, #999);
  margin-bottom: 22px;
}
.lux-blog__eyebrow::before {
  content: "";
  display: inline-block;
  width: 36px;
  height: 1px;
  background: currentColor;
  opacity: 0.6;
}
.lux-blog__heading {
  font-family: Georgia, "Times New Roman", "Playfair Display", serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin: 0 0 18px;
  color: var(--lux-text, #111);
}
.lux-blog__description {
  font-size: 15px;
  line-height: 1.7;
  color: var(--lux-muted, #6b6b6b);
  margin: 0;
  font-weight: 300;
  max-width: 560px;
}
.lux-blog__viewport { position: relative; }
.lux-blog__grid {
  display: grid;
  gap: 24px;
  grid-template-columns: 1fr;
}
@media (min-width: 600px) {
  .lux-blog__grid--grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 990px) {
  .lux-blog__grid--grid { grid-template-columns: repeat(var(--lux-cols, 3), 1fr); }
}

/* ===== Carousel mode ===== */
.lux-blog__grid--carousel {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(82vw, 320px);
  gap: 20px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scroll-padding-inline: clamp(16px, 4vw, 56px);
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  margin-inline: calc(-1 * clamp(16px, 4vw, 56px));
  padding-inline: clamp(16px, 4vw, 56px);
}
.lux-blog__grid--carousel::-webkit-scrollbar { display: none; }
.lux-blog__grid--carousel > .lux-blog__card {
  scroll-snap-align: start;
  scroll-snap-stop: always;
}
@media (min-width: 600px) {
  .lux-blog__grid--carousel { grid-auto-columns: minmax(0, calc((100% - 40px) / 2)); }
}
@media (min-width: 990px) {
  .lux-blog__grid--carousel { grid-auto-columns: minmax(0, calc((100% - 20px * (var(--lux-cols, 3) - 1)) / var(--lux-cols, 3))); }
}

.lux-blog__nav {
  position: absolute;
  top: 50%;
  z-index: 2;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--lux-border, #ebe9e3);
  background: rgba(255, 255, 255, 0.96);
  color: var(--lux-text, #111);
  border-radius: 999px;
  cursor: pointer;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transform: translateY(-50%);
  transition: opacity 0.3s ease, background 0.2s ease, border-color 0.2s ease;
  box-shadow: 0 6px 24px -8px rgba(17, 17, 17, 0.18);
}
.lux-blog__nav:hover { background: var(--lux-text, #111); color: #fff; border-color: var(--lux-text, #111); }
.lux-blog__nav[hidden] { opacity: 0; pointer-events: none; visibility: hidden; }
.lux-blog__nav:not([hidden]) { display: flex; }
.lux-blog__nav--prev { left: 8px; }
.lux-blog__nav--next { right: 8px; }
@media (max-width: 768px) {
  .lux-blog__nav { display: none !important; }
}
.lux-blog__card {
  display: flex;
  flex-direction: column;
  background: transparent;
  border: 0;
  border-radius: 0;
  overflow: visible;
  transition: transform 0.5s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__card:hover { transform: translateY(-3px); }
.lux-blog__media-link {
  display: block;
  text-decoration: none;
}
.lux-blog__media {
  position: relative;
  overflow: hidden;
  background: #ebe9e3;
  aspect-ratio: 4 / 5;
  border-radius: 2px;
  margin-bottom: 22px;
}
.lux-blog__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ebe9e3 0%, #d4d2cc 100%);
  color: #fff;
}
.lux-blog__card:hover .lux-blog__img {
  transform: scale(1.06);
}
.lux-blog__category {
  position: absolute;
  top: 16px;
  left: 16px;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #fff;
  background: transparent;
  padding: 0;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
}
.lux-blog__body {
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}
.lux-blog__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 10px;
  letter-spacing: 0.8px;
  color: var(--lux-muted, #999);
  text-transform: uppercase;
}
.lux-blog__dot { color: var(--lux-border, #d4d2cc); }
.lux-blog__title {
  font-family: Georgia, "Times New Roman", "Playfair Display", serif;
  font-size: 22px;
  font-weight: 400;
  line-height: 1.25;
  letter-spacing: -0.01em;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.lux-blog__title a {
  color: var(--lux-text, #111);
  text-decoration: none;
  transition: color 0.2s ease;
}
.lux-blog__title a:hover,
.lux-blog__title a:focus-visible {
  color: var(--lux-accent, #8a6f3f);
}
.lux-blog__excerpt {
  font-size: 13px;
  line-height: 1.6;
  color: var(--lux-muted, #777);
  margin: 0;
  font-weight: 300;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.lux-blog__readmore {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--lux-text, #111);
  text-decoration: none;
  padding-bottom: 0;
  align-self: flex-start;
  border-bottom: 0;
  transition: gap 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__readmore svg { transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1); }
.lux-blog__readmore:hover { gap: 14px; }
.lux-blog__readmore:hover svg { transform: translateX(4px); }
.lux-blog__cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 0 0 8px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--lux-text, #111);
  background: transparent;
  border: 0;
  border-bottom: 1px solid var(--lux-text, #111);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  position: relative;
  transition: gap 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__cta svg {
  transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__cta:hover { gap: 18px; }
.lux-blog__cta:hover svg { transform: translateX(6px); }
.lux-blog__cta--header { margin-bottom: 14px; }
.lux-blog__cta:hover {
  background: var(--lux-text, #111);
  color: var(--lux-bg, #faf9f6);
  gap: 18px;
}
.lux-blog__cta svg { transition: transform 0.3s ease; }
.lux-blog__cta:hover svg { transform: translateX(4px); }
.lux-blog__empty {
  text-align: center;
  color: var(--lux-muted, #888);
  font-style: italic;
}
@media (max-width: 768px) {
  .lux-blog { padding: 56px 0 64px; }
  .lux-blog__container { padding: 0 16px; }
  .lux-blog__header {
    grid-template-columns: 1fr;
    align-items: flex-start;
    column-gap: 0;
    row-gap: 24px;
    margin-bottom: 36px;
  }
  .lux-blog__cta--header { margin-bottom: 0; }
  .lux-blog__heading { font-size: clamp(28px, 7vw, 38px); }
  .lux-blog__body { padding: 18px 18px 20px; }
  .lux-blog__title { font-size: 18px; }
  .lux-blog__grid { gap: 20px; }
  .lux-blog__eyebrow { margin-bottom: 16px; }
}
{%- endstylesheet -%}

<script>
  (function () {
    var section = document.querySelector('.lux-blog[data-section-id="{{ section.id }}"]');
    if (!section) return;
    var track = section.querySelector('[data-lux-blog-track]');
    var prev = section.querySelector('[data-lux-blog-prev]');
    var next = section.querySelector('[data-lux-blog-next]');
    if (!track || !prev || !next) return;

    function update() {
      var max = track.scrollWidth - track.clientWidth - 4;
      prev.hidden = track.scrollLeft <= 4;
      next.hidden = track.scrollLeft >= max;
    }
    function step(dir) {
      var card = track.querySelector('.lux-blog__card');
      var amount = card ? card.getBoundingClientRect().width + 20 : track.clientWidth * 0.8;
      track.scrollBy({ left: dir * amount, behavior: 'smooth' });
    }
    prev.addEventListener('click', function () { step(-1); });
    next.addEventListener('click', function () { step(1); });
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
    setTimeout(update, 80);
  })();
</script>

{% schema %}
{
  "name": "Luxury Blog",
  "tag": "section",
  "class": "section-luxury-blog",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (kleine Überschrift)",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hauptüberschrift",
      "default": "Aktuelles aus dem Magazin"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Beschreibung",
      "default": "Geschichten, Guides und Insider-Wissen rund um Software, Lifestyle und Mode."
    },
    {
      "type": "header",
      "content": "Quelle"
    },
    {
      "type": "select",
      "id": "source_mode",
      "label": "Auswahlmodus",
      "options": [
        { "value": "automatic", "label": "Automatisch (neueste Artikel)" },
        { "value": "manual", "label": "Manuelle Auswahl (Beiträge)" }
      ],
      "default": "automatic",
      "info": "Manuell: Füge unten Blöcke hinzu und wähle für jede Karte einen Beitrag."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog (für automatischen Modus)",
      "info": "Wenn leer gelassen, werden automatisch Artikel aus dem 'News'-Blog geladen."
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Anzahl der Artikel (automatisch)",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Anzeigeart",
      "options": [
        { "value": "grid", "label": "Raster (mehrere Reihen)" },
        { "value": "carousel", "label": "Karussell (eine Reihe, scrollbar)" }
      ],
      "default": "grid",
      "info": "Karussell: Eine Reihe mit Pfeil-Navigation und Wischen auf Mobil."
    },
    {
      "type": "range",
      "id": "posts_per_row",
      "label": "Karten pro Reihe (Desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Bilder pro Karte (Override)",
      "info": "Optional: Eigene Bilder für die einzelnen Karten hochladen. Wenn leer, wird das Artikelbild verwendet."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Bild Karte 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Bild Karte 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Bild Karte 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bild Karte 4"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button-Text",
      "default": "Alle Beiträge ansehen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button-Link",
      "info": "Wenn leer, wird auf den ausgewählten Blog verlinkt."
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Sektion-Hintergrund",
      "default": "#faf9f6"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Karten-Hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Sekundärtext",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzent (Hover)",
      "default": "#8a6f3f"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Rahmen",
      "default": "#ebe9e3"
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Beitrag",
      "limit": 12,
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Beitrag auswählen"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild (optional, überschreibt Artikelbild)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxury Blog",
      "category": "Blog"
    }
  ]
}
{% endschema %}
