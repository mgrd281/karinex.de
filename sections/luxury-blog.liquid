{%- liquid
  assign source_blog = blogs[section.settings.blog]
  assign post_limit = section.settings.post_limit | default: 3
  assign articles = source_blog.articles | slice: 0, post_limit
  assign article_count = articles.size
  assign heading = section.settings.heading
  assign eyebrow = section.settings.eyebrow
  assign description = section.settings.description
  assign cta_label = section.settings.cta_label
  assign cta_link = section.settings.cta_link
-%}

<section
  class="lux-blog"
  data-section-id="{{ section.id }}"
  style="
    --lux-bg: {{ section.settings.bg_color }};
    --lux-text: {{ section.settings.text_color }};
    --lux-muted: {{ section.settings.muted_color }};
    --lux-accent: {{ section.settings.accent_color }};
    --lux-border: {{ section.settings.border_color }};
  ">
  <div class="lux-blog__container">
    <header class="lux-blog__header">
      {%- if eyebrow != blank -%}
        <span class="lux-blog__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="lux-blog__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if description != blank -%}
        <p class="lux-blog__description">{{ description }}</p>
      {%- endif -%}
    </header>

    {%- if article_count > 0 -%}
      <div class="lux-blog__grid lux-blog__grid--{{ article_count }}">
        {%- for article in articles -%}
          {%- assign is_feature = false -%}
          {%- if forloop.first and article_count >= 3 -%}
            {%- assign is_feature = true -%}
          {%- endif -%}

          <article class="lux-blog__card{% if is_feature %} lux-blog__card--feature{% endif %}">
            <a href="{{ article.url }}" class="lux-blog__media" aria-hidden="true" tabindex="-1">
              {%- if article.image -%}
                <img
                  src="{{ article.image | image_url: width: 1200 }}"
                  srcset="
                    {{ article.image | image_url: width: 600 }} 600w,
                    {{ article.image | image_url: width: 900 }} 900w,
                    {{ article.image | image_url: width: 1200 }} 1200w,
                    {{ article.image | image_url: width: 1600 }} 1600w
                  "
                  sizes="(min-width: 990px) {% if is_feature %}50vw{% else %}25vw{% endif %}, 100vw"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                  class="lux-blog__img">
              {%- else -%}
                <div class="lux-blog__img-placeholder"></div>
              {%- endif -%}
            </a>

            <div class="lux-blog__body">
              {%- assign cat_tag = article.tags | first -%}
              {%- if cat_tag != blank -%}
                <span class="lux-blog__category">{{ cat_tag }}</span>
              {%- endif -%}

              <h3 class="lux-blog__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {%- if is_feature and article.excerpt_or_content != blank -%}
                <p class="lux-blog__excerpt">
                  {{ article.excerpt_or_content | strip_html | truncatewords: 28 }}
                </p>
              {%- endif -%}

              <div class="lux-blog__meta">
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: format: 'abbreviated_date' }}
                </time>
                {%- if article.content != blank -%}
                  {%- assign words = article.content | strip_html | split: ' ' | size -%}
                  {%- assign minutes = words | divided_by: 220.0 | ceil -%}
                  {%- if minutes < 1 -%}{%- assign minutes = 1 -%}{%- endif -%}
                  <span class="lux-blog__dot" aria-hidden="true">·</span>
                  <span>{{ minutes }} Min. Lesezeit</span>
                {%- endif -%}
              </div>

              <a href="{{ article.url }}" class="lux-blog__readmore" aria-label="{{ article.title | escape }}">
                <span>Weiterlesen</span>
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="4" y1="12" x2="20" y2="12"/>
                  <polyline points="14 6 20 12 14 18"/>
                </svg>
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if cta_label != blank and cta_link != blank -%}
        <div class="lux-blog__footer">
          <a href="{{ cta_link }}" class="lux-blog__cta">
            <span>{{ cta_label }}</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="4" y1="12" x2="20" y2="12"/>
              <polyline points="14 6 20 12 14 18"/>
            </svg>
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <p class="lux-blog__empty">Noch keine Artikel verfügbar.</p>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
.lux-blog {
  background: var(--lux-bg, #faf9f6);
  color: var(--lux-text, #111);
  padding: 96px 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}
.lux-blog__container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 32px;
}
.lux-blog__header {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 64px;
}
.lux-blog__eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--lux-muted, #888);
  margin-bottom: 20px;
  position: relative;
  padding: 0 24px;
}
.lux-blog__eyebrow::before,
.lux-blog__eyebrow::after {
  content: "";
  position: absolute;
  top: 50%;
  width: 16px;
  height: 1px;
  background: var(--lux-border, #d4d2cc);
}
.lux-blog__eyebrow::before { right: 100%; }
.lux-blog__eyebrow::after { left: 100%; }
.lux-blog__heading {
  font-family: Georgia, "Times New Roman", "Playfair Display", serif;
  font-size: clamp(32px, 4.5vw, 56px);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.01em;
  margin: 0 0 20px;
  color: var(--lux-text, #111);
}
.lux-blog__description {
  font-size: 16px;
  line-height: 1.65;
  color: var(--lux-muted, #666);
  margin: 0;
  font-weight: 300;
}
.lux-blog__grid {
  display: grid;
  gap: 32px;
}
.lux-blog__grid--3 {
  grid-template-columns: 1fr;
}
@media (min-width: 990px) {
  .lux-blog__grid--3 {
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 40px;
  }
  .lux-blog__grid--3 .lux-blog__card--feature {
    grid-row: 1 / span 2;
  }
}
.lux-blog__grid--2 { grid-template-columns: 1fr; }
@media (min-width: 768px) {
  .lux-blog__grid--2 { grid-template-columns: 1fr 1fr; gap: 40px; }
}
.lux-blog__grid--1 { grid-template-columns: 1fr; max-width: 880px; margin: 0 auto; }
.lux-blog__card {
  display: flex;
  flex-direction: column;
  background: transparent;
}
.lux-blog__media {
  display: block;
  position: relative;
  overflow: hidden;
  background: #ebe9e3;
  aspect-ratio: 4 / 3;
  margin-bottom: 24px;
}
.lux-blog__card--feature .lux-blog__media {
  aspect-ratio: 4 / 5;
}
@media (min-width: 990px) {
  .lux-blog__card--feature {
    display: grid;
    grid-template-rows: 1fr auto;
  }
  .lux-blog__card--feature .lux-blog__media {
    aspect-ratio: auto;
    height: 100%;
    margin-bottom: 24px;
  }
}
.lux-blog__img,
.lux-blog__img-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.lux-blog__img-placeholder {
  background: linear-gradient(135deg, #ebe9e3 0%, #d4d2cc 100%);
}
.lux-blog__media:hover .lux-blog__img,
.lux-blog__media:focus-visible .lux-blog__img {
  transform: scale(1.04);
}
.lux-blog__body {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
}
.lux-blog__category {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--lux-accent, #8a6f3f);
  padding: 4px 0;
}
.lux-blog__title {
  font-family: Georgia, "Times New Roman", "Playfair Display", serif;
  font-size: 22px;
  font-weight: 400;
  line-height: 1.3;
  letter-spacing: -0.005em;
  margin: 0;
}
.lux-blog__card--feature .lux-blog__title {
  font-size: clamp(26px, 2.6vw, 34px);
  line-height: 1.2;
}
.lux-blog__title a {
  color: var(--lux-text, #111);
  text-decoration: none;
  background-image: linear-gradient(currentColor, currentColor);
  background-size: 0 1px;
  background-position: 0 100%;
  background-repeat: no-repeat;
  transition: background-size 0.4s ease;
}
.lux-blog__title a:hover,
.lux-blog__title a:focus-visible {
  background-size: 100% 1px;
}
.lux-blog__excerpt {
  font-size: 15px;
  line-height: 1.7;
  color: var(--lux-muted, #555);
  margin: 4px 0 0;
  font-weight: 300;
}
.lux-blog__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  letter-spacing: 0.5px;
  color: var(--lux-muted, #888);
  margin-top: 4px;
}
.lux-blog__dot { color: var(--lux-border, #d4d2cc); }
.lux-blog__readmore {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--lux-text, #111);
  text-decoration: none;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--lux-text, #111);
  transition: gap 0.3s ease, opacity 0.2s ease;
}
.lux-blog__readmore svg { transition: transform 0.3s ease; }
.lux-blog__readmore:hover { gap: 14px; }
.lux-blog__readmore:hover svg { transform: translateX(4px); }
.lux-blog__footer {
  margin-top: 64px;
  text-align: center;
  padding-top: 48px;
  border-top: 1px solid var(--lux-border, #e5e3dc);
}
.lux-blog__cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 16px 36px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--lux-text, #111);
  background: transparent;
  border: 1px solid var(--lux-text, #111);
  text-decoration: none;
  transition: all 0.3s ease;
}
.lux-blog__cta:hover {
  background: var(--lux-text, #111);
  color: var(--lux-bg, #faf9f6);
  gap: 18px;
}
.lux-blog__cta svg { transition: transform 0.3s ease; }
.lux-blog__cta:hover svg { transform: translateX(4px); }
.lux-blog__empty {
  text-align: center;
  color: var(--lux-muted, #888);
  font-style: italic;
}
@media (max-width: 768px) {
  .lux-blog { padding: 64px 0; }
  .lux-blog__container { padding: 0 20px; }
  .lux-blog__header { margin-bottom: 40px; }
  .lux-blog__media { margin-bottom: 16px; }
  .lux-blog__card--feature .lux-blog__title { font-size: 24px; }
  .lux-blog__title { font-size: 20px; }
}
{%- endstylesheet -%}

{% schema %}
{
  "name": "Luxury Blog",
  "tag": "section",
  "class": "section-luxury-blog",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (kleine Überschrift)",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hauptüberschrift",
      "default": "Aktuelles aus dem Magazin"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Beschreibung",
      "default": "Geschichten, Guides und Insider-Wissen rund um Software, Lifestyle und Mode."
    },
    {
      "type": "header",
      "content": "Quelle"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog auswählen"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Anzahl der Artikel",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "info": "3 Artikel = 1 großer + 2 kleine (Editorial-Layout)"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button-Text",
      "default": "Alle Beiträge ansehen"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button-Link"
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrund",
      "default": "#faf9f6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Sekundärtext",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzent (Kategorie)",
      "default": "#8a6f3f"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Trennlinien",
      "default": "#e5e3dc"
    }
  ],
  "presets": [
    {
      "name": "Luxury Blog",
      "category": "Blog"
    }
  ]
}
{% endschema %}
