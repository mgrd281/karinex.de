  color: var(--lux-muted, #888);
  font-style: italic;
}
@media (max-width: 768px) {
  .lux-blog { padding: 56px 0 64px; }
  .lux-blog__container { padding: 0 16px; }
  .lux-blog__header {
    grid-template-columns: 1fr;
    align-items: flex-start;
    column-gap: 0;
    row-gap: 16px;
    margin-bottom: 24px;
    padding: 0;
  }
  .lux-blog__cta--header { margin-bottom: 0; }
  .lux-blog__heading { font-size: clamp(28px, 7vw, 38px); }
  .lux-blog__body { padding: 18px 18px 20px; }
  .lux-blog__title { font-size: 18px; }
  .lux-blog__grid { gap: 20px; }
  .lux-blog__eyebrow { margin-bottom: 16px; }
}
