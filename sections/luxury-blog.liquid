  font-size: 26px;
  line-height: 1.18;
  color: #0A0A0A;
  -webkit-line-clamp: 3;
}
.lux-blog__card--karinex-numbered .lux-blog__title a { color: #0A0A0A; }
.lux-blog__card--karinex-numbered .lux-blog__title a:hover { color: #1D4739; }
.lux-blog__card--karinex-numbered .lux-blog__meta {
