}
.lux-blog__card--karinex-numbered:hover .lux-blog__media::after { opacity: 1; }
.lux-blog__card--karinex-numbered .lux-blog__body { padding: 0; gap: 12px; }
.lux-blog__card--karinex-numbered .lux-blog__category {
  position: relative;
  inset: auto;
  display: inline-block;
  background: transparent;
  color: #1D4739;
  padding: 0;
  font-family: "Helvetica Neue", Arial, sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  font-weight: 500;
  text-transform: uppercase;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
