.lux-blog__readmore:hover svg { transform: translateX(4px); }
.lux-blog__cta {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 0 0 8px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--lux-text, #111);
  background: transparent;
  border: 0;
  border-bottom: 1px solid var(--lux-text, #111);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  position: relative;
  transition: gap 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
