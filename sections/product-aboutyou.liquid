<script>
(function() {
  var modal = document.getElementById('videoModal');
  if (!modal) return;
  var backdrop = modal.querySelector('.video-modal__backdrop');
  var closeBtn = modal.querySelector('.video-modal__close');
  var nativeVid = document.getElementById('videoModalNative');
  var iframe = document.getElementById('videoModalFrame');
  var sidebar = document.getElementById('videoModalSidebar');
  var listEl = document.getElementById('videoModalList');
  var playOverlay = document.getElementById('videoPlayOverlay');
  var productTitle = {{ product.title | json }};
  var productVendor = {{ product.vendor | json }};

  function updateOverlay(playing) {
    if (playing) playOverlay.classList.add('is-playing');
    else playOverlay.classList.remove('is-playing');
  }
  playOverlay.addEventListener('click', function() {
    if (nativeVid.classList.contains('is-active')) {
      nativeVid.play().catch(function(){});
    } else if (iframe.classList.contains('is-active') && iframe.contentWindow) {
      try { iframe.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}','*'); iframe.contentWindow.postMessage('{"method":"play"}','*'); updateOverlay(true); } catch(e){}
    }
  });
  nativeVid.addEventListener('play', function() { updateOverlay(true); });
  nativeVid.addEventListener('pause', function() { updateOverlay(false); });
  nativeVid.addEventListener('ended', function() { updateOverlay(false); });

  modal.querySelectorAll('.video-modal__tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = this.getAttribute('data-tab');
      modal.querySelectorAll('.video-modal__tab').forEach(function(t){ t.classList.remove('is-active'); });
      modal.querySelectorAll('.video-modal__panel').forEach(function(p){ p.classList.remove('is-active'); });
      this.classList.add('is-active');
      modal.querySelector('[data-panel="'+target+'"]').classList.add('is-active');
      if (target === 'bilder') {
        nativeVid.pause && nativeVid.pause();
        if (iframe.classList.contains('is-active') && iframe.contentWindow) {
          try { iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}','*'); iframe.contentWindow.postMessage('{"method":"pause"}','*'); } catch(e){}
        }
      } else if (target === 'videos') {
        if (nativeVid.classList.contains('is-active') && nativeVid.src) nativeVid.play().catch(function(){});
        if (iframe.classList.contains('is-active') && iframe.contentWindow) {
          try { iframe.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}','*'); iframe.contentWindow.postMessage('{"method":"play"}','*'); } catch(e){}
        }
      }
    });
  });

  var videoItems = [];
  function getVideoPosterFallback() {
    var first = document.querySelector('.thumb-item[data-type="image"]');
    if (!first) return '';
    return first.getAttribute('data-src') || (first.querySelector('img') ? first.querySelector('img').src : '');
  }
  function updateSidebarThumb(idx, src) {
    if (!src) return;
    listEl.querySelectorAll('.video-modal__list-item[data-video-idx="'+idx+'"] img').forEach(function(img){ img.src = src; });
  }
  function tryGenerateAutoPoster(v, idx, onDone) {
    if (!v || v.type !== 'video' || !v.video) { onDone && onDone(''); return; }
    if (v._autoPosterTried) { onDone && onDone(v._autoPoster || ''); return; }
    v._autoPosterTried = true;
    var probe = document.createElement('video');
    var done = false;
    var tid = setTimeout(function(){ finalize(''); }, 3000);
    function finalize(r) { if(done) return; done=true; clearTimeout(tid); try{probe.pause();probe.removeAttribute('src');probe.load();}catch(e){} v._autoPoster=r||''; onDone&&onDone(v._autoPoster); }
    probe.muted=true; probe.playsInline=true; probe.preload='auto'; probe.crossOrigin='anonymous';
    probe.addEventListener('error', function(){ finalize(''); }, {once:true});
    probe.addEventListener('loadeddata', function(){ try{ var s=1.2; if(isFinite(probe.duration)&&probe.duration>0) s=Math.min(2.5,Math.max(0.4,probe.duration*0.25)); probe.currentTime=s; }catch(e){finalize('');} }, {once:true});
    probe.addEventListener('seeked', function(){ try{ var w=probe.videoWidth||0,h=probe.videoHeight||0; if(!w||!h){finalize('');return;} var mW=960,oW=Math.min(w,mW),oH=Math.round((h/w)*oW); var c=document.createElement('canvas');c.width=oW;c.height=oH; var ctx=c.getContext('2d');if(!ctx){finalize('');return;} ctx.drawImage(probe,0,0,oW,oH); finalize(c.toDataURL('image/jpeg',0.82)); }catch(e){finalize('');} }, {once:true});
    try{probe.src=v.video;probe.load();}catch(e){finalize('');}
  }
  function collectVideoItems() {
    videoItems = [];
    var fallback = getVideoPosterFallback();
    document.querySelectorAll('.ay-video-data .thumb-item[data-type="video"], .ay-video-data .thumb-item[data-type="external_video"]').forEach(function(t) {
      var img = t.querySelector('img');
      var src = t.getAttribute('data-src') || (img ? img.src : '');
      var poster = t.getAttribute('data-poster') || src || fallback;
      videoItems.push({
        type: t.getAttribute('data-type'),
        video: t.getAttribute('data-video'),
        videoSources: t.getAttribute('data-video-sources'),
        src: src, poster: poster,
        alt: img ? img.alt : '',
        created: t.getAttribute('data-created') || '',
        index: parseInt(t.getAttribute('data-index'),10)
      });
    });
  }
  var currentVideoIdx = 0;
  function buildSidebar() {
    sidebar.style.display = '';
    listEl.innerHTML = '';
    videoItems.forEach(function(v,i) {
      var item = document.createElement('div');
      item.className = 'video-modal__list-item' + (i===currentVideoIdx?' is-active':'');
      item.setAttribute('data-video-idx',i);
      item.innerHTML = '<div class="video-modal__list-thumb"><img src="'+(v.poster||v.src)+'" alt="'+(v.alt||productTitle).replace(/"/g,'&quot;')+'" loading="lazy" width="120" height="68"><span class="video-modal__list-thumb-play">&#9654;</span></div><div class="video-modal__list-info"><span class="video-modal__list-title">'+(v.alt||productTitle)+'</span><span class="video-modal__list-vendor">'+productVendor+'</span></div>';
      item.addEventListener('click', function(){ playVideo(i); });
      listEl.appendChild(item);
      if (!v.poster) tryGenerateAutoPoster(v,i, function(g){ if(!g) return; updateSidebarThumb(i,g); if(i===currentVideoIdx && nativeVid.classList.contains('is-active')) nativeVid.setAttribute('poster',g); });
    });
  }
  function playVideo(idx) {
    currentVideoIdx = idx;
    var v = videoItems[idx];
    updateOverlay(false);
    nativeVid.pause && nativeVid.pause();
    nativeVid.removeAttribute('src'); iframe.removeAttribute('src');
    nativeVid.classList.remove('is-active'); iframe.classList.remove('is-active');
    nativeVid.style.removeProperty('display'); iframe.style.removeProperty('display');
    if (v.type === 'video') {
      var ps = v.poster||v.src||getVideoPosterFallback();
      if(ps) nativeVid.setAttribute('poster',ps); else nativeVid.removeAttribute('poster');
      if(!v.poster) tryGenerateAutoPoster(v,idx,function(g){if(!g)return;updateSidebarThumb(idx,g);if(currentVideoIdx===idx&&nativeVid.classList.contains('is-active'))nativeVid.setAttribute('poster',g);});
      while(nativeVid.firstChild) nativeVid.removeChild(nativeVid.firstChild);
      nativeVid.removeAttribute('src');
      var sources = []; try{sources=JSON.parse(v.videoSources||'[]');}catch(e){}
      if(sources.length>0) { sources.sort(function(a,b){var aM=(a.type||'').indexOf('mp4')>-1?0:1;var bM=(b.type||'').indexOf('mp4')>-1?0:1;return aM-bM;}); sources.forEach(function(s){ var el=document.createElement('source');el.src=s.url;if(s.type)el.type=s.type;nativeVid.appendChild(el); }); } else { nativeVid.src=v.video; }
