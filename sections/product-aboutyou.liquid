  var VIDEO_ENGAGEMENT_API = 'https://script.google.com/macros/s/AKfycbzRAE7_bK9_m1-nEhAfpHVmsDqHkqCmR-qSMlkSLc8F8_k61H-scIQiMUnNXdYZnUHnYQ/exec';
  var viewsEl = document.getElementById('videoModalViews');
  var likeBtn = document.getElementById('videoLikeBtn');
  var dislikeBtn = document.getElementById('videoDislikeBtn');
  var likeCountEl = document.getElementById('videoLikeCount');
  var dislikeCountEl = document.getElementById('videoDislikeCount');
  var publishDateEl = document.getElementById('videoPublishDate');
  var CACHE_KEY = 'kx_vid_cache';

  function timeAgo(iso) {
    if(!iso) return ''; var s=String(iso).trim(), d=new Date(s.slice(0,10)+'T00:00:00');
    if(isNaN(d.getTime())) return '';
    var diff=Math.floor((Date.now()-d)/1000);
    if(diff<0) return 'Gerade hochgeladen'; if(diff<86400) return 'Heute';
    if(diff<2592000) return 'Vor '+Math.floor(diff/86400)+' Tagen';
    if(diff<31536000) return 'Vor '+Math.floor(diff/2592000)+' Monaten';
    return 'Vor '+Math.floor(diff/31536000)+' Jahren';
  }
  var prefetchStore={}, prefetchDone={};
  function getCached(vid){ try{var c=JSON.parse(localStorage.getItem(CACHE_KEY)||'{}');return c[vid]||null;}catch(e){return null;} }
  function setCache(vid,data){ try{var c=JSON.parse(localStorage.getItem(CACHE_KEY)||'{}');if(data.shares===undefined&&c[vid]&&c[vid].shares)data.shares=c[vid].shares;c[vid]=data;localStorage.setItem(CACHE_KEY,JSON.stringify(c));}catch(e){} }
  function getVisitorId(){ var id=localStorage.getItem('kx_visitor_id');if(!id){id='v_'+Math.random().toString(36).substr(2,12)+'_'+Date.now();localStorage.setItem('kx_visitor_id',id);}return id; }
  function videoId(){ var v=videoItems[currentVideoIdx];return v?(v.video||'').replace(/[^a-zA-Z0-9_-]/g,'').slice(0,80):''; }
  function vidKey(v){ return v?(v.video||'').replace(/[^a-zA-Z0-9_-]/g,'').slice(0,80):''; }
  function formatViews(n){ if(n>=1000000)return(n/1000000).toFixed(1).replace('.0','')+'Mio.';if(n>=1000)return(n/1000).toFixed(1).replace('.0','')+' Tsd.';return n.toLocaleString('de-DE'); }

  function renderEngagement(data) {
    var vid=videoId(), prev=prefetchStore[vid]||getCached(vid)||{};
    var shares=data.shares!==undefined?data.shares:(prev.shares||0);
    viewsEl.textContent=formatViews(data.views||0)+' Aufrufe';
    likeCountEl.textContent=data.likes||0; dislikeCountEl.textContent=data.dislikes||0;
    setShareCount(shares);
    likeBtn.classList.toggle('is-active',data.myAction==='like');
    dislikeBtn.classList.toggle('is-active',data.myAction==='dislike');
    data.shares=shares; prefetchStore[vid]=data; setCache(vid,data);
  }
  function apiCall(action,vid,cb){
    if(!vid||!VIDEO_ENGAGEMENT_API)return;
    var url=VIDEO_ENGAGEMENT_API+'?action='+action+'&vid='+encodeURIComponent(vid)+'&uid='+encodeURIComponent(getVisitorId());
    fetch(url).then(function(r){return r.json();}).then(function(data){if(cb)cb(data);}).catch(function(){});
  }
  function prefetchAll(){
    if(!VIDEO_ENGAGEMENT_API)return;
    collectVideoItems();
    videoItems.forEach(function(v){var key=vidKey(v);if(!key||prefetchDone[key])return;prefetchDone[key]=true;
      var url=VIDEO_ENGAGEMENT_API+'?action=get&vid='+encodeURIComponent(key)+'&uid='+encodeURIComponent(getVisitorId());
      fetch(url).then(function(r){return r.json();}).then(function(data){var prev=prefetchStore[key]||getCached(key)||{};if(data.shares===undefined)data.shares=prev.shares||0;prefetchStore[key]=data;setCache(key,data);}).catch(function(){});
    });
  }
  prefetchAll();

  function initEngagement(){
    var vid=videoId(), v=videoItems[currentVideoIdx];
    if(publishDateEl) publishDateEl.textContent=(v&&v.created)?timeAgo(v.created):'';
    if(prefetchStore[vid]){renderEngagement(prefetchStore[vid]);apiCall('view',vid,function(data){renderEngagement(data);});return;}
    var cached=getCached(vid); if(cached)renderEngagement(cached);
    if(!prefetchDone[vid])prefetchAll();
    apiCall('view',vid,function(data){renderEngagement(data);});
  }
  var _engagementSeq=0;
  function popBtn(btn){btn.classList.remove('kx-pop');void btn.offsetWidth;btn.classList.add('kx-pop');btn.addEventListener('animationend',function h(){btn.classList.remove('kx-pop');btn.removeEventListener('animationend',h);});}
  function animCount(el){el.classList.remove('kx-count-anim');void el.offsetWidth;el.classList.add('kx-count-anim');el.addEventListener('animationend',function h(){el.classList.remove('kx-count-anim');el.removeEventListener('animationend',h);});}

  function optimisticReact(action){
    var seq=++_engagementSeq,vid=videoId();
    var current=prefetchStore[vid]||getCached(vid)||{views:0,likes:0,dislikes:0,shares:0,myAction:''};
    var o={views:current.views,likes:current.likes,dislikes:current.dislikes,shares:current.shares||0,myAction:current.myAction};
    if(action==='like'){if(o.myAction==='like'){o.likes=Math.max(0,o.likes-1);o.myAction='';}else{if(o.myAction==='dislike')o.dislikes=Math.max(0,o.dislikes-1);o.likes+=1;o.myAction='like';}popBtn(likeBtn);}
    else{if(o.myAction==='dislike'){o.dislikes=Math.max(0,o.dislikes-1);o.myAction='';}else{if(o.myAction==='like')o.likes=Math.max(0,o.likes-1);o.dislikes+=1;o.myAction='dislike';}popBtn(dislikeBtn);}
    likeCountEl.textContent=o.likes;dislikeCountEl.textContent=o.dislikes;animCount(action==='like'?likeCountEl:dislikeCountEl);
    likeBtn.classList.toggle('is-active',o.myAction==='like');dislikeBtn.classList.toggle('is-active',o.myAction==='dislike');
    prefetchStore[vid]=o;setCache(vid,o);
    apiCall(action,vid,function(data){if(seq!==_engagementSeq)return;if(data.shares===undefined)data.shares=prefetchStore[vid]?(prefetchStore[vid].shares||0):0;likeCountEl.textContent=data.likes||0;dislikeCountEl.textContent=data.dislikes||0;likeBtn.classList.toggle('is-active',data.myAction==='like');dislikeBtn.classList.toggle('is-active',data.myAction==='dislike');prefetchStore[vid]=data;setCache(vid,data);});
  }
  likeBtn.addEventListener('click',function(){optimisticReact('like');});
  dislikeBtn.addEventListener('click',function(){optimisticReact('dislike');});

  function recordShare(){
    var vid=videoId(),current=prefetchStore[vid]||getCached(vid)||{views:0,likes:0,dislikes:0,shares:0,myAction:''};
    var ns=(current.shares||0)+1;setShareCount(ns);animCount(shareCountEl);
    if(current){current.shares=ns;prefetchStore[vid]=current;setCache(vid,current);}
    apiCall('share',vid,function(data){var ss=data.shares!==undefined?data.shares:ns;setShareCount(ss);data.shares=ss;prefetchStore[vid]=data;setCache(vid,data);});
  }
  ['kxShareWa','kxShareFb','kxShareX','kxShareMail','kxSharePin','kxShareLi'].forEach(function(id){document.getElementById(id).addEventListener('click',function(){recordShare();});});
  document.getElementById('kxShareCopyBtn').addEventListener('click',function(){copyText(document.getElementById('kxShareUrl').textContent,'Link kopiert!');recordShare();closeSharePanel();});
  document.getElementById('kxShareIg').addEventListener('click',function(){copyText(document.getElementById('kxShareUrl').textContent,'Link kopiert! Jetzt in Instagram einfügen.');window.open('https://www.instagram.com/','_blank');recordShare();closeSharePanel();});
  document.getElementById('kxShareTt').addEventListener('click',function(){copyText(document.getElementById('kxShareUrl').textContent,'Link kopiert! Jetzt in TikTok einfügen.');window.open('https://www.tiktok.com/','_blank');recordShare();closeSharePanel();});
  document.getElementById('kxShareEmbed').addEventListener('click',function(){var url=document.getElementById('kxShareUrl').textContent;var code=getEmbedCode(url);document.getElementById('kxEmbedCode').textContent=code;document.getElementById('kxEmbedView').classList.toggle('is-open');});
  document.getElementById('kxEmbedCopyBtn').addEventListener('click',function(){copyText(document.getElementById('kxEmbedCode').textContent,'Einbettungscode kopiert!');closeSharePanel();});
  shareBtn.addEventListener('click',function(){var url=window.location.href.split('#')[0];openSharePanel(url);popBtn(shareBtn);});

  var _origPlayVideo = playVideo;
  playVideo = function(idx) { currentVideoIdx=idx; initEngagement(); _origPlayVideo(idx); };
})();
</script>

