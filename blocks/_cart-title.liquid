

{% assign block_settings = block.settings %}

<div
  class="cart-title cart-title--editorial spacing-style text-{{ block_settings.alignment }}"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  {%- unless cart.empty? -%}
    {%- if block_settings.show_count -%}
      <span class="cart-title__eyebrow" aria-hidden="true">
        {{ cart.item_count }} Artikel
      </span>
      <span class="visually-hidden">
        {{- 'accessibility.cart_count' | t -}}: {{ cart.item_count }}
      </span>
    {%- endif -%}
  {%- endunless -%}

  <h2 class="cart-title__h {{ block_settings.type_preset | default: 'h2' }}">
    {%- if cart.empty? -%}
      {{ 'content.your_cart_is_empty' | t }}
    {%- else -%}
      Warenkorb
    {%- endif -%}
  </h2>
</div>

{% stylesheet %}
  /* ============================
     EDITORIAL CART HEADER
     ============================ */
  .cart-title.cart-title--editorial {
    padding: 24px 20px 0 !important;
    border-bottom: 0 !important;
    background: transparent !important;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    min-height: 0;
    box-sizing: border-box;
  }
  .cart-title.cart-title--editorial.text-center { align-items: center; }
  .cart-title.cart-title--editorial.text-right  { align-items: flex-end; }

  .cart-title__eyebrow {
    font-family: 'Inter Tight', Inter, 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #8A8A85;
    line-height: 1;
  }

  .cart-title__h {
    margin-block-end: 0;
    color: #0d2e22 !important;
  }

  /* Close (X) button on the cart drawer — kept from the previous block
     so unrelated drawer styling continues to behave. */
  .cart-drawer .drawer__close,
  .cart-drawer button.drawer__close {
    position: absolute !important;
    top: calc(50% - 4px) !important;
    transform: translateY(-50%) !important;
    right: 16px !important;
    z-index: 200 !important;
    opacity: 0.55 !important;
    padding: 8px !important;
    background: none !important;
    border: none !important;
    line-height: 1 !important;
    transition: opacity 0.2s ease !important;
  }
  .cart-drawer .drawer__close:hover,
  .cart-drawer button.drawer__close:hover {
    opacity: 1 !important;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.title",
  "tag": null,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:settings.cart_title",
      "default": "t:text_defaults.cart"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "t:settings.cart_count",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "",
          "label": "t:options.default"
        },
        {
          "value": "paragraph",
          "label": "t:options.paragraph"
        },
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "",
      "info": "t:info.edit_presets_in_theme_settings"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.title"
    }
  ]
}
{% endschema %}
